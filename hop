function normalizeSessionName(rawName) {
    if (!rawName || typeof rawName !== 'string') return null;
    if (!SESSION_NAME_RE.test(rawName)) return null;
    if (rawName.startsWith(HOP_SESSION_PREFIX)) return rawName;
    return HOP_SESSION_PREFIX + rawName;
}

