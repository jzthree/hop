#!/usr/bin/env node

const { spawn, execSync } = require('child_process');
const fs = require('fs');
const path = require('path');
const crypto = require('crypto');
const http = require('http');
const httpProxy = require('http-proxy');
const { authenticator } = require('otplib');
const qrcode = require('qrcode-terminal');
const cookie = require('cookie');
const EventEmitter = require('events');
const url = require('url');

// Configure TOTP to accept codes ±1 time step (handles clock drift)
authenticator.options = { window: 1 };

// --- Configuration ---
const STATE_FILE = path.join(__dirname, '.tunnel-state');
const SECRET_FILE = path.join(__dirname, '.auth_secret');
const SESSION_COOKIE_NAME = 'tunnel_session';

// Check if tunnel is already running
function isServerRunning() {
    if (!fs.existsSync(STATE_FILE)) return null;
    try {
        const state = JSON.parse(fs.readFileSync(STATE_FILE, 'utf8'));
        // Check if the process is still alive
        try {
            process.kill(state.pid, 0);
            return state;
        } catch (e) {
            // Process is dead, clean up
            fs.unlinkSync(STATE_FILE);
            return null;
        }
    } catch (e) {
        return null;
    }
}

// Generate or load session secret
let SESSION_SECRET;
const existingState = isServerRunning();
if (existingState) {
    SESSION_SECRET = existingState.sessionSecret;
} else {
    SESSION_SECRET = crypto.randomBytes(32).toString('hex');
}

// Persistence for Stable QR Code
let AUTH_SECRET;
if (fs.existsSync(SECRET_FILE)) {
    AUTH_SECRET = fs.readFileSync(SECRET_FILE, 'utf8').trim();
} else {
    AUTH_SECRET = authenticator.generateSecret();
    fs.writeFileSync(SECRET_FILE, AUTH_SECRET);
}

// Port configuration
const BASE_PORT = existingState ? existingState.port : Math.floor(Math.random() * (50000 - 10000 + 1) + 10000);
const PROXY_PORT = BASE_PORT;

// Session Management
const activeSessions = {}; // { sessionName: { ttyd: Process, port: number } }
let nextPort = BASE_PORT + 1;

// Colors
const RESET = "\x1b[0m";
const GREEN = "\x1b[32m";
const YELLOW = "\x1b[33m";
const CYAN = "\x1b[36m";
const RED = "\x1b[31m";
const BOLD = "\x1b[1m";
const MAGENTA = "\x1b[35m";

function log(msg, color = RESET) {
    console.log(`${color}${msg}${RESET}`);
}

async function runCommand(command, args, opts = {}) {
    return new Promise((resolve, reject) => {
        const proc = spawn(command, args, { stdio: 'inherit', ...opts });
        proc.on('close', (code) => {
            if (code === 0) resolve();
            else reject(new Error(`Command ${command} exited with code ${code}`));
        });
        proc.on('error', (err) => reject(err));
    });
}

async function checkAndInstallDependencies() {
    log(`[1/4] Checking dependencies...`, BOLD);
    try { await runCommand('brew', ['--version'], { stdio: 'ignore' }); }
    catch (e) { log(`Error: Homebrew missing.`, RED); process.exit(1); }

    const deps = ['tmux', 'ttyd', 'cloudflared'];
    for (const dep of deps) {
        try {
            await runCommand('which', [dep], { stdio: 'ignore' });
            log(`  - ${dep} found.`, GREEN);
        } catch (e) {
            log(`  - ${dep} NOT found. Installing...`, YELLOW);
            try {
                await runCommand('brew', ['install', dep]);
                log(`  - ${dep} installed.`, GREEN);
            } catch (err) {
                log(`  - Failed to install ${dep}. Check Xcode license?`, RED);
                process.exit(1);
            }
        }
    }
}

// Get list of tmux sessions
function listTmuxSessions() {
    try {
        const output = execSync('tmux list-sessions -F "#{session_name}|#{session_windows}|#{session_attached}"', { encoding: 'utf8' });
        return output.trim().split('\n').filter(Boolean).map(line => {
            const [name, windows, attached] = line.split('|');
            return { name, windows: parseInt(windows), attached: attached === '1' };
        });
    } catch (e) {
        return [];
    }
}

// Light theme for ttyd - clean white background (tmux handles negative space)
function getTheme() {
    return JSON.stringify({
        'background': '#ffffff',
        'foreground': '#18181b',
        'cursor': '#7c3aed',
        'selectionBackground': '#ddd6fe',
        'black': '#18181b',
        'red': '#dc2626',
        'green': '#16a34a',
        'yellow': '#ca8a04',
        'blue': '#2563eb',
        'magenta': '#9333ea',
        'cyan': '#0891b2',
        'white': '#f4f4f5'
    });
}

// Start or get existing ttyd for a session
function getOrCreateSession(sessionName) {
    if (activeSessions[sessionName]) {
        return activeSessions[sessionName];
    }

    const port = nextPort++;
    const logFile = fs.openSync(path.join(__dirname, `ttyd-${sessionName}.log`), 'w');
    const themeJson = getTheme();

    // Shell wrapper with safety loop
    // Uses respawn-on-remain-exit in tmux for reliability
    // To cleanly exit: type "tunnel-exit" or kill the tmux session
    const ttyd = spawn('ttyd', [
        '-p', port.toString(),
        '-i', '127.0.0.1',
        '-W',
        '-t', `theme=${themeJson}`,
        '-t', 'fontFamily="Menlo, Monaco, Consolas, monospace"',
        '-t', 'fontSize=15',
        '-t', 'disableLeaveAlert=true',
        '-t', 'rendererType=canvas',
        'sh', '-c', `
            while true; do
                tmux new-session -A -s ${sessionName} zsh
                echo ""
                echo "[Session ended. Restarting in 2s... Type 'tunnel-exit' to stop]"
                if [ -f "${path.join(__dirname, '.exit-' + sessionName)}" ]; then
                    rm -f "${path.join(__dirname, '.exit-' + sessionName)}"
                    echo "[Clean exit requested]"
                    exit 0
                fi
                sleep 2
            done
        `
    ], {
        stdio: ['ignore', logFile, logFile],
        detached: false
    });

    ttyd.on('error', (err) => log(`Failed TTYD for ${sessionName}: ${err.message}`, RED));
    ttyd.on('close', () => {
        delete activeSessions[sessionName];
        log(`Session ${sessionName} closed.`, YELLOW);
    });

    activeSessions[sessionName] = { ttyd, port };
    log(`  Started session "${sessionName}" on port ${port}`, GREEN);
    return activeSessions[sessionName];
}

function startAuthProxy(authEmitter) {
    log(`[2/4] Starting Session Manager on port ${PROXY_PORT}...`, BOLD);

    const server = http.createServer((req, res) => {
        const parsedUrl = url.parse(req.url, true);
        const cookies = cookie.parse(req.headers.cookie || '');
        const isAuthenticated = cookies[SESSION_COOKIE_NAME] === SESSION_SECRET;

        // --- LOGIN PAGE ---
        if (!isAuthenticated) {
            if (req.method === 'POST' && parsedUrl.pathname === '/') {
                let body = '';
                req.on('data', chunk => body += chunk);
                req.on('end', () => {
                    const params = new URLSearchParams(body);
                    const token = params.get('token');

                    try {
                        if (authenticator.check(token, AUTH_SECRET)) {
                            res.setHeader('Set-Cookie', cookie.serialize(SESSION_COOKIE_NAME, SESSION_SECRET, {
                                httpOnly: true,
                                maxAge: 60 * 60 * 24 * 7
                            }));
                            res.writeHead(302, { 'Location': '/' });
                            res.end();
                            if (authEmitter) authEmitter.emit('authenticated');
                        } else {
                            res.writeHead(401, { 'Content-Type': 'text/html; charset=utf-8' });
                            res.end('Invalid Code. <a href="/">Try Again</a>');
                        }
                    } catch (e) {
                        res.writeHead(401);
                        res.end('Error verifying code');
                    }
                });
                return;
            }

            // Show login page
            res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8' });
            res.end(`
                <html>
                    <head>
                        <meta charset="UTF-8">
                        <meta name="viewport" content="width=device-width, initial-scale=1">
                        <title>Tunnel Shell</title>
                        <style>
                            body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: #fafafa; color: #18181b; display: flex; justify-content: center; align-items: center; height: 100vh; margin:0; }
                            .box { text-align: center; }
                            h2 { margin-bottom: 2rem; font-weight: 600; }
                            input { font-size: 2rem; width: 240px; text-align: center; margin-bottom: 1.5rem; border: none; border-bottom: 2px solid #e4e4e7; background: transparent; color: #18181b; padding: 0.5rem; outline: none; }
                            input:focus { border-bottom-color: #7c3aed; }
                            button { font-size: 1rem; padding: 0.8rem 2.5rem; background: #18181b; color: #fff; border: none; border-radius: 6px; cursor: pointer; font-weight: 500; }
                            button:hover { opacity: 0.8; }
                        </style>
                    </head>
                    <body>
                        <div class="box">
                            <h2>Tunnel Shell</h2>
                            <form method="POST">
                                <input type="text" name="token" pattern="[0-9]*" inputmode="numeric" placeholder="000 000" autofocus autocomplete="one-time-code">
                                <br>
                                <button type="submit">Enter</button>
                            </form>
                        </div>
                    </body>
                </html>
            `);
            return;
        }

        // --- AUTHENTICATED ROUTES ---
        const sessionName = parsedUrl.query.session;

        // API: List sessions
        if (parsedUrl.pathname === '/api/sessions' && req.method === 'GET') {
            const sessions = listTmuxSessions();
            const activeSessionNames = Object.keys(activeSessions);
            res.writeHead(200, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ sessions, active: activeSessionNames }));
            return;
        }

        // API: Create session
        if (parsedUrl.pathname === '/api/sessions' && req.method === 'POST') {
            let body = '';
            req.on('data', chunk => body += chunk);
            req.on('end', () => {
                const { name } = JSON.parse(body);
                if (!name || !/^[a-zA-Z0-9_-]+$/.test(name)) {
                    res.writeHead(400, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Invalid session name' }));
                    return;
                }
                getOrCreateSession(name);
                res.writeHead(200, { 'Content-Type': 'application/json' });
                res.end(JSON.stringify({ ok: true, name }));
            });
            return;
        }

        // If no session selected, show picker
        if (!sessionName) {
            res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8' });
            res.end(`
                <html>
                    <head>
                        <meta charset="UTF-8">
                        <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
                        <title>Session Picker</title>
                        <style>
                            * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
                            body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: #fafafa; color: #18181b; margin: 0; padding: 1.5rem; min-height: 100vh; }
                            .container { max-width: 600px; margin: 0 auto; }
                            h1 { font-size: 1.25rem; font-weight: 600; margin-bottom: 0.5rem; }
                            .subtitle { color: #71717a; font-size: 0.875rem; margin-bottom: 1rem; }
                            .session-list { background: #fff; border: 1px solid #e4e4e7; border-radius: 12px; overflow: hidden; margin-bottom: 1.5rem; }
                            .session-item { display: flex; justify-content: space-between; align-items: center; padding: 1rem; border-bottom: 1px solid #e4e4e7; gap: 1rem; }
                            .session-item:last-child { border-bottom: none; }
                            .session-item:active { background: #f4f4f5; }
                            .session-name { font-weight: 500; font-size: 1rem; }
                            .session-meta { color: #71717a; font-size: 0.8rem; margin-top: 0.25rem; }
                            .btn { padding: 0.75rem 1.25rem; border: none; border-radius: 8px; cursor: pointer; font-size: 1rem; font-weight: 500; text-decoration: none; display: inline-block; min-width: 80px; text-align: center; transition: opacity 0.2s; }
                            .btn-primary { background: #18181b; color: #fff; }
                            .btn-primary:hover, .btn-primary:active { opacity: 0.85; }
                            .btn-secondary { background: #e4e4e7; color: #18181b; }
                            .btn-secondary:hover { background: #d4d4d8; }
                            .btn:disabled { opacity: 0.5; cursor: wait; }
                            .new-session { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 0.75rem; }
                            .new-session input { flex: 1; min-width: 200px; padding: 0.875rem 1rem; border: 1px solid #e4e4e7; border-radius: 8px; font-size: 1rem; background: #fff; }
                            .new-session input:focus { outline: none; border-color: #7c3aed; }
                            .quick-names { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem; }
                            .quick-names button { padding: 0.5rem 1rem; font-size: 0.875rem; border-radius: 6px; }
                            .empty { padding: 2rem; text-align: center; color: #71717a; }
                            .active-badge { background: #22c55e; color: #fff; padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.7rem; margin-left: 0.5rem; vertical-align: middle; }
                            .loading { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(255,255,255,0.9); justify-content: center; align-items: center; flex-direction: column; z-index: 100; }
                            .loading.show { display: flex; }
                            .spinner { width: 40px; height: 40px; border: 3px solid #e4e4e7; border-top-color: #7c3aed; border-radius: 50%; animation: spin 1s linear infinite; }
                            @keyframes spin { to { transform: rotate(360deg); } }
                            @media (max-width: 480px) {
                                body { padding: 1rem; }
                                .new-session { flex-direction: column; }
                                .new-session input { min-width: 100%; }
                                .new-session .btn { width: 100%; }
                            }
                        </style>
                    </head>
                    <body>
                        <div class="loading" id="loading">
                            <div class="spinner"></div>
                            <p style="margin-top: 1rem; color: #71717a;">Starting session...</p>
                        </div>
                        <div class="container">
                            <h1>Session Picker</h1>
                            <p class="subtitle">Create a new session or join an existing one</p>
                            <div class="new-session">
                                <input type="text" id="newName" placeholder="Session name..." pattern="[a-zA-Z0-9_-]+">
                                <button class="btn btn-primary" onclick="createSession()">Create</button>
                            </div>
                            <div class="session-list" id="sessionList">
                                <div class="empty">Loading sessions...</div>
                            </div>
                        </div>
                        <script>
                            function showLoading() {
                                document.getElementById('loading').classList.add('show');
                            }
                            
                            async function loadSessions() {
                                const res = await fetch('/api/sessions');
                                const data = await res.json();
                                const list = document.getElementById('sessionList');
                                
                                if (data.sessions.length === 0 && data.active.length === 0) {
                                    list.innerHTML = '<div class="empty">No sessions yet. Create one above or use a quick-start button!</div>';
                                    return;
                                }
                                
                                const allSessions = new Set([...data.sessions.map(s => s.name), ...data.active]);
                                list.innerHTML = Array.from(allSessions).map(name => {
                                    const tmuxSession = data.sessions.find(s => s.name === name);
                                    const isActive = data.active.includes(name);
                                    return \`
                                        <div class="session-item">
                                            <div>
                                                <span class="session-name">\${name}</span>
                                                \${isActive ? '<span class="active-badge">LIVE</span>' : ''}
                                                <div class="session-meta">\${tmuxSession ? tmuxSession.windows + ' window(s)' : 'Starting...'}</div>
                                            </div>
                                            <a href="/?session=\${encodeURIComponent(name)}" class="btn btn-primary" onclick="showLoading()">Join</a>
                                        </div>
                                    \`;
                                }).join('');
                            }
                            
                            async function createSession() {
                                const input = document.getElementById('newName');
                                const name = input.value.trim();
                                if (!name) { input.focus(); return; }
                                if (!/^[a-zA-Z0-9_-]+$/.test(name)) return alert('Only letters, numbers, - and _ allowed');
                                
                                showLoading();
                                await fetch('/api/sessions', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({ name })
                                });
                                window.location.href = '/?session=' + encodeURIComponent(name);
                            }
                            
                            document.getElementById('newName').addEventListener('keypress', e => {
                                if (e.key === 'Enter') createSession();
                            });
                            
                            loadSessions();
                            setInterval(loadSessions, 3000);
                        </script>
                    </body>
                </html>
            `);
            return;
        }

        // --- PROXY TO SESSION ---
        const session = getOrCreateSession(sessionName);
        const proxy = httpProxy.createProxyServer({ target: `http://127.0.0.1:${session.port}`, ws: false });
        proxy.web(req, res, {}, (err) => {
            res.writeHead(502);
            res.end('Session not ready. Try again.');
        });
    });

    // WebSocket upgrade for terminal
    server.on('upgrade', (req, socket, head) => {
        const parsedUrl = url.parse(req.url, true);
        const cookies = cookie.parse(req.headers.cookie || '');

        if (cookies[SESSION_COOKIE_NAME] !== SESSION_SECRET) {
            socket.write('HTTP/1.1 401 Unauthorized\r\n\r\n');
            socket.destroy();
            return;
        }

        const sessionName = parsedUrl.query.session;
        if (!sessionName || !activeSessions[sessionName]) {
            socket.write('HTTP/1.1 404 Session Not Found\r\n\r\n');
            socket.destroy();
            return;
        }

        const session = activeSessions[sessionName];
        const proxy = httpProxy.createProxyServer({ target: `http://127.0.0.1:${session.port}`, ws: true });
        proxy.ws(req, socket, head);
    });

    server.listen(PROXY_PORT, '127.0.0.1');
    return server;
}

function startTunnel() {
    log(`[3/4] Opening Cloudflare Tunnel...`, BOLD);
    const tunnel = spawn('cloudflared', ['tunnel', '--url', `http://localhost:${PROXY_PORT}`]);
    let urlFound = false;

    return new Promise((resolve) => {
        tunnel.stderr.on('data', (data) => {
            if (urlFound) return;
            const output = data.toString();
            const match = output.match(/https:\/\/[a-zA-Z0-9-]+\.trycloudflare\.com/);

            if (match) {
                const publicUrl = match[0];
                if (publicUrl.includes('api.trycloudflare.com')) return;

                urlFound = true;
                resolve({ tunnel, publicUrl });
            }
        });
    });
}

function waitForStart(authEmitter, publicUrl) {
    return new Promise((resolve) => {
        console.clear();
        log(`\n==================================================`, MAGENTA);
        log(`            >>>  TUNNEL SHELL  <<<`, BOLD + MAGENTA);
        log(`==================================================\n`, MAGENTA);

        log(`SETUP (First time only):`, BOLD + YELLOW);
        log(`  Scan this QR with an authenticator app`, YELLOW);
        log(`  (Google Authenticator, Authy, 1Password, etc.)`, YELLOW);

        qrcode.generate(`otpauth://totp/TunnelShell?secret=${AUTH_SECRET}&issuer=TunnelShell`, { small: true });

        log(`  Secret saved to: .auth_secret`, RESET);
        log(`\nACCESS:`, BOLD + CYAN);
        log(`  ${publicUrl}`, CYAN);
        log(`\n--------------------------------------------------`, RESET);

        const readline = require('readline');
        const rl = readline.createInterface({ input: process.stdin, output: process.stdout });

        log(`\n[READY]`, GREEN + BOLD);
        log(`Press ENTER to launch local session, or login remotely to auto-launch...`, RESET);

        let resolved = false;

        const finish = (reason) => {
            if (resolved) return;
            resolved = true;
            rl.close();
            log(`\n${reason}. Launching local session...`, GREEN);
            setTimeout(resolve, 800);
        };

        rl.question('', () => finish('Manual Start'));
        authEmitter.once('authenticated', () => finish('Remote Login'));
    });
}

async function main() {
    // Check if tunnel is already running
    const existingTunnel = isServerRunning();

    if (existingTunnel) {
        // ATTACH MODE: Tunnel already running, just connect to a session
        log(`\n${BOLD}${GREEN}Tunnel already running!${RESET}`, GREEN);
        log(`URL: ${existingTunnel.url}`, CYAN);
        log(`\nAttaching to session...`, RESET);

        // Just attach to tmux - the tunnel and ttyd are already running
        const tmux = spawn('tmux', ['new-session', '-A', '-s', 'default'], { stdio: 'inherit' });

        tmux.on('close', () => {
            log(`\nLocal session ended. (Tunnel still running in background)`, YELLOW);
            log(`Run again to reattach, or kill processes to stop tunnel.`, RESET);
            process.exit(0);
        });

        return;
    }

    // SERVER MODE: Start new tunnel
    await checkAndInstallDependencies();
    const authEmitter = new EventEmitter();

    const proxyServer = startAuthProxy(authEmitter);
    const { tunnel: tunnelProc, publicUrl } = await startTunnel();

    // Save state for other terminals to find
    fs.writeFileSync(STATE_FILE, JSON.stringify({
        pid: process.pid,
        port: BASE_PORT,
        url: publicUrl,
        sessionSecret: SESSION_SECRET,
        startTime: Date.now()
    }));

    await waitForStart(authEmitter, publicUrl);

    log(`[4/4] Attaching to default session...`, BOLD);

    // Create and attach to default session locally
    // Use spawn with respawn loop - exit requires confirmation
    const defaultSession = getOrCreateSession('default');
    const tmux = spawn('sh', ['-c', `
        while true; do
            tmux new-session -A -s default
            echo ""
            echo "[Session ended]"
            read -p "Type 'quit' to shutdown tunnel, or press Enter to restart: " answer
            if [ "$answer" = "quit" ] || [ "$answer" = "QUIT" ]; then
                exit 0
            fi
            echo "Restarting..."
        done
    `], { stdio: 'inherit' });

    // Modern tmux styling - OpenCode/Tokyo Night inspired with truecolor shading
    setTimeout(() => {
        const s = 'default';

        // Enable truecolor (24-bit color) support - critical for shaded negative space
        spawn('tmux', ['set-option', '-g', 'default-terminal', 'tmux-256color']);
        spawn('tmux', ['set-option', '-ga', 'terminal-overrides', ',xterm*:Tc,alacritty:Tc,*:Tc']);

        // Core settings
        spawn('tmux', ['set-option', '-t', s, 'mouse', 'on']);
        spawn('tmux', ['set-option', '-t', s, 'escape-time', '0']);
        spawn('tmux', ['set-option', '-g', 'window-size', 'latest']);
        spawn('tmux', ['set-window-option', '-t', s, 'aggressive-resize', 'on']);

        // Fill character - pure space for shaded negative space
        spawn('tmux', ['set-option', '-g', 'fill-character', ' ']);

        // Color palette (Tokyo Night / OpenCode inspired - light theme)
        // Primary bg: #f0f0f0, Negative space: #e4e4e7, Divider: #a1a1aa, Inactive: #71717a

        // Status bar with shaded negative space
        spawn('tmux', ['set-option', '-t', s, 'status', 'on']);
        spawn('tmux', ['set-option', '-t', s, 'status-position', 'bottom']);

        // Main status bar: slightly tinted background for negative space feel
        spawn('tmux', ['set-option', '-t', s, 'status-style', 'bg=#e4e4e7,fg=#52525b']);

        // Left: accent + label
        spawn('tmux', ['set-option', '-t', s, 'status-left', '#[fg=#7c3aed,bold]●#[fg=#52525b,nobold] TUNNEL #[fg=#a1a1aa]│#[bg=#e4e4e7]  ']);
        spawn('tmux', ['set-option', '-t', s, 'status-left-length', '25']);

        // Right: URL with shaded padding (negative space)
        spawn('tmux', ['set-option', '-t', s, 'status-right', `#[bg=#e4e4e7]    #[fg=#a1a1aa]│ #[fg=#71717a]${publicUrl} `]);
        spawn('tmux', ['set-option', '-t', s, 'status-right-length', '200']);

        // Window status - shaded inactive windows
        spawn('tmux', ['set-window-option', '-t', s, 'window-status-current-style', 'fg=#18181b,bold']);
        spawn('tmux', ['set-window-option', '-t', s, 'window-status-style', 'fg=#a1a1aa']);
        spawn('tmux', ['set-window-option', '-t', s, 'window-status-separator', '#[fg=#d4d4d8] │ ']);

        // Pane borders - subtle dividers
        spawn('tmux', ['set-option', '-t', s, 'pane-border-style', 'fg=#e4e4e7']);
        spawn('tmux', ['set-option', '-t', s, 'pane-active-border-style', 'fg=#7c3aed']);

        // Message styling
        spawn('tmux', ['set-option', '-t', s, 'message-style', 'bg=#f0f0f0,fg=#18181b']);

        // Mode styling (copy mode, etc)
        spawn('tmux', ['set-option', '-t', s, 'mode-style', 'bg=#ddd6fe,fg=#18181b']);
    }, 1000);

    tmux.on('close', () => {
        log(`\nLocal session ended. Shutting down tunnel...`, YELLOW);
        cleanup();
    });

    const cleanup = () => {
        log(`Cleaning up...`, YELLOW);

        // Remove state file
        if (fs.existsSync(STATE_FILE)) {
            try { fs.unlinkSync(STATE_FILE); } catch (e) { }
        }

        // Kill all ttyd sessions
        Object.values(activeSessions).forEach(s => {
            try { s.ttyd.kill('SIGTERM'); } catch (e) { }
        });

        // Kill cloudflared tunnel
        try { tunnelProc.kill('SIGTERM'); } catch (e) { }

        // Close proxy server
        try { proxyServer.close(); } catch (e) { }

        // Kill tmux server to clean up all sessions
        try {
            require('child_process').execSync('tmux kill-server 2>/dev/null || true');
        } catch (e) { }

        log(`Goodbye!`, GREEN);
        process.exit(0);
    };

    process.on('SIGINT', cleanup);
    process.on('SIGTERM', cleanup);
    process.on('exit', cleanup);
}

main().catch(err => {
    log(`Fatal: ${err.message}`, RED);
    process.exit(1);
});
