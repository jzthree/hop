    log(`Scan this QR code with your Authenticator app.`, CYAN);
}

async function startLocalSession(proxyServer, tunnelProc, publicUrl) {
    log(`[4/4] Attaching to session...`, BOLD);

    // Create and attach to session locally
    // Find next available session name (in case another hop already created one)
    const cwdName = path.basename(process.cwd()).replace(/[^a-zA-Z0-9_-]/g, '-');
    const existingSessions = new Set(listTmuxSessions().map(s => s.name));
    let counter = 1;
    let displayName = `${cwdName}-${counter}`;
    let defaultSessionName = toInternalSessionName(displayName);
    while (existingSessions.has(defaultSessionName)) {
        counter++;
        displayName = `${cwdName}-${counter}`;
        defaultSessionName = toInternalSessionName(displayName);
    }

    log(`Starting session: ${displayName}`, RESET);
    getOrCreateSession(defaultSessionName);

    // Apply styling continuously to handle respawns and URL changes (every 1 second)
    const styleInterval = setInterval(() => {
        // Use currentPublicUrl to pick up URL changes after tunnel restarts
        applyTmuxStyles(defaultSessionName, currentPublicUrl || publicUrl);
    }, 1000);

    // Apply immediately (no delay needed since execSync is synchronous)
    applyTmuxStyles(defaultSessionName, publicUrl);

    // Also update when tunnel URL changes
    tunnelEmitter.on('urlChanged', (newUrl) => {
        applyTmuxStyles(defaultSessionName, newUrl);
    });

    const cleanup = () => {
        if (shuttingDown) return;
        shuttingDown = true;  // Prevent tunnel auto-restart
        log(`Cleaning up...`, YELLOW);

        clearInterval(styleInterval);

        // Remove state file
        if (fs.existsSync(STATE_FILE)) {
            try { fs.unlinkSync(STATE_FILE); } catch (e) { }
        }

        // Kill all ttyd sessions
        Object.values(activeSessions).forEach(s => {
            try { s.ttyd.kill('SIGTERM'); } catch (e) { }
        });

        // Kill cloudflared tunnel (use currentTunnelProc in case it was restarted)
        try { (currentTunnelProc || tunnelProc).kill('SIGTERM'); } catch (e) { }

        // Close proxy server
        try { proxyServer.close(); } catch (e) { }

        log(`Goodbye!`, GREEN);
        process.exit(0);
    };

    if (useItermControl) {
        log(`${CYAN}iTerm control mode enabled for local session.${RESET}`, RESET);
    }

    const runLocalSessionLoop = async () => {
        const readline = require('readline');
        while (true) {
            // For iTerm control mode, wait for session to be ready to avoid protocol corruption
            if (useItermControl) {
                await waitForTmuxSessionReady(defaultSessionName);
            }
            await new Promise(resolve => {
                if (useItermControl) setControlModeActive(true);
                const tmux = spawn('tmux', getLocalTmuxArgs(defaultSessionName), { stdio: 'inherit' });
                tmux.on('close', () => {
                    if (useItermControl) setControlModeActive(false);
                    resolve();
                });
            });
            log(`\n[Session ended]`, YELLOW);
            const answer = await new Promise(resolve => {
                const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
                rl.question(`Type 'quit' to shutdown tunnel, or press Enter to restart: `, (resp) => {
                    rl.close();
                    resolve(resp || '');
                });
            });
            if (String(answer).trim().toLowerCase() === 'quit') {
                break;
            }
            log(`Restarting...`, RESET);
            await new Promise(resolve => setTimeout(resolve, 500));
        }
    };

    runLocalSessionLoop().then(() => {
        log(`\nLocal session ended. Shutting down tunnel...`, YELLOW);
        cleanup();
    });

    process.on('SIGINT', cleanup);
    process.on('SIGTERM', cleanup);
    process.on('exit', cleanup);
}

async function main() {
    if (process.argv.includes('--iterm')) {
        if (isITerm()) {
            enableITermControlMode();
        } else {
            log(`${YELLOW}--iterm requested, but iTerm was not detected. Ignoring.${RESET}`, YELLOW);
        }
    }
    // Handle `hop client` - run as a user with exported credentials
    if (process.argv[2] === 'client') {
        const credentialsArg = process.argv[3];
        const hostnameArgIndex = process.argv.indexOf('--hostname');
        const hostnameOverride = hostnameArgIndex !== -1 ? process.argv[hostnameArgIndex + 1] : null;

        if (!credentialsArg || credentialsArg === '--help' || credentialsArg === '-h') {
            log(`\n${BOLD}Hop Client Mode${RESET}\n`, CYAN);
            log(`Run hop with credentials from your admin.\n`, RESET);
            log(`${BOLD}Usage:${RESET}`, RESET);
            log(`  hop client <credentials.json>              Start tunnel with credentials`, RESET);
            log(`  hop client <folder>                        Start tunnel (folder contains credentials.json)`, RESET);
            log('');
            log(`${BOLD}Options:${RESET}`, RESET);
            log(`  --hostname <name>  Override hostname if config.yml is missing`, RESET);
            log('');
            log(`${BOLD}First run:${RESET}`, RESET);
            log(`  You'll be prompted to set a password and scan a QR code`, RESET);
            log(`  for your authenticator app.`, RESET);
            log('');
            log(`${BOLD}Example:${RESET}`, RESET);
            log(`  hop client ./my-credentials.json`, RESET);
            log('');
            process.exit(0);
        }

        // Find credentials file
        let credentialsPath = credentialsArg;
        if (fs.existsSync(credentialsArg) && fs.statSync(credentialsArg).isDirectory()) {
            credentialsPath = path.join(credentialsArg, 'credentials.json');
        }

        if (!fs.existsSync(credentialsPath)) {
            log(`Credentials file not found: ${credentialsPath}`, RED);
            process.exit(1);
        }

        // Load credentials
        let credentials;
        try {
            credentials = JSON.parse(fs.readFileSync(credentialsPath, 'utf8'));
        } catch (e) {
            log(`Invalid credentials file: ${e.message}`, RED);
            process.exit(1);
        }

        // Client config is stored per-tunnel (based on tunnel ID)
        const tunnelId = credentials.TunnelID || credentials.tunnelId || path.basename(credentialsPath, '.json');
        const clientConfigDir = path.join(HOME_DIR, 'clients', tunnelId);
        ensurePrivateDir(clientConfigDir);

        PASSWORD_FILE_PATH = path.join(clientConfigDir, '.password_hash');
        SECRET_FILE_PATH = path.join(clientConfigDir, '.auth_secret');
        const clientConfigFile = path.join(clientConfigDir, '.config.json');

        // Load or create client config
        let clientConfig = {};
        if (fs.existsSync(clientConfigFile)) {
            try {
                clientConfig = JSON.parse(fs.readFileSync(clientConfigFile, 'utf8'));
            } catch (e) { }
        }

        let hostname = clientConfig.hostname || null;
        if (hostnameOverride) {
            hostname = hostnameOverride;
        }

        // Try to find hostname in config.yml in the export folder
        const configYmlPath = path.join(path.dirname(credentialsPath), 'config.yml');
        if (!hostname && fs.existsSync(configYmlPath)) {
            const configYml = fs.readFileSync(configYmlPath, 'utf8');
            const hostnameMatch = configYml.match(/hostname:\s*(\S+)/);
            if (hostnameMatch) hostname = hostnameMatch[1];
        }

        if (!hostname) {
            log(`Hostname not found.`, RED);
            log(`Ask your admin to export a fresh bundle or pass --hostname.`, YELLOW);
            process.exit(1);
        }

        if (clientConfig.hostname !== hostname) {
            clientConfig.hostname = hostname;
            writePrivateFile(clientConfigFile, JSON.stringify(clientConfig, null, 2));
        }

        // First time setup - require password and TOTP
        const clientPasswordExists = isPasswordEnabled();
        const clientSecretExists = fs.existsSync(SECRET_FILE_PATH);

        if (!clientPasswordExists || !clientSecretExists) {
            log(`\n${BOLD}${YELLOW}⚠ First time setup required${RESET}\n`, YELLOW);
            log(`Your tunnel URL will be publicly accessible.`, RESET);
            log(`Password + authenticator code protects your hop login.\n`, RESET);

            const readline = require('readline');
            const stream = require('stream');

            const askPassword = (prompt) => new Promise((resolve) => {
                const rl = readline.createInterface({
                    input: process.stdin,
                    output: new stream.Writable({
                        write: (chunk, encoding, callback) => callback()
                    }),
                    terminal: true
                });
                process.stdout.write(prompt);
                rl.question('', (answer) => {
                    rl.close();
                    process.stdout.write('\n');
                    resolve(answer);
                });
            });

            // Set password
            if (!clientPasswordExists) {
                const password = await askPassword('Set a password: ');
                if (password.length < 4) {
                    log(`Password too short (min 4 characters).`, RED);
                    process.exit(1);
                }
                const confirm = await askPassword('Confirm password: ');
                if (password !== confirm) {
                    log(`Passwords do not match.`, RED);
                    process.exit(1);
                }
                setPassword(password);
                log(`${GREEN}✓ Password set.${RESET}`, GREEN);
            }

            // Set up TOTP
            if (!clientSecretExists) {
                loadAuthSecret();
                log(`\n${BOLD}Scan this QR code with your authenticator app:${RESET}\n`, CYAN);
                const label = hostname ? `Hop-${hostname}` : `Hop-${tunnelId.slice(0, 8)}`;
                showQrCode(label);
            }

            log(`\n${GREEN}✓ Setup complete!${RESET}\n`, GREEN);
        }

        loadAuthSecret();

        await checkAndInstallDependencies();
        const authEmitter = new EventEmitter();

        const proxyServer = startAuthProxy(authEmitter);
        CLIENT_TUNNEL_CONFIG = {
            tunnelId,
            credentialsPath,
            hostname,
            configDir: clientConfigDir
        };
        const { tunnel: tunnelProc, publicUrl } = await startClientTunnel();

        // Save state for other terminals to find
        writePrivateFile(STATE_FILE, JSON.stringify({
            pid: process.pid,
            port: BASE_PORT,
            url: publicUrl,
            sessionSecret: SESSION_SECRET,
            startTime: Date.now()
        }));

        await waitForStart(authEmitter, publicUrl, `Hop-${hostname}`);

        await startLocalSession(proxyServer, tunnelProc, publicUrl);
        return;
    }

    // Handle `hop --help` or `hop help`
    if (process.argv[2] === '--help' || process.argv[2] === '-h' || process.argv[2] === 'help') {
        log(`\n${BOLD}Hop - Remote Terminal Access${RESET}\n`, CYAN);
        log(`${BOLD}Usage:${RESET}`, RESET);
        log(`  hop                       Start tunnel (or attach to existing)`, RESET);
        log(`  hop --iterm               Use iTerm tmux control mode for local session`, RESET);
        log(`  hop --help                Show this help message`, RESET);
        log('');
        log(`${BOLD}URL & QR:${RESET}`, RESET);
        log(`  hop url                   Print current tunnel URL`, RESET);
        log(`  hop qr                    Show URL as QR code`, RESET);
        log('');
        log(`${BOLD}Custom Domain:${RESET}`, RESET);
        log(`  hop domain                Show current domain config`, RESET);
        log(`  hop domain <hostname>     Setup custom domain (e.g., hop.example.com)`, RESET);
        log(`  hop domain-clear          Remove custom domain, use random URLs`, RESET);
        log('');
        log(`${BOLD}Security:${RESET}`, RESET);
        log(`  hop password              Show password status`, RESET);
        log(`  hop password set          Set or change password`, RESET);
        log(`  hop password clear        Remove password protection`, RESET);
        log('');
        log(`${BOLD}Multi-user (admin):${RESET}`, RESET);
        log(`  hop user list             List all users`, RESET);
        log(`  hop user add <name>       Add a user (creates tunnel + DNS)`, RESET);
        log(`  hop user remove <name>    Remove a user`, RESET);
        log(`  hop user export <name>    Export credentials for a user`, RESET);
        log('');
        log(`${BOLD}Sessions:${RESET}`, RESET);
        log(`  hop session list                 List sessions`, RESET);
        log(`  hop session add <name>           Add terminal session`, RESET);
        log(`  hop session add <name> --port N  Add port session (proxy)`, RESET);
        log(`  hop session remove <name>        Remove a session`, RESET);
        log('');
        log(`${BOLD}Client mode (for users):${RESET}`, RESET);
        log(`  hop client <credentials>  Run tunnel with exported credentials`, RESET);
        log('');
        log(`${BOLD}Maintenance:${RESET}`, RESET);
        log(`  hop wipe                  Kill all hop tmux sessions`, RESET);
        log('');
        process.exit(0);
    }

    // Handle `hop url` command - prints current tunnel URL (easy to copy)
    if (process.argv[2] === 'url') {
        const state = isServerRunning();
        if (!state) {
            log(`Hop is not running.`, RED);
            process.exit(1);
        }
        // Print just the URL for easy copying/piping
        console.log(state.url);
        process.exit(0);
    }

    // Handle `hop qr` command - shows QR code for current URL
    if (process.argv[2] === 'qr') {
        const state = isServerRunning();
        if (!state) {
            log(`Hop is not running.`, RED);
            process.exit(1);
        }
        log(`\nCurrent tunnel URL:`, BOLD);
        log(`${state.url}\n`, GREEN);
        qrcode.generate(state.url, { small: true });
        process.exit(0);
    }

    // Handle `hop domain <hostname>` command - setup custom domain
    if (process.argv[2] === 'domain') {
        const hostname = process.argv[3];
        if (!hostname) {
            // Show current domain config
            const config = getDomainConfig();
            if (config) {
                log(`\nCurrent custom domain configuration:`, BOLD);
                log(`  Hostname: ${config.hostname}`, GREEN);
                log(`  Tunnel:   ${config.tunnelName}`, RESET);
                log(`\nTo change: hop domain <new-hostname>`, RESET);
                log(`To remove: hop domain-clear`, RESET);
            } else {
                log(`\nNo custom domain configured.`, YELLOW);
                log(`\nUsage: hop domain <hostname>`, RESET);
                log(`Example: hop domain hop.yourdomain.com`, RESET);
            }
            process.exit(0);
        }
        // Validate hostname format
        if (!/^[a-zA-Z0-9]([a-zA-Z0-9-]*\.)+[a-zA-Z]{2,}$/.test(hostname)) {
            log(`Invalid hostname format: ${hostname}`, RED);
            log(`Example: hop.yourdomain.com`, RESET);
            process.exit(1);
        }
        await setupDomain(hostname);
        process.exit(0);
    }

    // Handle `hop domain-clear` command - remove custom domain config
    if (process.argv[2] === 'domain-clear') {
        if (fs.existsSync(DOMAIN_CONFIG_FILE)) {
            fs.unlinkSync(DOMAIN_CONFIG_FILE);
            log(`Custom domain configuration removed.`, GREEN);
            log(`Hop will use random Cloudflare URLs again.`, RESET);
        } else {
            log(`No custom domain configured.`, YELLOW);
        }
        process.exit(0);
    }

    // Handle `hop password` commands
    if (process.argv[2] === 'password') {
        const subcommand = process.argv[3];
        const readline = require('readline');

        if (!subcommand || subcommand === 'status') {
            if (isPasswordEnabled()) {
                log(`Password protection: ${GREEN}ENABLED${RESET}`, BOLD);
                log(`\nTo change: hop password set`, RESET);
                log(`To remove: hop password clear`, RESET);
            } else {
                log(`Password protection: ${YELLOW}DISABLED${RESET}`, BOLD);
                log(`\nTo enable: hop password set`, RESET);
            }
            process.exit(0);
        }

        if (subcommand === 'set') {
            // Use muted readline for password input
            const askPassword = (prompt) => new Promise((resolve) => {
                const rl = readline.createInterface({
                    input: process.stdin,
                    output: new (require('stream').Writable)({
                        write: (chunk, encoding, callback) => callback()
                    }),
                    terminal: true
                });

                process.stdout.write(prompt);
                rl.question('', (answer) => {
                    rl.close();
                    process.stdout.write('\n');
                    resolve(answer);
                });
            });

            const password = await askPassword('Enter new password: ');
            if (password.length < 4) {
                log(`Password too short (min 4 characters).`, RED);
                process.exit(1);
            }

            const confirm = await askPassword('Confirm password: ');
            if (password !== confirm) {
                log(`Passwords do not match.`, RED);
                process.exit(1);
            }

            setPassword(password);
            log(`\n${GREEN}✓ Password set successfully.${RESET}`, GREEN);
            log(`\nLogin will now require password + TOTP code.`, RESET);
            process.exit(0);
        }

        if (subcommand === 'clear') {
            if (!isPasswordEnabled()) {
                log(`Password is not set.`, YELLOW);
                process.exit(0);
            }
            clearPassword();
            log(`${GREEN}✓ Password protection removed.${RESET}`, GREEN);
            log(`\nLogin will only require TOTP code.`, RESET);
            process.exit(0);
        }

        // Unknown subcommand
        log(`\n${BOLD}Password commands:${RESET}\n`, CYAN);
        log(`  hop password           Show password status`, RESET);
        log(`  hop password set       Set or change password`, RESET);
        log(`  hop password clear     Remove password protection`, RESET);
        process.exit(0);
    }

    // Handle `hop user` commands - multi-user management
    if (process.argv[2] === 'user') {
        const subcommand = process.argv[3];
        const username = process.argv[4];

        if (!subcommand || subcommand === 'list') {
            listUsersCommand();
            process.exit(0);
        }

        if (subcommand === 'add') {
            if (!username) {
                log(`Usage: hop user add <username>`, RED);
                process.exit(1);
            }
            await addUser(username);
            process.exit(0);
        }

        if (subcommand === 'remove' || subcommand === 'rm' || subcommand === 'delete') {
            if (!username) {
                log(`Usage: hop user remove <username>`, RED);
                process.exit(1);
            }
            await removeUser(username);
            process.exit(0);
        }

        if (subcommand === 'export') {
            if (!username) {
                log(`Usage: hop user export <username>`, RED);
                process.exit(1);
            }
            await exportUserCredentials(username);
            process.exit(0);
        }

        // Unknown subcommand - show help
        log(`\n${BOLD}User management commands:${RESET}\n`, CYAN);
        log(`  hop user list              List all users`, RESET);
        log(`  hop user add <username>    Add a new user`, RESET);
        log(`  hop user remove <username> Remove a user`, RESET);
        log(`  hop user export <username> Export credentials for a user`, RESET);
        process.exit(0);
    }

    // Handle `hop session` commands
    if (process.argv[2] === 'session') {
        const subcommand = process.argv[3];
        const nameArg = process.argv[4];

        if (!subcommand || subcommand === 'list') {
            const sessions = listAllSessionEntries();
            if (sessions.length === 0) {
                log(`No sessions configured.`, YELLOW);
                process.exit(0);
            }
            log(`\n${BOLD}Sessions:${RESET}\n`, CYAN);
            sessions.forEach(s => {
                if (s.type === 'port') {
                    log(`  ${BOLD}${s.displayName}${RESET}  ${YELLOW}[PORT ${s.port}]${RESET}`, RESET);
                } else {
                    log(`  ${BOLD}${s.displayName}${RESET}  ${GREEN}[TERMINAL]${RESET}`, RESET);
                }
            });
            process.exit(0);
        }

        if (subcommand === 'add') {
            if (!nameArg) {
                log(`Usage: hop session add <name> [--port <number>]`, RED);
                process.exit(1);
            }
            const displayName = nameArg;
            const name = toInternalSessionName(displayName);
            if (!name) {
                log(`Invalid session name.`, RED);
                process.exit(1);
            }
            const portArgIndex = process.argv.indexOf('--port');
            if (portArgIndex !== -1) {
                const portArg = parseInt(process.argv[portArgIndex + 1], 10);
                if (!Number.isInteger(portArg) || portArg < 1 || portArg > 65535) {
                    log(`Invalid port. Use 1-65535.`, RED);
                    process.exit(1);
                }
                if (hopSessionExists(name)) {
                    log(`Terminal session already exists with this name.`, RED);
                    process.exit(1);
                }
                setPortSessionConfig(name, portArg);
                log(`Added port session "${displayName}" → localhost:${portArg}`, GREEN);
                process.exit(0);
            }

            const existingConfig = getSessionConfig(name);
            if (existingConfig && existingConfig.type === 'port') {
                log(`Port session already exists with this name.`, RED);
                process.exit(1);
            }
            ensureTerminalSessionConfig(name);
            log(`Added terminal session "${displayName}".`, GREEN);
            process.exit(0);
        }

        if (subcommand === 'remove' || subcommand === 'rm' || subcommand === 'delete') {
            if (!nameArg) {
                log(`Usage: hop session remove <name>`, RED);
                process.exit(1);
            }
            const displayName = nameArg;
            const name = toInternalSessionName(displayName);
            if (!name) {
                log(`Invalid session name.`, RED);
                process.exit(1);
            }
            const config = getSessionConfig(name);
            if (config && config.type === 'port') {
                deleteSessionConfig(name);
                log(`Removed port session "${displayName}".`, GREEN);
                process.exit(0);
            }
            try {
                if (hopSessionExists(name)) {
                    execFileSync('tmux', ['kill-session', '-t', name], { stdio: 'ignore' });
                }
            } catch (e) { }
            if (activeSessions[name]) {
                try { activeSessions[name].ttyd.kill(); } catch (e) { }
                delete activeSessions[name];
            }
            deleteSessionConfig(name);
            log(`Removed terminal session "${displayName}".`, GREEN);
            process.exit(0);
        }

        log(`\n${BOLD}Session commands:${RESET}\n`, CYAN);
        log(`  hop session list                 List sessions`, RESET);
        log(`  hop session add <name>           Add terminal session`, RESET);
        log(`  hop session add <name> --port N  Add port session`, RESET);
        log(`  hop session remove <name>        Remove a session`, RESET);
        process.exit(0);
    }

    // Handle `hop wipe` command - kills all hop sessions
    if (process.argv[2] === 'wipe') {
        const sessions = listTmuxSessions().filter(s => s.name.startsWith(HOP_SESSION_PREFIX));
        if (sessions.length === 0) {
            log(`No hop sessions to clean up.`, GREEN);
            process.exit(0);
        }
        log(`Killing ${sessions.length} hop session(s)...`, YELLOW);
        for (const s of sessions) {
            try {
                execSync(`tmux kill-session -t ${s.name}`, { stdio: 'ignore' });
                log(`  - ${toDisplaySessionName(s.name)}`, RESET);
            } catch (e) { }
        }
        log(`Done.`, GREEN);
        process.exit(0);
    }

    process.stdout.write('\x1Bc'); // Clear screen

    // Only one instance allowed
    const existingTunnel = isServerRunning();
    if (existingTunnel) {
        // CLIENT MODE: Connect to existing tunnel
        // If args are provided, try to send them as a command? (TODO)

        log(`Hop tunnel is already running!`, GREEN);
        log(`URL: ${existingTunnel.url}`, BOLD);

        // Generate smart session name: dir-N
        const cwdName = path.basename(process.cwd()).replace(/[^a-zA-Z0-9_-]/g, '-');
        let displayName = `${cwdName}-1`;
        let sessionName = toInternalSessionName(displayName);

        log(`\nFinding next available session...`, RESET);

        try {
            // Get existing sessions first
            const sessionsRes = await new Promise((resolve, reject) => {
                const opts = {
                    hostname: '127.0.0.1',
                    port: existingTunnel.port,
                    path: '/api/sessions',
                    method: 'GET',
                    headers: { 'Authorization': `Bearer ${existingTunnel.sessionSecret}` }
                };
                http.get(opts, res => {
                    let data = '';
                    res.on('data', c => data += c);
                    res.on('end', () => resolve(JSON.parse(data)));
                }).on('error', reject);
            });

            // Find next available number
            if (sessionsRes && sessionsRes.sessions && sessionsRes.active) {
                const allNames = new Set([...sessionsRes.active, ...sessionsRes.sessions.map(s => s.name)]);
                let counter = 1;
                while (allNames.has(`${cwdName}-${counter}`)) {
                    counter++;
                }
                displayName = `${cwdName}-${counter}`;
                sessionName = toInternalSessionName(displayName);
            }

            log(`Creating new session: ${displayName}...`, RESET);

            // Register session with local server so ttyd starts
            const res = await new Promise((resolve, reject) => {
                const opts = {
                    hostname: '127.0.0.1',
                    port: existingTunnel.port,
                    path: '/api/sessions',
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${existingTunnel.sessionSecret}`
                    }
                };

                const req = http.request(opts, (response) => {
                    let data = '';
                    response.on('data', c => data += c);
                    response.on('end', () => {
                        try {
                            resolve(JSON.parse(data));
                        } catch (e) {
                            // Server returned non-JSON (likely HTML login page)
                            reject(new Error(`Server returned non-JSON (status ${response.statusCode})`));
                        }
                    });
                });

                req.on('error', reject);
                req.write(JSON.stringify({ name: displayName }));
                req.end();
            });

            if (!res.ok && !res.success) throw new Error(res.error || 'Failed to create session');

        } catch (e) {
            log(`Note: Could not register session with server: ${e.message}`, YELLOW);
            log(`Session will still work locally.`, RESET);
        }

        log(`Attaching...`, RESET);

        // For iTerm control mode, wait for session to be ready to avoid protocol corruption
        if (useItermControl) {
            await waitForTmuxSessionReady(sessionName);
        }

        // Attach to the specific session
        if (useItermControl) setControlModeActive(true);
        const tmux = spawn('tmux', getLocalTmuxArgs(sessionName), { stdio: 'inherit' });

        // Apply styling immediately and continuously refresh (every 1 second)
        // Re-read state file each time to pick up URL changes after tunnel restarts
        applyTmuxStyles(sessionName, existingTunnel.url);

        const styleInterval = setInterval(() => {
            try {
                const currentState = JSON.parse(fs.readFileSync(STATE_FILE, 'utf8'));
                applyTmuxStyles(sessionName, currentState.url);
            } catch (e) {
                // State file missing = server died, keep old URL
                applyTmuxStyles(sessionName, existingTunnel.url);
            }
        }, 1000);

        tmux.on('close', () => {
            if (useItermControl) setControlModeActive(false);
            clearInterval(styleInterval);
            log(`\nSession disconnected.`, YELLOW);
            process.exit(0);
        });

        return;
    }

    // SERVER MODE: Start new tunnel

    // Require password for custom domains
    const domainConfig = getDomainConfig();
    if (domainConfig && domainConfig.hostname && !isPasswordEnabled()) {
        log(`\n${RED}ERROR: Password required for custom domain.${RESET}`, RED);
        log(`\nYour fixed URL (${domainConfig.hostname}) is publicly known.`, YELLOW);
        log(`Password protection is required for security.\n`, RESET);
        log(`Run: ${CYAN}hop password set${RESET}`, RESET);
        process.exit(1);
    }

    loadAuthSecret();
    await checkAndInstallDependencies();
    const authEmitter = new EventEmitter();

    const proxyServer = startAuthProxy(authEmitter);
    const { tunnel: tunnelProc, publicUrl } = await startTunnel();

    // Save state for other terminals to find
    writePrivateFile(STATE_FILE, JSON.stringify({
        pid: process.pid,
        port: BASE_PORT,
        url: publicUrl,
        sessionSecret: SESSION_SECRET,
        startTime: Date.now()
    }));

    await waitForStart(authEmitter, publicUrl);

    await startLocalSession(proxyServer, tunnelProc, publicUrl);
}

main().catch(err => {
    log(`Fatal: ${err.message}`, RED);
    process.exit(1);
});
