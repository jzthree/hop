function waitForStartPolling(state, label) {
    return new Promise((resolve) => {
        if (process.stdout.isTTY) console.clear();
        log(`\n==================================================`, MAGENTA);
        log(`            >>>  HOP - TUNNEL SHELL  <<<`, BOLD + MAGENTA);
        log(`==================================================\n`, MAGENTA);

        log(`TUNNEL URL:`, BOLD + GREEN);
        log(`  ${state.url}`, GREEN);
        log(`  Scan to open on mobile:`, RESET);
        qrcode.generate(state.url, { small: true });

        log(`\n--------------------------------------------------`, RESET);
        printStartupAuthSection(label);
        log(`\n--------------------------------------------------`, RESET);

        const readline = require('readline');
        const rl = readline.createInterface({ input: process.stdin, output: process.stdout });

        log(`\n[READY]`, GREEN + BOLD);
        log(`Press ENTER to launch local session, or login remotely...`, RESET);

        let resolved = false;
        const startedAt = Date.now();
        let pollTimer = null;

        const finish = (reason) => {
            if (resolved) return;
            resolved = true;
            if (pollTimer) clearInterval(pollTimer);
            rl.close();
            log(`\n${reason}. Launching local session...`, GREEN);
            setTimeout(resolve, 800);
        };

        rl.question('', () => finish('Manual Start'));

        const poll = () => {
            if (resolved) return;
            const opts = {
                hostname: '127.0.0.1',
                port: state.port,
                path: '/api/auth',
                method: 'GET',
                headers: { 'Authorization': `Bearer ${state.sessionSecret}` }
            };
            const req = http.request(opts, res => {
                let data = '';
                res.on('data', c => data += c);
                res.on('end', () => {
                    if (res.statusCode !== 200) return;
                    try {
                        const payload = JSON.parse(data);
                        if (payload.lastAuthAt && payload.lastAuthAt >= startedAt) {
                            finish('Remote Login');
                        }
                    } catch (e) { }
                });
            });
            req.on('error', () => { });
            req.end();
        };

        pollTimer = setInterval(poll, 1000);
        poll();
    });
}

