function setNoCache(res) {
    res.setHeader('Cache-Control', 'no-store, no-cache, must-revalidate, proxy-revalidate');
    res.setHeader('Pragma', 'no-cache');
    res.setHeader('Expires', '0');
}

function appendSetCookie(res, cookies) {
    const existing = res.getHeader('Set-Cookie');
    if (!existing) {
        res.setHeader('Set-Cookie', cookies);
        return;
    }
    const merged = Array.isArray(existing) ? existing.concat(cookies) : [existing].concat(cookies);
    res.setHeader('Set-Cookie', merged);
}

function clearAuthCookies(res) {
    const expires = new Date(0);
    appendSetCookie(res, [
        cookie.serialize(SESSION_COOKIE_NAME, '', {
            httpOnly: true,
            secure: true,
            sameSite: 'lax',
            path: '/',
            expires,
            maxAge: 0
        }),
        cookie.serialize(SESSION_COOKIE_NAME, '', {
            httpOnly: true,
            secure: true,
            sameSite: 'lax',
            path: '/api',
            expires,
            maxAge: 0
        })
    ]);
}

function escapeHtml(value) {
    return String(value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/\"/g, '&quot;')
        .replace(/'/g, '&#39;');
}

function startAuthProxy(authEmitter) {
    log(`[2/4] Starting Session Manager on port ${PROXY_PORT}...`, BOLD);

    const server = http.createServer((req, res) => {
        const parsedUrl = url.parse(req.url, true);
        const cookies = cookie.parse(req.headers.cookie || '');
        const ip = getClientIp(req);
        const sessionInfo = parseSessionFromRequest(req, parsedUrl);

        // Check auth via cookie OR Authorization header (internal hop-to-hop only)
        // Bearer token is read from state file by other hop processes on same machine
        const authHeader = req.headers.authorization;
        const tokenFromHeader = authHeader && authHeader.startsWith('Bearer ')
            ? authHeader.substring(7)
            : null;
        const isAuthenticated = cookies[SESSION_COOKIE_NAME] === SESSION_SECRET
            || tokenFromHeader === SESSION_SECRET;

        // --- LOGIN PAGE ---
        if (!isAuthenticated) {
            const passwordRequired = isPasswordEnabled();
            const storedPasswordHash = getStoredPassword();

            // API Login endpoint - authenticates via password (if enabled) + TOTP
            if (req.method === 'POST' && parsedUrl.pathname === '/api/login') {
                const limit = checkRateLimit(ip);
                if (!limit.allowed) {
                    res.writeHead(429, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ success: false, error: `Too many attempts. Try again in ${limit.remaining}s.` }));
                    return;
                }

                let body = '';
                req.on('data', chunk => body += chunk);
                req.on('end', () => {
                    try {
                        const { totp, password } = JSON.parse(body);

                        // Check password if enabled
                        if (passwordRequired && !verifyPassword(password || '', storedPasswordHash)) {
                            recordFailure(ip);
                            res.writeHead(401, { 'Content-Type': 'application/json' });
                            res.end(JSON.stringify({ success: false, error: 'Invalid password' }));
                            return;
                        }

                        // Check TOTP
                        if (authenticator.check(totp, AUTH_SECRET)) {
                            resetFailure(ip);
                            appendSetCookie(res, [
                                cookie.serialize(SESSION_COOKIE_NAME, SESSION_SECRET, {
                                    httpOnly: true,
                                    secure: true,
                                    sameSite: 'lax',
                                    path: '/',
                                    maxAge: 60 * 60 * 24 * 7
                                })
                            ]);
                            res.writeHead(200, { 'Content-Type': 'application/json' });
                            res.end(JSON.stringify({ success: true }));
                            if (authEmitter) authEmitter.emit('authenticated');
                        } else {
                            recordFailure(ip);
                            res.writeHead(401, { 'Content-Type': 'application/json' });
                            res.end(JSON.stringify({ success: false, error: 'Invalid code' }));
                        }
                    } catch (e) {
                        res.writeHead(400, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ success: false, error: 'Invalid request' }));
                    }
                });
                return;
            }

            // Web form login (support / and /s/<name>/)
            if (req.method === 'POST' && (parsedUrl.pathname === '/' || parsedUrl.pathname.startsWith('/s/'))) {
                const limit = checkRateLimit(ip);
                if (!limit.allowed) {
                    res.writeHead(429, { 'Content-Type': 'text/html; charset=utf-8' });
                    res.end(`Too many attempts. Try again in ${limit.remaining}s. <a href="/">Back</a>`);
                    return;
                }

                let body = '';
                req.on('data', chunk => body += chunk);
                req.on('end', () => {
                    const params = new URLSearchParams(body);
                    const token = params.get('token');
                    const password = params.get('password');
                    const requestedDisplayName = params.get('session') || sessionInfo?.displayName;
                    const requestedInternalName = requestedDisplayName
                        ? toInternalSessionName(requestedDisplayName)
                        : null;

                    try {
                        // Check password if enabled
                        if (passwordRequired && !verifyPassword(password || '', storedPasswordHash)) {
                            recordFailure(ip);
                            res.writeHead(401, { 'Content-Type': 'text/html; charset=utf-8' });
                            res.end('Invalid password. <a href="/">Try Again</a>');
                            return;
                        }

                        // Check TOTP
                        if (authenticator.check(token, AUTH_SECRET)) {
                            resetFailure(ip);
                            appendSetCookie(res, [
                                cookie.serialize(SESSION_COOKIE_NAME, SESSION_SECRET, {
                                    httpOnly: true,
                                    secure: true,
                                    sameSite: 'lax',
                                    path: '/',
                                    maxAge: 60 * 60 * 24 * 7
                                })
                            ]);
                            const redirectTarget = requestedInternalName
                                ? buildSessionPath(requestedDisplayName)
                                : '/sessions';
                            res.writeHead(302, { 'Location': redirectTarget });
                            res.end();
                            if (authEmitter) authEmitter.emit('authenticated');
                        } else {
                            recordFailure(ip);
                            res.writeHead(401, { 'Content-Type': 'text/html; charset=utf-8' });
                            res.end('Invalid Code. <a href="/">Try Again</a>');
                        }
                    } catch (e) {
                        res.writeHead(401);
                        res.end('Error verifying code');
                    }
                });
                return;
            }

            // Show login page - with password field if enabled
            const passwordFieldHtml = passwordRequired ? `
                <div style="margin-bottom: 1.5rem;">
                    <input type="password" name="password" id="passwordField" placeholder="Password"
                        style="width: 100%; padding: 0.8rem 1rem; font-size: 1rem; border: 1px solid #e4e4e7; border-radius: 8px; background: #fff; color: #18181b; box-sizing: border-box;"
                        required>
                </div>
                <p style="color: #71717a; margin-bottom: 1rem; font-size: 0.9rem;">Then enter your authenticator code:</p>
            ` : '';

            const passwordCheckJs = passwordRequired ? `
                const passwordField = document.getElementById('passwordField');
                if (!passwordField.value) {
                    passwordField.focus();
                    return;
                }
            ` : '';

            const requestedDisplayName = sessionInfo?.displayName;
            const requestedInternalName = requestedDisplayName
                ? toInternalSessionName(requestedDisplayName)
                : null;
            const sessionFieldHtml = requestedInternalName
                ? `<input type="hidden" name="session" value="${escapeHtml(requestedDisplayName)}">`
                : '';

            clearAuthCookies(res);
            setNoCache(res);
            res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8' });
            res.end(`
                <html>
                    <head>
                        <meta charset="UTF-8">
                        <meta name="viewport" content="width=device-width, initial-scale=1">
                        <title>Verify Identity</title>
                        <style>
                            body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: #fafafa; color: #18181b; display: flex; justify-content: center; align-items: center; height: 100vh; margin:0; }
                            .box { text-align: center; max-width: 400px; padding: 2rem; }
                            h2 { margin-bottom: 1.5rem; font-weight: 600; font-size: 1.5rem; }
                            .code-inputs { display: flex; gap: 8px; justify-content: center; margin-bottom: 2rem; }
                            .code-inputs input {
                                width: 44px; height: 56px;
                                font-size: 24px; text-align: center;
                                border: 1px solid #e4e4e7; border-radius: 8px;
                                background: #fff; color: #18181b;
                                -moz-appearance: textfield;
                            }
                            .code-inputs input:focus { outline: none; border-color: #7c3aed; box-shadow: 0 0 0 2px rgba(124, 58, 237, 0.1); }
                            .code-inputs input::-webkit-outer-spin-button,
                            .code-inputs input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
                            input[type="password"]:focus { outline: none; border-color: #7c3aed; box-shadow: 0 0 0 2px rgba(124, 58, 237, 0.1); }

                            button { font-size: 1rem; padding: 0.8rem 2.5rem; background: #18181b; color: #fff; border: none; border-radius: 8px; cursor: pointer; font-weight: 500; width: 100%; transition: opacity 0.2s; }
                            button:hover { opacity: 0.9; }
                            .hidden-submit { position: absolute; left: -9999px; }
                        </style>
                    </head>
                    <body>
                        <div class="box">
                            <h2>Security Check</h2>
                            ${passwordRequired ? '<p style="color: #71717a; margin-bottom: 1rem; font-size: 0.9rem;">Enter your password:</p>' : '<p style="color: #71717a; margin-bottom: 2rem; font-size: 0.9rem;">Please enter the verification code from your authenticator app to continue.</p>'}
                            <form method="POST" id="authForm">
                                ${passwordFieldHtml}
                                ${sessionFieldHtml}
                                <div class="code-inputs" id="inputs">
                                    <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" required>
                                    <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" required>
                                    <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" required>
                                    <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" required>
                                    <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" required>
                                    <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" required>
                                </div>
                                <input type="hidden" name="token" id="fullToken">
                                <button type="submit">Verify</button>
                            </form>
                        </div>
                        <script>
                            const inputs = document.querySelectorAll('.code-inputs input');
                            const form = document.getElementById('authForm');
                            const hidden = document.getElementById('fullToken');

                            inputs.forEach((input, i) => {
                                input.addEventListener('input', e => {
                                    if (e.target.value.length === 1) {
                                        if (i < inputs.length - 1) inputs[i + 1].focus();
                                        else submit();
                                    }
                                });
                                input.addEventListener('keydown', e => {
                                    if (e.key === 'Backspace' && !e.target.value && i > 0) {
                                        inputs[i - 1].focus();
                                    }
                                });
                                input.addEventListener('paste', e => {
                                    e.preventDefault();
                                    const text = (e.clipboardData || window.clipboardData).getData('text');
                                    const digits = text.replace(/[^0-9]/g, '').slice(0, 6);
                                    if (digits.length === 0) return;
                                    digits.split('').forEach((char, index) => {
                                        if (inputs[index]) inputs[index].value = char;
                                    });
                                    if (digits.length === 6) submit();
                                    else inputs[Math.min(digits.length, 5)].focus();
                                });
                            });

                            function submit() {
                                ${passwordCheckJs}
                                const code = Array.from(inputs).map(i => i.value).join('');
                                if (code.length === 6) {
                                    hidden.value = code;
                                    form.submit();
                                }
                            }

                            form.addEventListener('submit', e => {
                                const code = Array.from(inputs).map(i => i.value).join('');
                                hidden.value = code;
                            });
                        </script>
                    </body>
                </html>
            `);
            return;
        }

        // --- AUTHENTICATED ROUTES ---
        const sessionInfoAuth = parseSessionFromRequest(req, parsedUrl);
        const sessionName = sessionInfoAuth ? sessionInfoAuth.internalName : null;
        const displayName = sessionInfoAuth ? sessionInfoAuth.displayName : null;
        const strippedUrl = sessionInfoAuth ? sessionInfoAuth.strippedUrl : req.url;
        const strippedPathname = sessionInfoAuth ? sessionInfoAuth.strippedPathname : (parsedUrl.pathname || '/');

        if (sessionInfoAuth && sessionInfoAuth.source === 'query' && shouldRedirectToSessionPath(req)) {
            res.writeHead(302, { 'Location': buildSessionPath(displayName) });
            res.end();
            return;
        }
        if (sessionInfoAuth && sessionInfoAuth.source === 'path' && sessionInfoAuth.needsSlash && shouldRedirectToSessionPath(req)) {
            const target = buildSessionPath(displayName) + (parsedUrl.search || '');
            res.writeHead(302, { 'Location': target });
            res.end();
            return;
        }

        // API: Ping (triggers auth event for mobile login)
        if (parsedUrl.pathname === '/api/ping' && req.method === 'POST') {
            if (authEmitter) authEmitter.emit('authenticated');
            res.writeHead(200, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ ok: true, message: 'Mobile login' }));
            return;
        }

        // API: List sessions
        if (parsedUrl.pathname === '/api/sessions' && req.method === 'GET') {
            const sessions = listAllSessionEntries().map(s => ({
                name: s.displayName,
                displayName: s.displayName,
                windows: s.windows,
                attached: s.attached,
                type: s.type,
                port: s.port
            }));
            const activeSessionNames = Object.keys(activeSessions).map(toDisplaySessionName);
            const startingSessionNames = Array.from(startingSessions).map(toDisplaySessionName);
            res.writeHead(200, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ sessions, active: activeSessionNames, starting: startingSessionNames }));
            return;
        }

        // API: Create session
        if (parsedUrl.pathname === '/api/sessions' && req.method === 'POST') {
            let body = '';
            req.on('data', chunk => body += chunk);
            req.on('end', () => {
                try {
                    let { name, type, port } = JSON.parse(body);
                    const displayName = name;
                    const internalName = toInternalSessionName(displayName);
                    if (!internalName) {
                        res.writeHead(400, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Invalid session name' }));
                        return;
                    }
                    type = (type || 'terminal').toLowerCase();
                    if (type !== 'terminal' && type !== 'port') {
                        res.writeHead(400, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Invalid session type' }));
                        return;
                    }
                    if (type === 'port') {
                        const parsedPort = parseInt(port, 10);
                        if (!Number.isInteger(parsedPort) || parsedPort < 1 || parsedPort > 65535) {
                            res.writeHead(400, { 'Content-Type': 'application/json' });
                            res.end(JSON.stringify({ error: 'Invalid port' }));
                            return;
                        }
                        if (hopSessionExists(internalName)) {
                            res.writeHead(409, { 'Content-Type': 'application/json' });
                            res.end(JSON.stringify({ error: 'Terminal session already exists with this name' }));
                            return;
                        }
                        const existingConfig = getSessionConfig(internalName);
                        if (existingConfig && existingConfig.type === 'terminal') {
                            res.writeHead(409, { 'Content-Type': 'application/json' });
                            res.end(JSON.stringify({ error: 'Terminal session already exists with this name' }));
                            return;
                        }
                        setPortSessionConfig(internalName, parsedPort);
                    } else {
                        const existingConfig = getSessionConfig(internalName);
                        if (existingConfig && existingConfig.type === 'port') {
                            res.writeHead(409, { 'Content-Type': 'application/json' });
                            res.end(JSON.stringify({ error: 'Port session already exists with this name' }));
                            return;
                        }
                        getOrCreateSession(internalName);
                    }
                    res.writeHead(200, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ ok: true, name: displayName, type }));
                } catch (e) {
                    res.writeHead(400, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Invalid request body' }));
                }
            });
            return;
        }

        // API: Rename session
        if (parsedUrl.pathname === '/api/sessions/rename' && req.method === 'POST') {
            let body = '';
            req.on('data', chunk => body += chunk);
            req.on('end', () => {
                let { oldName, newName } = JSON.parse(body);
                const oldDisplayName = oldName;
                const newDisplayName = newName;
                oldName = toInternalSessionName(oldDisplayName);
                newName = toInternalSessionName(newDisplayName);
                // Validate BOTH names to prevent command injection
                if (!oldName) {
                    res.writeHead(400, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Invalid old name' }));
                    return;
                }
                if (!newName) {
                    res.writeHead(400, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Invalid new name' }));
                    return;
                }
                if (getSessionConfig(newName) || hopSessionExists(newName)) {
                    res.writeHead(409, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Session name already in use' }));
                    return;
                }

                // Rename in tmux
                try {
                    const config = getSessionConfig(oldName);
                    if (config && config.type === 'port') {
                        deleteSessionConfig(oldName);
                        setSessionConfig(newName, { ...config, updatedAt: new Date().toISOString() });
                    } else {
                        if (!hopSessionExists(oldName)) {
                            res.writeHead(404, { 'Content-Type': 'application/json' });
                            res.end(JSON.stringify({ error: 'Session not found' }));
                            return;
                        }
                        execFileSync('tmux', ['rename-session', '-t', oldName, newName], { stdio: 'ignore' });
                        if (config) {
                            deleteSessionConfig(oldName);
                            setSessionConfig(newName, { ...config, type: 'terminal', updatedAt: new Date().toISOString() });
                        } else {
                            deleteSessionConfig(oldName);
                            ensureTerminalSessionConfig(newName);
                        }
                    }

                    // Update internal map if it's managed by us
                    if (activeSessions[oldName]) {
                        activeSessions[newName] = activeSessions[oldName];
                        delete activeSessions[oldName];
                    }

                    // Track rename so styling intervals can follow
                    sessionRenames[oldName] = newName;

                    // Rename log/exit files if they exist (optional cleanup)

                    res.writeHead(200, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ ok: true }));
                } catch (e) {
                    res.writeHead(500, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Rename failed' }));
                }
            });
            return;
        }

        // API: Delete session
        if (parsedUrl.pathname === '/api/sessions/delete' && req.method === 'POST') {
            let body = '';
            req.on('data', chunk => body += chunk);
            req.on('end', () => {
                let { name } = JSON.parse(body);
                name = toInternalSessionName(name);
                // Validate name to prevent command injection
                if (!name) {
                    res.writeHead(400, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Invalid session name' }));
                    return;
                }

                try {
                    const config = getSessionConfig(name);
                    if (config && config.type === 'port') {
                        deleteSessionConfig(name);
                    } else {
                        if (!hopSessionExists(name)) {
                            res.writeHead(404, { 'Content-Type': 'application/json' });
                            res.end(JSON.stringify({ error: 'Session not found' }));
                            return;
                        }
                        // Kill the tmux session
                        execFileSync('tmux', ['kill-session', '-t', name], { stdio: 'ignore' });

                        // Clean up internal tracking
                        if (activeSessions[name]) {
                            if (activeSessions[name].ttyd) {
                                activeSessions[name].ttyd.kill();
                            }
                            delete activeSessions[name];
                        }
                        deleteSessionConfig(name);
                    }

                    res.writeHead(200, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ ok: true }));
                } catch (e) {
                    res.writeHead(500, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Delete failed' }));
                }
            });
            return;
        }

        // If no session selected, show session picker
        if (parsedUrl.pathname === '/sessions') {
            const sessionsFile = path.join(__dirname, 'sessions.html');
            let sessionsHtml = '<!-- sessions.html not found -->';
            try {
                sessionsHtml = fs.readFileSync(sessionsFile, 'utf8');
            } catch (e) {
                log(`Warning: sessions.html not found`, YELLOW);
            }
            res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8' });
            res.end(sessionsHtml);
            return;
        }
        if (!sessionName) {
            const sessionsFile = path.join(__dirname, 'sessions.html');
            let sessionsHtml = '<!-- sessions.html not found -->';
            try {
                sessionsHtml = fs.readFileSync(sessionsFile, 'utf8');
            } catch (e) {
                log(`Warning: sessions.html not found`, YELLOW);
            }
            res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8' });
            res.end(sessionsHtml);
            return;
        }
        // --- CHECK FOR iOS - Intercept and inject virtual keyboard ---
        const userAgent = req.headers['user-agent'] || '';
        const isIOS = /iPad|iPhone|iPod/.test(userAgent);
        const isMobile = isIOS || /Android/i.test(userAgent);
        const sessionConfig = getSessionConfig(sessionName);
        if (sessionConfig && sessionConfig.type === 'port') {
            const targetPort = sessionConfig.port;
            if (!targetPort) {
                res.writeHead(500);
                res.end('Port session missing target port.');
                return;
            }
            const shouldInject = isMobile && shouldInjectSessionSwitcher(req);
            if (shouldInject) {
                waitForPort(targetPort).then((ready) => {
                    if (!ready) {
                        sendStartingPage(res, displayName);
                        return;
                    }
                    const headers = { ...req.headers };
                    delete headers['accept-encoding'];
                    const proxyReq = http.request({
                        hostname: '127.0.0.1',
                        port: targetPort,
                        method: req.method,
                        path: strippedUrl,
                        headers
                    }, (proxyRes) => {
                        const contentType = String(proxyRes.headers['content-type'] || '').toLowerCase();
                        const contentEncoding = String(proxyRes.headers['content-encoding'] || '').toLowerCase();
                        const isHtml = contentType.includes('text/html');
                        const isPlain = contentType.includes('text/plain');
                        const canModify = (isHtml || isPlain) && (!contentEncoding || contentEncoding === 'identity');
                        if (!canModify) {
                            res.writeHead(proxyRes.statusCode || 200, proxyRes.headers);
                            proxyRes.pipe(res);
                            return;
                        }
                        let chunks = [];
                        proxyRes.on('data', chunk => chunks.push(chunk));
                        proxyRes.on('end', () => {
                            let html = Buffer.concat(chunks).toString('utf8');
                            const overlay = getSessionSwitcherOverlay();
                            if (isPlain && !html.includes('<html')) {
                                const body = `<pre style="white-space:pre-wrap;font:14px/1.4 ui-monospace,Menlo,Monaco,Consolas,monospace;margin:24px;color:#18181b;">${escapeHtml(html)}</pre>`;
                                html = `<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1"></head><body>${body}${overlay}</body></html>`;
                            } else if (html.includes('</body>')) {
                                html = html.split('</body>').join(overlay + '</body>');
                            } else {
                                html += overlay;
                            }
                            const outHeaders = { ...proxyRes.headers };
                            delete outHeaders['content-length'];
                            delete outHeaders['content-encoding'];
                            if (isPlain) {
                                outHeaders['content-type'] = 'text/html; charset=utf-8';
                            }
                            res.writeHead(proxyRes.statusCode || 200, outHeaders);
                            res.end(html);
                        });
                    });
                    proxyReq.on('error', () => {
                        sendStartingPage(res, displayName);
                    });
                    req.pipe(proxyReq);
                });
                return;
            }

            waitForPort(targetPort).then((ready) => {
                if (!ready) {
                    sendStartingPage(res, displayName);
                    return;
                }
                const proxy = httpProxy.createProxyServer({ target: `http://127.0.0.1:${targetPort}`, ws: false });
                const originalUrl = req.url;
                req.url = strippedUrl;
                proxy.web(req, res, {}, () => {
                    sendStartingPage(res, displayName);
                });
                req.url = originalUrl;
            });
            return;
        }

        // Ensure session exists (creates termshare room if needed)
        try {
            getOrCreateSession(sessionName);
        } catch (e) {
            res.writeHead(500);
            res.end('Failed to create session');
            return;
        }

        // Serve termshare web client (has built-in mobile keyboard)
        const reqPath = strippedPathname || '/';

        // Map request path to file
        let filePath;
        if (reqPath === '/' || reqPath === '') {
            filePath = path.join(TERMSHARE_WEB_DIR, 'index.html');
        } else if (reqPath.startsWith('/assets/')) {
            filePath = path.join(TERMSHARE_WEB_DIR, reqPath);
        } else {
            // Fallback to index.html for SPA routing
            filePath = path.join(TERMSHARE_WEB_DIR, 'index.html');
        }

        // Check if file exists
        if (!fs.existsSync(filePath)) {
            res.writeHead(404);
            res.end('Not Found');
            return;
        }

        // Determine content type
        const ext = path.extname(filePath).toLowerCase();
        const contentTypes = {
            '.html': 'text/html; charset=utf-8',
            '.js': 'application/javascript',
            '.css': 'text/css',
            '.json': 'application/json',
            '.png': 'image/png',
            '.jpg': 'image/jpeg',
            '.svg': 'image/svg+xml',
            '.ico': 'image/x-icon'
        };
        const contentType = contentTypes[ext] || 'application/octet-stream';

        // Read and serve the file
        let content = fs.readFileSync(filePath);

        // For HTML files, inject room parameter and WebSocket URL
        if (ext === '.html') {
            let html = content.toString('utf8');
            // Inject room parameter into URL so termshare web client connects to the right room
            const injectScript = `<script>
                // Hop session configuration
                window.__HOP_SESSION__ = ${JSON.stringify({
                    room: sessionName,
                    name: 'Guest',
                    wsUrl: '/ws'
                })};
                // Auto-set room in URL params if not present
                if (!new URLSearchParams(location.search).get('room')) {
                    const url = new URL(location.href);
                    url.searchParams.set('room', ${JSON.stringify(sessionName)});
                    history.replaceState(null, '', url.toString());
                }
            </script>`;
            html = html.replace('<head>', '<head>' + injectScript);
            content = Buffer.from(html, 'utf8');
        }

        res.writeHead(200, {
            'Content-Type': contentType,
            'Content-Length': content.length
        });
        res.end(content);
    });

    // WebSocket upgrade for terminal
    server.on('upgrade', (req, socket, head) => {
        const parsedUrl = url.parse(req.url, true);
        const cookies = cookie.parse(req.headers.cookie || '');

        // Auth via cookie only (tokens in URLs get logged - security risk)
        const isAuthenticated = cookies[SESSION_COOKIE_NAME] === SESSION_SECRET;

        if (!isAuthenticated) {
            socket.write('HTTP/1.1 401 Unauthorized\r\n\r\n');
            socket.destroy();
            return;
        }

        const sessionInfo = parseSessionFromRequest(req, parsedUrl);
        const sessionName = sessionInfo ? sessionInfo.internalName : null;
        if (!sessionName) {
            socket.write('HTTP/1.1 404 Session Not Found\r\n\r\n');
            socket.destroy();
            return;
        }

        const sessionConfig = getSessionConfig(sessionName);
        if (sessionConfig && sessionConfig.type === 'port') {
            const targetPort = sessionConfig.port;
            if (!targetPort) {
                socket.write('HTTP/1.1 502 Bad Gateway\r\n\r\n');
                socket.destroy();
                return;
            }
            const proxy = httpProxy.createProxyServer({ target: `http://127.0.0.1:${targetPort}`, ws: true });
            const originalUrl = req.url;
            req.url = sessionInfo.strippedUrl;
            proxy.ws(req, socket, head);
            req.url = originalUrl;
            return;
        }

        // Get or create termshare session
        let session = activeSessions[sessionName];
        if (!session) {
            try {
                session = getOrCreateSession(sessionName);
            } catch (e) {
                socket.write('HTTP/1.1 500 Server Error\r\n\r\n');
                socket.destroy();
                return;
            }
        }

        // Create WebSocket server for this upgrade
        const wss = new WebSocket.Server({ noServer: true });
        wss.handleUpgrade(req, socket, head, (ws) => {
            // Parse query params for client info
            const wsUrl = new URL(req.url, 'http://localhost');
            const clientName = termshare.sanitizeName(wsUrl.searchParams.get('name') || 'Anonymous');
            const cols = parseInt(wsUrl.searchParams.get('cols') || '80', 10);
            const rows = parseInt(wsUrl.searchParams.get('rows') || '24', 10);

            const clientId = termshare.generateClientId();
            const colorIndex = Math.floor(Math.random() * 1000);

            // Attach client to termshare room
            session.room.attachClient(
                { id: clientId, name: clientName, colorIndex, cols, rows },
                termshare.createSocketAdapter(ws)
            );
        });
    });

    server.listen(PROXY_PORT, '127.0.0.1');
    return server;
}

// Tunnel manager - handles auto-restart and URL updates
let currentTunnelProc = null;
let currentPublicUrl = null;
let shuttingDown = false;  // Prevent restart during cleanup
const tunnelEmitter = new EventEmitter();
let CLIENT_TUNNEL_CONFIG = null; // { tunnelId, credentialsPath, hostname, configDir }

function startTunnel(isRestart = false) {
    const domainConfig = getDomainConfig();
    const useNamedTunnel = domainConfig && domainConfig.tunnelName && domainConfig.hostname;

    if (!isRestart) {
        if (useNamedTunnel) {
            log(`[3/4] Opening Cloudflare Tunnel (${domainConfig.hostname})...`, BOLD);
        } else {
            log(`[3/4] Opening Cloudflare Tunnel...`, BOLD);
        }
    } else {
        log(`[Tunnel] Reconnecting...`, YELLOW);
    }

    // Use named tunnel if configured, otherwise quick tunnel
    let tunnel;
    let publicUrl;

    if (useNamedTunnel) {
        // Named tunnel with custom domain - URL is fixed
        publicUrl = `https://${domainConfig.hostname}`;

        // Create config file for the tunnel
        const tunnelConfigPath = path.join(HOME_DIR, '.tunnel-config.yml');
        const tunnelConfig = `
url: http://localhost:${PROXY_PORT}
tunnel: ${domainConfig.tunnelName}
`;
        fs.writeFileSync(tunnelConfigPath, tunnelConfig);

        tunnel = spawn('cloudflared', [
            'tunnel',
            '--config', tunnelConfigPath,
            'run', domainConfig.tunnelName
        ]);
    } else {
        // Quick tunnel - URL is random
        tunnel = spawn('cloudflared', ['tunnel', '--url', `http://localhost:${PROXY_PORT}`]);
    }

    tunnel.on('close', (code) => {
        if (shuttingDown) return;  // Don't restart during cleanup
        if (code !== null) {
            log(`[Tunnel] Disconnected (code ${code}). Restarting in 3s...`, YELLOW);
            setTimeout(() => {
                if (!shuttingDown) startTunnelWithRestart();
            }, 3000);
        }
    });

    tunnel.on('error', (err) => {
        if (shuttingDown) return;  // Don't restart during cleanup
        log(`[Tunnel] Error: ${err.message}. Restarting in 3s...`, RED);
        setTimeout(() => {
            if (!shuttingDown) startTunnelWithRestart();
        }, 3000);
    });

    // For named tunnels, resolve immediately with the known URL
    if (useNamedTunnel) {
        currentTunnelProc = tunnel;
        currentPublicUrl = publicUrl;

        // Wait a moment for tunnel to establish, then resolve
        return new Promise((resolve) => {
            let resolved = false;

            // Listen for successful connection or error
            tunnel.stderr.on('data', (data) => {
                const output = data.toString();
                // Look for connection established message
                if (!resolved && (output.includes('Registered tunnel connection') || output.includes('Connection'))) {
                    resolved = true;
                    if (isRestart) {
                        tunnelEmitter.emit('urlChanged', publicUrl);
                        log(`[Tunnel] Reconnected: ${publicUrl}`, GREEN);
                    }
                    resolve({ tunnel, publicUrl });
                }
            });

            // Timeout fallback - assume connected after 5 seconds
            setTimeout(() => {
                if (!resolved) {
                    resolved = true;
                    if (isRestart) {
                        tunnelEmitter.emit('urlChanged', publicUrl);
                    }
                    resolve({ tunnel, publicUrl });
                }
            }, 5000);
        });
    }

    // For quick tunnels, parse URL from output
    let urlFound = false;
    return new Promise((resolve) => {
        tunnel.stderr.on('data', (data) => {
            if (urlFound) return;
            const output = data.toString();
            const match = output.match(/https:\/\/[a-zA-Z0-9-]+\.trycloudflare\.com/);

            if (match) {
                const parsedUrl = match[0];
                if (parsedUrl.includes('api.trycloudflare.com')) return;

                urlFound = true;
                currentTunnelProc = tunnel;
                currentPublicUrl = parsedUrl;

                // Emit URL change event for restarts
                if (isRestart) {
                    tunnelEmitter.emit('urlChanged', parsedUrl);
                    log(`[Tunnel] New URL: ${parsedUrl}`, GREEN);
                }

                resolve({ tunnel, publicUrl: parsedUrl });
            }
        });
    });
}

function startClientTunnel(isRestart = false) {
    if (!CLIENT_TUNNEL_CONFIG) {
        throw new Error('Client tunnel config missing');
    }

    const { tunnelId, credentialsPath, hostname, configDir } = CLIENT_TUNNEL_CONFIG;
    const publicUrl = hostname ? `https://${hostname}` : null;

    if (!isRestart) {
        log(`[3/4] Opening Cloudflare Tunnel${hostname ? ` (${hostname})` : ''}...`, BOLD);
    } else {
        log(`[Tunnel] Reconnecting...`, YELLOW);
    }

    const tunnelConfigPath = path.join(configDir, 'tunnel-config.yml');
    const tunnelConfig = `
url: http://localhost:${PROXY_PORT}
tunnel: ${tunnelId}
credentials-file: ${path.resolve(credentialsPath)}
`;
    writePrivateFile(tunnelConfigPath, tunnelConfig);

    const tunnel = spawn('cloudflared', ['tunnel', '--config', tunnelConfigPath, 'run'], {
        stdio: ['ignore', 'pipe', 'pipe']
    });

    tunnel.on('close', (code) => {
        if (shuttingDown) return;  // Don't restart during cleanup
        if (code !== null) {
            log(`[Tunnel] Disconnected (code ${code}). Restarting in 3s...`, YELLOW);
            setTimeout(() => {
                if (!shuttingDown) startTunnelWithRestart();
            }, 3000);
        }
    });

    tunnel.on('error', (err) => {
        if (shuttingDown) return;  // Don't restart during cleanup
        log(`[Tunnel] Error: ${err.message}. Restarting in 3s...`, RED);
        setTimeout(() => {
            if (!shuttingDown) startTunnelWithRestart();
        }, 3000);
    });

    currentTunnelProc = tunnel;
    currentPublicUrl = publicUrl;

    return new Promise((resolve) => {
        let resolved = false;

        tunnel.stderr.on('data', (data) => {
            const output = data.toString();
            if (!resolved && (output.includes('Registered tunnel connection') || output.includes('Connection'))) {
                resolved = true;
                if (isRestart) {
                    if (publicUrl) {
                        tunnelEmitter.emit('urlChanged', publicUrl);
                        log(`[Tunnel] Reconnected: ${publicUrl}`, GREEN);
                    } else {
                        log(`[Tunnel] Reconnected.`, GREEN);
                    }
                }
                resolve({ tunnel, publicUrl });
            }
        });

        // Timeout fallback - assume connected after 5 seconds
        setTimeout(() => {
            if (!resolved) {
                resolved = true;
                if (isRestart && publicUrl) {
                    tunnelEmitter.emit('urlChanged', publicUrl);
                }
                resolve({ tunnel, publicUrl });
            }
        }, 5000);
    });
}

async function startTunnelWithRestart() {
    try {
        const { tunnel, publicUrl } = CLIENT_TUNNEL_CONFIG
            ? await startClientTunnel(true)
            : await startTunnel(true);

        // Update state file
        if (fs.existsSync(STATE_FILE)) {
            try {
                const state = JSON.parse(fs.readFileSync(STATE_FILE, 'utf8'));
                state.url = publicUrl;
                writePrivateFile(STATE_FILE, JSON.stringify(state));
            } catch (e) { }
        }

        // Update all active session tmux bars
        Object.keys(activeSessions).forEach(sessionName => {
            applyTmuxStyles(sessionName, publicUrl);
        });
    } catch (e) {
        log(`[Tunnel] Failed to restart: ${e.message}. Retrying in 5s...`, RED);
        setTimeout(startTunnelWithRestart, 5000);
    }
}

function waitForStart(authEmitter, publicUrl, label) {
    return new Promise((resolve) => {
        console.clear();
        log(`\n==================================================`, MAGENTA);
        log(`            >>>  HOP - TUNNEL SHELL  <<<`, BOLD + MAGENTA);
        log(`==================================================\n`, MAGENTA);

        log(`TUNNEL URL:`, BOLD + GREEN);
        log(`  ${publicUrl}`, GREEN);
        log(`  Scan to open on mobile:`, RESET);

        // Simple URL QR code - scan with any camera app
        qrcode.generate(publicUrl, { small: true });

        log(`\n--------------------------------------------------`, RESET);

        // Standardized TOTP QR Code using the helper function
        showQrCode(label || 'Hop');

        log(`\n--------------------------------------------------`, RESET);

        const readline = require('readline');
        const rl = readline.createInterface({ input: process.stdin, output: process.stdout });

        log(`\n[READY]`, GREEN + BOLD);
        log(`Press ENTER to launch local session, or login remotely...`, RESET);

        let resolved = false;

        const finish = (reason) => {
            if (resolved) return;
            resolved = true;
            rl.close();
            log(`\n${reason}. Launching local session...`, GREEN);
            setTimeout(resolve, 800);
        };

        rl.question('', () => finish('Manual Start'));
        authEmitter.once('authenticated', () => finish('Remote Login'));
    });
}

// Generate QR code and prompt for verification
function showQrCode(label = 'Hop') {
