// Start or get existing session (uses hay for terminal sharing)
function getOrCreateSession(sessionName, cwd, displayName) {
    if (!sessionName || typeof sessionName !== 'string' || !SESSION_NAME_RE.test(sessionName)) {
        throw new Error('Invalid session name');
    }
    const existingConfig = getEffectiveSessionConfig(sessionName);
    if (existingConfig && existingConfig.type === 'port') {
        throw new Error('Session is configured as a port proxy');
    }
    rememberRuntimeSessionMetadata(sessionName, {
        type: 'terminal',
        cwd: cwd || existingConfig?.cwd,
        displayName: displayName || existingConfig?.displayName || toDisplaySessionName(sessionName),
        shell: existingConfig?.shell,
        env: existingConfig?.env,
        cols: existingConfig?.cols,
        rows: existingConfig?.rows,
        startup: existingConfig?.startup,
        autoStart: existingConfig?.autoStart,
        createdBy: existingConfig?.createdBy || 'user',
        agentPermitted: typeof existingConfig?.agentPermitted === 'boolean'
            ? existingConfig.agentPermitted
            : (existingConfig?.createdBy === 'agent'),
        folderId: existingConfig?.folderId || null,
        workspaceName: resolveSessionWorkspaceName(existingConfig)
    });
    if (activeSessions[sessionName]) {
        return activeSessions[sessionName];
    }
    if (isExternalTerminalBackend()) {
        const hostState = getExternalHayHostStateOrThrow();
        activeSessions[sessionName] = {
            backend: 'external',
            hostPort: hostState.port
        };
        return activeSessions[sessionName];
    }

    const config = getEffectiveSessionConfig(sessionName);
    const workspaceName = resolveSessionWorkspaceName(config);
    const ptyRuntime = buildSessionPtyEnv(sessionName, config, workspaceName);
    const effectiveCwd = cwd || config?.cwd;
    const initialCols = Number.isInteger(config?.cols) ? config.cols : 80;
    const initialRows = Number.isInteger(config?.rows) ? config.rows : 24;
    const display = config?.displayName || getSessionDisplayName(sessionName);

    // Create hay room for this session (with optional cwd/shell/env override)
    const room = hayRooms.getRoom(sessionName, { cols: initialCols, rows: initialRows }, {
        cwd: effectiveCwd,
        shell: config?.shell,
        env: ptyRuntime.env
    });
    const auditState = getSessionAuditState(sessionName, ptyRuntime.workspaceName, display);

    appendSessionAuditEvent(sessionName, ptyRuntime.workspaceName, 'session_start', {
        displayName: display,
        workspaceName: ptyRuntime.workspaceName,
        cwd: effectiveCwd || null,
        shell: config?.shell || null,
        historyFile: ptyRuntime.historyFile,
        auditMode: auditState.mode
    });

    room.on('pty_output', (event) => {
        handleSessionAuditOutput(auditState, event);
    });

    room.on('pty_input', (event) => {
        const actor = event?.actor || resolveSessionClientActor(sessionName, event?.clientId) || 'unknown';
        appendSessionAuditEvent(sessionName, ptyRuntime.workspaceName, 'input', {
            displayName: display,
            workspaceName: ptyRuntime.workspaceName,
            clientId: event?.clientId || null,
            actor,
            source: event?.source || null,
            ...truncateAuditText(event?.data)
        });
        detectAndRecordCommandLaunch(auditState, event, actor, event?.clientId || null);
    });

    room.on('pty_state', (event) => {
        const eventTs = Number.isFinite(event?.timestamp) ? Number(event.timestamp) : Date.now();
        const nextAlternate = event?.alternateScreen === true;
        const nextCursorHidden = event?.cursorHidden === true;
        auditState.alternateScreen = nextAlternate;
        auditState.cursorHidden = nextCursorHidden;
        setSessionAuditMode(
            auditState,
            nextAlternate ? 'tui_keyframe' : 'stream',
            'pty_state',
            eventTs
        );
        appendSessionAuditEvent(sessionName, ptyRuntime.workspaceName, 'pty_state', {
            displayName: display,
            workspaceName: ptyRuntime.workspaceName,
            alternateScreen: nextAlternate,
            cursorHidden: nextCursorHidden
        });
    });

    room.on('pty_resize', (event) => {
        appendSessionAuditEvent(sessionName, ptyRuntime.workspaceName, 'resize', {
            displayName: display,
            workspaceName: ptyRuntime.workspaceName,
            clientId: event?.clientId || null,
            actor: resolveSessionClientActor(sessionName, event?.clientId) || 'unknown',
            cols: event?.cols,
            rows: event?.rows
        });
    });

    room.on('session_end', (event) => {
        flushSessionTuiKeyframe(auditState, event?.timestamp, true);
        appendSessionAuditEvent(sessionName, ptyRuntime.workspaceName, 'session_end', {
            displayName: display,
            workspaceName: ptyRuntime.workspaceName,
            exitCode: event?.exitCode ?? null,
            signal: event?.signal ?? null,
            message: event?.message || 'Session ended'
        });
    });

    applyPostStartupHistoryIsolation(room, config, ptyRuntime);

    room.on('empty', () => {
        closeSessionAuditSink(sessionName);
        clearSessionClientActors(sessionName);
        delete activeSessions[sessionName];
        clearRuntimeSessionMetadata(sessionName);
        log(`Session ${getSessionDisplayName(sessionName)} closed.`, YELLOW);
        sessionClientSummary.delete(sessionName);
    });

    activeSessions[sessionName] = { room };
    log(`  Started session "${getSessionDisplayName(sessionName)}" (hay)`, GREEN);

    return activeSessions[sessionName];
}

function createVirtualClientAdapter(onServerMessage) {
    let messageHandler = null;
    const closeHandlers = [];
    let errorHandler = null;
    let open = true;

    return {
        adapter: {
            send: (data) => {
                if (!open) return;
                onServerMessage?.(data);
            },
            onMessage: (handler) => {
                messageHandler = handler;
            },
            onClose: (handler) => {
                closeHandlers.push(handler);
            },
            onError: (handler) => {
                errorHandler = handler;
            },
            close: () => {
                if (!open) return;
                open = false;
                for (const handler of closeHandlers) {
                    handler();
                }
            },
            isOpen: () => open
        },
        emit: (payload) => {
            if (!open) return;
            if (messageHandler) {
                messageHandler(payload);
            }
        },
        error: (err) => {
            if (errorHandler) errorHandler(err);
        },
        close: () => {
            if (!open) return;
            open = false;
            for (const handler of closeHandlers) {
                handler();
            }
        }
    };
}

function closeTerminalApiEntry(terminalId) {
    terminalApiSessions.delete(terminalId);
    const streams = terminalApiStreams.get(terminalId);
    if (streams) {
        for (const res of streams) {
            res.end();
        }
        terminalApiStreams.delete(terminalId);
    }
    clearTerminalEventBuffer(terminalId);
}

function handleTerminalApiServerMessage(terminalId, parsed) {
    if (!parsed || !parsed.type) return;
    if (parsed.type === 'output' || parsed.type === 'snapshot') {
        sendTerminalStreamEvent(terminalId, {
            type: parsed.type,
            data: parsed.data,
            alternateScreen: parsed.alternateScreen,
            cursorHidden: parsed.cursorHidden,
            timestamp: Date.now()
        });
        return;
    }
    if (parsed.type === 'session_ended') {
        sendTerminalStreamEvent(terminalId, {
            type: 'session_ended',
            exitCode: parsed.exitCode,
            signal: parsed.signal,
            message: parsed.message,
            timestamp: Date.now()
        });
        closeTerminalApiEntry(terminalId);
    }
}

async function attachExternalTerminalApiClient(sessionName, displayName, opts = {}) {
    await ensureExternalRuntimeSession(sessionName, opts.cwd, displayName, {
        shell: opts.shell,
        env: opts.env,
        cols: opts.cols,
        rows: opts.rows,
        startup: opts.startup,
        autoStart: opts.autoStart,
        createdBy: opts.createdBy,
        agentPermitted: opts.agentPermitted,
        workspaceName: opts.workspaceName,
        folderId: opts.folderId,
        saveDefinition: opts.saveDefinition === true
    });

    const cols = Number.isInteger(opts.cols) ? opts.cols : 80;
    const rows = Number.isInteger(opts.rows) ? opts.rows : 24;
    const label = opts.label || 'agent';
    const terminalId = `t_${crypto.randomBytes(6).toString('hex')}`;
    const clientId = hay.generateClientId();
    const sessionCwd = opts.cwd || (getEffectiveSessionConfig(sessionName) || {}).cwd;
    const wsUrl = buildExternalHayWsUrl(sessionName, {
        name: label,
        cols,
        rows,
        source: `terminal-api-${opts.actor || 'user'}`,
        cwd: sessionCwd
    });
    const ws = new WebSocket(wsUrl);
    let open = false;
    let closed = false;
    const pendingPayloads = [];

    const adapterBundle = {
        emit: (payload) => {
            if (closed || !payload) return;
            if (open && ws.readyState === WebSocket.OPEN) {
                ws.send(payload);
                return;
            }
            pendingPayloads.push(payload);
        },
        close: () => {
            if (closed) return;
            closed = true;
            closeTerminalApiEntry(terminalId);
            try { ws.close(); } catch (e) { }
        }
    };

    ws.on('open', () => {
        if (closed) return;
        open = true;
        while (pendingPayloads.length > 0 && ws.readyState === WebSocket.OPEN) {
            const payload = pendingPayloads.shift();
            if (payload) {
                ws.send(payload);
            }
        }
    });

    ws.on('message', (payload) => {
        let parsed = null;
        try {
            parsed = hay.safeParseServerMessage ? hay.safeParseServerMessage(payload.toString()) : JSON.parse(payload.toString());
        } catch (e) {
            parsed = null;
        }
        handleTerminalApiServerMessage(terminalId, parsed);
    });

    ws.on('close', () => {
        if (closed) return;
        closed = true;
        closeTerminalApiEntry(terminalId);
    });

    ws.on('error', () => {
        if (closed) return;
        closed = true;
        closeTerminalApiEntry(terminalId);
    });

    const sessionEntry = {
        id: terminalId,
        sessionName,
        displayName: displayName || getSessionDisplayName(sessionName),
        actor: opts.actor || 'user',
        clientId,
        adapter: adapterBundle,
        createdAt: new Date().toISOString()
    };
    terminalApiSessions.set(terminalId, sessionEntry);
    return sessionEntry;
}

async function attachTerminalApiClient(sessionName, displayName, opts = {}) {
    if (isExternalTerminalBackend()) {
        return await attachExternalTerminalApiClient(sessionName, displayName, opts);
    }
    const session = activeSessions[sessionName] || getOrCreateSession(sessionName, opts.cwd, displayName);
    const room = session.room;
    const cols = Number.isInteger(opts.cols) ? opts.cols : 80;
    const rows = Number.isInteger(opts.rows) ? opts.rows : 24;
    const label = opts.label || 'agent';
    const colorIndex = Math.floor(Math.random() * 1000);

    const terminalId = `t_${crypto.randomBytes(6).toString('hex')}`;
    const clientId = hay.generateClientId();

    const adapterBundle = createVirtualClientAdapter((payload) => {
        let parsed = null;
        try {
            parsed = hay.safeParseServerMessage ? hay.safeParseServerMessage(payload) : JSON.parse(payload);
        } catch (e) {
            parsed = null;
        }
        handleTerminalApiServerMessage(terminalId, parsed);
    });

    room.attachClient(
        { id: clientId, name: label, colorIndex, cols, rows },
        adapterBundle.adapter
    );
    registerSessionClientActor(sessionName, clientId, opts.actor || label || 'agent');

    adapterBundle.adapter.onClose(() => {
        unregisterSessionClientActor(sessionName, clientId);
        closeTerminalApiEntry(terminalId);
    });

    const sessionEntry = {
        id: terminalId,
        sessionName,
        displayName: displayName || getSessionDisplayName(sessionName),
        actor: opts.actor || 'user',
        clientId,
        adapter: adapterBundle,
        createdAt: new Date().toISOString()
    };
    terminalApiSessions.set(terminalId, sessionEntry);
    return sessionEntry;
}

function sendTerminalInput(entry, data) {
    if (!entry || !data) return;
    entry.adapter.emit(JSON.stringify({ type: 'input', data }));
}

function sendTerminalResize(entry, cols, rows) {
    if (!entry || !Number.isFinite(cols) || !Number.isFinite(rows)) return;
    entry.adapter.emit(JSON.stringify({ type: 'resize', cols, rows }));
}

// Resolve display name aliases (follows rename chain)
function resolveDisplayNameAlias(name) {
    if (!name || typeof name !== 'string') return name;
    let current = name;
    const seen = new Set();
    while (sessionAliases[current] && !seen.has(current)) {
        seen.add(current);
        current = sessionAliases[current];
    }
    return current;
}

