// Start or get existing session (uses termshare for terminal sharing)
function getOrCreateSession(sessionName) {
    if (!sessionName || typeof sessionName !== 'string' || !SESSION_NAME_RE.test(sessionName)) {
        throw new Error('Invalid session name');
    }
    const existingConfig = getSessionConfig(sessionName);
    if (existingConfig && existingConfig.type === 'port') {
        throw new Error('Session is configured as a port proxy');
    }
    ensureTerminalSessionConfig(sessionName);
    if (activeSessions[sessionName]) {
        return activeSessions[sessionName];
    }

    // Create termshare room for this session
    const room = termshareRooms.getRoom(sessionName, { cols: 80, rows: 24 });

    room.on('empty', () => {
        delete activeSessions[sessionName];
        log(`Session ${toDisplaySessionName(sessionName)} closed.`, YELLOW);
    });

    room.on('exit', () => {
        delete activeSessions[sessionName];
        log(`Session ${toDisplaySessionName(sessionName)} exited.`, YELLOW);
    });

    activeSessions[sessionName] = { room };
    log(`  Started session "${toDisplaySessionName(sessionName)}" (termshare)`, GREEN);

    return activeSessions[sessionName];
}

