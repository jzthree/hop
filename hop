const PRIVATE_DIR_MODE = 0o700;
const PRIVATE_FILE_MODE = 0o600;

function ensurePrivateDir(dirPath) {
    try {
        if (!fs.existsSync(dirPath)) {
            fs.mkdirSync(dirPath, { recursive: true, mode: PRIVATE_DIR_MODE });
        } else {
            fs.chmodSync(dirPath, PRIVATE_DIR_MODE);
        }
    } catch (e) { }
}

function ensurePrivateFile(filePath, mode = PRIVATE_FILE_MODE) {
    try {
        if (fs.existsSync(filePath)) {
            fs.chmodSync(filePath, mode);
        }
    } catch (e) { }
}

function writePrivateFile(filePath, data, mode = PRIVATE_FILE_MODE) {
    fs.writeFileSync(filePath, data, { mode });
    ensurePrivateFile(filePath, mode);
}

