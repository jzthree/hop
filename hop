        log(`  hop stop --all            Stop daemon, hay-host, and all terminal sessions`, RESET);
        log(`  hop status                Show daemon, tunnel, and session status`, RESET);
        log(`  hop doctor                Run environment/health checks`, RESET);
        log(`  hop logs [-f] [hay-host]  Show daemon logs (-f to follow)`, RESET);
        log(`  hop --help                Show this help message`, RESET);
        log('');
        log(`${BOLD}URL & QR:${RESET}`, RESET);
        log(`  hop url                   Print current tunnel URL`, RESET);
        log(`  hop qr                    Show tunnel URL as QR code`, RESET);
        log(`  hop qr auth               Show authenticator setup QR code`, RESET);
        log('');
        log(`${BOLD}Config:${RESET}`, RESET);
        log(`  hop config                Show hop config`, RESET);
        log(`  hop config theme [name]   Show or set the session naming theme`, RESET);
        log('');
        log(`${BOLD}Custom Domain:${RESET}`, RESET);
        log(`  hop domain                Show current domain config`, RESET);
        log(`  hop domain <hostname>     Setup custom domain (e.g., hop.example.com)`, RESET);
        log(`  hop domain-clear          Remove custom domain, use random URLs`, RESET);
        log('');
        log(`${BOLD}Security:${RESET}`, RESET);
        log(`  hop password              Show password status`, RESET);
        log(`  hop password set          Set or change password`, RESET);
        log(`  hop password clear        Remove password protection`, RESET);
        log('');
        log(`${BOLD}Multi-user (admin):${RESET}`, RESET);
        log(`  hop user list             List all users`, RESET);
        log(`  hop user add <name>       Add a user (creates tunnel + DNS)`, RESET);
        log(`  hop user remove <name>    Remove a user`, RESET);
        log(`  hop user export <name>    Export credentials for a user`, RESET);
        log('');
        log(`${BOLD}Sessions:${RESET}`, RESET);
        log(`  hop session list [--all|-a]      List live sessions (--all/-a adds workspace defs across all workspaces)`, RESET);
        log(`  hop session add <name> [--cwd P] --workspace W  Save a terminal definition to a workspace`, RESET);
        log(`  hop session add <name> --port N --workspace W   Save a port definition to a workspace`, RESET);
        log(`  hop session rename <old> <new>   Rename a session`, RESET);
        log(`  hop session remove <name>        Remove a session`, RESET);
        log(`  hop session permit <name>        Allow agent access`, RESET);
        log(`  hop session block <name>         Block agent access`, RESET);
        log('');
        log(`${BOLD}Workspaces:${RESET}`, RESET);
        log(`  hop workspace list            List workspaces`, RESET);
        log(`  hop workspace create <name>   Create an empty workspace`, RESET);
        log(`  hop workspace show <name>     Show saved definitions in a workspace`, RESET);
        log(`  hop workspace save <name>     Save selected live sessions into a workspace`, RESET);
        log(`  hop workspace load <name>     Start sessions defined in a workspace`, RESET);
        log(`  hop workspace delete <name> [--yes]  Delete a workspace (asks before deleting a non-empty one)`, RESET);
        log('');
        log(`${BOLD}Client mode (for users):${RESET}`, RESET);
        log(`  hop client <credentials>  Run tunnel with exported credentials`, RESET);
        log('');
        log(`${BOLD}Maintenance:${RESET}`, RESET);
        log(`  hop health [--restart]    Check tunnel health (--restart forces a tunnel restart)`, RESET);
        log(`  hop wipe [--all] [--yes]  Remove workspace-defined sessions (--all kills live; --yes skips confirmation)`, RESET);
        log(`  hop wipe --agent          Close all agent-created terminal API sessions`, RESET);
        log('');
        process.exit(0);
    }

    // Handle `hop url` command - prints current tunnel URL (easy to copy)
    // Handle `hop config` command
    if (process.argv[2] === 'config') {
        const subCmd = process.argv[3];
        if (subCmd === 'theme' || subCmd === 'naming-theme') {
            const themeArg = process.argv[4];
            if (themeArg) {
                if (!isValidTheme(themeArg)) {
                    log(`Unknown theme "${themeArg}". Available: ${getThemeChoices().map(c => c.id).join(', ')}`, RED);
                    process.exit(1);
                }
                setNamingTheme(themeArg);
                log(`Naming theme set to "${themeArg}".`, GREEN);
            } else {
                const current = getNamingTheme();
                if (current) {
                    log(`Current naming theme: ${current}`, RESET);
                    log(`Change with: hop config theme <name>`, DIM);
                } else {
                    log(`No naming theme configured. Run \`hop config theme <name>\` to set one.`, YELLOW);
                }
                log(`\nAvailable themes:`, RESET);
                for (const c of getThemeChoices()) {
                    const marker = c.id === current ? ` ${GREEN}(active)${RESET}` : '';
                    log(`  ${c.id.padEnd(10)} ${DIM}${c.example}${RESET}${marker}`);
                }
            }
            process.exit(0);
        }
        // Show all config
        const config = getHopConfig();
        log(`Hop config (${HOP_CONFIG_FILE}):`, BOLD);
        log(JSON.stringify(config, null, 2));
        process.exit(0);
    }

    if (process.argv[2] === 'url') {
        const state = isServerRunning();
        if (!state) {
            log(`Hop is not running.`, RED);
            process.exit(1);
        }
        // Print just the URL for easy copying/piping
        console.log(state.url);
        process.exit(0);
    }

    // Handle `hop qr` command - shows either the tunnel URL QR or authenticator QR
    if (process.argv[2] === 'qr') {
        const qrTarget = process.argv[3];

        if (qrTarget === 'auth') {
            if (!fs.existsSync(SECRET_FILE_PATH)) {
                log(`No authenticator secret is configured yet.`, RED);
                log(`Start hop once to complete setup, or reset by deleting ${SECRET_FILE_PATH}.`, RESET);
                process.exit(1);
            }
            loadAuthSecret();
            log(`\nAuthenticator setup QR:`, BOLD);
            log(`Scan this with Duo/Authy/1Password, not with your camera app.\n`, CYAN);
            showAuthQrCode(getAuthQrLabel());
            process.exit(0);
        }

        if (qrTarget && qrTarget !== 'url') {
            log(`Unknown qr target: ${qrTarget}`, RED);
            log(`Use ${CYAN}hop qr${RESET} for the tunnel URL or ${CYAN}hop qr auth${RESET} for the authenticator QR.`, RESET);
            process.exit(1);
        }

        const state = isServerRunning();
        if (!state) {
            log(`Hop is not running.`, RED);
            process.exit(1);
        }
        log(`\nCurrent tunnel URL:`, BOLD);
        log(`${state.url}\n`, GREEN);
        log(`This QR opens your Hop URL. It is not the authenticator setup QR.`, YELLOW);
        log(`Use ${CYAN}hop qr auth${RESET} for Duo/Authy/1Password.\n`, RESET);
        qrcode.generate(state.url, { small: true });
        process.exit(0);
    }

    // Handle `hop health` command - check tunnel health and optionally restart
    if (process.argv[2] === 'health') {
        const state = isServerRunning();
        if (!state) {
            log(`Hop is not running.`, RED);
            process.exit(1);
        }

        log(`\nChecking tunnel health...`, BOLD);
        log(`  URL: ${state.url}`, RESET);
        const result = await probeTunnelHealth(state.url, TUNNEL_HEALTH_TIMEOUT);
        let localStatus = null;
        try {
            const localRes = await callLocalApi(state, '/api/tunnel/status', 'GET');
            if (localRes && localRes.status === 200) {
                localStatus = localRes.data;
            }
        } catch (e) { }

        if (result.ok) {
            log(`  Status: ${GREEN}OK${RESET} (${result.status}) - ${result.time}ms`, GREEN);
        } else {
            const reason = result.error || (result.status ? `HTTP ${result.status}` : 'Unknown error');
            log(`  Status: ${RED}FAILED${RESET} - ${reason} (${result.time}ms)`, RED);
            if (localStatus) {
                const tunnelState = localStatus.connected ? `${GREEN}connected${RESET}` : `${RED}disconnected${RESET}`;
                log(`  Local tunnel: ${tunnelState}`, RESET);
                if (localStatus.lastEvent) {
                    log(`  Last event: ${localStatus.lastEvent}`, RESET);
                }
                if (localStatus.lastError) {
                    log(`  Last error: ${localStatus.lastError}`, YELLOW);
                }
            }

            if (process.argv[3] === '--restart' || process.argv[3] === '-r') {
                log(`\nRestarting tunnel...`, YELLOW);
                let restarted = false;
                try {
                    const res = await callLocalApi(state, '/api/tunnel/restart', 'POST');
                    if (res && res.status >= 200 && res.status < 300) {
                        restarted = true;
                        log(`Restart request sent. Waiting for tunnel to become healthy...`, GREEN);
                    }
                } catch (e) { }
                if (!restarted) {
                    try {
                        process.kill(state.pid, 'SIGUSR1');  // Fallback to signal daemon to restart tunnel
                        restarted = true;
                        log(`Restart signal sent. Waiting for tunnel to become healthy...`, GREEN);
                    } catch (e) {
                        log(`Failed to signal daemon: ${e.message}`, RED);
                    }
                }
                if (restarted) {
                    const waitStartedAt = Date.now();
                    const waitTimeoutMs = TUNNEL_RESTART_VERIFY_TIMEOUT + 5000;
                    let recovered = null;
                    let activeUrl = state.url;

                    while ((Date.now() - waitStartedAt) < waitTimeoutMs) {
                        try {
                            const freshLocal = await callLocalApi(state, '/api/tunnel/status', 'GET');
                            if (freshLocal && freshLocal.status === 200 && freshLocal.data && freshLocal.data.url) {
                                activeUrl = freshLocal.data.url;
                            }
                        } catch (e) { }

                        recovered = await probeTunnelHealth(activeUrl, TUNNEL_HEALTH_TIMEOUT);
                        if (recovered.ok) {
                            log(`Tunnel healthy again: ${GREEN}${recovered.status}${RESET} after ${Date.now() - waitStartedAt}ms`, GREEN);
                            process.exit(0);
                        }
                        await new Promise((resolve) => setTimeout(resolve, TUNNEL_RESTART_VERIFY_INTERVAL));
                    }
                    const reason = (recovered && (recovered.error || (recovered.status ? `HTTP ${recovered.status}` : null))) || 'Unknown error';
                    log(`Tunnel restart did not recover within ${Math.ceil((Date.now() - waitStartedAt) / 1000)}s: ${reason}`, RED);
                }
            } else {
                log(`\nRun ${CYAN}hop health --restart${RESET} to force tunnel restart.`, RESET);
            }
        }
        process.exit(result.ok ? 0 : 1);
    }

    // Handle `hop domain <hostname>` command - setup custom domain
    if (process.argv[2] === 'domain') {
        const hostname = process.argv[3];
        if (!hostname) {
            // Show current domain config
            const config = getDomainConfig();
            if (config) {
                log(`\nCurrent custom domain configuration:`, BOLD);
                log(`  Hostname: ${config.hostname}`, GREEN);
                log(`  Tunnel:   ${config.tunnelName}`, RESET);
                log(`\nTo change: hop domain <new-hostname>`, RESET);
                log(`To remove: hop domain-clear`, RESET);
            } else {
                log(`\nNo custom domain configured.`, YELLOW);
                log(`\nUsage: hop domain <hostname>`, RESET);
                log(`Example: hop domain hop.yourdomain.com`, RESET);
            }
            process.exit(0);
        }
        // Validate hostname format
        if (!/^[a-zA-Z0-9]([a-zA-Z0-9-]*\.)+[a-zA-Z]{2,}$/.test(hostname)) {
            log(`Invalid hostname format: ${hostname}`, RED);
            log(`Example: hop.yourdomain.com`, RESET);
            process.exit(1);
        }
        await setupDomain(hostname);
        process.exit(0);
    }

    // Handle `hop domain-clear` command - remove custom domain config
    if (process.argv[2] === 'domain-clear') {
        if (fs.existsSync(DOMAIN_CONFIG_FILE)) {
            fs.unlinkSync(DOMAIN_CONFIG_FILE);
            log(`Custom domain configuration removed.`, GREEN);
            log(`Hop will use random Cloudflare URLs again.`, RESET);
        } else {
            log(`No custom domain configured.`, YELLOW);
        }
        process.exit(0);
    }

    // Handle `hop password` commands
    if (process.argv[2] === 'password') {
        const subcommand = process.argv[3];
        const readline = require('readline');

        if (!subcommand || subcommand === 'status') {
            if (isPasswordEnabled()) {
                log(`Password protection: ${GREEN}ENABLED${RESET}`, BOLD);
                log(`\nTo change: hop password set`, RESET);
                log(`To remove: hop password clear`, RESET);
            } else {
                log(`Password protection: ${YELLOW}DISABLED${RESET}`, BOLD);
                log(`\nTo enable: hop password set`, RESET);
            }
            process.exit(0);
        }

        if (subcommand === 'set') {
            // Use muted readline for password input
            const askPassword = (prompt) => new Promise((resolve) => {
                const rl = readline.createInterface({
                    input: process.stdin,
                    output: new (require('stream').Writable)({
                        write: (chunk, encoding, callback) => callback()
                    }),
                    terminal: true
                });

                process.stdout.write(prompt);
                rl.question('', (answer) => {
                    rl.close();
                    process.stdout.write('\n');
                    resolve(answer);
                });
            });

            const password = await askPassword('Enter new password: ');
            if (password.length < 4) {
                log(`Password too short (min 4 characters).`, RED);
                process.exit(1);
            }

            const confirm = await askPassword('Confirm password: ');
            if (password !== confirm) {
                log(`Passwords do not match.`, RED);
                process.exit(1);
            }

            setPassword(password);
            log(`\n${GREEN}✓ Password set successfully.${RESET}`, GREEN);
            log(`\nLogin will now require password + TOTP code.`, RESET);
            process.exit(0);
        }

        if (subcommand === 'clear') {
            if (!isPasswordEnabled()) {
                log(`Password is not set.`, YELLOW);
                process.exit(0);
            }
            clearPassword();
            log(`${GREEN}✓ Password protection removed.${RESET}`, GREEN);
            log(`\nLogin will only require TOTP code.`, RESET);
            process.exit(0);
        }

        const unknownPasswordSub = subcommand && subcommand !== 'help' && subcommand !== '--help';
        if (unknownPasswordSub) {
            log(`Unknown subcommand: ${subcommand}`, RED);
        }
        log(`\n${BOLD}Password commands:${RESET}\n`, CYAN);
        log(`  hop password           Show password status`, RESET);
        log(`  hop password set       Set or change password`, RESET);
        log(`  hop password clear     Remove password protection`, RESET);
        process.exit(unknownPasswordSub ? 1 : 0);
    }

    // Handle `hop user` commands - multi-user management
    if (process.argv[2] === 'user') {
        const subcommand = process.argv[3];
        const username = process.argv[4];

        if (!subcommand || subcommand === 'list') {
            listUsersCommand();
            process.exit(0);
        }

        if (subcommand === 'add') {
            if (!username) {
                log(`Usage: hop user add <username>`, RED);
                process.exit(1);
            }
            await addUser(username);
            process.exit(0);
        }

        if (subcommand === 'remove' || subcommand === 'rm' || subcommand === 'delete') {
            if (!username) {
                log(`Usage: hop user remove <username>`, RED);
                process.exit(1);
            }
            await removeUser(username);
            process.exit(0);
        }

        if (subcommand === 'export') {
            if (!username) {
                log(`Usage: hop user export <username>`, RED);
                process.exit(1);
            }
            await exportUserCredentials(username);
            process.exit(0);
        }

        const unknownUserSub = subcommand && subcommand !== 'help' && subcommand !== '--help';
        if (unknownUserSub) {
            log(`Unknown subcommand: ${subcommand}`, RED);
        }
        log(`\n${BOLD}User management commands:${RESET}\n`, CYAN);
        log(`  hop user list              List all users`, RESET);
        log(`  hop user add <username>    Add a new user`, RESET);
        log(`  hop user remove <username> Remove a user`, RESET);
        log(`  hop user export <username> Export credentials for a user`, RESET);
        process.exit(unknownUserSub ? 1 : 0);
    }

    // Handle `hop workspace` commands
    if (process.argv[2] === 'workspace') {
        const subcommand = process.argv[3];
        const nameArg = process.argv[4];
        const existing = isServerRunning();

        if (!subcommand || subcommand === 'list') {
            if (existing) {
                const res = await callLocalApi(existing, '/api/workspaces', 'GET');
                if (res.status !== 200) {
                    log(`Failed to list workspaces.`, RED);
                    process.exit(1);
                }
                const names = res.data.workspaces || [];
                if (names.length === 0) {
                    log(`No workspaces found.`, YELLOW);
                } else {
                    log(`\n${BOLD}Workspaces:${RESET}\n`, CYAN);
                    names.forEach((name) => {
                        log(`  ${name}`, RESET);
                    });
                }
            } else {
                const names = listWorkspaceNames();
                if (names.length === 0) {
                    log(`No workspaces found.`, YELLOW);
                } else {
                    log(`\n${BOLD}Workspaces:${RESET}\n`, CYAN);
                    names.forEach((name) => {
                        log(`  ${name}`, RESET);
                    });
                }
            }
            process.exit(0);
        }

        if (subcommand === 'create') {
            if (!nameArg) {
                log(`Usage: hop workspace create <name>`, RED);
                process.exit(1);
            }
            if (existing) {
                const res = await callLocalApi(existing, '/api/workspaces/create', 'POST', { name: nameArg });
                if (res.status !== 200) {
                    log(res.data?.error || `Failed to create workspace.`, RED);
                    process.exit(1);
                }
            } else {
                const created = createWorkspaceFile(nameArg);
                if (created === null) {
                    log(`Invalid workspace name.`, RED);
                    process.exit(1);
                }
                if (created === false) {
                    log(`Workspace already exists.`, RED);
                    process.exit(1);
                }
            }
            log(`Workspace "${nameArg}" created.`, GREEN);
            process.exit(0);
        }

        if (subcommand === 'show') {
            if (!nameArg) {
                log(`Usage: hop workspace show <name>`, RED);
                process.exit(1);
            }
            let workspace = null;
            if (existing) {
                const res = await callLocalApi(existing, `/api/workspaces/show?name=${encodeURIComponent(nameArg)}`, 'GET');
                if (res.status !== 200) {
                    log(res.data?.error || `Workspace not found: ${nameArg}`, RED);
                    process.exit(1);
                }
                workspace = res.data?.workspace || null;
            } else {
                workspace = loadWorkspaceFile(nameArg);
                if (!workspace) {
                    log(`Workspace not found: ${nameArg}`, RED);
                    process.exit(1);
                }
            }
            printWorkspaceDetails(workspace);
            process.exit(0);
        }

        if (subcommand === 'save') {
            if (!nameArg) {
                log(`Usage: hop workspace save <name>`, RED);
                process.exit(1);
            }
            if (existing) {
                const sessionsRes = await callLocalApi(existing, '/api/sessions', 'GET');
                if (sessionsRes.status !== 200) {
                    log(`Failed to list live sessions.`, RED);
                    process.exit(1);
                }
                const liveEntries = (sessionsRes.data.sessions || [])
                    .filter((entry) => entry && entry.type === 'terminal' && entry.live === true)
                    .map((entry) => ({
                        internalName: entry.internalName,
                        displayName: entry.displayName || entry.name,
                        cwd: entry.cwd
                    }));
                const selection = await promptForWorkspaceSnapshotSelection(liveEntries);
                if (selection.cancelled) {
                    log(`Workspace save cancelled.`, YELLOW);
                    process.exit(0);
                }
                const res = await callLocalApi(existing, '/api/workspaces/save', 'POST', {
                    name: nameArg,
                    sessionNames: selection.selectedInternalNames
                });
                if (res.status !== 200) {
                    log(res.data?.error || `Failed to save workspace.`, RED);
                    process.exit(1);
                }
                const selected = Array.isArray(res.data?.selected) ? res.data.selected : [];
                log(`Workspace "${nameArg}" saved with ${selected.length} session(s).`, GREEN);
            } else {
                const snapshot = await listAllSessionEntriesRuntimeFirst();
                const liveEntries = snapshot.entries.filter((entry) => entry && entry.type === 'terminal' && entry.live === true);
                const selection = await promptForWorkspaceSnapshotSelection(liveEntries);
                if (selection.cancelled) {
                    log(`Workspace save cancelled.`, YELLOW);
                    process.exit(0);
                }
                const result = await snapshotWorkspaceFile(nameArg, selection.selectedInternalNames);
                if (!result || result.error === 'invalid-workspace') {
                    log(`Invalid workspace name.`, RED);
                    process.exit(1);
                }
                if (result.error === 'no-live-sessions') {
                    log(`No live terminal sessions to save.`, RED);
                    process.exit(1);
                }
                log(`Workspace "${nameArg}" saved with ${result.selected.length} session(s).`, GREEN);
            }
            process.exit(0);
        }

        if (subcommand === 'load') {
            if (!nameArg) {
                log(`Usage: hop workspace load <name>`, RED);
                process.exit(1);
            }
            if (existing) {
                const res = await callLocalApi(existing, '/api/workspaces/load', 'POST', { name: nameArg });
                if (res.status !== 200) {
                    log(`Failed to load workspace.`, RED);
                    process.exit(1);
                }
                const result = res.data.result || {};
                if (result.created?.length) {
                    log(`Created sessions: ${result.created.join(', ')}`, GREEN);
                }
                if (result.skipped?.length) {
                    log(`Skipped sessions: ${result.skipped.map(s => s.name).join(', ')}`, YELLOW);
                }
            } else {
                const workspace = loadWorkspaceFile(nameArg);
                if (!workspace) {
                    log(`Workspace not found: ${nameArg}`, RED);
                    process.exit(1);
                }
                await applyWorkspace(workspace, { startSessions: false, workspaceName: nameArg });
            }
            log(`Workspace "${nameArg}" loaded.`, GREEN);
            process.exit(0);
        }

        if (subcommand === 'delete' || subcommand === 'remove' || subcommand === 'rm') {
            if (!nameArg) {
                log(`Usage: hop workspace delete <name> [--yes]`, RED);
                process.exit(1);
            }
            // Confirm before deleting a workspace that still has saved definitions.
            const skipDeleteConfirm = process.argv.includes('--yes') || process.argv.includes('-y');
            if (!skipDeleteConfirm) {
                let savedCount = 0;
                if (existing) {
                    try {
                        const showRes = await callLocalApi(existing, `/api/workspaces/show?name=${encodeURIComponent(nameArg)}`, 'GET');
                        if (showRes.status === 200) {
                            savedCount = Object.keys(showRes.data?.workspace?.sessions || {}).length;
                        }
                    } catch (e) { }
                } else {
                    const workspace = loadWorkspaceFile(nameArg);
                    savedCount = Object.keys(workspace?.sessions || {}).length;
                }
                if (savedCount > 0) {
                    log(`Workspace "${nameArg}" contains ${savedCount} saved session definition(s).`, YELLOW);
                    if (!process.stdin.isTTY) {
                        log(`Refusing to delete a non-empty workspace without confirmation. Re-run with --yes.`, RED);
                        process.exit(1);
                    }
                    const confirmed = await promptYesNo(`Delete workspace "${nameArg}" and its saved definitions? [y/N] `);
                    if (!confirmed) {
                        log(`Aborted. Workspace was not deleted.`, YELLOW);
                        process.exit(1);
                    }
                }
            }
            if (existing) {
                const res = await callLocalApi(existing, '/api/workspaces/delete', 'POST', { name: nameArg });
                if (res.status !== 200) {
                    log(res.data?.error || `Failed to delete workspace.`, RED);
                    process.exit(1);
                }
            } else {
                const deleted = deleteWorkspaceFile(nameArg);
                if (deleted === null) {
                    log(`Invalid workspace name.`, RED);
                    process.exit(1);
                }
                if (deleted === false) {
                    log(`Workspace not found: ${nameArg}`, RED);
                    process.exit(1);
                }
            }
            log(`Workspace "${nameArg}" deleted.`, GREEN);
            process.exit(0);
        }

        const unknownWorkspaceSub = subcommand && subcommand !== 'help' && subcommand !== '--help';
        if (unknownWorkspaceSub) {
            log(`Unknown subcommand: ${subcommand}`, RED);
        }
        log(`\n${BOLD}Workspace commands:${RESET}\n`, CYAN);
        log(`  hop workspace list           List workspaces`, RESET);
        log(`  hop workspace create <name>  Create an empty workspace`, RESET);
        log(`  hop workspace show <name>    Show saved definitions in a workspace`, RESET);
        log(`  hop workspace save <name>    Save selected live sessions into a workspace`, RESET);
        log(`  hop workspace load <name>    Start sessions defined in a workspace`, RESET);
        log(`  hop workspace delete <name> [--yes]  Delete a workspace`, RESET);
        process.exit(unknownWorkspaceSub ? 1 : 0);
    }

    // Handle `hop session` commands
    if (process.argv[2] === 'session') {
        await ensureHayLoaded();
        const subcommand = process.argv[3];
        const nameArg = process.argv[4];

        if (!subcommand || subcommand === 'list') {
            const includeAll = process.argv.includes('--all') || process.argv.includes('-a');
            const snapshot = await listAllSessionEntriesRuntimeFirst();
            let sessions;
            if (includeAll) {
                const liveSessions = snapshot.entries.filter((session) => session && session.live === true);
                const workspaceDefs = listWorkspaceSessionDefinitions();
                const liveByName = new Map(liveSessions.map((session) => [
                    session.internalName,
                    { ...session, workspaceNames: [] }
                ]));
                const savedOnly = new Map();

                for (const def of workspaceDefs) {
                    if (liveByName.has(def.internalName)) {
                        const entry = liveByName.get(def.internalName);
                        entry.workspaceNames.push(def.workspaceName);
                        liveByName.set(def.internalName, entry);
                        continue;
                    }
                    const existing = savedOnly.get(def.internalName);
                    if (existing) {
                        existing.workspaceNames.push(def.workspaceName);
                        savedOnly.set(def.internalName, existing);
                    } else {
                        savedOnly.set(def.internalName, {
                            ...def,
                            live: false,
                            workspaceNames: [def.workspaceName]
                        });
                    }
                }

                sessions = [
                    ...liveByName.values(),
                    ...savedOnly.values()
                ];
            } else {
                sessions = snapshot.entries.filter((session) => session && session.type === 'terminal' && session.live === true);
            }
            if (sessions.length === 0) {
                log(includeAll ? `No sessions configured.` : `No live sessions.`, YELLOW);
                process.exit(0);
            }
            log(`\n${BOLD}Sessions:${RESET}\n`, CYAN);
            sessions.forEach(s => {
                if (s.type === 'port') {
                    const workspaceSuffix = Array.isArray(s.workspaceNames) && s.workspaceNames.length
                        ? `, WORKSPACE ${s.workspaceNames.join(',')}`
                        : '';
                    log(`  ${BOLD}${s.displayName}${RESET}  ${YELLOW}[PORT ${s.port}${workspaceSuffix}]${RESET}`, RESET);
                } else {
                    const workspaceSuffix = Array.isArray(s.workspaceNames) && s.workspaceNames.length
                        ? `, WORKSPACE ${s.workspaceNames.join(',')}`
                        : '';
                    const stateLabel = s.live
                        ? `${GREEN}[TERMINAL, LIVE${workspaceSuffix}]${RESET}`
                        : `${YELLOW}[TERMINAL${workspaceSuffix}]${RESET}`;
                    log(`  ${BOLD}${s.displayName}${RESET}  ${stateLabel}`, RESET);
                }
            });
            process.exit(0);
        }

        if (subcommand === 'add') {
            if (!nameArg) {
                log(`Usage: hop session add <name> [--port <number>] [--cwd <path>] --workspace <name>`, RED);
                process.exit(1);
            }
            const existingTunnel = isServerRunning();
            const displayName = nameArg;
            const name = toInternalSessionName(displayName);
            const workspaceArgIndex = process.argv.indexOf('--workspace');
            const explicitWorkspaceName = workspaceArgIndex !== -1
                ? normalizeWorkspaceName(process.argv[workspaceArgIndex + 1])
                : null;
            if (!explicitWorkspaceName) {
                log(`session add requires --workspace <name> to choose where the definition is saved.`, RED);
                log(`Example: ${CYAN}hop session add ${displayName} --port 3000 --workspace dev${RESET}`, RESET);
                log(`Tip: ${CYAN}hop workspace save <name>${RESET} snapshots live sessions instead.`, RESET);
                process.exit(1);
            }
            if (!name) {
                log(`Invalid session name.`, RED);
                process.exit(1);
            }
            if (isDisplayNameInUse(displayName)) {
                log(`Session name already in use.`, RED);
                process.exit(1);
            }
            if (hasSavedSessionConfig(name)) {
                log(`Session internal name already exists.`, RED);
                process.exit(1);
            }
            const cwdArgIndex = process.argv.indexOf('--cwd');
            let cwdPath = process.cwd();
            if (cwdArgIndex !== -1) {
                const cwdArg = process.argv[cwdArgIndex + 1];
                if (!cwdArg || cwdArg.startsWith('--')) {
                    log(`Missing path after --cwd.`, RED);
                    process.exit(1);
                }
                cwdPath = path.resolve(cwdArg);
                try {
                    if (!fs.existsSync(cwdPath) || !fs.statSync(cwdPath).isDirectory()) {
                        log(`Invalid directory for --cwd: ${cwdPath}`, RED);
                        process.exit(1);
                    }
                } catch (e) {
                    log(`Invalid directory for --cwd: ${cwdPath}`, RED);
                    process.exit(1);
                }
            }
            const portArgIndex = process.argv.indexOf('--port');
            if (portArgIndex !== -1) {
                const portArg = parseInt(process.argv[portArgIndex + 1], 10);
                if (!Number.isInteger(portArg) || portArg < 1 || portArg > 65535) {
                    log(`Invalid port. Use 1-65535.`, RED);
                    process.exit(1);
                }
                if (existingTunnel) {
                    let res = null;
                    try {
                        res = await callLocalApi(existingTunnel, '/api/sessions', 'POST', {
                            name: displayName,
                            type: 'port',
                            port: portArg,
                            startRuntime: false,
                            workspace: explicitWorkspaceName
                        });
                    } catch (e) {
                        res = null; // daemon unreachable; fall back to direct file edit
                    }
                    if (res) {
                        if (res.status >= 200 && res.status < 300) {
                            log(`Saved port session "${displayName}" → localhost:${portArg} to workspace "${explicitWorkspaceName}".`, GREEN);
                            process.exit(0);
                        }
                        log(res.data?.error || `Request failed (status ${res.status})`, RED);
                        process.exit(1);
                    }
                }
                if (await runtimeTerminalSessionExists(name)) {
                    log(`Terminal session already exists with this name.`, RED);
                    process.exit(1);
                }
                const saved = upsertWorkspaceSessionDefinition(explicitWorkspaceName, name, {
                    type: 'port',
                    port: portArg,
                    displayName,
                    createdAt: new Date().toISOString(),
                    updatedAt: new Date().toISOString(),
                    createdBy: 'user',
                    agentPermitted: false,
                    workspaceName: explicitWorkspaceName
                });
                if (!saved) {
                    log(`Failed to save port session definition.`, RED);
                    process.exit(1);
                }
                log(`Saved port session "${displayName}" → localhost:${portArg} to workspace "${explicitWorkspaceName}".`, GREEN);
                process.exit(0);
            }

            const existingConfig = getEffectiveSessionConfig(name);
            if (existingConfig && existingConfig.type === 'port') {
                log(`Port session already exists with this name.`, RED);
                process.exit(1);
            }
            if (existingTunnel) {
                let res = null;
                try {
                    res = await callLocalApi(existingTunnel, '/api/sessions', 'POST', {
                        name: displayName,
                        type: 'terminal',
                        cwd: cwdPath,
                        startRuntime: false,
                        workspace: explicitWorkspaceName
                    });
                } catch (e) {
                    res = null; // daemon unreachable; fall back to direct file edit
                }
                if (res) {
                    if (res.status >= 200 && res.status < 300) {
                        log(`Saved terminal session "${displayName}" to workspace "${explicitWorkspaceName}".`, GREEN);
                        process.exit(0);
                    }
                    log(res.data?.error || `Request failed (status ${res.status})`, RED);
                    process.exit(1);
                }
            }
            const saved = upsertWorkspaceSessionDefinition(explicitWorkspaceName, name, {
                type: 'terminal',
                cwd: cwdPath,
                displayName,
                createdAt: new Date().toISOString(),
                updatedAt: new Date().toISOString(),
                createdBy: 'user',
                agentPermitted: false,
                workspaceName: explicitWorkspaceName
            });
            if (!saved) {
                log(`Failed to save terminal session definition.`, RED);
                process.exit(1);
            }
            log(`Saved terminal session "${displayName}" to workspace "${explicitWorkspaceName}".`, GREEN);
            process.exit(0);
        }

        if (subcommand === 'permit' || subcommand === 'block') {
            if (!nameArg) {
                log(`Usage: hop session ${subcommand} <name>`, RED);
                process.exit(1);
            }
            const displayName = nameArg;
            const resolvedDisplayName = resolveDisplayNameAlias(displayName);
            const internalName = findInternalSessionName(resolvedDisplayName) || toInternalSessionName(resolvedDisplayName);
            const allowed = subcommand === 'permit';

            const existingTunnel = isServerRunning();
            if (existingTunnel) {
                let res = null;
                try {
                    res = await callLocalApi(existingTunnel, '/api/sessions/agent-permission', 'POST', {
                        internalName,
                        allowed
                    });
                } catch (e) {
                    res = null; // daemon unreachable; fall back to direct file edit
                }
                if (res) {
                    if (res.status >= 200 && res.status < 300) {
                        log(`${allowed ? 'Allowed' : 'Blocked'} agent access for "${displayName}".`, GREEN);
                        process.exit(0);
                    }
                    log(res.data?.error || `Request failed (status ${res.status})`, RED);
                    process.exit(1);
                }
            }

            const savedConfig = getSessionConfig(internalName);
            const config = getEffectiveSessionConfig(internalName);
            if (!config || config.type === 'port') {
                log(`Session not found or not a terminal.`, RED);
                process.exit(1);
            }
            config.agentPermitted = allowed;
            if (!config.createdBy) config.createdBy = 'user';
            config.updatedAt = new Date().toISOString();
            if (savedConfig) {
                setSessionConfig(internalName, config);
            } else {
                rememberRuntimeSessionMetadata(internalName, config);
            }
            log(`${allowed ? 'Allowed' : 'Blocked'} agent access for "${displayName}".`, GREEN);
            process.exit(0);
        }

        if (subcommand === 'rename' || subcommand === 'mv') {
            const newNameArg = process.argv[5];
            if (!nameArg || !newNameArg) {
                log(`Usage: hop session rename <old-name> <new-name>`, RED);
                process.exit(1);
            }
            const oldDisplayName = nameArg;
            const newDisplayName = newNameArg;

            const existingTunnel = isServerRunning();
            if (existingTunnel) {
                let res = null;
                try {
                    res = await callLocalApi(existingTunnel, '/api/sessions/rename', 'POST', {
                        oldName: oldDisplayName,
                        newName: newDisplayName
                    });
                } catch (e) {
                    res = null; // daemon unreachable; fall back to direct file edit
                }
                if (res) {
                    if (res.status >= 200 && res.status < 300) {
                        log(`Renamed session "${oldDisplayName}" to "${newDisplayName}".`, GREEN);
                        process.exit(0);
                    }
                    log(res.data?.error || `Request failed (status ${res.status})`, RED);
                    process.exit(1);
                }
            }

            try {
                renameSessionDisplayName(oldDisplayName, newDisplayName);
                log(`Renamed session "${oldDisplayName}" to "${newDisplayName}".`, GREEN);
                process.exit(0);
            } catch (e) {
                log(e?.message || 'Rename failed.', RED);
                process.exit(1);
            }
        }

        if (subcommand === 'remove' || subcommand === 'rm' || subcommand === 'delete') {
            if (!nameArg) {
                log(`Usage: hop session remove <name>`, RED);
                process.exit(1);
            }
            const displayName = nameArg;
            const resolvedDisplayName = resolveDisplayNameAlias(displayName);
            const name = hasSavedSessionConfig(displayName)
                ? displayName
                : (findInternalSessionName(resolvedDisplayName) || toInternalSessionName(resolvedDisplayName));
            if (!name) {
                log(`Session not found.`, RED);
                process.exit(1);
            }
            const existingTunnel = isServerRunning();
            if (existingTunnel) {
                let res = null;
                try {
                    res = await callLocalApi(existingTunnel, '/api/sessions/delete', 'POST', {
                        internalName: name
                    });
                } catch (e) {
                    res = null; // daemon unreachable; fall back to direct file edit
                }
                if (res) {
                    if (res.status >= 200 && res.status < 300) {
                        if (res.data?.type === 'port') {
                            log(`Removed port session "${displayName}".`, GREEN);
                        } else {
                            log(`Removed terminal session "${displayName}".`, GREEN);
                        }
                        process.exit(0);
                    }
                    log(res.data?.error || `Request failed (status ${res.status})`, RED);
                    process.exit(1);
                }
            }
            const savedConfig = getSessionConfig(name);
            const config = getEffectiveSessionConfig(name);
            if (config && config.type === 'port') {
                deleteSessionConfig(name);
                clearRuntimeSessionMetadata(name);
                log(`Removed port session "${displayName}".`, GREEN);
                process.exit(0);
            }
            // Close hay room if it exists
            if (isExternalTerminalBackend()) {
                await terminateExternalHaySession(name);
            } else if (hayRooms.hasRoom(name)) {
                hayRooms.closeRoom(name);
            }
            if (activeSessions[name]) {
                delete activeSessions[name];
            }
            clearRuntimeSessionMetadata(name);
            if (savedConfig) {
                deleteSessionConfig(name);
            }
            log(`Removed terminal session "${displayName}".`, GREEN);
            process.exit(0);
        }

        const unknownSessionSub = subcommand && subcommand !== 'help' && subcommand !== '--help';
        if (unknownSessionSub) {
            log(`Unknown subcommand: ${subcommand}`, RED);
        }
        log(`\n${BOLD}Session commands:${RESET}\n`, CYAN);
        log(`  hop session list [--all|-a]      List live sessions (--all/-a adds workspace defs across all workspaces)`, RESET);
        log(`  hop session add <name> [--cwd P] --workspace W  Save a terminal definition to a workspace`, RESET);
        log(`  hop session add <name> --port N --workspace W   Save a port definition to a workspace`, RESET);
        log(`  hop session rename <old> <new>   Rename a session`, RESET);
        log(`  hop session remove <name>        Remove a session`, RESET);
        log(`  hop session permit <name>        Allow agent access`, RESET);
        log(`  hop session block <name>         Block agent access`, RESET);
        process.exit(unknownSessionSub ? 1 : 0);
    }

    // Handle `hop wipe` command - removes workspace-defined sessions by default
    if (process.argv[2] === 'wipe') {
        const wipeAll = process.argv.includes('--all');
        const wipeAgent = process.argv.includes('--agent');
        const existingTunnel = isServerRunning();

        // hop wipe --agent: close all agent-created terminal API sessions
        if (wipeAgent) {
            if (!existingTunnel) {
                log(`Hop server is not running. Start hop first.`, YELLOW);
                process.exit(1);
            }
            const http = require('http');
            const terminalsRes = await new Promise((resolve, reject) => {
                const opts = {
                    hostname: '127.0.0.1',
                    port: existingTunnel.port,
                    path: '/api/terminals',
                    method: 'GET',
                    headers: { 'Authorization': `Bearer ${existingTunnel.sessionSecret}` }
                };
                const req = http.request(opts, res => {
                    let data = '';
                    res.on('data', chunk => data += chunk);
                    res.on('end', () => resolve({ status: res.statusCode, data }));
                });
                req.on('error', reject);
                req.end();
            });
            const terminalsData = JSON.parse(terminalsRes.data);
            const agentTerminals = (terminalsData.terminals || []).filter(t => t && t.actor === 'agent');
            if (agentTerminals.length === 0) {
                log(`No agent terminal sessions to clean up.`, GREEN);
                process.exit(0);
            }
            log(`Closing ${agentTerminals.length} agent terminal session(s)...`, YELLOW);
            for (const t of agentTerminals) {
                try {
                    await new Promise((resolve, reject) => {
                        const opts = {
                            hostname: '127.0.0.1',
                            port: existingTunnel.port,
                            path: `/api/terminals/${encodeURIComponent(t.id)}`,
                            method: 'DELETE',
                            headers: { 'Authorization': `Bearer ${existingTunnel.sessionSecret}` }
                        };
                        const req = http.request(opts, res => {
                            let data = '';
                            res.on('data', chunk => data += chunk);
                            res.on('end', () => resolve({ status: res.statusCode, data }));
                        });
                        req.on('error', reject);
                        req.end();
                    });
                    log(`  - ${t.displayName || t.sessionName || t.id}`, RESET);
                } catch (e) {
                    log(`  - ${t.displayName || t.sessionName || t.id} (failed)`, YELLOW);
                }
            }
            log(`Done.`, GREEN);
            process.exit(0);
        }

        if (existingTunnel) {
            // Server is running - call API to delete sessions
            const http = require('http');

            // First get list of sessions
            const sessionsRes = await new Promise((resolve, reject) => {
                const opts = {
                    hostname: '127.0.0.1',
                    port: existingTunnel.port,
                    path: '/api/sessions',
                    method: 'GET',
                    headers: { 'Authorization': `Bearer ${existingTunnel.sessionSecret}` }
                };
                const req = http.request(opts, res => {
                    let data = '';
                    res.on('data', chunk => data += chunk);
                    res.on('end', () => resolve({ status: res.statusCode, data }));
                });
                req.on('error', reject);
                req.end();
            });

            const sessionsData = JSON.parse(sessionsRes.data);
            const sessions = Array.isArray(sessionsData.sessions) ? sessionsData.sessions : [];
            const liveSessions = sessions.filter((s) => s.type === 'terminal' && s.live === true);
            const unknownTerminalSessions = sessions.filter((s) => s.type === 'terminal' && typeof s.live !== 'boolean');
            const targets = wipeAll
                ? sessions
                : sessions.filter((s) => s.type === 'port' || s.live === false);

            if (targets.length === 0) {
                if (wipeAll) {
                    log(`No hop sessions to clean up.`, GREEN);
                } else {
                    if (liveSessions.length > 0 || unknownTerminalSessions.length > 0) {
                        log(`No workspace-defined sessions to clean up.`, GREEN);
                        if (liveSessions.length > 0) {
                            log(`Use ${CYAN}hop wipe --all${RESET} to also kill ${liveSessions.length} live session(s).`, RESET);
                        }
                        if (unknownTerminalSessions.length > 0) {
                            log(`Keeping ${unknownTerminalSessions.length} terminal session(s) with unknown live state. Restart Hop to classify them, or use ${CYAN}hop wipe --all${RESET}.`, RESET);
                        }
                    } else {
                        log(`No hop sessions to clean up.`, GREEN);
                    }
                }
                process.exit(0);
            }

            if (wipeAll) {
                // Killing live sessions is destructive; confirm unless --yes was passed.
                const skipWipeConfirm = process.argv.includes('--yes') || process.argv.includes('-y');
                if (!skipWipeConfirm) {
                    log(`About to kill ${targets.length} session(s):`, YELLOW);
                    targets.forEach((s) => log(`  - ${s.displayName || s.name}`, RESET));
                    if (!process.stdin.isTTY) {
                        log(`Refusing to kill sessions without confirmation (non-interactive). Re-run with --yes.`, RED);
                        process.exit(1);
                    }
                    const confirmed = await promptYesNo(`Kill these ${targets.length} session(s)? [y/N] `);
                    if (!confirmed) {
                        log(`Aborted. No sessions were killed.`, YELLOW);
                        process.exit(1);
                    }
                }
                log(`Killing ${targets.length} hop session(s)...`, YELLOW);
            } else {
                const skippedLive = liveSessions.length;
                log(`Removing ${targets.length} workspace-defined session(s)...`, YELLOW);
                if (skippedLive > 0) {
                    log(`Keeping ${skippedLive} live session(s). Use ${CYAN}hop wipe --all${RESET} to kill them.`, RESET);
                }
                if (unknownTerminalSessions.length > 0) {
                    log(`Keeping ${unknownTerminalSessions.length} terminal session(s) with unknown live state. Restart Hop to classify them, or use ${CYAN}hop wipe --all${RESET}.`, RESET);
                }
            }

            for (const s of targets) {
                try {
                    await new Promise((resolve, reject) => {
                        const opts = {
                            hostname: '127.0.0.1',
                            port: existingTunnel.port,
                            path: '/api/sessions/delete',
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'Authorization': `Bearer ${existingTunnel.sessionSecret}`
                            }
                        };
                        const req = http.request(opts, res => {
                            let data = '';
                            res.on('data', chunk => data += chunk);
                            res.on('end', () => resolve({ status: res.statusCode, data }));
                        });
                        req.on('error', reject);
                        req.write(JSON.stringify({ name: s.name }));
                        req.end();
                    });
                    log(`  - ${s.displayName || s.name}`, RESET);
                } catch (e) {
                    log(`  - ${s.displayName || s.name} (failed)`, YELLOW);
                }
            }
            log(`Done.`, GREEN);
        } else {
            // Server not running - just clean up config files
            const sessions = Object.keys(sessionStore.sessions);
            if (sessions.length === 0) {
                log(`No hop sessions to clean up.`, GREEN);
                process.exit(0);
            }
            log(`Cleaning up ${sessions.length} session config(s)...`, YELLOW);
            for (const name of sessions) {
                deleteSessionConfig(name);
                log(`  - ${getSessionDisplayName(name)}`, RESET);
            }
            log(`Done.`, GREEN);
        }
        process.exit(0);
    }

    // Every known command returned or exited above; anything else here is a typo.
    // Only bare `hop` (or the internal --daemon flag) may reach the default flow.
    if (process.argv[2] && process.argv[2] !== '--daemon') {
        const badCommand = process.argv[2];
        log(`Unknown command: ${badCommand}`, RED);
        const suggestion = suggestNearestCommand(badCommand);
        if (suggestion) {
            log(`Did you mean ${CYAN}hop ${suggestion}${RESET}?`, RESET);
        }
        log(`Run ${CYAN}hop --help${RESET} for usage.`, RESET);
        process.exit(2);
    }

    if (process.stdout.isTTY) console.clear(); // Clear screen without wiping scrollback

    // Only one instance allowed
    if (!DAEMON_FLAG) {
        const existingTunnel = isServerRunning();
        if (existingTunnel) {
            await attachToExistingTunnel(existingTunnel);
            return;
        }

        // No server yet: start daemon and wait for it to come up
        loadAuthSecret();
        await checkAndInstallDependencies();
        startDaemon();
        const state = await waitForDaemonReady();
        const domainConfig = getDomainConfig();
        const label = domainConfig?.hostname ? `Hop-${domainConfig.hostname}` : 'Hop';
        loadAuthSecret();
        await waitForStartPolling(state, label);
        await attachToExistingTunnel(state);
        return;
    }

    // SERVER MODE: Start new tunnel

    // Require password for custom domains
    const domainConfig = getDomainConfig();
    if (domainConfig && domainConfig.hostname && !isPasswordEnabled()) {
        log(`\n${RED}ERROR: Password required for custom domain.${RESET}`, RED);
        log(`\nYour fixed URL (${domainConfig.hostname}) is publicly known.`, YELLOW);
        log(`Password protection is required for security.\n`, RESET);
        log(`Run: ${CYAN}hop password set${RESET}`, RESET);
        process.exit(1);
    }

    loadAuthSecret();

    // Write state file early to prevent race condition where multiple daemons spawn
    // Other hop processes will see this and wait instead of spawning another daemon
    if (DAEMON_FLAG) {
        writePrivateFile(STATE_FILE, JSON.stringify({
            pid: process.pid,
            port: BASE_PORT,
            url: null,  // Not yet known, will be updated after tunnel starts
            sessionSecret: SESSION_SECRET,
            startTime: Date.now()
        }));
    }

    await checkAndInstallDependencies();
    await ensureHayLoaded();
    await ensureExternalHayHostReady();
    await reconcileExternalRuntimeSessions();
    const authEmitter = new EventEmitter();

    const proxyServer = startAuthProxy(authEmitter);
    const { tunnel: tunnelProc, publicUrl } = await startTunnel();

    // Save state for other terminals to find
    writePrivateFile(STATE_FILE, JSON.stringify({
        pid: process.pid,
        port: BASE_PORT,
        url: publicUrl,
        sessionSecret: SESSION_SECRET,
        startTime: Date.now()
    }));

    // Start tunnel health monitoring (detects stale connections after VPN changes)
    startTunnelHealthMonitor();

    if (DAEMON_FLAG) {
        const cleanup = () => {
            if (shuttingDown) return;
            shuttingDown = true;
            log(`Cleaning up...`, YELLOW);

            stopTunnelHealthMonitor();

            if (fs.existsSync(STATE_FILE)) {
                try { fs.unlinkSync(STATE_FILE); } catch (e) { }
            }

            if (!isExternalTerminalBackend()) {
                hayRooms.closeAll();
            }
            closeAllSessionAuditSinks();

            try { (currentTunnelProc || tunnelProc).kill('SIGTERM'); } catch (e) { }
            try { proxyServer.close(); } catch (e) { }

            process.exit(0);
        };

        process.on('SIGINT', cleanup);
        process.on('SIGTERM', cleanup);
        process.on('exit', cleanup);

        // SIGUSR1 = restart tunnel (used by `hop health --restart`)
        process.on('SIGUSR1', () => {
            log(`[Tunnel] Received restart signal. Restarting tunnel...`, YELLOW);
            if (currentTunnelProc && !currentTunnelProc.killed) {
                try { currentTunnelProc.kill('SIGTERM'); } catch (e) { }
                // The 'close' handler will trigger startTunnelWithRestart
            } else {
                // Cloudflared already dead, restart directly
                startTunnelWithRestart();
            }
        });

        await new Promise(() => {});
    }

    await waitForStart(authEmitter, publicUrl);

    await startLocalSession(proxyServer, tunnelProc, publicUrl);
}

main().catch(err => {
    log(`Fatal: ${err.message}`, RED);
    process.exit(1);
});
