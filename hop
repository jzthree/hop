            `);
            return;
        }

        // --- CHECK FOR iOS - Intercept and inject virtual keyboard ---
        const userAgent = req.headers['user-agent'] || '';
        const isIOS = /iPad|iPhone|iPod/.test(userAgent);
        const session = getOrCreateSession(sessionName);

        // Only inject keyboard for iOS on the root path (main HTML page)
        const reqPath = parsedUrl.pathname || '/';
        if (isIOS && (reqPath === '/' || reqPath === '')) {
            // Intercept ttyd's HTML response and inject our keyboard
            const ttydReq = http.request({
                hostname: '127.0.0.1',
                port: session.port,
                path: '/',
                method: 'GET',
                headers: {
                    'Accept': 'text/html',
                    'User-Agent': userAgent
                }
            }, (ttydRes) => {
                let chunks = [];
                ttydRes.on('data', chunk => chunks.push(chunk));
                ttydRes.on('end', () => {
                    let html = Buffer.concat(chunks).toString('utf8');
                    // Inject WebSocket hook in <head> BEFORE ttyd scripts run
                    // Inject keyboard UI before </body>
                    if (html.includes('<head>') && html.includes('</body>')) {
                        const { hook, ui } = getIOSKeyboardInjection();
                        // Use split/join instead of replace to avoid any $ interpretation
                        html = html.split('<head>').join('<head>' + hook);
                        html = html.split('</body>').join(ui + '</body>');
                        // log(`[Hop] Injected keyboard UI (${ui.length} bytes)`, GREEN);
                    }
                    res.writeHead(200, {
                        'Content-Type': 'text/html; charset=utf-8',
                        'Content-Length': Buffer.byteLength(html)
                    });
                    res.end(html);
                });
            });
            ttydReq.on('error', () => {
                res.writeHead(502);
                res.end('Session not ready.');
            });
            ttydReq.end();
            return;
        }

        // --- PROXY TO SESSION (non-iOS) ---
        const proxy = httpProxy.createProxyServer({ target: `http://127.0.0.1:${session.port}`, ws: false });
        proxy.web(req, res, {}, (err) => {
            res.writeHead(502);
            res.end('Session not ready. Try again.');
        });
    });

    // WebSocket upgrade for terminal
    server.on('upgrade', (req, socket, head) => {
        const parsedUrl = url.parse(req.url, true);
        const cookies = cookie.parse(req.headers.cookie || '');

        // Check auth via cookie OR query param (for mobile apps)
        const tokenFromQuery = parsedUrl.query.token;
        const isAuthenticated = cookies[SESSION_COOKIE_NAME] === SESSION_SECRET
            || tokenFromQuery === SESSION_SECRET;

        if (!isAuthenticated) {
            socket.write('HTTP/1.1 401 Unauthorized\r\n\r\n');
            socket.destroy();
            return;
        }

        const sessionName = parsedUrl.query.session;
        if (!sessionName || !activeSessions[sessionName]) {
            socket.write('HTTP/1.1 404 Session Not Found\r\n\r\n');
            socket.destroy();
            return;
        }

        const session = activeSessions[sessionName];
        const proxy = httpProxy.createProxyServer({ target: `http://127.0.0.1:${session.port}`, ws: true });
        proxy.ws(req, socket, head);
    });

    server.listen(PROXY_PORT, '127.0.0.1');
    return server;
}

function startTunnel() {
    log(`[3/4] Opening Cloudflare Tunnel...`, BOLD);
    const tunnel = spawn('cloudflared', ['tunnel', '--url', `http://localhost:${PROXY_PORT}`]);
    let urlFound = false;

    return new Promise((resolve) => {
        tunnel.stderr.on('data', (data) => {
            if (urlFound) return;
            const output = data.toString();
            const match = output.match(/https:\/\/[a-zA-Z0-9-]+\.trycloudflare\.com/);

            if (match) {
                const publicUrl = match[0];
                if (publicUrl.includes('api.trycloudflare.com')) return;

                urlFound = true;
                resolve({ tunnel, publicUrl });
            }
        });
    });
}

function waitForStart(authEmitter, publicUrl) {
    return new Promise((resolve) => {
        console.clear();
        log(`\n==================================================`, MAGENTA);
        log(`            >>>  HOP - TUNNEL SHELL  <<<`, BOLD + MAGENTA);
        log(`==================================================\n`, MAGENTA);

        log(`TUNNEL URL:`, BOLD + GREEN);
        log(`  ${publicUrl}`, GREEN);
        log(`  Scan to open on mobile:`, RESET);

        // Simple URL QR code - scan with any camera app
        qrcode.generate(publicUrl, { small: true });

        log(`\n--------------------------------------------------`, RESET);

        // Standardized TOTP QR Code using the helper function
        showQrCode();

        log(`\n--------------------------------------------------`, RESET);

        const readline = require('readline');
        const rl = readline.createInterface({ input: process.stdin, output: process.stdout });

        log(`\n[READY]`, GREEN + BOLD);
        log(`Press ENTER to launch local session, or login remotely...`, RESET);

        let resolved = false;

        const finish = (reason) => {
            if (resolved) return;
            resolved = true;
            rl.close();
            log(`\n${reason}. Launching local session...`, GREEN);
            setTimeout(resolve, 800);
        };

        rl.question('', () => finish('Manual Start'));
        authEmitter.once('authenticated', () => finish('Remote Login'));
    });
}

// Generate QR code and prompt for verification
function showQrCode() {
    log(`[3/4] Setup Authenticator...`, BOLD);

    // Manually construct URL for minimalist "Hop" label without username
    const label = 'Hop';
    const otpauth = `otpauth://totp/${encodeURIComponent(label)}?secret=${AUTH_SECRET}&issuer=${encodeURIComponent(label)}`;

    qrcode.generate(otpauth, { small: true });

    log(`Scan this QR code with your Authenticator app.`, CYAN);
    log(`Account: ${label}`, CYAN);
    log(`\n(Secret hidden for security. View ~/.hop-shell/.auth_secret if needed)\n`, RESET);
}

async function main() {
    process.stdout.write('\x1Bc'); // Clear screen

    // Only one instance allowed
    const existingTunnel = isServerRunning();
    if (existingTunnel) {
        // CLIENT MODE: Connect to existing tunnel
        // If args are provided, try to send them as a command? (TODO)

        log(`Hop tunnel is already running!`, GREEN);
        log(`URL: ${existingTunnel.url}`, BOLD);

        // Generate smart session name: dir-N
        const cwdName = path.basename(process.cwd()).replace(/[^a-zA-Z0-9_-]/g, '-');
        let sessionName = `${cwdName}-1`;

        log(`\nFinding next available session...`, RESET);

        try {
            // Get existing sessions first
            const sessionsRes = await new Promise((resolve, reject) => {
                const opts = {
                    hostname: '127.0.0.1',
                    port: existingTunnel.port,
                    path: '/api/sessions',
                    method: 'GET',
                    headers: { 'Authorization': `Bearer ${existingTunnel.sessionSecret}` }
                };
                http.get(opts, res => {
                    let data = '';
                    res.on('data', c => data += c);
                    res.on('end', () => resolve(JSON.parse(data)));
                }).on('error', reject);
            });

            // Find next available number
            if (sessionsRes && sessionsRes.sessions && sessionsRes.active) {
                const allNames = new Set([...sessionsRes.active, ...sessionsRes.sessions.map(s => s.name)]);
                let counter = 1;
                while (allNames.has(`${cwdName}-${counter}`)) {
                    counter++;
                }
                sessionName = `${cwdName}-${counter}`;
            }

            log(`Creating new session: ${sessionName}...`, RESET);

            // Register session with local server so ttyd starts
            const res = await new Promise((resolve, reject) => {
                const opts = {
                    hostname: '127.0.0.1',
                    port: existingTunnel.port,
                    path: '/api/sessions',
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${existingTunnel.sessionSecret}`
                    }
                };

                const req = http.request(opts, (response) => {
                    let data = '';
                    response.on('data', c => data += c);
                    response.on('end', () => {
                        try {
                            resolve(JSON.parse(data));
                        } catch (e) {
                            // Server returned non-JSON (likely HTML login page)
                            reject(new Error(`Server returned non-JSON (status ${response.statusCode})`));
                        }
                    });
                });

                req.on('error', reject);
                req.write(JSON.stringify({ name: sessionName }));
                req.end();
            });

            if (!res.ok && !res.success) throw new Error(res.error || 'Failed to create session');

        } catch (e) {
            log(`Note: Could not register session with server: ${e.message}`, YELLOW);
            log(`Session will still work locally.`, RESET);
        }

        log(`Attaching...`, RESET);

        // Attach to the specific session
        const tmux = spawn('sh', ['-c', `
            tmux -f ${HOP_TMUX_CONF} new-session -A -s ${sessionName}
        `], { stdio: 'inherit' });

        // Apply styling immediately and continuously refresh (every 1 second)
        applyTmuxStyles(sessionName, existingTunnel.url);

        const styleInterval = setInterval(() => {
            applyTmuxStyles(sessionName, existingTunnel.url);
        }, 1000);

        tmux.on('close', () => {
            clearInterval(styleInterval);
            log(`\nSession disconnected.`, YELLOW);
            process.exit(0);
        });

        return;
    }

    // SERVER MODE: Start new tunnel
    await checkAndInstallDependencies();
    const authEmitter = new EventEmitter();

    const proxyServer = startAuthProxy(authEmitter);
    const { tunnel: tunnelProc, publicUrl } = await startTunnel();

    // Save state for other terminals to find
    fs.writeFileSync(STATE_FILE, JSON.stringify({
        pid: process.pid,
        port: BASE_PORT,
        url: publicUrl,
        sessionSecret: SESSION_SECRET,
        startTime: Date.now()
    }));

    await waitForStart(authEmitter, publicUrl);

    log(`[4/4] Attaching to session...`, BOLD);

    // Create and attach to session locally
    // Find next available session name (in case another hop already created one)
    const cwdName = path.basename(process.cwd()).replace(/[^a-zA-Z0-9_-]/g, '-');
    const existingSessions = listTmuxSessions().map(s => s.name);
    let counter = 1;
    while (existingSessions.includes(`${cwdName}-${counter}`)) {
        counter++;
    }
    const defaultSessionName = `${cwdName}-${counter}`;

    log(`Starting session: ${defaultSessionName}`, RESET);
    const defaultSession = getOrCreateSession(defaultSessionName);

    // Apply styling continuously to handle respawns (every 1 second)
    const styleInterval = setInterval(() => {
        applyTmuxStyles(defaultSessionName, publicUrl);
    }, 1000);

    // Apply immediately (no delay needed since execSync is synchronous)
    applyTmuxStyles(defaultSessionName, publicUrl);

    // Use spawn with respawn loop - exit requires confirmation
    const tmux = spawn('sh', ['-c', `
        while true; do
            tmux -f ${HOP_TMUX_CONF} new-session -A -s ${defaultSessionName}
            echo ""
            echo "[Session ended]"
            read -p "Type 'quit' to shutdown tunnel, or press Enter to restart: " answer
            if [ "$answer" = "quit" ] || [ "$answer" = "QUIT" ]; then
                exit 0
            fi
            echo "Restarting..."
            sleep 0.5
        done
    `], { stdio: 'inherit' });

    tmux.on('close', () => {
        log(`\nLocal session ended. Shutting down tunnel...`, YELLOW);
        cleanup();
    });

    const cleanup = () => {
        log(`Cleaning up...`, YELLOW);

        // Remove state file
        if (fs.existsSync(STATE_FILE)) {
            try { fs.unlinkSync(STATE_FILE); } catch (e) { }
        }

        // Kill all ttyd sessions
        Object.values(activeSessions).forEach(s => {
            try { s.ttyd.kill('SIGTERM'); } catch (e) { }
        });

        // Kill cloudflared tunnel
        try { tunnelProc.kill('SIGTERM'); } catch (e) { }

        // Close proxy server
        try { proxyServer.close(); } catch (e) { }

        // Kill tmux server to clean up all sessions
        try {
            require('child_process').execSync('tmux kill-server 2>/dev/null || true');
        } catch (e) { }

        log(`Goodbye!`, GREEN);
        process.exit(0);
    };

    process.on('SIGINT', cleanup);
    process.on('SIGTERM', cleanup);
    process.on('exit', cleanup);
}

main().catch(err => {
    log(`Fatal: ${err.message}`, RED);
    process.exit(1);
});
