function shouldInjectSessionSwitcher(req) {
    if (!req || req.method !== 'GET') return false;
    const accept = String(req.headers?.accept || '').toLowerCase();
    if (!accept.includes('text/html')) return false;
    const dest = String(req.headers?.['sec-fetch-dest'] || '');
    if (dest && dest !== 'document') return false;
    return true;
}

function buildSessionPath(displayName) {
    return `/s/${encodeURIComponent(displayName)}/`;
}

function resolveSessionDisplayName(displayName) {
    const resolvedDisplayName = resolveDisplayNameAlias(displayName);
    const internalFromConfig = findInternalSessionName(resolvedDisplayName);
    const fallbackInternalName = toInternalSessionName(resolvedDisplayName);
    const internalName = internalFromConfig
        || (fallbackInternalName && hopSessionExists(fallbackInternalName) ? fallbackInternalName : fallbackInternalName);
    return {
        displayName: resolvedDisplayName,
        internalName,
        aliasRedirect: resolvedDisplayName !== displayName
    };
}

function stripSessionParam(search) {
    if (!search) return '';
    const params = new URLSearchParams(search);
    params.delete('session');
    const qs = params.toString();
    return qs ? `?${qs}` : '';
}

function parseSessionFromRequest(req, parsedUrl) {
    const pathname = parsedUrl.pathname || '';
    if (pathname.startsWith('/s/')) {
        const rest = pathname.slice(3);
        const parts = rest.split('/');
        const rawName = parts.shift() || '';
        let displayName = '';
        try {
            displayName = decodeURIComponent(rawName);
        } catch (e) {
            return null;
        }
        if (!SESSION_NAME_RE.test(displayName)) return null;
        const resolved = resolveSessionDisplayName(displayName);
        if (!resolved.internalName) return null;
        const needsSlash = pathname === `/s/${rawName}`;
        const strippedPathname = '/' + parts.join('/');
        const normalizedPathname = strippedPathname === '/' ? '/' : strippedPathname;
        const strippedUrl = normalizedPathname + (parsedUrl.search || '');
        return {
            displayName: resolved.displayName,
            internalName: resolved.internalName,
            requestedDisplayName: displayName,
            aliasRedirect: resolved.aliasRedirect,
            strippedPathname: normalizedPathname,
            strippedUrl,
            source: 'path',
            needsSlash
        };
    }

    const sessionParam = parsedUrl.query.session;
    if (sessionParam && SESSION_NAME_RE.test(sessionParam)) {
        const displayName = sessionParam;
        const resolved = resolveSessionDisplayName(displayName);
        if (!resolved.internalName) return null;
        const strippedPathname = parsedUrl.pathname || '/';
        const strippedUrl = strippedPathname + stripSessionParam(parsedUrl.search || '');
        return {
            displayName: resolved.displayName,
            internalName: resolved.internalName,
            requestedDisplayName: displayName,
            aliasRedirect: resolved.aliasRedirect,
            strippedPathname,
            strippedUrl,
            source: 'query'
        };
    }

    return null;
}

function shouldRedirectToSessionPath(req) {
    if (!req || req.method !== 'GET') return false;
    const accept = String(req.headers?.accept || '').toLowerCase();
    return accept.includes('text/html');
}

// Helper to get client IP (handles proxies)
function getClientIp(req) {
    return req.headers['cf-connecting-ip'] ||
        req.headers['x-forwarded-for'] ||
        req.socket.remoteAddress ||
        'unknown';
}

const ACTOR_HEADER = 'x-hop-actor';

function resolveActor(req) {
    return resolveActorFromHeaders(req?.headers || {}, ACTOR_HEADER);
}

function resolveSessionInternalName(name, internalName) {
    if (internalName && (getEffectiveSessionConfig(internalName) || hopSessionExists(internalName))) return internalName;
    if (!name) return null;
    const displayName = resolveDisplayNameAlias(name);
    return findInternalSessionName(displayName) || toInternalSessionName(displayName);
}

function waitForPort(port, host = '127.0.0.1', timeoutMs = 4000, intervalMs = 120) {
    const start = Date.now();
    return new Promise((resolve) => {
        const tryConnect = () => {
            const socket = net.connect({ port, host });
            socket.once('connect', () => {
                socket.end();
                resolve(true);
            });
            socket.once('error', () => {
                socket.destroy();
                if (Date.now() - start >= timeoutMs) {
                    resolve(false);
                    return;
                }
                setTimeout(tryConnect, intervalMs);
            });
        };
        tryConnect();
    });
}

function allocateLocalPort(host = '127.0.0.1') {
    return new Promise((resolve, reject) => {
        const server = net.createServer();
        server.unref();
        server.once('error', reject);
        server.listen(0, host, () => {
            const address = server.address();
            const port = address && typeof address === 'object' ? Number(address.port) : 0;
            server.close((err) => {
                if (err) {
                    reject(err);
                    return;
                }
                if (!Number.isInteger(port) || port <= 0 || port > 65535) {
                    reject(new Error('Failed to allocate local port'));
                    return;
                }
                resolve(port);
            });
        });
    });
}

function isExternalTerminalBackend() {
    return TERMINAL_BACKEND === 'external';
}

function isProcessAlive(pid) {
    if (!Number.isInteger(pid) || pid <= 0) return false;
    try {
        process.kill(pid, 0);
        return true;
    } catch (e) {
        return false;
    }
}

function readHayHostStateFile() {
    if (!fs.existsSync(HAY_HOST_STATE_FILE)) return null;
    try {
        ensurePrivateFile(HAY_HOST_STATE_FILE);
        const parsed = JSON.parse(fs.readFileSync(HAY_HOST_STATE_FILE, 'utf8'));
        const pid = Number(parsed?.pid);
        const port = Number(parsed?.port);
        if (!Number.isInteger(pid) || pid <= 0) return null;
        if (!Number.isInteger(port) || port < 1 || port > 65535) return null;
        return { pid, port, startedAt: Number(parsed?.startedAt) || Date.now() };
    } catch (e) {
        return null;
    }
}

function writeHayHostStateFile(state) {
    if (!state) return;
    hayHostState = { pid: state.pid, port: state.port, startedAt: state.startedAt || Date.now() };
    hayHostDiscoveryCache = { expiresAt: 0, hosts: [] };
    writePrivateFile(HAY_HOST_STATE_FILE, JSON.stringify(hayHostState));
}

function clearHayHostStateFile() {
    hayHostState = null;
    hayHostDiscoveryCache = { expiresAt: 0, hosts: [] };
    try {
        if (fs.existsSync(HAY_HOST_STATE_FILE)) {
            fs.unlinkSync(HAY_HOST_STATE_FILE);
        }
    } catch (e) { }
}

function parseListeningPortForPid(pid) {
    if (!Number.isInteger(pid) || pid <= 0) return null;
    try {
        const output = execFileSync('lsof', [
            '-nP',
            '-a',
            '-p', String(pid),
            '-iTCP',
            '-sTCP:LISTEN',
            '-Fn'
        ], {
            encoding: 'utf8',
            stdio: ['ignore', 'pipe', 'ignore']
        });
        const lines = String(output || '').split(/\r?\n/);
        for (const line of lines) {
            if (!line.startsWith('n')) continue;
            const match = line.match(/:(\d+)(?:->|$)/);
            if (!match) continue;
            const port = Number.parseInt(match[1], 10);
            if (Number.isInteger(port) && port > 0 && port <= 65535) {
                return port;
            }
        }
    } catch (e) { }
    return null;
}

function listDiscoveredHayHostCandidates(force = false) {
    if (!isExternalTerminalBackend()) return [];
    const now = Date.now();
    if (!force && hayHostDiscoveryCache.expiresAt > now) {
        return hayHostDiscoveryCache.hosts.map((host) => ({ ...host }));
    }

    const candidates = [];
    const seen = new Set();
    const recorded = hayHostState || readHayHostStateFile();
    const hostScript = path.join(__dirname, 'scripts', 'hay-host.js');

    const remember = (candidate) => {
        if (!candidate) return;
        const pid = Number(candidate.pid);
        const port = Number(candidate.port);
        if (!Number.isInteger(pid) || pid <= 0) return;
        if (!Number.isInteger(port) || port <= 0 || port > 65535) return;
        const key = `${pid}:${port}`;
        if (seen.has(key)) return;
        seen.add(key);
        candidates.push({
            pid,
            port,
            startedAt: Number(candidate.startedAt) || 0,
            scoped: candidate.scoped === true
        });
    };

    if (recorded && isProcessAlive(recorded.pid)) {
        remember(recorded);
    }

    try {
        const output = execFileSync('ps', ['-axo', 'pid=,command='], {
            encoding: 'utf8',
            stdio: ['ignore', 'pipe', 'ignore']
        });
        const lines = String(output || '').split(/\r?\n/);
        for (const line of lines) {
            const trimmed = line.trim();
            if (!trimmed) continue;
            const match = trimmed.match(/^(\d+)\s+(.+)$/);
            if (!match) continue;
            const pid = Number.parseInt(match[1], 10);
            const command = match[2] || '';
            if (!Number.isInteger(pid) || pid <= 0) continue;
            if (!command.includes(hostScript)) continue;
            if (!isProcessAlive(pid)) continue;
            const port = parseListeningPortForPid(pid);
            if (!port) continue;
            const startedAt = recorded && recorded.pid === pid && recorded.port === port
                ? recorded.startedAt
                : 0;
            remember({ pid, port, startedAt, scoped: command.includes(HAY_HOST_HOME_FLAG) });
        }
    } catch (e) { }

    hayHostDiscoveryCache = {
        expiresAt: now + HAY_HOST_DISCOVERY_CACHE_MS,
        hosts: candidates
    };
    return candidates.map((host) => ({ ...host }));
}

async function fetchExternalHayRuntimeRoomsFromHost(hostState) {
    if (!isExternalTerminalBackend()) return null;
    if (!hostState || !Number.isInteger(hostState.port) || hostState.port <= 0) return null;
    return await new Promise((resolve) => {
        let settled = false;
        const finish = (value) => {
            if (settled) return;
            settled = true;
            resolve(value);
        };
        const opts = {
            hostname: '127.0.0.1',
            port: hostState.port,
            path: '/rooms',
            method: 'GET'
        };
        const req = http.request(opts, (res) => {
            let data = '';
            res.on('data', (chunk) => { data += chunk; });
            res.on('end', () => {
                if ((res.statusCode || 0) < 200 || (res.statusCode || 0) >= 300) {
                    finish(null);
                    return;
                }
                try {
                    const parsed = JSON.parse(data || '{}');
                    const rawRooms = Array.isArray(parsed?.rooms) ? parsed.rooms : [];
                    const rooms = rawRooms
                        .map((room) => {
                            const id = String(room?.id || '').trim();
                            if (!id || !SESSION_NAME_RE.test(id)) return null;
                            const cwd = typeof room?.cwd === 'string' && room.cwd.trim() ? room.cwd : undefined;
                            const clientCountRaw = Number(room?.clientCount);
                            const clientCount = Number.isFinite(clientCountRaw) && clientCountRaw >= 0
                                ? Math.floor(clientCountRaw)
                                : 0;
                            const localCliCountRaw = Number(room?.localCliCount);
                            const localCliCount = Number.isFinite(localCliCountRaw) && localCliCountRaw >= 0
                                ? Math.floor(localCliCountRaw)
                                : 0;
                            return {
                                id,
                                cwd,
                                clientCount,
                                localCliCount,
                                hasLocalCli: localCliCount > 0,
                                hostPid: hostState.pid,
                                hostPort: hostState.port,
                                scoped: hostState.scoped === true
                            };
                        })
                        .filter(Boolean);
                    finish(rooms);
                } catch (e) {
                    finish(null);
                }
            });
        });
        req.on('error', () => finish(null));
        req.setTimeout(1200, () => {
            req.destroy();
            finish(null);
        });
        req.end();
    });
}

async function probeExternalHayHostFromHost(hostState, timeoutMs = 1200) {
    if (!isExternalTerminalBackend()) return false;
    if (!hostState || !Number.isInteger(hostState.port) || hostState.port <= 0) return false;
    return await new Promise((resolve) => {
        let settled = false;
        const finish = (value) => {
            if (settled) return;
            settled = true;
            resolve(value);
        };
        const req = http.request({
            hostname: '127.0.0.1',
            port: hostState.port,
            path: '/health',
            method: 'GET'
        }, (res) => {
            let data = '';
            res.on('data', (chunk) => { data += chunk; });
            res.on('end', () => {
                if ((res.statusCode || 0) < 200 || (res.statusCode || 0) >= 300) {
                    finish(false);
                    return;
                }
                try {
                    const parsed = JSON.parse(data || '{}');
                    finish(parsed?.ok === true && parsed?.capabilities?.localCliCount === true);
                } catch (e) {
                    finish(false);
                }
            });
        });
        req.on('error', () => finish(false));
        req.setTimeout(timeoutMs, () => {
            req.destroy();
            finish(false);
        });
        req.end();
    });
}

function choosePreferredHayHost(inspectedHosts, preferredHost = null) {
    if (!Array.isArray(inspectedHosts) || inspectedHosts.length === 0) return null;
    const preferredPid = Number(preferredHost?.pid);
    const preferredPort = Number(preferredHost?.port);
    const ranked = [...inspectedHosts].sort((a, b) => {
        const aRooms = Array.isArray(a.rooms) ? a.rooms.length : 0;
        const bRooms = Array.isArray(b.rooms) ? b.rooms.length : 0;
        if (aRooms !== bRooms) return bRooms - aRooms;
        const aPreferred = a.host.pid === preferredPid && a.host.port === preferredPort ? 1 : 0;
        const bPreferred = b.host.pid === preferredPid && b.host.port === preferredPort ? 1 : 0;
        if (aPreferred !== bPreferred) return bPreferred - aPreferred;
        const aStarted = Number(a.host.startedAt) || 0;
        const bStarted = Number(b.host.startedAt) || 0;
        return bStarted - aStarted;
    });
    return ranked[0]?.host || null;
}

async function inspectExternalHayHosts(force = false) {
    if (!isExternalTerminalBackend()) return [];
    const candidates = listDiscoveredHayHostCandidates(force);
    if (candidates.length === 0) return [];
    const inspected = await Promise.all(candidates.map(async (host) => ({
        host,
        healthy: await probeExternalHayHostFromHost(host),
        rooms: await fetchExternalHayRuntimeRoomsFromHost(host)
    })));
    return inspected.filter((entry) => entry.healthy === true && Array.isArray(entry.rooms));
}

function hostBelongsToCurrentHome(entry, preferredHost = null) {
    if (!entry || !entry.host) return false;
    if (entry.host.scoped === true) return true;
    const preferredPid = Number(preferredHost?.pid);
    const preferredPort = Number(preferredHost?.port);
    if (entry.host.pid === preferredPid && entry.host.port === preferredPort) {
        return true;
    }
    return false;
}

function getExternalHayHostStateOrThrow() {
    if (!isExternalTerminalBackend()) return null;
    if (!hayHostState) {
        hayHostState = readHayHostStateFile();
    }
    if (!hayHostState || !isProcessAlive(hayHostState.pid)) {
        clearHayHostStateFile();
        throw new Error('External hay host is not running');
    }
    return hayHostState;
}

async function stopExternalHayHostProcess(hostState, timeoutMs = 1500) {
    const pid = Number(hostState?.pid);
    if (!Number.isInteger(pid) || pid <= 0) return true;
    if (!isProcessAlive(pid)) return true;
    try {
        process.kill(pid, 'SIGTERM');
    } catch (e) {
        return !isProcessAlive(pid);
    }
    const deadline = Date.now() + timeoutMs;
    while (Date.now() < deadline) {
        if (!isProcessAlive(pid)) return true;
        await new Promise((resolve) => setTimeout(resolve, 100));
    }
    if (!isProcessAlive(pid)) return true;
    try {
        process.kill(pid, 'SIGKILL');
    } catch (e) { }
    const forceDeadline = Date.now() + 500;
    while (Date.now() < forceDeadline) {
        if (!isProcessAlive(pid)) return true;
        await new Promise((resolve) => setTimeout(resolve, 100));
    }
    return !isProcessAlive(pid);
}

async function ensureExternalHayHostReady() {
    if (!isExternalTerminalBackend()) return null;

    const existing = hayHostState || readHayHostStateFile();
    const inspectedExisting = await inspectExternalHayHosts();
    const relevantExisting = inspectedExisting.filter((entry) => hostBelongsToCurrentHome(entry, existing));
    const preferredExisting = choosePreferredHayHost(relevantExisting, existing);
    if (preferredExisting) {
        writeHayHostStateFile(preferredExisting);
        return preferredExisting;
    }

    if (existing && isProcessAlive(existing.pid)) {
        const healthy = await probeExternalHayHostFromHost(existing, 1200);
        if (healthy) {
            writeHayHostStateFile(existing);
            return existing;
        }
        log(`[Hay] Existing host on port ${existing.port} is unresponsive. Restarting it.`, YELLOW);
        await stopExternalHayHostProcess(existing);
    }

    clearHayHostStateFile();

    const hostScript = path.join(__dirname, 'scripts', 'hay-host.js');
    if (!fs.existsSync(hostScript)) {
        throw new Error('Hay host script missing');
    }

    const requestedPort = Number.parseInt(process.env.HOP_HAY_HOST_PORT || '', 10);
    const hostPort = Number.isInteger(requestedPort) && requestedPort > 0
        ? requestedPort
        : await allocateLocalPort('127.0.0.1');
    const hayHostLogFile = path.join(LOG_DIR, 'hay-host.log');
    const hayHostLogFd = rotateAndOpenLogFd(hayHostLogFile);
    let child;
    try {
        child = spawn(process.execPath, [hostScript, HAY_HOST_HOME_FLAG], {
            detached: true,
            stdio: ['ignore', hayHostLogFd, hayHostLogFd],
            env: {
                ...process.env,
                HAY_HOST_PORT: String(hostPort),
                HAY_HOST_CWD: process.cwd()
            }
        });
    } finally {
        try { fs.closeSync(hayHostLogFd); } catch (e) { }
    }

    const started = {
        pid: Number(child?.pid) || 0,
        port: hostPort,
        startedAt: Date.now()
    };
    if (!Number.isInteger(started.pid) || started.pid <= 0) {
        throw new Error(`Hay host failed to start; see ${hayHostLogFile}`);
    }

    const ready = await waitForPort(started.port, '127.0.0.1', HAY_HOST_READY_TIMEOUT_MS, 120);
    if (!ready) {
        await stopExternalHayHostProcess(started);
        throw new Error(`Hay host did not open its port in time; see ${hayHostLogFile}`);
    }
    const healthy = await probeExternalHayHostFromHost(started, 1500);
    if (!healthy) {
        await stopExternalHayHostProcess(started);
        throw new Error(`Hay host failed health check after startup; see ${hayHostLogFile}`);
    }

    writeHayHostStateFile(started);
    child.unref();
    return started;
}

async function callExternalHayHostApi(apiPath, method = 'GET', body = null, timeoutMs = 2000) {
    if (!isExternalTerminalBackend()) return null;
    const state = await ensureExternalHayHostReady();
    return await new Promise((resolve, reject) => {
        const headers = {};
        let payload = null;
        if (body !== null && body !== undefined) {
            payload = JSON.stringify(body);
            headers['Content-Type'] = 'application/json';
            headers['Content-Length'] = Buffer.byteLength(payload);
        }
        const req = http.request({
            hostname: '127.0.0.1',
            port: state.port,
            path: apiPath,
            method,
            headers
        }, (res) => {
            let data = '';
            res.on('data', (chunk) => { data += chunk; });
            res.on('end', () => {
                let parsed = null;
                try {
                    parsed = data ? JSON.parse(data) : {};
                } catch (e) {
                    parsed = null;
                }
                resolve({
                    status: res.statusCode || 500,
                    data: parsed
                });
            });
        });
        req.on('error', reject);
        req.setTimeout(timeoutMs, () => {
            req.destroy(new Error('Hay host request timeout'));
        });
        if (payload) {
            req.write(payload);
        }
        req.end();
    });
}

function rememberExternalRuntimeSession(sessionName, hostPort = null) {
    if (!sessionName) return null;
    let resolvedHostPort = Number(hostPort);
    if (!Number.isInteger(resolvedHostPort) || resolvedHostPort <= 0 || resolvedHostPort > 65535) {
        const fallbackState = getExternalHayHostStateOrThrow();
        resolvedHostPort = fallbackState.port;
    }
    activeSessions[sessionName] = {
        backend: 'external',
        hostPort: resolvedHostPort
    };
    return activeSessions[sessionName];
}

async function ensureExternalRuntimeSession(sessionName, cwd, displayName, opts = {}) {
    if (!isExternalTerminalBackend()) {
        return getOrCreateSession(sessionName, cwd, displayName);
    }
    if (!sessionName || typeof sessionName !== 'string' || !SESSION_NAME_RE.test(sessionName)) {
        throw new Error('Invalid session name');
    }

    const savedConfig = getSavedSessionConfig(sessionName);
    const runtimeConfig = getRuntimeSessionMetadata(sessionName);
    const existingConfig = getEffectiveSessionConfig(sessionName);
    const saveDefinition = opts.saveDefinition === true || !!savedConfig;
    const createdBy = opts.createdBy || existingConfig?.createdBy || 'user';
    const agentPermitted = typeof opts.agentPermitted === 'boolean'
        ? opts.agentPermitted
        : (typeof existingConfig?.agentPermitted === 'boolean'
            ? existingConfig.agentPermitted
            : createdBy === 'agent');
    const effectiveConfig = {
        type: 'terminal',
        cwd: cwd || existingConfig?.cwd || process.cwd(),
        shell: opts.shell || existingConfig?.shell,
        env: opts.env || existingConfig?.env,
        cols: Number.isInteger(opts.cols) ? opts.cols : existingConfig?.cols,
        rows: Number.isInteger(opts.rows) ? opts.rows : existingConfig?.rows,
        startup: opts.startup || existingConfig?.startup,
        autoStart: typeof opts.autoStart === 'boolean'
            ? opts.autoStart
            : existingConfig?.autoStart,
        createdBy,
        agentPermitted,
        displayName: displayName || existingConfig?.displayName || toDisplaySessionName(sessionName),
        folderId: opts.folderId !== undefined
            ? (opts.folderId || null)
            : (existingConfig?.folderId || null),
        workspaceName: resolveSessionWorkspaceName(savedConfig || existingConfig, { workspaceName: opts.workspaceName })
    };

    if (saveDefinition) {
        ensureTerminalSessionConfig(sessionName, effectiveConfig.cwd, effectiveConfig.displayName, effectiveConfig.folderId, {
            shell: effectiveConfig.shell,
            env: effectiveConfig.env,
            cols: effectiveConfig.cols,
            rows: effectiveConfig.rows,
            startup: effectiveConfig.startup,
            autoStart: effectiveConfig.autoStart,
            createdBy: effectiveConfig.createdBy,
            agentPermitted: effectiveConfig.agentPermitted,
            workspaceName: effectiveConfig.workspaceName
        });
    }

    rememberRuntimeSessionMetadata(sessionName, effectiveConfig);

    const ptyRuntime = buildSessionPtyEnv(sessionName, effectiveConfig, effectiveConfig.workspaceName);
    const response = await callExternalHayHostApi('/rooms', 'POST', {
        id: sessionName,
        cwd: effectiveConfig.cwd,
        cols: Number.isInteger(effectiveConfig.cols) ? effectiveConfig.cols : 80,
        rows: Number.isInteger(effectiveConfig.rows) ? effectiveConfig.rows : 24,
        shell: effectiveConfig.shell,
        env: ptyRuntime.env
    }, 2500);
    if (!response || response.status < 200 || response.status >= 300 || !response.data?.ok) {
        const reason = response?.data?.error || `status ${response?.status || 'unknown'}`;
        throw new Error(`Failed to start external session "${displayName || sessionName}": ${reason}`);
    }

    const room = response.data.room || {};
    const resolvedCwd = typeof room.cwd === 'string' && room.cwd ? room.cwd : effectiveConfig.cwd;
    rememberRuntimeSessionMetadata(sessionName, { ...effectiveConfig, cwd: resolvedCwd });
    if (saveDefinition) {
        ensureTerminalSessionConfig(
            sessionName,
            resolvedCwd,
            effectiveConfig.displayName,
            effectiveConfig.folderId,
            {
                shell: effectiveConfig.shell,
                env: effectiveConfig.env,
                cols: Number.isInteger(effectiveConfig.cols) ? effectiveConfig.cols : undefined,
                rows: Number.isInteger(effectiveConfig.rows) ? effectiveConfig.rows : undefined,
                startup: effectiveConfig.startup,
                autoStart: effectiveConfig.autoStart,
                createdBy: effectiveConfig.createdBy,
                agentPermitted: effectiveConfig.agentPermitted,
                workspaceName: effectiveConfig.workspaceName
            }
        );
    }

    return rememberExternalRuntimeSession(sessionName, getExternalHayHostStateOrThrow().port);
}

async function reconcileExternalRuntimeSessions() {
    if (!isExternalTerminalBackend()) return { rooms: [], runtimeAvailable: false };
    await ensureExternalHayHostReady();
    const rooms = await fetchExternalHayRuntimeRooms();
    if (!Array.isArray(rooms)) {
        return { rooms: [], runtimeAvailable: false };
    }

    const runtimeIds = new Set();
    for (const room of rooms) {
        if (!room || !room.id) continue;
        runtimeIds.add(room.id);
        const savedConfig = getSessionConfig(room.id);
        const runtimeConfig = getRuntimeSessionMetadata(room.id);
        const createdBy = savedConfig?.createdBy || runtimeConfig?.createdBy || 'user';
        rememberRuntimeSessionMetadata(room.id, {
            type: 'terminal',
            cwd: room.cwd || savedConfig?.cwd || runtimeConfig?.cwd,
            displayName: savedConfig?.displayName || runtimeConfig?.displayName || toDisplaySessionName(room.id) || room.id,
            folderId: savedConfig?.folderId || runtimeConfig?.folderId || null,
            shell: savedConfig?.shell || runtimeConfig?.shell,
            env: savedConfig?.env || runtimeConfig?.env,
            cols: Number.isInteger(savedConfig?.cols) ? savedConfig.cols : runtimeConfig?.cols,
            rows: Number.isInteger(savedConfig?.rows) ? savedConfig.rows : runtimeConfig?.rows,
            startup: savedConfig?.startup || runtimeConfig?.startup,
            autoStart: typeof savedConfig?.autoStart === 'boolean' ? savedConfig.autoStart : runtimeConfig?.autoStart,
            createdBy,
            agentPermitted: typeof savedConfig?.agentPermitted === 'boolean'
                ? savedConfig.agentPermitted
                : (typeof runtimeConfig?.agentPermitted === 'boolean'
                    ? runtimeConfig.agentPermitted
                    : createdBy === 'agent'),
            workspaceName: resolveSessionWorkspaceName(savedConfig || runtimeConfig, {
                workspaceName: savedConfig?.workspaceName || runtimeConfig?.workspaceName
            })
        });
        rememberExternalRuntimeSession(room.id, room.hostPort);
    }

    for (const [name, session] of Object.entries(activeSessions)) {
        if (session?.backend === 'external' && !runtimeIds.has(name)) {
            delete activeSessions[name];
            clearRuntimeSessionMetadata(name);
        }
    }
    for (const name of Array.from(runtimeSessionMetadata.keys())) {
        if (!runtimeIds.has(name)) {
            clearRuntimeSessionMetadata(name);
        }
    }

    return { rooms, runtimeAvailable: true };
}

function buildExternalHayWsPath(parsedUrl, sessionName) {
    const params = new URLSearchParams();
    const query = parsedUrl?.query || {};
    for (const [key, value] of Object.entries(query)) {
        if (key === 'room' || key === 'token') continue;
        if (Array.isArray(value)) {
            for (const part of value) {
                if (part !== undefined && part !== null) {
                    params.append(key, String(part));
                }
            }
        } else if (value !== undefined && value !== null) {
            params.append(key, String(value));
        }
    }
    params.set('room', sessionName);
    if (!params.has('cwd')) {
        const sessionCwd = (getEffectiveSessionConfig(sessionName) || {}).cwd;
        if (sessionCwd) params.set('cwd', sessionCwd);
    }
    return `/ws?${params.toString()}`;
}

function getExternalHayHostPortForSession(sessionName, options = {}) {
    const requestedPort = Number(options.hostPort);
    if (Number.isInteger(requestedPort) && requestedPort > 0 && requestedPort <= 65535) {
        return requestedPort;
    }
    const sessionPort = Number(activeSessions[sessionName]?.hostPort);
    if (Number.isInteger(sessionPort) && sessionPort > 0 && sessionPort <= 65535) {
        return sessionPort;
    }
    const state = getExternalHayHostStateOrThrow();
    return state.port;
}

function buildExternalHayWsUrl(sessionName, options = {}) {
    const port = getExternalHayHostPortForSession(sessionName, options);
    const params = new URLSearchParams();
    params.set('room', sessionName);
    if (options.name) params.set('name', String(options.name));
    if (Number.isFinite(options.cols)) params.set('cols', String(Math.floor(Number(options.cols))));
    if (Number.isFinite(options.rows)) params.set('rows', String(Math.floor(Number(options.rows))));
    if (options.source) params.set('source', String(options.source));
    if (options.claim) params.set('claim', String(options.claim));
    if (options.cwd) params.set('cwd', String(options.cwd));
    return `ws://127.0.0.1:${port}/ws?${params.toString()}`;
}

async function waitForExternalHaySessionClosed(sessionName, hostPort = null, timeoutMs = 1500, intervalMs = 120) {
    if (!isExternalTerminalBackend() || !sessionName) return true;
    const targetPort = Number(hostPort) || getExternalHayHostPortForSession(sessionName, { hostPort });
    const deadline = Date.now() + timeoutMs;
    while (Date.now() <= deadline) {
        const rooms = await fetchExternalHayRuntimeRoomsFromHost({ port: targetPort, scoped: true });
        if (Array.isArray(rooms) && !rooms.some((room) => room && room.id === sessionName)) {
            return true;
        }
        await new Promise((resolve) => setTimeout(resolve, intervalMs));
    }
    const finalRooms = await fetchExternalHayRuntimeRoomsFromHost({ port: targetPort, scoped: true });
    return Array.isArray(finalRooms) && !finalRooms.some((room) => room && room.id === sessionName);
}

async function terminateExternalHaySession(sessionName) {
    if (!isExternalTerminalBackend() || !sessionName) return true;
    const hostPort = getExternalHayHostPortForSession(sessionName);
    try {
        const response = await callExternalHayHostApi(`/rooms/${encodeURIComponent(sessionName)}`, 'DELETE', null, 1500);
        if (response && response.status >= 200 && response.status < 300) {
            const closed = await waitForExternalHaySessionClosed(sessionName, hostPort);
            if (closed && activeSessions[sessionName]) {
                delete activeSessions[sessionName];
            }
            return closed;
        }
    } catch (e) { }

    let ws;
    try {
        ws = new WebSocket(buildExternalHayWsUrl(sessionName, {
            name: 'hop-control',
            cols: 80,
            rows: 24,
            source: 'hop-kill'
        }));
    } catch (e) {
        return false;
    }

    await new Promise((resolve) => {
        let finished = false;
        const finish = () => {
            if (finished) return;
            finished = true;
            try { ws.close(); } catch (e) { }
            resolve();
        };

        ws.once('open', () => {
            try {
                ws.send(JSON.stringify({ type: 'kill_session' }));
            } catch (e) { }
            setTimeout(finish, 120);
        });
        ws.once('error', finish);
        ws.once('close', finish);
        setTimeout(finish, 800);
    });

    const closed = await waitForExternalHaySessionClosed(sessionName, hostPort);
    if (closed && activeSessions[sessionName]) {
        delete activeSessions[sessionName];
    }
    return closed;
}

