                            async function renameSession(oldName) {
                                const newName = prompt('Enter new session name:', oldName);
                                if (!newName || newName === oldName) return;
                                if (!/^[a-zA-Z0-9_-]+$/.test(newName)) return alert('Only letters, numbers, - and _ allowed');
                                
                                await fetch('/api/sessions/rename', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({ oldName, newName })
                                });
                                loadSessions();
                            }
                            
                            document.getElementById('newName').addEventListener('keypress', e => {
                                if (e.key === 'Enter') createSession();
                            });
                            
                            loadSessions();
