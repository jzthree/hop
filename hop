}

// Get base domain from existing config (e.g., hop.example.com -> example.com)
function getBaseDomain() {
    const config = getDomainConfig();
    if (!config || !config.hostname) return null;
    // Extract base domain: hop.example.com -> example.com
    const parts = config.hostname.split('.');
    if (parts.length >= 2) {
        return parts.slice(-2).join('.');
    }
    return config.hostname;
}

// Get subdomain prefix (e.g., hop.example.com -> hop)
function getSubdomainPrefix() {
    const config = getDomainConfig();
    if (!config || !config.hostname) return 'hop';
    const parts = config.hostname.split('.');
    if (parts.length >= 3) {
        return parts[0];
    }
    return 'hop';
}

async function addUser(username) {
    // Validate username
    if (!/^[a-zA-Z0-9_-]+$/.test(username)) {
        log(`Invalid username. Use only letters, numbers, underscore, hyphen.`, RED);
        process.exit(1);
    }

    const baseDomain = getBaseDomain();
    const prefix = getSubdomainPrefix();

    if (!baseDomain) {
        log(`You must set up your own domain first.`, RED);
        log(`Run: hop domain <your-subdomain.yourdomain.com>`, RESET);
        process.exit(1);
    }

    if (!isCloudflaredLoggedIn()) {
        log(`You must be logged in to Cloudflare.`, RED);
        log(`Run: hop domain <hostname> to set up.`, RESET);
        process.exit(1);
    }

    const users = getUsers();
    if (users[username]) {
        log(`User "${username}" already exists.`, YELLOW);
        log(`Hostname: ${users[username].hostname}`, RESET);
        process.exit(0);
    }

    const tunnelName = `hop-${username}`;
    const hostname = `${username}.${prefix}.${baseDomain}`;
    let tunnelCreatedByUs = false;

    log(`\n${BOLD}Adding user: ${username}${RESET}\n`, CYAN);

    // Step 1: Create tunnel
    log(`[1/3] Creating tunnel...`, BOLD);
    const tunnels = listCloudflaredTunnels();
    let tunnel = tunnels.find(t => t.name === tunnelName);

    if (tunnel) {
        log(`  Tunnel already exists: ${tunnelName}`, GREEN);
    } else {
        try {
            execSync(`cloudflared tunnel create ${tunnelName}`, { encoding: 'utf8', stdio: ['pipe', 'pipe', 'pipe'] });
            log(`  Tunnel created: ${tunnelName}`, GREEN);
            tunnelCreatedByUs = true;
            // Re-fetch to get the ID
            const newTunnels = listCloudflaredTunnels();
            tunnel = newTunnels.find(t => t.name === tunnelName);
        } catch (e) {
            log(`Failed to create tunnel: ${e.message}`, RED);
            process.exit(1);
        }
    }

    // Step 2: Setup DNS
    log(`[2/3] Configuring DNS...`, BOLD);
    let dnsSuccess = false;
    try {
        const result = execSync(`cloudflared tunnel route dns ${tunnelName} ${hostname} 2>&1`, {
            encoding: 'utf8'
        });
        // Check for failure FIRST
        if (result.includes('Failed to add route') || result.includes('Failed to create record')) {
            log(`\n${RED}ERROR: DNS failed: ${result.trim()}${RESET}`, RED);
            dnsSuccess = false;
        } else if (result.includes('Added CNAME')) {
            dnsSuccess = true;
            log(`  DNS configured: ${hostname}`, GREEN);
        } else if (result.includes('already exists') && !result.includes('Failed')) {
            dnsSuccess = true;
            log(`  DNS already configured.`, GREEN);
        } else {
            log(`  Unexpected response: ${result.trim()}`, YELLOW);
        }
    } catch (e) {
        const errorOutput = e.stdout || e.stderr || e.message || '';
        // Check for failure FIRST
        if (errorOutput.includes('Failed to add route') || errorOutput.includes('Failed to create record')) {
            log(`\n${RED}ERROR: DNS failed: ${errorOutput.trim()}${RESET}`, RED);
        } else if (errorOutput.includes('already exists') && !errorOutput.includes('Failed')) {
            dnsSuccess = true;
            log(`  DNS already configured.`, GREEN);
        } else if (errorOutput.includes('zone') || errorOutput.includes('not found')) {
            log(`\n${RED}ERROR: Domain not in your Cloudflare account.${RESET}`, RED);
        } else {
            log(`\n${RED}ERROR: DNS failed: ${errorOutput.trim()}${RESET}`, RED);
        }
    }

    // If DNS failed, clean up
    if (!dnsSuccess) {
        if (tunnelCreatedByUs) {
            log(`\nCleaning up...`, YELLOW);
            try {
                execSync(`cloudflared tunnel delete ${tunnelName}`, { stdio: 'ignore' });
                log(`  Deleted tunnel: ${tunnelName}`, RESET);
            } catch (e) { }
        }
        process.exit(1);
    }

    // Step 3: Save user info
    log(`[3/3] Saving user...`, BOLD);

    // Find the credentials file
    const cloudflaredDir = path.join(os.homedir(), '.cloudflared');
    let credentialsFile = null;
    if (tunnel && tunnel.id) {
        credentialsFile = path.join(cloudflaredDir, `${tunnel.id}.json`);
    }

    users[username] = {
        tunnelName,
        tunnelId: tunnel ? tunnel.id : null,
        hostname,
        credentialsFile,
        createdAt: new Date().toISOString()
    };
    saveUsers(users);
    log(`  User saved.`, GREEN);

    log(`\n${BOLD}${GREEN}✓ User "${username}" added!${RESET}`, GREEN);
    log(`\nTheir URL: https://${hostname}`, BOLD);
    log(`\nTo export credentials for them:`, RESET);
    log(`  ${CYAN}hop user export ${username}${RESET}`, RESET);
}

async function removeUser(username) {
    const users = getUsers();

    if (!users[username]) {
        log(`User "${username}" not found.`, RED);
        process.exit(1);
    }

    const user = users[username];

    log(`\n${BOLD}Removing user: ${username}${RESET}\n`, YELLOW);

    // Delete tunnel
    log(`[1/2] Deleting tunnel...`, BOLD);
    try {
        execSync(`cloudflared tunnel delete ${user.tunnelName}`, {
            encoding: 'utf8',
            stdio: ['pipe', 'pipe', 'pipe']
        });
        log(`  Tunnel deleted: ${user.tunnelName}`, GREEN);
    } catch (e) {
        log(`  Warning: Could not delete tunnel (may already be gone).`, YELLOW);
    }

    // Note: DNS record may remain, Cloudflare doesn't auto-delete it
    log(`[2/2] Removing user record...`, BOLD);
    delete users[username];
    saveUsers(users);
    log(`  User removed.`, GREEN);

    log(`\n${BOLD}${GREEN}✓ User "${username}" removed.${RESET}`, GREEN);
    log(`\nNote: DNS record for ${user.hostname} may need manual removal in Cloudflare dashboard.`, YELLOW);
}

