// Check if tunnel is already running
function isServerRunning() {
    if (!fs.existsSync(STATE_FILE)) return null;
    ensurePrivateFile(STATE_FILE);
    try {
        const state = JSON.parse(fs.readFileSync(STATE_FILE, 'utf8'));
        // Check if the process is still alive
        try {
            process.kill(state.pid, 0);
            return state;
        } catch (e) {
            // Process is dead, clean up
            fs.unlinkSync(STATE_FILE);
            return null;
        }
    } catch (e) {
        return null;
    }
}

function isValidSessionSecret(secret) {
    if (typeof secret !== 'string') return false;
    const trimmed = secret.trim();
    return /^[0-9a-f]{64}$/i.test(trimmed);
}

function loadSessionSecret(existingState) {
    if (existingState && isValidSessionSecret(existingState.sessionSecret)) {
        return existingState.sessionSecret;
    }

    if (!ENABLE_PERSIST_SESSION_SECRET) {
        return crypto.randomBytes(32).toString('hex');
    }

    if (fs.existsSync(SESSION_SECRET_FILE)) {
        try {
            const raw = fs.readFileSync(SESSION_SECRET_FILE, 'utf8');
            const trimmed = raw.trim();
            if (isValidSessionSecret(trimmed)) {
                ensurePrivateFile(SESSION_SECRET_FILE);
                return trimmed;
            }
        } catch (e) {
            // Fall through to regeneration below.
        }
    }

    const generated = crypto.randomBytes(32).toString('hex');
    writePrivateFile(SESSION_SECRET_FILE, generated);
    return generated;
}

// Generate or load session secret
const existingState = isServerRunning();
const SESSION_SECRET = loadSessionSecret(existingState);

