function listTmuxSessions() {
    try {
        const output = execSync('tmux list-sessions -F "#{session_name}|#{session_windows}|#{session_attached}"', { encoding: 'utf8' });
        return output.trim().split('\n').filter(Boolean).map(line => {
            const [name, windows, attached] = line.split('|');
            return { name, windows: parseInt(windows), attached: attached === '1' };
        });
    } catch (e) {
        return [];
    }
}

function hopSessionExists(name) {
    if (!name) return false;
    return listTmuxSessions().some(s => s.name === name);
}

// Wait for tmux session to exist and be ready for control mode attachment
// Returns true if ready, false if timeout
async function waitForTmuxSessionReady(sessionName, maxWaitMs = 5000) {
    const startTime = Date.now();
    while (Date.now() - startTime < maxWaitMs) {
        try {
            // Check if session exists
            execSync(`tmux has-session -t ${sessionName}`, { stdio: 'ignore' });
            // Session exists - wait a bit more for shell prompt to settle
            await new Promise(resolve => setTimeout(resolve, 300));
            // Clear the pane to avoid stale output corrupting control mode
            try {
                execSync(`tmux send-keys -t ${sessionName} '' C-l`, { stdio: 'ignore' });
            } catch (e) { }
            await new Promise(resolve => setTimeout(resolve, 100));
            return true;
        } catch (e) {
            // Session doesn't exist yet, wait and retry
            await new Promise(resolve => setTimeout(resolve, 100));
        }
    }
    return false;
}

function listAllSessionEntries() {
