                    const totp=document.getElementById('totp').value;
                    try{
                        const res=await fetch('/api/login',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({password,totp})});
                        const data=await res.json();
                        if(data.success){location.reload();}
                        else{error.textContent=data.error||'Login failed';error.style.display='block';}
                    }catch(e){error.textContent='Connection error';error.style.display='block';}
                }
                document.getElementById('totp').addEventListener('keyup',e=>{if(e.key==='Enter')login();});
                document.getElementById('password').addEventListener('keyup',e=>{if(e.key==='Enter')document.getElementById('totp').focus();});
                </script></body></html>`);
                return;
            }

            // Authenticated - proxy to local service
            const proxy = httpProxy.createProxyServer({ target: `http://127.0.0.1:${localPort}` });
            proxy.web(req, res, {}, (err) => {
                res.writeHead(502);
                res.end(`Cannot connect to localhost:${localPort}. Is your service running?`);
            });
        });

        // Handle WebSocket upgrade
        clientServer.on('upgrade', (req, socket, head) => {
            const cookies = cookie.parse(req.headers.cookie || '');
            if (cookies['hop_client_session'] !== clientSessionSecret) {
                socket.write('HTTP/1.1 401 Unauthorized\r\n\r\n');
                socket.destroy();
                return;
            }
            const proxy = httpProxy.createProxyServer({ target: `http://127.0.0.1:${localPort}`, ws: true });
            proxy.ws(req, socket, head);
        });

        clientServer.listen(clientProxyPort, '127.0.0.1');

        // Start cloudflared tunnel
        const tunnelConfigPath = path.join(clientConfigDir, 'tunnel-config.yml');
        const tunnelConfigContent = `
url: http://localhost:${clientProxyPort}
tunnel: ${tunnelId}
credentials-file: ${path.resolve(credentialsPath)}
`;
        fs.writeFileSync(tunnelConfigPath, tunnelConfigContent);

        const cloudflared = spawn('cloudflared', ['tunnel', '--config', tunnelConfigPath, 'run'], {
            stdio: ['ignore', 'pipe', 'pipe']
        });

        cloudflared.stderr.on('data', (data) => {
            const output = data.toString();
            if (output.includes('Registered tunnel connection')) {
                log(`${GREEN}✓ Tunnel connected!${RESET}`, GREEN);
            }
        });

        cloudflared.on('close', (code) => {
            log(`Tunnel closed (code ${code})`, YELLOW);
            clientServer.close();
            process.exit(code || 0);
        });

        log(`Waiting for tunnel connection...`, RESET);

        // Handle shutdown
        process.on('SIGINT', () => {
            log(`\nShutting down...`, YELLOW);
            cloudflared.kill();
            clientServer.close();
            process.exit(0);
        });

        return; // Keep running
    }

    // Handle `hop --help` or `hop help`
    if (process.argv[2] === '--help' || process.argv[2] === '-h' || process.argv[2] === 'help') {
        log(`\n${BOLD}Hop - Remote Terminal Access${RESET}\n`, CYAN);
        log(`${BOLD}Usage:${RESET}`, RESET);
        log(`  hop                       Start tunnel (or attach to existing)`, RESET);
        log(`  hop --help                Show this help message`, RESET);
        log('');
        log(`${BOLD}URL & QR:${RESET}`, RESET);
        log(`  hop url                   Print current tunnel URL`, RESET);
        log(`  hop qr                    Show URL as QR code`, RESET);
        log('');
        log(`${BOLD}Custom Domain:${RESET}`, RESET);
        log(`  hop domain                Show current domain config`, RESET);
        log(`  hop domain <hostname>     Setup custom domain (e.g., hop.example.com)`, RESET);
        log(`  hop domain-clear          Remove custom domain, use random URLs`, RESET);
        log('');
        log(`${BOLD}Security:${RESET}`, RESET);
        log(`  hop password              Show password status`, RESET);
        log(`  hop password set          Set or change password`, RESET);
        log(`  hop password clear        Remove password protection`, RESET);
        log('');
        log(`${BOLD}Multi-user (admin):${RESET}`, RESET);
        log(`  hop user list             List all users`, RESET);
        log(`  hop user add <name>       Add a user (creates tunnel + DNS)`, RESET);
        log(`  hop user remove <name>    Remove a user`, RESET);
        log(`  hop user export <name>    Export credentials for a user`, RESET);
        log('');
        log(`${BOLD}Client mode (for users):${RESET}`, RESET);
        log(`  hop client <credentials>  Run tunnel with exported credentials`, RESET);
        log('');
        log(`${BOLD}Maintenance:${RESET}`, RESET);
        log(`  hop wipe                  Kill all hop tmux sessions`, RESET);
        log('');
        process.exit(0);
    }

    // Handle `hop url` command - prints current tunnel URL (easy to copy)
    if (process.argv[2] === 'url') {
        const state = isServerRunning();
        if (!state) {
            log(`Hop is not running.`, RED);
            process.exit(1);
        }
        // Print just the URL for easy copying/piping
        console.log(state.url);
        process.exit(0);
    }

    // Handle `hop qr` command - shows QR code for current URL
    if (process.argv[2] === 'qr') {
        const state = isServerRunning();
        if (!state) {
            log(`Hop is not running.`, RED);
            process.exit(1);
        }
        log(`\nCurrent tunnel URL:`, BOLD);
        log(`${state.url}\n`, GREEN);
        qrcode.generate(state.url, { small: true });
        process.exit(0);
    }

    // Handle `hop domain <hostname>` command - setup custom domain
    if (process.argv[2] === 'domain') {
        const hostname = process.argv[3];
        if (!hostname) {
            // Show current domain config
            const config = getDomainConfig();
            if (config) {
                log(`\nCurrent custom domain configuration:`, BOLD);
                log(`  Hostname: ${config.hostname}`, GREEN);
                log(`  Tunnel:   ${config.tunnelName}`, RESET);
                log(`\nTo change: hop domain <new-hostname>`, RESET);
                log(`To remove: hop domain-clear`, RESET);
            } else {
                log(`\nNo custom domain configured.`, YELLOW);
                log(`\nUsage: hop domain <hostname>`, RESET);
                log(`Example: hop domain hop.yourdomain.com`, RESET);
            }
            process.exit(0);
        }
        // Validate hostname format
        if (!/^[a-zA-Z0-9]([a-zA-Z0-9-]*\.)+[a-zA-Z]{2,}$/.test(hostname)) {
            log(`Invalid hostname format: ${hostname}`, RED);
            log(`Example: hop.yourdomain.com`, RESET);
            process.exit(1);
        }
        await setupDomain(hostname);
        process.exit(0);
    }

    // Handle `hop domain-clear` command - remove custom domain config
    if (process.argv[2] === 'domain-clear') {
        if (fs.existsSync(DOMAIN_CONFIG_FILE)) {
            fs.unlinkSync(DOMAIN_CONFIG_FILE);
            log(`Custom domain configuration removed.`, GREEN);
            log(`Hop will use random Cloudflare URLs again.`, RESET);
        } else {
            log(`No custom domain configured.`, YELLOW);
        }
        process.exit(0);
    }

    // Handle `hop password` commands
    if (process.argv[2] === 'password') {
        const subcommand = process.argv[3];
        const readline = require('readline');

        if (!subcommand || subcommand === 'status') {
            if (isPasswordEnabled()) {
                log(`Password protection: ${GREEN}ENABLED${RESET}`, BOLD);
                log(`\nTo change: hop password set`, RESET);
                log(`To remove: hop password clear`, RESET);
            } else {
                log(`Password protection: ${YELLOW}DISABLED${RESET}`, BOLD);
                log(`\nTo enable: hop password set`, RESET);
            }
            process.exit(0);
        }

        if (subcommand === 'set') {
            // Use muted readline for password input
            const askPassword = (prompt) => new Promise((resolve) => {
                const rl = readline.createInterface({
                    input: process.stdin,
                    output: new (require('stream').Writable)({
                        write: (chunk, encoding, callback) => callback()
                    }),
                    terminal: true
                });

                process.stdout.write(prompt);
                rl.question('', (answer) => {
                    rl.close();
                    process.stdout.write('\n');
                    resolve(answer);
                });
            });

            const password = await askPassword('Enter new password: ');
            if (password.length < 4) {
                log(`Password too short (min 4 characters).`, RED);
                process.exit(1);
            }

            const confirm = await askPassword('Confirm password: ');
            if (password !== confirm) {
                log(`Passwords do not match.`, RED);
                process.exit(1);
            }

            setPassword(password);
            log(`\n${GREEN}✓ Password set successfully.${RESET}`, GREEN);
            log(`\nLogin will now require password + TOTP code.`, RESET);
            process.exit(0);
        }

        if (subcommand === 'clear') {
            if (!isPasswordEnabled()) {
                log(`Password is not set.`, YELLOW);
                process.exit(0);
            }
            clearPassword();
            log(`${GREEN}✓ Password protection removed.${RESET}`, GREEN);
            log(`\nLogin will only require TOTP code.`, RESET);
            process.exit(0);
        }

        // Unknown subcommand
        log(`\n${BOLD}Password commands:${RESET}\n`, CYAN);
        log(`  hop password           Show password status`, RESET);
        log(`  hop password set       Set or change password`, RESET);
        log(`  hop password clear     Remove password protection`, RESET);
        process.exit(0);
    }

    // Handle `hop user` commands - multi-user management
    if (process.argv[2] === 'user') {
        const subcommand = process.argv[3];
        const username = process.argv[4];

        if (!subcommand || subcommand === 'list') {
            listUsersCommand();
            process.exit(0);
        }

        if (subcommand === 'add') {
            if (!username) {
                log(`Usage: hop user add <username>`, RED);
                process.exit(1);
            }
            await addUser(username);
            process.exit(0);
        }

        if (subcommand === 'remove' || subcommand === 'rm' || subcommand === 'delete') {
            if (!username) {
                log(`Usage: hop user remove <username>`, RED);
                process.exit(1);
            }
            await removeUser(username);
            process.exit(0);
        }

        if (subcommand === 'export') {
            if (!username) {
                log(`Usage: hop user export <username>`, RED);
                process.exit(1);
            }
            await exportUserCredentials(username);
            process.exit(0);
        }

        // Unknown subcommand - show help
        log(`\n${BOLD}User management commands:${RESET}\n`, CYAN);
        log(`  hop user list              List all users`, RESET);
        log(`  hop user add <username>    Add a new user`, RESET);
        log(`  hop user remove <username> Remove a user`, RESET);
        log(`  hop user export <username> Export credentials for a user`, RESET);
        process.exit(0);
    }

    // Handle `hop wipe` command - kills all hop sessions
    if (process.argv[2] === 'wipe') {
        const sessions = listTmuxSessions().filter(s => s.name.startsWith(HOP_SESSION_PREFIX));
        if (sessions.length === 0) {
            log(`No hop sessions to clean up.`, GREEN);
            process.exit(0);
        }
        log(`Killing ${sessions.length} hop session(s)...`, YELLOW);
        for (const s of sessions) {
            try {
                execSync(`tmux kill-session -t ${s.name}`, { stdio: 'ignore' });
                log(`  - ${s.name}`, RESET);
            } catch (e) { }
        }
        log(`Done.`, GREEN);
        process.exit(0);
    }

    process.stdout.write('\x1Bc'); // Clear screen

    // Only one instance allowed
    const existingTunnel = isServerRunning();
    if (existingTunnel) {
        // CLIENT MODE: Connect to existing tunnel
        // If args are provided, try to send them as a command? (TODO)

        log(`Hop tunnel is already running!`, GREEN);
        log(`URL: ${existingTunnel.url}`, BOLD);

        // Generate smart session name: hop-dir-N
        const cwdName = path.basename(process.cwd()).replace(/[^a-zA-Z0-9_-]/g, '-');
        let sessionName = `${HOP_SESSION_PREFIX}${cwdName}-1`;

        log(`\nFinding next available session...`, RESET);

        try {
            // Get existing sessions first
            const sessionsRes = await new Promise((resolve, reject) => {
                const opts = {
                    hostname: '127.0.0.1',
                    port: existingTunnel.port,
                    path: '/api/sessions',
                    method: 'GET',
                    headers: { 'Authorization': `Bearer ${existingTunnel.sessionSecret}` }
                };
                http.get(opts, res => {
                    let data = '';
                    res.on('data', c => data += c);
                    res.on('end', () => resolve(JSON.parse(data)));
                }).on('error', reject);
            });

            // Find next available number
            if (sessionsRes && sessionsRes.sessions && sessionsRes.active) {
                const allNames = new Set([...sessionsRes.active, ...sessionsRes.sessions.map(s => s.name)]);
                let counter = 1;
                while (allNames.has(`${HOP_SESSION_PREFIX}${cwdName}-${counter}`)) {
                    counter++;
                }
                sessionName = `${HOP_SESSION_PREFIX}${cwdName}-${counter}`;
            }

            log(`Creating new session: ${sessionName}...`, RESET);

            // Register session with local server so ttyd starts
            const res = await new Promise((resolve, reject) => {
                const opts = {
                    hostname: '127.0.0.1',
                    port: existingTunnel.port,
                    path: '/api/sessions',
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${existingTunnel.sessionSecret}`
                    }
                };

                const req = http.request(opts, (response) => {
                    let data = '';
                    response.on('data', c => data += c);
                    response.on('end', () => {
                        try {
                            resolve(JSON.parse(data));
                        } catch (e) {
                            // Server returned non-JSON (likely HTML login page)
                            reject(new Error(`Server returned non-JSON (status ${response.statusCode})`));
                        }
                    });
                });

                req.on('error', reject);
                req.write(JSON.stringify({ name: sessionName }));
                req.end();
            });

            if (!res.ok && !res.success) throw new Error(res.error || 'Failed to create session');

        } catch (e) {
            log(`Note: Could not register session with server: ${e.message}`, YELLOW);
            log(`Session will still work locally.`, RESET);
        }

        log(`Attaching...`, RESET);

        // Attach to the specific session
        const tmux = spawn('tmux', ['-f', HOP_TMUX_CONF, 'new-session', '-A', '-s', sessionName], { stdio: 'inherit' });

        // Apply styling immediately and continuously refresh (every 1 second)
        // Re-read state file each time to pick up URL changes after tunnel restarts
        applyTmuxStyles(sessionName, existingTunnel.url);

        const styleInterval = setInterval(() => {
            try {
                const currentState = JSON.parse(fs.readFileSync(STATE_FILE, 'utf8'));
                applyTmuxStyles(sessionName, currentState.url);
            } catch (e) {
                // State file missing = server died, keep old URL
                applyTmuxStyles(sessionName, existingTunnel.url);
            }
        }, 1000);

        tmux.on('close', () => {
            clearInterval(styleInterval);
            log(`\nSession disconnected.`, YELLOW);
            process.exit(0);
        });

        return;
    }

    // SERVER MODE: Start new tunnel

    // Require password for custom domains
    const domainConfig = getDomainConfig();
    if (domainConfig && domainConfig.hostname && !isPasswordEnabled()) {
        log(`\n${RED}ERROR: Password required for custom domain.${RESET}`, RED);
        log(`\nYour fixed URL (${domainConfig.hostname}) is publicly known.`, YELLOW);
        log(`Password protection is required for security.\n`, RESET);
        log(`Run: ${CYAN}hop password set${RESET}`, RESET);
        process.exit(1);
    }

    await checkAndInstallDependencies();
    const authEmitter = new EventEmitter();

    const proxyServer = startAuthProxy(authEmitter);
    const { tunnel: tunnelProc, publicUrl } = await startTunnel();

    // Save state for other terminals to find
    writePrivateFile(STATE_FILE, JSON.stringify({
        pid: process.pid,
        port: BASE_PORT,
        url: publicUrl,
        sessionSecret: SESSION_SECRET,
        startTime: Date.now()
    }));

    await waitForStart(authEmitter, publicUrl);

    log(`[4/4] Attaching to session...`, BOLD);

    // Create and attach to session locally
    // Find next available session name (in case another hop already created one)
    const cwdName = path.basename(process.cwd()).replace(/[^a-zA-Z0-9_-]/g, '-');
    const existingSessions = listTmuxSessions().map(s => s.name);
    let counter = 1;
    while (existingSessions.includes(`${HOP_SESSION_PREFIX}${cwdName}-${counter}`)) {
        counter++;
    }
    const defaultSessionName = `${HOP_SESSION_PREFIX}${cwdName}-${counter}`;

    log(`Starting session: ${defaultSessionName}`, RESET);
    const defaultSession = getOrCreateSession(defaultSessionName);

    // Apply styling continuously to handle respawns and URL changes (every 1 second)
    const styleInterval = setInterval(() => {
        // Use currentPublicUrl to pick up URL changes after tunnel restarts
        applyTmuxStyles(defaultSessionName, currentPublicUrl || publicUrl);
    }, 1000);

    // Apply immediately (no delay needed since execSync is synchronous)
    applyTmuxStyles(defaultSessionName, publicUrl);

    // Also update when tunnel URL changes
    tunnelEmitter.on('urlChanged', (newUrl) => {
        applyTmuxStyles(defaultSessionName, newUrl);
    });

    const cleanup = () => {
        shuttingDown = true;  // Prevent tunnel auto-restart
        log(`Cleaning up...`, YELLOW);

        // Remove state file
        if (fs.existsSync(STATE_FILE)) {
            try { fs.unlinkSync(STATE_FILE); } catch (e) { }
        }

        // Kill all ttyd sessions
        Object.values(activeSessions).forEach(s => {
            try { s.ttyd.kill('SIGTERM'); } catch (e) { }
        });

        // Kill cloudflared tunnel (use currentTunnelProc in case it was restarted)
        try { (currentTunnelProc || tunnelProc).kill('SIGTERM'); } catch (e) { }

        // Close proxy server
        try { proxyServer.close(); } catch (e) { }

        log(`Goodbye!`, GREEN);
        process.exit(0);
    };

    const runLocalSessionLoop = async () => {
        const readline = require('readline');
        while (true) {
            await new Promise(resolve => {
                const tmux = spawn('tmux', ['-f', HOP_TMUX_CONF, 'new-session', '-A', '-s', defaultSessionName], { stdio: 'inherit' });
                tmux.on('close', resolve);
            });
            log(`\n[Session ended]`, YELLOW);
            const answer = await new Promise(resolve => {
                const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
                rl.question(`Type 'quit' to shutdown tunnel, or press Enter to restart: `, (resp) => {
                    rl.close();
                    resolve(resp || '');
                });
            });
            if (String(answer).trim().toLowerCase() === 'quit') {
                break;
            }
            log(`Restarting...`, RESET);
            await new Promise(resolve => setTimeout(resolve, 500));
        }
    };

    runLocalSessionLoop().then(() => {
        log(`\nLocal session ended. Shutting down tunnel...`, YELLOW);
        cleanup();
    });

    process.on('SIGINT', cleanup);
    process.on('SIGTERM', cleanup);
    process.on('exit', cleanup);
}

main().catch(err => {
    log(`Fatal: ${err.message}`, RED);
    process.exit(1);
});
