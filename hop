    // Status bar styling
    run(`tmux set-option -t ${s} status on`);
    run(`tmux set-option -t ${s} status-position bottom`);
    run(`tmux set-option -t ${s} status-style 'bg=#e4e4e7,fg=#52525b'`);
    run(`tmux set-option -t ${s} status-left '#[fg=#7c3aed,bold]● #[fg=#18181b,bold]${sessionName} #[fg=#a1a1aa,nobold]│#[bg=#e4e4e7]  '`);
