function ensureTerminalEventBuffer(id) {
    let state = terminalApiEventBuffers.get(id);
    if (!state) {
        state = { nextId: 1, events: [] };
        terminalApiEventBuffers.set(id, state);
    }
    return state;
}

function appendTerminalEvent(id, payload) {
    const state = ensureTerminalEventBuffer(id);
    const event = {
        id: state.nextId++,
        payload: { ...payload, streamEventId: state.nextId - 1 }
    };
    state.events.push(event);
    if (state.events.length > TERMINAL_API_EVENT_BUFFER_LIMIT) {
        state.events.splice(0, state.events.length - TERMINAL_API_EVENT_BUFFER_LIMIT);
    }
    return event.payload;
}

function listTerminalEvents(id, afterId = 0) {
    const state = terminalApiEventBuffers.get(id);
    if (!state || state.events.length === 0) return [];
    const cursor = Number.isFinite(afterId) ? Number(afterId) : 0;
    if (cursor <= 0) {
        return state.events.map(entry => entry.payload);
    }
    return state.events
        .filter(entry => entry.id > cursor)
        .map(entry => entry.payload);
}

function clearTerminalEventBuffer(id) {
    terminalApiEventBuffers.delete(id);
}

function sendTerminalStreamEvent(id, payload) {
    const enrichedPayload = appendTerminalEvent(id, payload);
    const streams = terminalApiStreams.get(id);
    if (!streams || streams.size === 0) return;
    const line = `data: ${JSON.stringify(enrichedPayload)}\n\n`;
    for (const res of streams) {
        res.write(line);
    }
}

function registerTerminalStream(id, res) {
    if (!terminalApiStreams.has(id)) {
        terminalApiStreams.set(id, new Set());
    }
    terminalApiStreams.get(id).add(res);
}

function unregisterTerminalStream(id, res) {
    const streams = terminalApiStreams.get(id);
    if (!streams) return;
    streams.delete(res);
    if (streams.size === 0) {
        terminalApiStreams.delete(id);
    }
}

// --- Login Rate Limiting (Exponential Backoff) ---
const failedAttempts = new Map(); // ip -> { count: number, lastAttempt: number }
const FAILED_ATTEMPT_TTL_MS = 6 * 60 * 60 * 1000; // 6 hours
const FAILED_ATTEMPT_MAX = 1000;

function pruneFailedAttempts(now = Date.now()) {
    for (const [ip, record] of failedAttempts.entries()) {
        if (now - record.lastAttempt > FAILED_ATTEMPT_TTL_MS) {
            failedAttempts.delete(ip);
        }
    }
    if (failedAttempts.size > FAILED_ATTEMPT_MAX) {
        const entries = Array.from(failedAttempts.entries())
            .sort((a, b) => a[1].lastAttempt - b[1].lastAttempt);
        const overflow = failedAttempts.size - FAILED_ATTEMPT_MAX;
        for (let i = 0; i < overflow; i++) {
            failedAttempts.delete(entries[i][0]);
        }
    }
}

function checkRateLimit(ip) {
    pruneFailedAttempts();
    const record = failedAttempts.get(ip);
    if (!record || record.count < 5) return { allowed: true };

    const now = Date.now();
    // 5 failures = 30s, 6 = 60s, 7 = 120s... (30 * 2^(n-5))
    const waitSeconds = 30 * Math.pow(2, record.count - 5);
    const lockedUntil = record.lastAttempt + (waitSeconds * 1000);

    if (now < lockedUntil) {
        return { allowed: false, remaining: Math.ceil((lockedUntil - now) / 1000) };
    }
    return { allowed: true };
}

function recordFailure(ip) {
    const now = Date.now();
    pruneFailedAttempts(now);
    const record = failedAttempts.get(ip) || { count: 0, lastAttempt: 0 };
    record.count++;
    record.lastAttempt = now;
    failedAttempts.set(ip, record);
}

function resetFailure(ip) {
    failedAttempts.delete(ip);
}

// Colors
const RESET = "\x1b[0m";
const GREEN = "\x1b[32m";
const YELLOW = "\x1b[33m";
const CYAN = "\x1b[36m";
const RED = "\x1b[31m";
const BOLD = "\x1b[1m";
const DIM = "\x1b[2m";
const MAGENTA = "\x1b[35m";

function log(msg, color = RESET) {
    if (DAEMON_FLAG) {
        // The daemon's stdout/stderr are redirected to logs/hop-daemon.log.
        // Timestamp each line and drop the wrapping color codes so the file
        // stays grep-friendly.
        console.log(`[${new Date().toISOString()}] ${msg}`);
        return;
    }
    console.log(`${color}${msg}${RESET}`);
}

// Process-level crash guards. Without these, a single stray throw or rejected
// promise anywhere in the daemon's async paths kills the process — and with it
// the cloudflared tunnel and every remote user's session. In the daemon we log
// and stay alive (no supervisor restarts us, so dying is the worse outcome);
// in an interactive CLI invocation we preserve fail-fast and exit non-zero.
function describeError(value) {
    if (value && value.stack) return value.stack;
    if (value instanceof Error) return `${value.name}: ${value.message}`;
    return String(value);
}
process.on('uncaughtException', (err) => {
    try { log(`[uncaughtException] ${describeError(err)}`); } catch (e) { }
    if (!DAEMON_FLAG) process.exit(1);
});
process.on('unhandledRejection', (reason) => {
    try { log(`[unhandledRejection] ${describeError(reason)}`); } catch (e) { }
    if (!DAEMON_FLAG) process.exit(1);
});

async function runCommand(command, args, opts = {}) {
    return new Promise((resolve, reject) => {
        const proc = spawn(command, args, { stdio: 'inherit', ...opts });
        proc.on('close', (code) => {
            if (code === 0) resolve();
            else reject(new Error(`Command ${command} exited with code ${code}`));
        });
        proc.on('error', (err) => reject(err));
    });
}

async function checkAndInstallDependencies() {
    log(`[1/4] Checking dependencies...`, BOLD);
    try {
        await runCommand('brew', ['--version'], { stdio: 'ignore' });
    } catch (e) {
        log(`  - Homebrew not found.`, YELLOW);

        // Never block on a prompt without a terminal (e.g. daemon mode).
        if (!process.stdin.isTTY || !process.stdout.isTTY) {
            log(`Error: Homebrew required. Install from https://brew.sh and re-run hop.`, RED);
            process.exit(1);
        }

        const readline = require('readline');
        const rl = readline.createInterface({ input: process.stdin, output: process.stdout });

        const answer = await new Promise(resolve => {
            rl.question(`  Install Homebrew now? (y/N) `, resolve);
        });
        rl.close();

        if (answer.toLowerCase() !== 'y') {
            log(`Error: Homebrew required. Install from https://brew.sh`, RED);
            process.exit(1);
        }

        log(`  - Installing Homebrew...`, YELLOW);
        try {
            await runCommand('/bin/bash', ['-c',
                'curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh | bash'
            ], { stdio: 'inherit' });

            // Add brew to PATH for Apple Silicon
            const brewPaths = ['/opt/homebrew/bin', '/usr/local/bin'];
            for (const p of brewPaths) {
                if (fs.existsSync(path.join(p, 'brew'))) {
                    process.env.PATH = `${p}:${process.env.PATH}`;
                    break;
                }
            }
            log(`  - Homebrew installed.`, GREEN);
        } catch (err) {
            log(`Error: Failed to install Homebrew.`, RED);
            process.exit(1);
        }
    }

    const deps = ['cloudflared']; // tmux/ttyd not needed - using node-pty via hay
    for (const dep of deps) {
        try {
            await runCommand('which', [dep], { stdio: 'ignore' });
            log(`  - ${dep} found.`, GREEN);
        } catch (e) {
            log(`  - ${dep} NOT found.`, YELLOW);
            // Ask before installing anything; without a terminal, print manual instructions instead.
            if (!process.stdin.isTTY || !process.stdout.isTTY) {
                log(`Error: ${dep} is required. Install it manually: brew install ${dep}`, RED);
                process.exit(1);
            }
            const readline = require('readline');
            const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
            const answer = await new Promise(resolve => {
                rl.question(`  Install ${dep} via Homebrew now? (y/N) `, resolve);
            });
            rl.close();
            if (answer.toLowerCase() !== 'y') {
                log(`Error: ${dep} is required. Install it manually: brew install ${dep}`, RED);
                process.exit(1);
            }
            log(`  - Installing ${dep}...`, YELLOW);
            try {
                await runCommand('brew', ['install', dep]);
                log(`  - ${dep} installed.`, GREEN);
            } catch (err) {
                log(`  - Failed to install ${dep}. Check Xcode license?`, RED);
                process.exit(1);
            }
        }
    }
}

// List active hay rooms as sessions
function listActiveSessions() {
    if (isExternalTerminalBackend()) {
        return Object.keys(activeSessions).map((name) => ({
            name,
            windows: 1,
            attached: false
        }));
    }
    const sessions = [];
    for (const [name, room] of hayRooms.rooms) {
        sessions.push({
            name,
            windows: 1,
            attached: room.clients.size > 0
        });
    }
    return sessions;
}

async function listActiveSessionsRuntimeFirst() {
    if (!isExternalTerminalBackend()) {
        return { sessions: listActiveSessions(), runtimeAvailable: true };
    }
    try {
        await reconcileExternalRuntimeSessions();
    } catch (e) {
        return { sessions: [], runtimeAvailable: false };
    }
    const runtimeRooms = await fetchExternalHayRuntimeRooms();
    if (!Array.isArray(runtimeRooms)) {
        return { sessions: [], runtimeAvailable: false };
    }
    const sessions = runtimeRooms.map((room) => ({
        name: room.id,
        windows: 1,
        attached: Number(room.clientCount) > 0,
        localCliCount: Number(room.localCliCount) || 0,
        hasLocalCli: room.hasLocalCli === true || Number(room.localCliCount) > 0,
        cwd: room.cwd,
        hostPort: room.hostPort
    }));
    return { sessions, runtimeAvailable: true };
}

function pruneExpiredLocalCliClaims() {
    const now = Date.now();
    for (const [claimId, claim] of localCliClaims.entries()) {
        if (!claim || Number(claim.expiresAt) <= now) {
            localCliClaims.delete(claimId);
        }
    }
}

function countPendingLocalCliClaims(sessionName) {
    if (!sessionName) return 0;
    pruneExpiredLocalCliClaims();
    let count = 0;
    for (const claim of localCliClaims.values()) {
        if (claim?.sessionName === sessionName) {
            count += 1;
        }
    }
    return count;
}

function claimPendingLocalCliSession(sessionName) {
    if (!sessionName) return null;
    pruneExpiredLocalCliClaims();
    const claimId = crypto.randomBytes(8).toString('hex');
    localCliClaims.set(claimId, {
        sessionName,
        expiresAt: Date.now() + LOCAL_CLI_CLAIM_TTL_MS
    });
    return claimId;
}

function consumePendingLocalCliClaim(sessionName, claimId) {
    if (!sessionName || !claimId) return false;
    pruneExpiredLocalCliClaims();
    const claim = localCliClaims.get(claimId);
    if (!claim || claim.sessionName !== sessionName) return false;
    localCliClaims.delete(claimId);
    return true;
}

function noteClientConnected(sessionName, source, claimId = null) {
    if (!sessionName) return;
    if (source === 'local-cli') {
        consumePendingLocalCliClaim(sessionName, claimId);
    }
    const entry = sessionClientSummary.get(sessionName) || { localCliCount: 0, total: 0 };
    entry.total += 1;
    if (source === 'local-cli') {
        entry.localCliCount += 1;
    }
    sessionClientSummary.set(sessionName, entry);
}

function noteClientDisconnected(sessionName, source) {
    if (!sessionName) return;
    const entry = sessionClientSummary.get(sessionName);
    if (!entry) return;
    entry.total = Math.max(0, entry.total - 1);
    if (source === 'local-cli') {
        entry.localCliCount = Math.max(0, entry.localCliCount - 1);
    }
    if (entry.total === 0 && entry.localCliCount === 0) {
        sessionClientSummary.delete(sessionName);
    } else {
        sessionClientSummary.set(sessionName, entry);
    }
}

function getSessionClientSummary(sessionName) {
    const pendingLocalCliCount = countPendingLocalCliClaims(sessionName);
    const entry = sessionClientSummary.get(sessionName) || { localCliCount: 0, total: 0 };
    return {
        localCliCount: entry.localCliCount + pendingLocalCliCount,
        totalClients: entry.total,
        hasLocalCli: entry.localCliCount + pendingLocalCliCount > 0
    };
}

async function withLocalCliClaimLock(fn) {
    const previous = localCliClaimLock;
    let release;
    localCliClaimLock = new Promise((resolve) => {
        release = resolve;
    });
    await previous;
    try {
        return await fn();
    } finally {
        release();
    }
}

function hopSessionExists(name) {
    if (!name) return false;
    if (isExternalTerminalBackend()) {
        return !!activeSessions[name] || !!getRuntimeSessionMetadata(name);
    }
    return hayRooms.hasRoom(name) || activeSessions[name];
}

function buildSessionEntries(haySessions, opts = {}) {
    const includeStoredTerminalSessions = opts.includeStoredTerminalSessions !== false;
    const sessionMap = new Map();
    const runtimeSessionNames = new Set();

    for (const s of Array.isArray(haySessions) ? haySessions : []) {
        const config = getEffectiveSessionConfig(s.name);
        const type = config?.type || 'terminal';
        const displayName = config?.displayName || s.name;
        const folderId = config?.folderId || null;
        const clientSummary = getSessionClientSummary(s.name);
        const localCliCount = Math.max(clientSummary.localCliCount, Number(s.localCliCount) || 0);
        const attached = typeof s.attached === 'boolean'
            ? s.attached
            : (clientSummary.totalClients > 0);
        runtimeSessionNames.add(s.name);
        sessionMap.set(s.name, {
            ...s,
            attached,
            type,
            live: type === 'terminal',
            port: config?.port,
            displayName,
            folderId,
            internalName: s.name,
            cwd: s.cwd || config?.cwd,
            shell: config?.shell,
            env: config?.env,
            workspaceName: config?.workspaceName || resolveSessionWorkspaceName(config),
            cols: config?.cols,
            rows: config?.rows,
            startup: config?.startup,
            autoStart: config?.autoStart,
            createdAt: config?.createdAt,
            createdBy: config?.createdBy || 'user',
            agentPermitted: config?.agentPermitted === true,
            localCliCount,
            hasLocalCli: clientSummary.hasLocalCli || localCliCount > 0 || s.hasLocalCli === true
        });
    }

    for (const [name, config] of Object.entries(sessionStore.sessions)) {
        const type = config?.type || 'terminal';
        if (type !== 'port' && !includeStoredTerminalSessions && !sessionMap.has(name)) {
            continue;
        }
        const displayName = config?.displayName || toDisplaySessionName(name);
        const folderId = config?.folderId || null;
        const clientSummary = getSessionClientSummary(name);
        if (!sessionMap.has(name)) {
            sessionMap.set(name, {
                name,
                windows: null,
                attached: false,
                type,
                live: type === 'terminal' ? runtimeSessionNames.has(name) : null,
                port: config.port,
                displayName,
                folderId,
                internalName: name,
                cwd: config?.cwd,
                shell: config?.shell,
                env: config?.env,
                workspaceName: config?.workspaceName || resolveSessionWorkspaceName(config),
                cols: config?.cols,
                rows: config?.rows,
                startup: config?.startup,
                autoStart: config?.autoStart,
                createdAt: config?.createdAt,
                createdBy: config?.createdBy || 'user',
                agentPermitted: config?.agentPermitted === true,
                localCliCount: clientSummary.localCliCount,
                hasLocalCli: clientSummary.hasLocalCli
            });
        } else {
            const entry = sessionMap.get(name);
            const localCliCount = Math.max(clientSummary.localCliCount, Number(entry.localCliCount) || 0);
            entry.type = type || entry.type;
            entry.live = type === 'terminal' ? runtimeSessionNames.has(name) : null;
            entry.port = config.port;
            entry.displayName = displayName;
            entry.folderId = folderId;
            entry.internalName = name;
            entry.cwd = config?.cwd;
            entry.shell = config?.shell;
            entry.env = config?.env;
            entry.workspaceName = config?.workspaceName || resolveSessionWorkspaceName(config);
            entry.cols = config?.cols;
            entry.rows = config?.rows;
            entry.startup = config?.startup;
            entry.autoStart = config?.autoStart;
            entry.createdAt = config?.createdAt;
            entry.createdBy = config?.createdBy || 'user';
            entry.agentPermitted = config?.agentPermitted === true;
            entry.localCliCount = localCliCount;
            entry.hasLocalCli = clientSummary.hasLocalCli || localCliCount > 0 || entry.hasLocalCli === true;
        }
    }

    for (const [name, config] of runtimeSessionMetadata.entries()) {
        if (!name || sessionMap.has(name)) continue;
        const type = config?.type || 'terminal';
        if (type !== 'port' && !includeStoredTerminalSessions) continue;
        const displayName = config?.displayName || toDisplaySessionName(name);
        const folderId = config?.folderId || null;
        const clientSummary = getSessionClientSummary(name);
        sessionMap.set(name, {
            name,
            windows: null,
            attached: clientSummary.totalClients > 0,
            type,
            live: type === 'terminal' ? runtimeSessionNames.has(name) : null,
            port: config.port,
            displayName,
            folderId,
            internalName: name,
            cwd: config?.cwd,
            shell: config?.shell,
            env: config?.env,
            workspaceName: config?.workspaceName || resolveSessionWorkspaceName(config),
            cols: config?.cols,
            rows: config?.rows,
            startup: config?.startup,
            autoStart: config?.autoStart,
            createdAt: config?.createdAt,
            createdBy: config?.createdBy || 'user',
            agentPermitted: config?.agentPermitted === true,
            localCliCount: clientSummary.localCliCount,
            hasLocalCli: clientSummary.hasLocalCli
        });
    }

    const folderIndex = new Map();
    folderIndex.set('root', -1);
    sessionStore.order.folders.forEach((id, index) => {
        folderIndex.set(id, index);
    });
    const sessionOrderIndex = new Map();
    for (const [bucket, list] of Object.entries(sessionStore.order.sessions)) {
        list.forEach((id, index) => {
            sessionOrderIndex.set(`${bucket}:${id}`, index);
        });
    }

    return Array.from(sessionMap.values()).sort((a, b) => {
        const aBucket = a.folderId && sessionStore.folders[a.folderId] ? a.folderId : 'root';
        const bBucket = b.folderId && sessionStore.folders[b.folderId] ? b.folderId : 'root';
        const aFolderIndex = folderIndex.has(aBucket) ? folderIndex.get(aBucket) : Number.MAX_SAFE_INTEGER;
        const bFolderIndex = folderIndex.has(bBucket) ? folderIndex.get(bBucket) : Number.MAX_SAFE_INTEGER;
        if (aFolderIndex !== bFolderIndex) return aFolderIndex - bFolderIndex;
        const aSessionIndex = sessionOrderIndex.has(`${aBucket}:${a.internalName}`)
            ? sessionOrderIndex.get(`${aBucket}:${a.internalName}`)
            : Number.MAX_SAFE_INTEGER;
        const bSessionIndex = sessionOrderIndex.has(`${bBucket}:${b.internalName}`)
            ? sessionOrderIndex.get(`${bBucket}:${b.internalName}`)
            : Number.MAX_SAFE_INTEGER;
        if (aSessionIndex !== bSessionIndex) return aSessionIndex - bSessionIndex;
        return a.displayName.localeCompare(b.displayName);
    });
}

function listAllSessionEntries() {
    return buildSessionEntries(listActiveSessions(), { includeStoredTerminalSessions: true });
}

async function listAllSessionEntriesRuntimeFirst() {
    const runtime = await listActiveSessionsRuntimeFirst();
    const entries = buildSessionEntries(runtime.sessions, { includeStoredTerminalSessions: true });
    const activeDisplayNames = (Array.isArray(runtime.sessions) ? runtime.sessions : [])
        .map((entry) => {
            if (!entry || entry.type === 'port') return null;
            const config = getEffectiveSessionConfig(entry.name);
            return config?.displayName || getSessionDisplayName(entry.name) || entry.name;
        })
        .filter(Boolean);
    return { entries, runtimeAvailable: runtime.runtimeAvailable, activeDisplayNames };
}

async function runtimeTerminalSessionExists(sessionName) {
