                            .btn:disabled { opacity: 0.5; cursor: wait; }
                            .new-session { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 0.75rem; }
                            .new-session input { flex: 1; min-width: 200px; padding: 0.875rem 1rem; border: 1px solid #e4e4e7; border-radius: 8px; font-size: 1rem; background: #fff; }
