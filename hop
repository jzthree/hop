  function setPos(x, y) {
    fab.style.left = x + 'px';
    fab.style.top = y + 'px';
  }
  function initPos() {
    var pad = 12;
    var x = (stored && typeof stored.x === 'number') ? stored.x : (window.innerWidth - 56);
    var y = (stored && typeof stored.y === 'number') ? stored.y : (window.innerHeight - 120);
    x = clamp(x, pad, window.innerWidth - 56);
    y = clamp(y, pad, window.innerHeight - 56);
    setPos(x, y);
  }
  initPos();

  var dragging = false;
  var moved = false;
  var startX = 0, startY = 0, origX = 0, origY = 0;

  function onDown(e) {
    dragging = true;
    moved = false;
    var touch = e.touches ? e.touches[0] : e;
    startX = touch.clientX;
    startY = touch.clientY;
    var rect = fab.getBoundingClientRect();
    origX = rect.left;
    origY = rect.top;
    e.preventDefault();
  }
  function onMove(e) {
    if (!dragging) return;
    var touch = e.touches ? e.touches[0] : e;
    var dx = touch.clientX - startX;
    var dy = touch.clientY - startY;
    if (Math.abs(dx) > 4 || Math.abs(dy) > 4) moved = true;
    var x = clamp(origX + dx, 8, window.innerWidth - 56);
    var y = clamp(origY + dy, 8, window.innerHeight - 56);
    setPos(x, y);
  }
  function onUp() {
    if (!dragging) return;
    dragging = false;
    var rect = fab.getBoundingClientRect();
    try { localStorage.setItem('hop-fab-pos', JSON.stringify({ x: rect.left, y: rect.top })); } catch (e) { }
  }

  btn.addEventListener('touchstart', onDown, { passive: false });
  btn.addEventListener('touchmove', onMove, { passive: false });
  btn.addEventListener('touchend', onUp);
  btn.addEventListener('mousedown', onDown);
  window.addEventListener('mousemove', onMove);
  window.addEventListener('mouseup', onUp);

  function closeMenu() {
    fab.classList.remove('open');
    menu.setAttribute('aria-hidden', 'true');
  }
  function toggleMenu() {
    if (fab.classList.contains('open')) {
      closeMenu();
      return;
    }
    fab.classList.add('open');
    menu.setAttribute('aria-hidden', 'false');
    fetchSessions();
  }

  btn.addEventListener('click', function(e) {
    if (moved) return;
    e.preventDefault();
    toggleMenu();
  });

  document.addEventListener('click', function(e) {
    if (!fab.contains(e.target)) closeMenu();
  });

  function fetchSessions() {
    fetch('/api/sessions')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        list.innerHTML = '';
        var sessions = data.sessions || [];
        var active = data.active || [];
        if (!sessions.length) {
          var empty = document.createElement('div');
          empty.className = 'hop-item';
          empty.textContent = 'No sessions';
          list.appendChild(empty);
          return;
        }
        var current = getCurrentSession();
        sessions.forEach(function(s) {
          var displayName = s.displayName || s.name;
          var row = document.createElement('div');
          row.className = 'hop-item-row';

          var item = document.createElement('button');
          item.className = 'hop-item';
          if (s.name === current) item.classList.add('current');
          if (active.indexOf(s.name) !== -1) {
            var dot = document.createElement('span');
            dot.className = 'hop-dot';
            item.appendChild(dot);
          }
          var label = document.createElement('span');
          var suffix = s.type === 'port' ? (s.port ? ' (PORT ' + s.port + ')' : ' (PORT)') : '';
          label.textContent = displayName + suffix;
          item.appendChild(label);
          item.addEventListener('click', function(ev) {
            ev.stopPropagation();
            window.location.href = '/s/' + encodeURIComponent(s.name) + '/';
          });

          var renameBtn = document.createElement('button');
          renameBtn.className = 'hop-action';
          renameBtn.textContent = 'Rename';
          renameBtn.addEventListener('click', function(ev) {
            ev.stopPropagation();
            var nextName = prompt('Rename session:', displayName);
            if (!nextName || nextName === displayName) return;
            if (!/^[a-zA-Z0-9_-]+$/.test(nextName)) {
              alert('Only letters, numbers, - and _ allowed');
              return;
            }
            fetch('/api/sessions/rename', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ oldName: displayName, newName: nextName })
            }).then(function() { fetchSessions(); });
          });

          row.appendChild(item);
          row.appendChild(renameBtn);
          list.appendChild(row);
        });
      })
      .catch(function() {
        list.innerHTML = '<div class="hop-item hop-subtle">Failed to load</div>';
      });
  }
})();
</script>
