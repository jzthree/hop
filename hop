// --- Login Rate Limiting (Exponential Backoff) ---
const failedAttempts = new Map(); // ip -> { count: number, lastAttempt: number }
const FAILED_ATTEMPT_TTL_MS = 6 * 60 * 60 * 1000; // 6 hours
const FAILED_ATTEMPT_MAX = 1000;

function pruneFailedAttempts(now = Date.now()) {
    for (const [ip, record] of failedAttempts.entries()) {
        if (now - record.lastAttempt > FAILED_ATTEMPT_TTL_MS) {
            failedAttempts.delete(ip);
        }
    }
    if (failedAttempts.size > FAILED_ATTEMPT_MAX) {
        const entries = Array.from(failedAttempts.entries())
            .sort((a, b) => a[1].lastAttempt - b[1].lastAttempt);
        const overflow = failedAttempts.size - FAILED_ATTEMPT_MAX;
        for (let i = 0; i < overflow; i++) {
            failedAttempts.delete(entries[i][0]);
        }
    }
}

function checkRateLimit(ip) {
    pruneFailedAttempts();
    const record = failedAttempts.get(ip);
    if (!record || record.count < 5) return { allowed: true };

    const now = Date.now();
    // 5 failures = 30s, 6 = 60s, 7 = 120s... (30 * 2^(n-5))
    const waitSeconds = 30 * Math.pow(2, record.count - 5);
    const lockedUntil = record.lastAttempt + (waitSeconds * 1000);

    if (now < lockedUntil) {
        return { allowed: false, remaining: Math.ceil((lockedUntil - now) / 1000) };
    }
    return { allowed: true };
}

function recordFailure(ip) {
    const now = Date.now();
    pruneFailedAttempts(now);
    const record = failedAttempts.get(ip) || { count: 0, lastAttempt: 0 };
    record.count++;
    record.lastAttempt = now;
    failedAttempts.set(ip, record);
}

function resetFailure(ip) {
    failedAttempts.delete(ip);
}

