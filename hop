    run(`tmux set-option -t ${s} mode-style 'bg=#ddd6fe,fg=#18181b'`);
}

// iOS Virtual Keyboard - Returns {hook, ui} for proper injection timing
// hook: WebSocket interceptor script (goes in <head> before ttyd scripts)
// ui: keyboard HTML/CSS/JS (goes before </body>)
function getIOSKeyboardInjection() {
    // WebSocket interceptor - MUST run before ttyd creates its socket
    const hook = `
<script>
(function() {
    // Capture ttyd's WebSocket when it's created
    window.__hopSocket = null;
    window.__hopOnData = null;
    function patchTerminal(Terminal) {
        if (!Terminal || Terminal.__hopPatched) return;
        var orig = Terminal.prototype.onData;
        if (typeof orig !== 'function') return;
        Terminal.prototype.onData = function(cb) {
            window.__hopOnData = cb;
            window.__hopTerm = this;
            return orig.call(this, cb);
        };
        Terminal.__hopPatched = true;
    }
    try { patchTerminal(window.Terminal); } catch (e) { }
    try {
        var desc = Object.getOwnPropertyDescriptor(window, 'Terminal');
        if (!desc || desc.configurable) {
            var terminalValue = window.Terminal;
            Object.defineProperty(window, 'Terminal', {
                configurable: true,
                get: function() { return terminalValue; },
                set: function(v) { terminalValue = v; patchTerminal(v); }
            });
        } else {
            setInterval(function() { patchTerminal(window.Terminal); }, 250);
        }
    } catch (e) {
        setInterval(function() { patchTerminal(window.Terminal); }, 250);
    }
    var OriginalWebSocket = window.WebSocket;
    window.WebSocket = function(url, protocols) {
        // Call original constructor properly (with or without protocols)
        var ws = protocols ? new OriginalWebSocket(url, protocols) : new OriginalWebSocket(url);
        
        // Check if this is ttyd's socket by protocol OR URL pattern
        var isTtyProtocol = protocols === 'tty' ||
            (Array.isArray(protocols) && protocols.indexOf('tty') >= 0);
        var wsUrl = '';
        try { wsUrl = (typeof url === 'string') ? url : (url && url.toString ? url.toString() : ''); } catch (e) { wsUrl = ''; }
        var isTtyUrl = wsUrl && /\\/ws(?:\\?|$|\\/)/.test(wsUrl);
        
        if (isTtyProtocol || isTtyUrl) {
            console.log('[HopKb] Captured ttyd socket via ' + (isTtyProtocol ? 'protocol' : 'URL'));
            ws.binaryType = 'arraybuffer';
            window.__hopSocket = ws;
        }
        return ws;
    };
    window.WebSocket.CONNECTING = OriginalWebSocket.CONNECTING;
    window.WebSocket.OPEN = OriginalWebSocket.OPEN;
    window.WebSocket.CLOSING = OriginalWebSocket.CLOSING;
    window.WebSocket.CLOSED = OriginalWebSocket.CLOSED;
    window.WebSocket.prototype = OriginalWebSocket.prototype;
})();
</script>`;

    // Read keyboard UI from file
    const keyboardFile = path.join(__dirname, 'keyboard.html');
    let ui = '<!-- keyboard.html not found -->';
    try {
        ui = fs.readFileSync(keyboardFile, 'utf8');
    } catch (e) {
        log(`Warning: keyboard.html not found`, YELLOW);
    }

    return { hook, ui };
}

// Helper to get client IP (handles proxies)
function getClientIp(req) {
    return req.headers['cf-connecting-ip'] ||
        req.headers['x-forwarded-for'] ||
        req.socket.remoteAddress ||
        'unknown';
}

function startAuthProxy(authEmitter) {
    log(`[2/4] Starting Session Manager on port ${PROXY_PORT}...`, BOLD);

    const server = http.createServer((req, res) => {
        const parsedUrl = url.parse(req.url, true);
        const cookies = cookie.parse(req.headers.cookie || '');
        const ip = getClientIp(req);

        // Check auth via cookie OR Authorization header (for mobile apps)
        const authHeader = req.headers.authorization;
        const tokenFromHeader = authHeader && authHeader.startsWith('Bearer ')
            ? authHeader.substring(7)
            : null;
        const isAuthenticated = cookies[SESSION_COOKIE_NAME] === SESSION_SECRET
            || tokenFromHeader === SESSION_SECRET;

        // --- LOGIN PAGE ---
        if (!isAuthenticated) {
            // API Login for mobile apps - returns token in JSON
            if (req.method === 'POST' && parsedUrl.pathname === '/api/login') {
                const limit = checkRateLimit(ip);
                if (!limit.allowed) {
                    res.writeHead(429, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ success: false, error: `Too many attempts. Try again in ${limit.remaining}s.` }));
                    return;
                }

                let body = '';
                req.on('data', chunk => body += chunk);
                req.on('end', () => {
                    try {
                        const { totp } = JSON.parse(body);
                        if (authenticator.check(totp, AUTH_SECRET)) {
                            resetFailure(ip);
                            res.setHeader('Set-Cookie', cookie.serialize(SESSION_COOKIE_NAME, SESSION_SECRET, {
                                httpOnly: false, // Allow JS access for mobile
                                maxAge: 60 * 60 * 24 * 7
                            }));
                            res.writeHead(200, { 'Content-Type': 'application/json' });
                            res.end(JSON.stringify({
                                success: true,
                                token: SESSION_SECRET  // Return token for mobile to use in headers
                            }));
                            if (authEmitter) authEmitter.emit('authenticated');
                        } else {
                            recordFailure(ip);
                            res.writeHead(401, { 'Content-Type': 'application/json' });
                            res.end(JSON.stringify({ success: false, error: 'Invalid code' }));
                        }
                    } catch (e) {
                        res.writeHead(400, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ success: false, error: 'Invalid request' }));
                    }
                });
                return;
            }

            // Web form login
            if (req.method === 'POST' && parsedUrl.pathname === '/') {
                const limit = checkRateLimit(ip);
                if (!limit.allowed) {
                    res.writeHead(429, { 'Content-Type': 'text/html; charset=utf-8' });
                    res.end(`Too many attempts. Try again in ${limit.remaining}s. <a href="/">Back</a>`);
                    return;
                }

                let body = '';
                req.on('data', chunk => body += chunk);
                req.on('end', () => {
                    const params = new URLSearchParams(body);
                    const token = params.get('token');

                    try {
                        if (authenticator.check(token, AUTH_SECRET)) {
                            resetFailure(ip);
                            res.setHeader('Set-Cookie', cookie.serialize(SESSION_COOKIE_NAME, SESSION_SECRET, {
                                httpOnly: true,
                                maxAge: 60 * 60 * 24 * 7
                            }));
                            res.writeHead(302, { 'Location': '/' });
                            res.end();
                            if (authEmitter) authEmitter.emit('authenticated');
                        } else {
                            recordFailure(ip);
                            res.writeHead(401, { 'Content-Type': 'text/html; charset=utf-8' });
                            res.end('Invalid Code. <a href="/">Try Again</a>');
                        }
                    } catch (e) {
                        res.writeHead(401);
                        res.end('Error verifying code');
                    }
                });
                return;
            }

            // Show login page
            res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8' });
            res.end(`
                <html>
                    <head>
                        <meta charset="UTF-8">
                        <meta name="viewport" content="width=device-width, initial-scale=1">
                        <title>Verify Identity</title>
                        <style>
                            body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: #fafafa; color: #18181b; display: flex; justify-content: center; align-items: center; height: 100vh; margin:0; }
                            .box { text-align: center; max-width: 400px; padding: 2rem; }
                            h2 { margin-bottom: 2rem; font-weight: 600; font-size: 1.5rem; }
                            .code-inputs { display: flex; gap: 8px; justify-content: center; margin-bottom: 2rem; }
                            .code-inputs input { 
                                width: 44px; height: 56px; 
                                font-size: 24px; text-align: center; 
                                border: 1px solid #e4e4e7; border-radius: 8px; 
                                background: #fff; color: #18181b; 
                                -moz-appearance: textfield;
                            }
                            .code-inputs input:focus { outline: none; border-color: #7c3aed; box-shadow: 0 0 0 2px rgba(124, 58, 237, 0.1); }
                            .code-inputs input::-webkit-outer-spin-button,
                            .code-inputs input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
                            
                            button { font-size: 1rem; padding: 0.8rem 2.5rem; background: #18181b; color: #fff; border: none; border-radius: 8px; cursor: pointer; font-weight: 500; width: 100%; transition: opacity 0.2s; }
                            button:hover { opacity: 0.9; }
                            .hidden-submit { position: absolute; left: -9999px; }
                        </style>
                    </head>
                    <body>
                        <div class="box">
                            <h2>Security Check</h2>
                            <p style="color: #71717a; margin-bottom: 2rem; font-size: 0.9rem;">Please enter the verification code from your authenticator app to continue.</p>
                            <form method="POST" id="authForm">
                                <div class="code-inputs" id="inputs">
                                    <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" required>
                                    <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" required>
                                    <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" required>
                                    <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" required>
                                    <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" required>
                                    <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" required>
                                </div>
                                <input type="hidden" name="token" id="fullToken">
                                <button type="submit">Verify</button>
                            </form>
                        </div>
                        <script>
                            const inputs = document.querySelectorAll('.code-inputs input');
                            const form = document.getElementById('authForm');
                            const hidden = document.getElementById('fullToken');
                            
                            inputs.forEach((input, i) => {
                                input.addEventListener('input', e => {
                                    if (e.target.value.length === 1) {
                                        if (i < inputs.length - 1) inputs[i + 1].focus();
                                        else submit();
                                    }
                                });
                                input.addEventListener('keydown', e => {
                                    if (e.key === 'Backspace' && !e.target.value && i > 0) {
                                        inputs[i - 1].focus();
                                    }
                                });
                                input.addEventListener('paste', e => {
                                    e.preventDefault();
                                    const text = (e.clipboardData || window.clipboardData).getData('text');
                                    const digits = text.replace(/[^0-9]/g, '').slice(0, 6);
                                    if (digits.length === 0) return;
                                    digits.split('').forEach((char, index) => {
                                        if (inputs[index]) inputs[index].value = char;
                                    });
                                    if (digits.length === 6) submit();
                                    else inputs[Math.min(digits.length, 5)].focus();
                                });
                            });
                            
                            function submit() {
                                const code = Array.from(inputs).map(i => i.value).join('');
                                if (code.length === 6) {
                                    hidden.value = code;
                                    form.submit();
                                }
                            }
                            
                            form.addEventListener('submit', e => {
                                const code = Array.from(inputs).map(i => i.value).join('');
                                hidden.value = code;
                            });
                        </script>
                    </body>
                </html>
            `);
            return;
        }

        // --- AUTHENTICATED ROUTES ---
        const sessionName = parsedUrl.query.session;

        // API: Ping (triggers auth event for mobile login)
        if (parsedUrl.pathname === '/api/ping' && req.method === 'POST') {
            if (authEmitter) authEmitter.emit('authenticated');
            res.writeHead(200, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ ok: true, message: 'Mobile login' }));
            return;
        }

        // API: List sessions
        if (parsedUrl.pathname === '/api/sessions' && req.method === 'GET') {
            const sessions = listTmuxSessions();
            const activeSessionNames = Object.keys(activeSessions);
            res.writeHead(200, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ sessions, active: activeSessionNames }));
            return;
        }

        // API: Create session
        if (parsedUrl.pathname === '/api/sessions' && req.method === 'POST') {
            let body = '';
            req.on('data', chunk => body += chunk);
            req.on('end', () => {
                try {
                    const { name } = JSON.parse(body);
                    if (!name || !/^[a-zA-Z0-9_-]+$/.test(name)) {
                        res.writeHead(400, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Invalid session name' }));
                        return;
                    }
                    getOrCreateSession(name);
                    res.writeHead(200, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ ok: true, name }));
                } catch (e) {
                    res.writeHead(400, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Invalid request body' }));
                }
            });
            return;
        }

        // API: Rename session
        if (parsedUrl.pathname === '/api/sessions/rename' && req.method === 'POST') {
            let body = '';
            req.on('data', chunk => body += chunk);
            req.on('end', () => {
                const { oldName, newName } = JSON.parse(body);
                if (!newName || !/^[a-zA-Z0-9_-]+$/.test(newName)) {
                    res.writeHead(400, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Invalid name' }));
                    return;
                }

                // Rename in tmux
                try {
                    execSync(`tmux rename-session -t ${oldName} ${newName}`);

                    // Update internal map if it's managed by us
                    if (activeSessions[oldName]) {
                        activeSessions[newName] = activeSessions[oldName];
                        delete activeSessions[oldName];
                    }

                    // Rename log/exit files if they exist (optional cleanup)

                    res.writeHead(200, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ ok: true }));
                } catch (e) {
                    res.writeHead(500, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Rename failed' }));
                }
            });
            return;
        }

        // If no session selected, show picker
        if (!sessionName) {
            res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8' });
            res.end(`
