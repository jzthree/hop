async function runCommand(command, args, opts = {}) {
    return new Promise((resolve, reject) => {
        const proc = spawn(command, args, { stdio: 'inherit', ...opts });
        proc.on('close', (code) => {
            if (code === 0) resolve();
            else reject(new Error(`Command ${command} exited with code ${code}`));
        });
        proc.on('error', (err) => reject(err));
    });
}

async function checkAndInstallDependencies() {
    log(`[1/4] Checking dependencies...`, BOLD);
    try {
        await runCommand('brew', ['--version'], { stdio: 'ignore' });
    } catch (e) {
        log(`  - Homebrew not found.`, YELLOW);

        const readline = require('readline');
        const rl = readline.createInterface({ input: process.stdin, output: process.stdout });

        const answer = await new Promise(resolve => {
            rl.question(`  Install Homebrew now? (y/n) `, resolve);
        });
        rl.close();

        if (answer.toLowerCase() !== 'y') {
            log(`Error: Homebrew required. Install from https://brew.sh`, RED);
            process.exit(1);
        }

        log(`  - Installing Homebrew...`, YELLOW);
        try {
            await runCommand('/bin/bash', ['-c',
                'curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh | bash'
            ], { stdio: 'inherit' });

            // Add brew to PATH for Apple Silicon
            const brewPaths = ['/opt/homebrew/bin', '/usr/local/bin'];
            for (const p of brewPaths) {
                if (fs.existsSync(path.join(p, 'brew'))) {
                    process.env.PATH = `${p}:${process.env.PATH}`;
                    break;
                }
            }
            log(`  - Homebrew installed.`, GREEN);
        } catch (err) {
            log(`Error: Failed to install Homebrew.`, RED);
            process.exit(1);
        }
    }

    const deps = ['tmux', 'ttyd', 'cloudflared'];
    for (const dep of deps) {
        try {
            await runCommand('which', [dep], { stdio: 'ignore' });
            log(`  - ${dep} found.`, GREEN);
        } catch (e) {
            log(`  - ${dep} NOT found. Installing...`, YELLOW);
            try {
                await runCommand('brew', ['install', dep]);
                log(`  - ${dep} installed.`, GREEN);
            } catch (err) {
                log(`  - Failed to install ${dep}. Check Xcode license?`, RED);
                process.exit(1);
            }
        }
    }
