function startDaemon() {
    const node = process.execPath;
    const script = __filename;
    // Capture the daemon's stdout/stderr to a log file instead of discarding it,
    // so tunnel restarts, health failures, and crashes leave a forensic trail.
    const logFd = rotateAndOpenLogFd(path.join(LOG_DIR, 'hop-daemon.log'));
    const child = spawn(node, [script, '--daemon'], {
        detached: true,
        stdio: ['ignore', logFd, logFd],
        env: process.env
    });
    child.unref();
    try { fs.closeSync(logFd); } catch (e) { } // child keeps its own dup
}

function waitForDaemonReady(timeoutMs = 20000) {
    return new Promise((resolve) => {
        const start = Date.now();
        const check = () => {
            const state = isServerRunning();
            // State file now written early, so also check that URL is populated
            if (state && state.url) return resolve(state);
            if (Date.now() - start > timeoutMs) {
                log(`Timed out waiting for the hop daemon to start.`, RED);
                const daemonLogPath = path.join(LOG_DIR, 'hop-daemon.log');
                try {
                    const tail = fs.readFileSync(daemonLogPath, 'utf8').trimEnd().split('\n').slice(-10);
                    if (tail.length && tail[0] !== '') {
                        log(`Last ${tail.length} line(s) of ${daemonLogPath}:`, YELLOW);
                        tail.forEach((line) => log(`  ${line}`, RESET));
                    }
                } catch (e) { }
                log(`See ${CYAN}hop logs${RESET} for the full daemon log.`, RESET);
                process.exit(1);
            }
            setTimeout(check, 250);
        };
        check();
    });
}

async function startLocalSession(proxyServer, tunnelProc, publicUrl) {
    log(`[4/4] Attaching to session...`, BOLD);

    // Reuse an actively attached user-facing session (typically remote login),
    // otherwise create a fresh local session for this CLI invocation.
    const existingSessions = listActiveSessions();
    const preferredExistingSession = existingSessions.find((session) => {
        if (!session?.attached) return false;
        const config = getEffectiveSessionConfig(session.name);
        if (config?.type === 'port') return false;
        return config?.createdBy !== 'agent';
    });
    let displayName;
    let defaultSessionName;

    let sessionCwd;
    if (preferredExistingSession) {
        defaultSessionName = preferredExistingSession.name;
        displayName = getSessionDisplayName(defaultSessionName);
        log(`Connecting to existing session: ${displayName}`, RESET);
    } else {
        // Create new session - find next available name
        const cwdName = path.basename(process.cwd()).replace(/[^a-zA-Z0-9_-]/g, '-');
        const existingInternalNames = new Set(Object.keys(sessionStore.sessions));
        const existingDisplayNames = new Set(
            Object.entries(sessionStore.sessions).map(([name, config]) => config?.displayName || toDisplaySessionName(name))
        );
        existingSessions.forEach((s) => {
            existingInternalNames.add(s.name);
            existingDisplayNames.add(getSessionDisplayName(s.name));
        });
        let counter = 1;
        displayName = `${cwdName}-${counter}`;
        defaultSessionName = toInternalSessionName(displayName);
        while (
            !defaultSessionName ||
            existingInternalNames.has(defaultSessionName) ||
            existingDisplayNames.has(displayName)
        ) {
            counter++;
            displayName = `${cwdName}-${counter}`;
            defaultSessionName = toInternalSessionName(displayName);
        }
        log(`Starting session: ${displayName}`, RESET);
        sessionCwd = process.cwd();
        getOrCreateSession(defaultSessionName, sessionCwd);
    }

    const cleanup = () => {
        if (shuttingDown) return;
        shuttingDown = true;  // Prevent tunnel auto-restart
        log(`Cleaning up...`, YELLOW);

        // Remove state file
        if (fs.existsSync(STATE_FILE)) {
            try { fs.unlinkSync(STATE_FILE); } catch (e) { }
        }

        // Remove session config for this local session in embedded mode.
        // External backend keeps terminal definitions persistent across hop restarts.
        if (!isExternalTerminalBackend()) {
            try {
                const config = getSessionConfig(defaultSessionName);
                if (config && config.type !== 'port') {
                    deleteSessionConfig(defaultSessionName);
                }
            } catch (e) { }
        }

        // Close all in-process rooms (external backend persists independently)
        if (!isExternalTerminalBackend()) {
            hayRooms.closeAll();
        }
        closeAllSessionAuditSinks();

        // Kill cloudflared tunnel (use currentTunnelProc in case it was restarted)
        try { (currentTunnelProc || tunnelProc).kill('SIGTERM'); } catch (e) { }

        // Close proxy server
        try { proxyServer.close(); } catch (e) { }

        log(`Goodbye!`, GREEN);
        process.exit(0);
    };

    const runLocalSessionLoop = () => {
        return new Promise((resolve) => {
            // Ensure session exists on server
            getOrCreateSession(defaultSessionName, sessionCwd);
            runHayCliAttach({
                internalName: defaultSessionName,
                displayName,
                cwd: sessionCwd
            }, publicUrl || '').then(resolve).catch((err) => {
                log(`Failed to start hay CLI: ${err.message}`, RED);
                resolve(1);
            });
        });
    };

    runLocalSessionLoop().then((code) => {
        // Ctrl+G (detach) exits hay CLI with code 10; keep tunnel alive.
        if (code === 10) {
            log(`\nDetached from local session. Tunnel is still running.`, YELLOW);
            log(`Press Ctrl+C to shut down.`, RESET);
            return;
        }
        log(`\nLocal session ended. Shutting down tunnel...`, YELLOW);
        cleanup();
    });

    process.on('SIGINT', cleanup);
    process.on('SIGTERM', cleanup);
    process.on('exit', cleanup);
}

async function attachToExistingTunnel(existingTunnel) {
    log(`Hop tunnel is already running!`, GREEN);
    log(`URL: ${existingTunnel.url}`, BOLD);

    await ensureExternalHayHostReady();
    await ensureNamingTheme();
    const cwdName = getCwdSessionBaseName();
    const cwdPath = process.cwd();

    let selection = null;
    try {
        selection = await claimLocalCliSession(existingTunnel, cwdPath, cwdName);
    } catch (e) {
        if (e?.status && e.status !== 404) {
            log(`Note: Could not claim session atomically (${e.message}). Falling back to local selection.`, YELLOW);
        }
    }

    if (!selection) {
        let sessionsRes = { sessions: [] };
        try {
            sessionsRes = await fetchSessionList(existingTunnel);
        } catch (e) {
            log(`Note: Could not query daemon sessions (${e.message}). Defaulting to create-new.`, YELLOW);
        }
        const sessions = Array.isArray(sessionsRes.sessions) ? sessionsRes.sessions : [];
        selection = await chooseUnnamedSessionTarget(sessions, { cwdPath, cwdName });
    }
    const target = selection.target;

    if (selection.createdNew) {
        log(`Creating new session: ${target.displayName}...`, RESET);
        if (!target.localCliClaimId) {
            try {
                const created = await callLocalApi(existingTunnel, '/api/sessions', 'POST', {
                    name: target.displayName,
                    cwd: cwdPath
                });
                if (created.status < 200 || created.status >= 300 || !(created.data?.ok || created.data?.success)) {
                    const errText = typeof created.data === 'string'
                        ? created.data
                        : (created.data?.error || `status ${created.status}`);
                    throw new Error(errText);
                }
            } catch (e) {
                log(`Note: Could not register session with daemon metadata: ${e.message}`, YELLOW);
                log(`Continuing with local attach.`, RESET);
            }
        }
    } else {
        log(`Attaching to existing session: ${target.displayName}`, RESET);
    }

    const code = await runHayCliAttach(target, existingTunnel.url || '');
    if (code === 10) {
        log(`\nDetached from local session.`, YELLOW);
        process.exit(0);
    }
    log(`\nSession disconnected.`, YELLOW);
    process.exit(code || 0);
}

async function fetchSessionList(existingTunnel) {
    const sessionsRes = await new Promise((resolve, reject) => {
        const opts = {
            hostname: '127.0.0.1',
            port: existingTunnel.port,
            path: '/api/sessions',
            method: 'GET',
            headers: { 'Authorization': `Bearer ${existingTunnel.sessionSecret}` }
        };
        http.get(opts, res => {
            let data = '';
            res.on('data', c => data += c);
            res.on('end', () => {
                try {
                    resolve(JSON.parse(data));
                } catch (e) {
                    reject(new Error('Failed to parse sessions response'));
                }
            });
        }).on('error', reject);
    });
    return sessionsRes || {};
}

async function claimLocalCliSession(existingTunnel, cwdPath, cwdName) {
    const claimed = await callLocalApi(existingTunnel, '/api/sessions/claim-local-cli', 'POST', {
        cwd: cwdPath,
        cwdName
    });
    if (claimed.status < 200 || claimed.status >= 300 || claimed.data?.ok !== true || !claimed.data?.target) {
        const err = new Error(claimed.data?.error || `status ${claimed.status}`);
        err.status = claimed.status;
        throw err;
    }
    return {
        target: claimed.data.target,
        createdNew: claimed.data.createdNew === true
    };
}

async function callLocalApi(existingTunnel, apiPath, method = 'GET', body = null) {
    return await new Promise((resolve, reject) => {
        const headers = { 'Authorization': `Bearer ${existingTunnel.sessionSecret}` };
        let payload = null;
        if (body) {
            payload = JSON.stringify(body);
            headers['Content-Type'] = 'application/json';
        }
        const opts = {
            hostname: '127.0.0.1',
            port: existingTunnel.port,
            path: apiPath,
            method,
            headers
        };
        const req = http.request(opts, res => {
            let data = '';
            res.on('data', c => data += c);
            res.on('end', () => {
                try {
                    resolve({ status: res.statusCode, data: JSON.parse(data) });
                } catch (e) {
                    resolve({ status: res.statusCode, data });
                }
            });
        });
        req.on('error', reject);
        if (payload) {
            req.write(payload);
        }
        req.end();
    });
}

async function fetchExternalHayRuntimeRooms() {
    if (!isExternalTerminalBackend()) return null;
    const preferredHost = hayHostState || readHayHostStateFile();
    const inspectedHosts = (await inspectExternalHayHosts())
        .filter((entry) => hostBelongsToCurrentHome(entry, preferredHost));
    if (inspectedHosts.length === 0) {
        return null;
    }

    const canonicalHost = choosePreferredHayHost(inspectedHosts, preferredHost);
    if (canonicalHost) {
        writeHayHostStateFile(canonicalHost);
    }

    const roomsById = new Map();
    for (const entry of inspectedHosts) {
        const rooms = Array.isArray(entry.rooms) ? entry.rooms : [];
        for (const room of rooms) {
            const existing = roomsById.get(room.id);
            if (!existing) {
                roomsById.set(room.id, room);
                continue;
            }
            const existingClients = Number(existing.clientCount) || 0;
            const nextClients = Number(room.clientCount) || 0;
            const existingPreferred = canonicalHost && existing.hostPort === canonicalHost.port;
            const nextPreferred = canonicalHost && room.hostPort === canonicalHost.port;
            if (nextClients > existingClients || (!existingPreferred && nextPreferred)) {
                roomsById.set(room.id, room);
            }
        }
    }

    return Array.from(roomsById.values());
}

async function listLocalTerminalSelectionCandidates() {
    const metadataSessions = listAllSessionEntries()
        .filter((session) => session && session.type !== 'port' && typeof session.displayName === 'string');
    const runtimeRooms = await fetchExternalHayRuntimeRooms();
    if (!Array.isArray(runtimeRooms)) {
        return {
            sessions: [],
            runtimeSessionNames: new Set(),
            source: 'runtime-unavailable'
        };
    }

    const metadataByInternalName = new Map();
    for (const session of metadataSessions) {
        const internalName = String(
            session.internalName ||
            toInternalSessionName(session.displayName || '')
        ).trim();
        if (!internalName) continue;
        metadataByInternalName.set(internalName, session);
    }

    const runtimeSessions = runtimeRooms
        .map((room) => {
            const internalName = room.id;
            const metadata = metadataByInternalName.get(internalName);
            const config = getEffectiveSessionConfig(internalName);
            const displayName = metadata?.displayName || config?.displayName || internalName;
            const localCliCount = Math.max(Number(room.localCliCount) || 0, Number(metadata?.localCliCount) || 0);
            return {
                type: 'terminal',
                internalName,
                displayName,
                cwd: room.cwd || metadata?.cwd || config?.cwd,
                hostPort: room.hostPort,
                createdAt: metadata?.createdAt || config?.createdAt,
                hasLocalCli: room.hasLocalCli === true || metadata?.hasLocalCli === true || localCliCount > 0,
                localCliCount
            };
        })
        .filter((session) => !!session && typeof session.displayName === 'string' && session.displayName);

    for (const session of metadataSessions) {
        if (!session || session.type === 'port' || !session.internalName) continue;
        if (runtimeSessions.some((entry) => entry.internalName === session.internalName)) continue;
        runtimeSessions.push({
            type: 'terminal',
            internalName: session.internalName,
            displayName: session.displayName,
            cwd: session.cwd,
            hostPort: null,
            createdAt: session.createdAt,
            hasLocalCli: session.hasLocalCli === true,
            localCliCount: Number(session.localCliCount) || 0
        });
    }

    return {
        sessions: runtimeSessions,
        runtimeSessionNames: new Set(runtimeSessions.map((session) => session.internalName)),
        source: 'runtime'
    };
}

function pickSessionForDir(sessions, cwdName, opts = {}) {
    const prefix = `${cwdName}-`;
    const matches = sessions
        .filter(s => s.type !== 'port')
        .filter(s => s.displayName === cwdName || s.displayName.startsWith(prefix));
    if (matches.length === 0) return { target: null, totalMatches: 0 };
    const filtered = opts.requireNoLocalCli ? matches.filter(s => !s.hasLocalCli) : matches;
    if (filtered.length === 0) return { target: null, totalMatches: matches.length };
    const scored = filtered.map(s => {
        let score = Number.MAX_SAFE_INTEGER;
        if (s.displayName === cwdName) {
            score = 0;
        } else if (s.displayName.startsWith(prefix)) {
            const suffix = s.displayName.slice(prefix.length);
            const num = parseInt(suffix, 10);
            if (Number.isFinite(num)) score = num;
        }
        const createdAtMs = Date.parse(s.createdAt || '');
        return {
            session: s,
            score,
            createdAtMs: Number.isFinite(createdAtMs) ? createdAtMs : Number.MAX_SAFE_INTEGER
        };
    });
    scored.sort((a, b) => (
        a.score - b.score ||
        a.createdAtMs - b.createdAtMs ||
        a.session.displayName.localeCompare(b.session.displayName)
    ));
    return { target: scored[0].session, totalMatches: matches.length };
}

function pickBestExactCwdSession(sessions, cwdName, opts = {}) {
    const exactMatches = (Array.isArray(sessions) ? sessions : [])
        .filter((session) => session && session.type !== 'port' && typeof session.displayName === 'string');
    if (exactMatches.length === 0) return null;
    const filtered = opts.requireNoLocalCli ? exactMatches.filter((session) => !session.hasLocalCli) : exactMatches;
    if (filtered.length === 0) return null;
    const prefix = `${cwdName}-`;
    const scored = filtered.map((session) => {
        let score = 2;
        if (session.displayName === cwdName) {
            score = 0;
        } else if (session.displayName.startsWith(prefix)) {
            score = 1;
        }
        const createdAtMs = Date.parse(session.createdAt || '');
        return {
            session,
            score,
            createdAtMs: Number.isFinite(createdAtMs) ? createdAtMs : Number.MAX_SAFE_INTEGER
        };
    });
    scored.sort((a, b) => (
        a.createdAtMs - b.createdAtMs ||
        a.score - b.score ||
        a.session.displayName.localeCompare(b.session.displayName)
    ));
    return scored[0].session;
}

function getCwdSessionBaseName() {
    return path.basename(process.cwd()).replace(/[^a-zA-Z0-9_-]/g, '-');
}

function buildNextSessionIdentity(existingSessions, cwdName, opts = {}) {
    const sessionList = Array.isArray(existingSessions) ? existingSessions : [];
    const includeStoredSessions = opts.includeStoredSessions !== false;
    const existingInternalNames = new Set();
    const existingDisplayNames = new Set();

    if (includeStoredSessions) {
        for (const [name, config] of Object.entries(sessionStore.sessions)) {
            existingInternalNames.add(name);
            existingDisplayNames.add(config?.displayName || toDisplaySessionName(name));
        }
    }

    for (const session of sessionList) {
        if (!session || session.type === 'port') continue;
        if (typeof session.internalName === 'string' && session.internalName) {
            existingInternalNames.add(session.internalName);
        }
        const displayName = typeof session.displayName === 'string'
            ? session.displayName
            : (typeof session.name === 'string' ? session.name : '');
        if (displayName) {
            existingDisplayNames.add(displayName);
            const internalName = toInternalSessionName(displayName);
            if (internalName) existingInternalNames.add(internalName);
        }
    }

    // Use naming theme if configured, otherwise fall back to cwdName-counter
    const theme = getNamingTheme();
    if (theme) {
        const allUsed = new Set([...existingInternalNames, ...existingDisplayNames]);
        const displayName = generateSessionName(theme, allUsed);
        const internalName = toInternalSessionName(displayName) || displayName;
        return { internalName, displayName };
    }

    // Legacy fallback: cwdName-counter
    let counter = 1;
    let displayName = `${cwdName}-${counter}`;
    let internalName = toInternalSessionName(displayName);
    while (
        !internalName ||
        existingInternalNames.has(internalName) ||
        existingDisplayNames.has(displayName)
    ) {
        counter += 1;
        displayName = `${cwdName}-${counter}`;
        internalName = toInternalSessionName(displayName);
    }
    return { internalName, displayName };
}

function pickSessionForCwd(sessions, cwdPath, cwdName, opts = {}) {
    const terminalSessions = (Array.isArray(sessions) ? sessions : [])
        .filter((session) => session && session.type !== 'port' && typeof session.displayName === 'string');
    const exactCwdMatches = terminalSessions.filter((session) => (
        typeof session.cwd === 'string' && session.cwd === cwdPath
    ));
    if (exactCwdMatches.length > 0) {
        return pickBestExactCwdSession(exactCwdMatches, cwdName, opts);
    }
    return pickSessionForDir(terminalSessions, cwdName, opts).target;
}

function buildAttachTargetFromSession(session) {
    if (!session || typeof session !== 'object') return null;
    const fallbackDisplay = typeof session.displayName === 'string' ? session.displayName : '';
    const internalName = session.internalName || toInternalSessionName(fallbackDisplay);
    if (!internalName || !SESSION_NAME_RE.test(internalName)) return null;
    const displayName = fallbackDisplay || internalName;
    return {
        internalName,
        displayName,
        cwd: session.cwd,
        hostPort: session.hostPort
    };
}

async function chooseUnnamedSessionTarget(existingSessions, opts = {}) {
    const cwdPath = typeof opts.cwdPath === 'string' && opts.cwdPath.trim()
        ? opts.cwdPath
        : process.cwd();
    const cwdName = typeof opts.cwdName === 'string' && opts.cwdName.trim()
        ? opts.cwdName
        : path.basename(cwdPath).replace(/[^a-zA-Z0-9_-]/g, '-');
    const matched = pickSessionForCwd(existingSessions, cwdPath, cwdName, {
        requireNoLocalCli: opts.requireNoLocalCli !== false
    });

    if (matched) {
        const attachTarget = buildAttachTargetFromSession(matched);
        if (attachTarget) {
            return { target: attachTarget, createdNew: false };
        }
    }

    const next = buildNextSessionIdentity(existingSessions, cwdName, {
        includeStoredSessions: opts.includeStoredSessions !== false
    });
    return {
        target: {
            internalName: next.internalName,
            displayName: next.displayName,
            cwd: cwdPath
        },
        createdNew: true
    };
}

async function claimUnnamedLocalCliSession(opts = {}) {
    const cwdPath = typeof opts.cwdPath === 'string' && opts.cwdPath.trim()
        ? opts.cwdPath
        : process.cwd();
    const cwdName = typeof opts.cwdName === 'string' && opts.cwdName.trim()
        ? opts.cwdName
        : path.basename(cwdPath).replace(/[^a-zA-Z0-9_-]/g, '-');
    const snapshot = await listAllSessionEntriesRuntimeFirst();
    const selection = await chooseUnnamedSessionTarget(snapshot.entries, {
        cwdPath,
        cwdName,
        includeStoredSessions: opts.includeStoredSessions !== false
    });
    const target = selection.target;
    if (!target || !target.internalName) {
        const err = new Error('Failed to choose session target');
        err.status = 500;
        throw err;
    }

    if (selection.createdNew) {
        rememberRuntimeSessionMetadata(target.internalName, {
            type: 'terminal',
            cwd: cwdPath,
            displayName: target.displayName,
            createdBy: 'user',
            agentPermitted: false,
            workspaceName: null
        });
    }

    const localCliClaimId = claimPendingLocalCliSession(target.internalName);
    return {
        target: {
            ...target,
            cwd: target.cwd || cwdPath,
            localCliClaimId
        },
        createdNew: selection.createdNew
    };
}

function resolveSessionTargetByDisplay(sessionsRes, displayName) {
    const sessions = Array.isArray(sessionsRes?.sessions) ? sessionsRes.sessions : [];
    let target = sessions.find((session) => (
        session && session.type !== 'port' && session.displayName === displayName
    ));
    if (!target && sessionsRes?.aliases && sessionsRes.aliases[displayName]) {
        const resolvedName = sessionsRes.aliases[displayName];
        target = sessions.find((session) => (
            session && session.type !== 'port' && session.displayName === resolvedName
        ));
    }
    return target || null;
}

async function runHayCliConnect(wsUrl, roomName, shareUrl) {
    const hayCli = resolveHayCliPath();
    return new Promise((resolve) => {
        const cliProc = spawn('node', [hayCli, '-s', wsUrl, '-r', roomName, '-n', 'Local'], {
            stdio: 'inherit',
            env: { ...process.env, FORCE_COLOR: '1', HAY_SHARE_URL: shareUrl || '' }
        });

        cliProc.on('close', (code) => {
            resolve(code || 0);
        });

        cliProc.on('error', (err) => {
            log(`\nConnection error: ${err.message}`, RED);
            resolve(1);
        });
    });
}

async function runHayCliAttach(target, shareUrl = '') {
    if (!target || typeof target !== 'object') {
        throw new Error('Missing session target');
    }
    const internalName = String(target.internalName || '').trim();
    if (!internalName || !SESSION_NAME_RE.test(internalName)) {
        throw new Error('Invalid session target');
    }
    const displayName = String(target.displayName || getSessionDisplayName(internalName) || internalName).trim();
    const savedConfig = getSessionConfig(internalName);
    const sessionCwd = target.cwd || (getEffectiveSessionConfig(internalName) || {}).cwd || process.cwd();

    rememberRuntimeSessionMetadata(internalName, {
        type: 'terminal',
        cwd: sessionCwd,
        displayName,
        createdBy: target.createdBy || savedConfig?.createdBy || 'user',
        agentPermitted: typeof target.agentPermitted === 'boolean'
            ? target.agentPermitted
            : (typeof savedConfig?.agentPermitted === 'boolean' ? savedConfig.agentPermitted : false),
        workspaceName: target.workspaceName || savedConfig?.workspaceName || null
    });
    await ensureExternalHayHostReady();
    await ensureExternalRuntimeSession(internalName, sessionCwd, displayName, {
        shell: target.shell,
        env: target.env,
        cols: target.cols,
        rows: target.rows,
        startup: target.startup,
        autoStart: target.autoStart,
        createdBy: target.createdBy || savedConfig?.createdBy || 'user',
        agentPermitted: typeof target.agentPermitted === 'boolean'
            ? target.agentPermitted
            : savedConfig?.agentPermitted,
        workspaceName: target.workspaceName || savedConfig?.workspaceName,
        folderId: target.folderId,
        saveDefinition: !!savedConfig
    });
    await reconcileExternalRuntimeSessions();
    const wsUrl = buildExternalHayWsUrl(internalName, {
        name: 'Local',
        source: 'local-cli',
        claim: target.localCliClaimId,
        cwd: sessionCwd,
        hostPort: target.hostPort
    });
    return runHayCliConnect(wsUrl, internalName, shareUrl);
}

function resolveOrCreateLocalTerminalSession(nameArg, opts = {}) {
    const existingSessions = Array.isArray(opts.existingSessions) ? opts.existingSessions : [];
    const runtimeSessionNames = opts.runtimeSessionNames instanceof Set ? opts.runtimeSessionNames : null;
    const requested = String(nameArg || '').trim();

    if (requested) {
        const requestedDisplay = resolveDisplayNameAlias(requested);
        const existingInternal = hasSavedSessionConfig(requested)
            ? requested
            : findInternalSessionName(requestedDisplay);

        if (existingInternal && (!runtimeSessionNames || runtimeSessionNames.has(existingInternal))) {
            const existingConfig = getEffectiveSessionConfig(existingInternal);
            if (existingConfig?.type === 'port') {
                throw new Error('Session is configured as a port proxy');
            }
            const runtimeMatch = existingSessions.find((session) => session && session.internalName === existingInternal);
            return {
                internalName: existingInternal,
                displayName: getSessionDisplayName(existingInternal),
                cwd: runtimeMatch?.cwd || existingConfig?.cwd,
                hostPort: runtimeMatch?.hostPort,
                shell: existingConfig?.shell,
                env: existingConfig?.env,
                cols: existingConfig?.cols,
                rows: existingConfig?.rows,
                startup: existingConfig?.startup,
                autoStart: existingConfig?.autoStart,
                createdBy: existingConfig?.createdBy,
                agentPermitted: existingConfig?.agentPermitted,
                folderId: existingConfig?.folderId,
                workspaceName: existingConfig?.workspaceName
            };
        }

        const existingByList = existingSessions.find((session) => {
            if (!session || session.type === 'port') return false;
            if (session.displayName === requestedDisplay) return true;
            if (session.internalName === requestedDisplay || session.internalName === requested) return true;
            return false;
        });
        if (existingByList && existingByList.internalName) {
            return {
                internalName: existingByList.internalName,
                displayName: existingByList.displayName || requestedDisplay,
                cwd: existingByList.cwd,
                hostPort: existingByList.hostPort
            };
        }

        const displayName = isLegacyInternalSessionName(requested)
            ? toDisplaySessionName(requested)
            : requestedDisplay;
        const internalName = toInternalSessionName(displayName);
        if (!internalName) {
            throw new Error('Invalid session name');
        }
        rememberRuntimeSessionMetadata(internalName, {
            type: 'terminal',
            cwd: process.cwd(),
            displayName,
            createdBy: 'user',
            agentPermitted: false,
            workspaceName: null
        });
        return { internalName, displayName, cwd: process.cwd(), createdBy: 'user', agentPermitted: false, workspaceName: null };
    }

    const cwdName = getCwdSessionBaseName();
    const cwdPath = process.cwd();
    const { internalName, displayName } = buildNextSessionIdentity(existingSessions, cwdName);

    rememberRuntimeSessionMetadata(internalName, {
        type: 'terminal',
        cwd: cwdPath,
        displayName,
        createdBy: 'user',
        agentPermitted: false,
        workspaceName: null
    });
    return { internalName, displayName, cwd: cwdPath, createdBy: 'user', agentPermitted: false, workspaceName: null };
}

async function runLocalOnlyTerminal(nameArg) {
    await ensureHayLoaded();
    await ensureExternalHayHostReady();

    const {
        sessions: existingSessions,
        runtimeSessionNames,
        source: selectionSource
    } = await listLocalTerminalSelectionCandidates();

    let target = null;
    const requested = String(nameArg || '').trim();
    if (requested) {
        target = resolveOrCreateLocalTerminalSession(requested, {
            existingSessions,
            runtimeSessionNames
        });
    } else {
        await ensureNamingTheme();
        const cwdName = getCwdSessionBaseName();
        const cwdPath = process.cwd();
        const selection = await chooseUnnamedSessionTarget(existingSessions, {
            cwdPath,
            cwdName,
            includeStoredSessions: true
        });
        target = selection.target;

        if (selection.createdNew) {
            rememberRuntimeSessionMetadata(target.internalName, {
                type: 'terminal',
                cwd: cwdPath,
                displayName: target.displayName,
                createdBy: 'user',
                agentPermitted: false,
                workspaceName: null
            });
        } else {
            log(`Attaching to existing session: ${target.displayName}`, RESET);
        }
    }

    log(`Launching local terminal: ${target.displayName}`, RESET);

    const code = await runHayCliAttach(target, '');
    if (code === 10) {
        log(`\nDetached from local session.`, YELLOW);
        process.exit(0);
    }
    log(`\nLocal session ended.`, YELLOW);
    process.exit(code || 0);
}

function listAttachableSessionNames(sessionsRes) {
    return (sessionsRes.sessions || [])
        .filter((s) => s && s.type !== 'port' && typeof s.displayName === 'string' && s.displayName)
        .map((s) => s.displayName)
        .sort();
}

function printAvailableSessionNames(sessionsRes) {
    const names = listAttachableSessionNames(sessionsRes);
    if (names.length) {
        log(`Available sessions:`, RESET);
        names.forEach((name) => log(`  ${name}`, RESET));
        log(`Attach with ${CYAN}hop attach <name>${RESET} (see ${CYAN}hop session list${RESET}).`, RESET);
    } else {
        log(`No terminal sessions are running. Run ${CYAN}hop${RESET} to start one.`, RESET);
    }
}

async function attachToNamedSession(existingTunnel, displayName) {
    const sessionsRes = await fetchSessionList(existingTunnel);
    const target = resolveSessionTargetByDisplay(sessionsRes, displayName);
    if (!target) {
        log(`Session not found: ${displayName}`, RED);
        printAvailableSessionNames(sessionsRes);
        process.exit(1);
    }
    const targetDisplayName = target.displayName || displayName;
    log(`Attaching to ${targetDisplayName}...`, RESET);
    const code = await runHayCliAttach({
        internalName: target.internalName || toInternalSessionName(targetDisplayName),
        displayName: targetDisplayName,
        cwd: target.cwd,
        hostPort: target.hostPort
    }, existingTunnel.url || '');
    if (code === 10) {
        log(`\nDetached from local session.`, YELLOW);
        process.exit(0);
    }
    log(`\nSession disconnected.`, YELLOW);
    process.exit(code || 0);
}

async function attachToSessionForDir(existingTunnel) {
    const sessionsRes = await fetchSessionList(existingTunnel);
    const sessions = sessionsRes.sessions || [];
    const cwdName = getCwdSessionBaseName();
    const target = pickSessionForCwd(sessions, process.cwd(), cwdName);
    if (!target) {
        log(`No existing session for ${cwdName}.`, RED);
        printAvailableSessionNames(sessionsRes);
        process.exit(1);
    }
    return attachToNamedSession(existingTunnel, target.displayName);
}

async function attachToAllSessions(existingTunnel) {
    const sessionsRes = await fetchSessionList(existingTunnel);
    const sessions = (sessionsRes.sessions || [])
        .filter((s) => s && s.type !== 'port' && typeof s.displayName === 'string' && s.displayName);

    if (sessions.length === 0) {
        log(`No terminal sessions to attach. Run ${CYAN}hop${RESET} to start one.`, YELLOW);
        process.exit(1);
    }

    sessions.sort((a, b) => a.displayName.localeCompare(b.displayName));
    log(`Attaching sequentially to ${sessions.length} session(s).`, CYAN);
    log(`Detach from a session (Ctrl+G) to continue to the next one.`, RESET);

    let sawNonZero = false;
    for (let i = 0; i < sessions.length; i++) {
        const s = sessions[i];
        log(`\n[${i + 1}/${sessions.length}] Attaching to ${s.displayName}...`, BOLD);
        const code = await runHayCliAttach({
            internalName: s.internalName || toInternalSessionName(s.displayName),
            displayName: s.displayName,
            cwd: s.cwd,
            hostPort: s.hostPort
        }, existingTunnel.url || '');
        if (code === 10) {
            log(`Detached from ${s.displayName}.`, YELLOW);
            continue;
        }
        if (code !== 0) {
            sawNonZero = true;
            log(`Session ${s.displayName} exited with code ${code}.`, YELLOW);
        }
    }

    if (sawNonZero) {
        process.exit(1);
    }
    log(`Finished attaching all sessions.`, GREEN);
    process.exit(0);
}

const KNOWN_COMMANDS = [
    'client', 'start', 'attach', 'local', 'stop', 'status', 'doctor', 'logs',
    'help', 'config', 'url', 'qr', 'health', 'domain', 'domain-clear',
    'password', 'user', 'workspace', 'session', 'wipe'
];

// Suggest the closest known command for typos (small edit distances only).
function suggestNearestCommand(input) {
    const editDistance = (a, b) => {
        const dp = Array.from({ length: a.length + 1 }, (_, i) => {
            const row = new Array(b.length + 1).fill(0);
            row[0] = i;
            return row;
        });
        for (let j = 0; j <= b.length; j++) dp[0][j] = j;
        for (let i = 1; i <= a.length; i++) {
            for (let j = 1; j <= b.length; j++) {
                dp[i][j] = Math.min(
                    dp[i - 1][j] + 1,
                    dp[i][j - 1] + 1,
                    dp[i - 1][j - 1] + (a[i - 1] === b[j - 1] ? 0 : 1)
                );
            }
        }
        return dp[a.length][b.length];
    };
    let best = null;
    let bestDistance = 3; // only suggest near misses
    for (const cmd of KNOWN_COMMANDS) {
        const d = editDistance(String(input).toLowerCase(), cmd);
        if (d < bestDistance) {
            bestDistance = d;
            best = cmd;
        }
    }
    return best;
}

async function main() {
    // Handle `hop client` - run as a user with exported credentials
    if (process.argv[2] === 'client') {
        // Separate flags from positionals so flag order doesn't matter.
        const clientArgs = process.argv.slice(3);
        let credentialsArg = null;
        let hostnameOverride = null;
        let wantClientHelp = false;
        let clientUsageError = null;
        for (let i = 0; i < clientArgs.length; i++) {
            const arg = clientArgs[i];
            if (arg === '--help' || arg === '-h') { wantClientHelp = true; continue; }
            if (arg === '--hostname') {
                const value = clientArgs[i + 1];
                if (!value || value.startsWith('-')) {
                    clientUsageError = 'Missing value after --hostname.';
                    break;
                }
                hostnameOverride = value;
                i++;
                continue;
            }
            if (arg.startsWith('-')) {
                clientUsageError = `Unknown option: ${arg}`;
                break;
            }
            if (credentialsArg === null) {
                credentialsArg = arg;
                continue;
            }
            clientUsageError = `Unexpected argument: ${arg}`;
            break;
        }
        if (clientUsageError) {
            log(clientUsageError, RED);
            log(`Usage: hop client <credentials.json|folder> [--hostname <name>]`, RESET);
            process.exit(1);
        }

        if (!credentialsArg || wantClientHelp) {
            log(`\n${BOLD}Hop Client Mode${RESET}\n`, CYAN);
            log(`Run hop with credentials from your admin.\n`, RESET);
            log(`${BOLD}Usage:${RESET}`, RESET);
            log(`  hop client <credentials.json>              Start tunnel with credentials`, RESET);
            log(`  hop client <folder>                        Start tunnel (folder contains credentials.json)`, RESET);
            log('');
            log(`${BOLD}Options:${RESET}`, RESET);
            log(`  --hostname <name>  Override hostname if config.yml is missing`, RESET);
            log('');
            log(`${BOLD}First run:${RESET}`, RESET);
            log(`  You'll be prompted to set a password and scan a QR code`, RESET);
            log(`  for your authenticator app.`, RESET);
            log('');
            log(`${BOLD}Example:${RESET}`, RESET);
            log(`  hop client ./my-credentials.json`, RESET);
            log('');
            process.exit(0);
        }

        // Find credentials file
        let credentialsPath = credentialsArg;
        if (fs.existsSync(credentialsArg) && fs.statSync(credentialsArg).isDirectory()) {
            credentialsPath = path.join(credentialsArg, 'credentials.json');
        }

        if (!fs.existsSync(credentialsPath)) {
            log(`Credentials file not found: ${credentialsPath}`, RED);
            process.exit(1);
        }

        // Load credentials
        let credentials;
        try {
            credentials = JSON.parse(fs.readFileSync(credentialsPath, 'utf8'));
        } catch (e) {
            log(`Invalid credentials file: ${e.message}`, RED);
            process.exit(1);
        }

        // Client config is stored per-tunnel (based on tunnel ID)
        const tunnelId = credentials.TunnelID || credentials.tunnelId || path.basename(credentialsPath, '.json');
        const clientConfigDir = path.join(HOME_DIR, 'clients', tunnelId);
        ensurePrivateDir(clientConfigDir);

        PASSWORD_FILE_PATH = path.join(clientConfigDir, '.password_hash');
        SECRET_FILE_PATH = path.join(clientConfigDir, '.auth_secret');
        const clientConfigFile = path.join(clientConfigDir, '.config.json');

        // Load or create client config
        let clientConfig = {};
        if (fs.existsSync(clientConfigFile)) {
            try {
                clientConfig = JSON.parse(fs.readFileSync(clientConfigFile, 'utf8'));
            } catch (e) { }
        }

        let hostname = clientConfig.hostname || null;
        if (hostnameOverride) {
            hostname = hostnameOverride;
        }

        // Try to find hostname in config.yml in the export folder
        const configYmlPath = path.join(path.dirname(credentialsPath), 'config.yml');
        if (!hostname && fs.existsSync(configYmlPath)) {
            const configYml = fs.readFileSync(configYmlPath, 'utf8');
            const hostnameMatch = configYml.match(/hostname:\s*(\S+)/);
            if (hostnameMatch) hostname = hostnameMatch[1];
        }

        if (!hostname) {
            log(`Hostname not found.`, RED);
            log(`Ask your admin to export a fresh bundle or pass --hostname.`, YELLOW);
            process.exit(1);
        }

        if (clientConfig.hostname !== hostname) {
            clientConfig.hostname = hostname;
            writePrivateFile(clientConfigFile, JSON.stringify(clientConfig, null, 2));
        }

        // First time setup - require password and TOTP
        const clientPasswordExists = isPasswordEnabled();
        const clientSecretExists = fs.existsSync(SECRET_FILE_PATH);

        if (!clientPasswordExists || !clientSecretExists) {
            log(`\n${BOLD}${YELLOW}⚠ First time setup required${RESET}\n`, YELLOW);
            log(`Your tunnel URL will be publicly accessible.`, RESET);
            log(`Password + authenticator code protects your hop login.\n`, RESET);

            const readline = require('readline');
            const stream = require('stream');

            const askPassword = (prompt) => new Promise((resolve) => {
                const rl = readline.createInterface({
                    input: process.stdin,
                    output: new stream.Writable({
                        write: (chunk, encoding, callback) => callback()
                    }),
                    terminal: true
                });
                process.stdout.write(prompt);
                rl.question('', (answer) => {
                    rl.close();
                    process.stdout.write('\n');
                    resolve(answer);
                });
            });

            // Set password
            if (!clientPasswordExists) {
                const password = await askPassword('Set a password: ');
                if (password.length < 4) {
                    log(`Password too short (min 4 characters).`, RED);
                    process.exit(1);
                }
                const confirm = await askPassword('Confirm password: ');
                if (password !== confirm) {
                    log(`Passwords do not match.`, RED);
                    process.exit(1);
                }
                setPassword(password);
                log(`${GREEN}✓ Password set.${RESET}`, GREEN);
            }

            // Set up TOTP
            if (!clientSecretExists) {
                loadAuthSecret();
                log(`\n${BOLD}Scan this QR code with your authenticator app:${RESET}\n`, CYAN);
                const label = hostname ? `Hop-${hostname}` : `Hop-${tunnelId.slice(0, 8)}`;
                showAuthQrCode(label);
                markAuthQrShown();
            }

            log(`\n${GREEN}✓ Setup complete!${RESET}\n`, GREEN);
        }

        loadAuthSecret();

        await checkAndInstallDependencies();
        await ensureHayLoaded();
        await ensureExternalHayHostReady();
        await reconcileExternalRuntimeSessions();
        const authEmitter = new EventEmitter();

        const proxyServer = startAuthProxy(authEmitter);
        CLIENT_TUNNEL_CONFIG = {
            tunnelId,
            credentialsPath,
            hostname,
            configDir: clientConfigDir
        };
        const { tunnel: tunnelProc, publicUrl } = await startClientTunnel();

        // Save state for other terminals to find
        writePrivateFile(STATE_FILE, JSON.stringify({
            pid: process.pid,
            port: BASE_PORT,
            url: publicUrl,
            sessionSecret: SESSION_SECRET,
            startTime: Date.now()
        }));

        // Start tunnel health monitoring (detects stale connections after VPN changes)
        startTunnelHealthMonitor();

        await waitForStart(authEmitter, publicUrl, `Hop-${hostname}`);

        await startLocalSession(proxyServer, tunnelProc, publicUrl);
        return;
    }

    // Handle `hop start` command - start daemon and print QR codes
    if (process.argv[2] === 'start') {
        const existing = isServerRunning();
        if (!existing) {
            loadAuthSecret();
            await checkAndInstallDependencies();
            startDaemon();
        }
        const state = existing || await waitForDaemonReady();
        const domainConfig = getDomainConfig();
        const label = domainConfig?.hostname ? `Hop-${domainConfig.hostname}` : 'Hop';
        loadAuthSecret();
        printStartupInfo(state.url, label);
        process.exit(0);
    }

    // Handle `hop attach` command - attach to existing session
    if (process.argv[2] === 'attach') {
        const existing = isServerRunning();
        if (!existing) {
            log(`Hop is not running.`, RED);
            process.exit(1);
        }
        const nameArg = process.argv[3];
        const attachAll = nameArg === 'all' || nameArg === '--all';
        if (attachAll) {
            await attachToAllSessions(existing);
            return;
        }
        const displayName = nameArg && isLegacyInternalSessionName(nameArg)
            ? getSessionDisplayName(nameArg)
            : nameArg;
        if (displayName) {
            await attachToNamedSession(existing, displayName);
        } else {
            await attachToSessionForDir(existing);
        }
        return;
    }

    // Handle `hop local` command - daemonless local terminal
    if (process.argv[2] === 'local') {
        const nameArg = process.argv[3];
        await runLocalOnlyTerminal(nameArg);
        return;
    }

    // Handle `hop stop [--all]` command - stop daemon (and hay-host + sessions with --all)
    if (process.argv[2] === 'stop') {
        const stopAll = process.argv.includes('--all');
        const state = isServerRunning();
        const hayHost = readHayHostStateFile();
        const hayHostAlive = !!(hayHost && isProcessAlive(hayHost.pid));

        if (!state && !(stopAll && hayHostAlive)) {
            log(`Hop is not running.`, RED);
            process.exit(1);
        }

        if (stopAll) {
            // Order matters: session deletion needs the daemon, so close sessions
            // first, then stop the daemon, then kill the hay-host process.
            if (state) {
                try {
                    const sessionsRes = await fetchSessionList(state);
                    const sessions = Array.isArray(sessionsRes?.sessions) ? sessionsRes.sessions : [];
                    for (const s of sessions) {
                        try {
                            await callLocalApi(state, '/api/sessions/delete', 'POST', { name: s.name || s.internalName });
                        } catch (e) { }
                    }
                    if (sessions.length > 0) {
                        log(`Closed ${sessions.length} session(s).`, GREEN);
                    }
                } catch (e) {
                    log(`Warning: could not close sessions via daemon: ${e.message}`, YELLOW);
                }
                try {
                    process.kill(state.pid, 'SIGTERM');
                    log(`Hop daemon stopped.`, GREEN);
                } catch (e) {
                    log(`Failed to stop hop daemon: ${e.message}`, RED);
                    process.exit(1);
                }
            }
            if (hayHostAlive) {
                const stopped = await stopExternalHayHostProcess(hayHost);
                if (!stopped) {
                    log(`Failed to stop hay-host (pid ${hayHost.pid}).`, RED);
                    process.exit(1);
                }
                clearHayHostStateFile();
                log(`Hay-host stopped. All terminal sessions ended.`, GREEN);
            } else if (hayHost) {
                clearHayHostStateFile();
            }
            process.exit(0);
        }

        // Count live sessions before killing the daemon so we can report them.
        let liveCount = 0;
        try {
            const sessionsRes = await fetchSessionList(state);
            liveCount = (sessionsRes.sessions || [])
                .filter((s) => s && s.type === 'terminal' && s.live === true).length;
        } catch (e) { }
        try {
            process.kill(state.pid, 'SIGTERM');
            log(`Hop stopped.`, GREEN);
        } catch (e) {
            log(`Failed to stop hop: ${e.message}`, RED);
            process.exit(1);
        }
        if (liveCount > 0) {
            log(`${liveCount} terminal session(s) keep running in the background (hop status).`, YELLOW);
            log(`Use ${CYAN}hop stop --all${RESET} to end them.`, RESET);
        } else if (hayHostAlive) {
            log(`The hay-host process keeps running in the background (hop status).`, YELLOW);
            log(`Use ${CYAN}hop stop --all${RESET} to end it.`, RESET);
        }
        process.exit(0);
    }

    // Handle `hop status` command - concise daemon/tunnel/session overview
    if (process.argv[2] === 'status') {
        const state = isServerRunning();
        log(`\n${BOLD}Hop Status${RESET}`, CYAN);
        if (!state) {
            log(`  Daemon:    ${RED}not running${RESET}`, RESET);
            log(`  Logs:      ${LOG_DIR}`, RESET);
            log(`\n  Start with: ${CYAN}hop${RESET}\n`, RESET);
            process.exit(0);
        }
        const fmtUptime = (ms) => {
            if (!Number.isFinite(ms) || ms < 0) return 'unknown';
            const s = Math.floor(ms / 1000), h = Math.floor(s / 3600), m = Math.floor((s % 3600) / 60);
            return h > 0 ? `${h}h ${m}m` : `${m}m`;
        };
        const uptime = state.startTime ? fmtUptime(Date.now() - state.startTime) : 'unknown';
        log(`  Daemon:    ${GREEN}running${RESET}  pid ${state.pid}  up ${uptime}  port ${state.port}`, RESET);

        let tunnel = null;
        try {
            const r = await callLocalApi(state, '/api/tunnel/status', 'GET');
            if (r && r.status === 200) tunnel = r.data;
        } catch (e) { }
        if (tunnel) {
            const conn = tunnel.connected ? `${GREEN}connected${RESET}` : `${RED}disconnected${RESET}`;
            log(`  Tunnel:    ${conn}  ${tunnel.url || state.url || ''}`, RESET);
            const failNote = tunnel.consecutiveFailures ? `, failures: ${tunnel.consecutiveFailures}` : '';
            if (tunnel.lastEvent) log(`             event: ${tunnel.lastEvent}${failNote}`, RESET);
            if (tunnel.lastError) log(`             ${YELLOW}last error: ${tunnel.lastError}${RESET}`, RESET);
        } else {
            log(`  Tunnel:    ${state.url || '(unknown)'}  ${YELLOW}(status unavailable)${RESET}`, RESET);
        }

        const hh = readHayHostStateFile();
        if (hh && hh.pid) {
            let alive = false;
            try { process.kill(hh.pid, 0); alive = true; } catch (e) { }
            log(`  Hay-host:  ${alive ? GREEN + 'running' + RESET : RED + 'dead' + RESET}  pid ${hh.pid}  port ${hh.port}`, RESET);
        } else {
            log(`  Hay-host:  ${YELLOW}none${RESET}`, RESET);
        }

        try {
            const sessionsRes = await fetchSessionList(state);
            const count = Array.isArray(sessionsRes?.sessions) ? sessionsRes.sessions.length : 0;
            const active = Array.isArray(sessionsRes?.active) ? sessionsRes.active.length : 0;
            log(`  Sessions:  ${count} (${active} active)`, RESET);
        } catch (e) {
            log(`  Sessions:  ${YELLOW}unavailable${RESET}`, RESET);
        }

        log(`  Logs:      ${LOG_DIR}  (hop logs -f)`, RESET);
        log('');
        process.exit(0);
    }

    // Handle `hop doctor` command - read-only environment/health checks
    if (process.argv[2] === 'doctor') {
        log(`\n${BOLD}Hop Doctor${RESET}\n`, CYAN);
        let problems = 0;
        const ok = (m) => log(`  ${GREEN}✓${RESET} ${m}`, RESET);
        const warn = (m) => log(`  ${YELLOW}!${RESET} ${m}`, RESET);
        const bad = (m) => { problems++; log(`  ${RED}✗${RESET} ${m}`, RESET); };

        let cfInstalled = false;
        try { execSync('command -v cloudflared', { stdio: 'ignore' }); cfInstalled = true; } catch (e) { }
        cfInstalled ? ok('cloudflared installed') : bad('cloudflared not found (brew install cloudflared)');

        const domain = getDomainConfig();
        if (domain && domain.hostname) {
            isCloudflaredLoggedIn()
                ? ok(`custom domain ${domain.hostname} (cloudflared logged in)`)
                : bad(`custom domain ${domain.hostname} but cloudflared is not logged in (cloudflared tunnel login)`);
            isPasswordEnabled()
                ? ok('password set (required for custom domain)')
                : bad('custom domain requires a password (hop password set)');
        } else {
            ok('quick tunnel mode (random URLs)');
        }

        fs.existsSync(SECRET_FILE_PATH)
            ? ok('2FA secret configured')
            : warn('2FA secret not yet created (created on first start)');

        const webOk = fs.existsSync(path.join(HAY_ROOT, 'apps/web/dist/index.html'));
        const serverOk = fs.existsSync(path.join(HAY_ROOT, 'apps/server/dist/lib.js'));
        const cliOk = fs.existsSync(path.join(HAY_ROOT, 'apps/cli/dist/index.js'));
        if (webOk && serverOk && cliOk) {
            ok('hay client/server/cli built');
        } else {
            const missing = [!webOk && 'web', !serverOk && 'server', !cliOk && 'cli'].filter(Boolean).join(', ');
            bad(`hay build missing (${missing}) — run hop once to build`);
        }

        if (fs.existsSync(STATE_FILE)) {
            try { JSON.parse(fs.readFileSync(STATE_FILE, 'utf8')); ok('state file is valid JSON'); }
            catch (e) { bad(`state file is corrupt: ${STATE_FILE}`); }
        }

        const running = isServerRunning();
        if (running) {
            const result = await probeTunnelHealth(running.url, TUNNEL_HEALTH_TIMEOUT);
            result.ok
                ? ok(`daemon running and tunnel healthy (${result.time}ms)`)
                : bad(`daemon running but tunnel unhealthy: ${result.error || ('HTTP ' + result.status)} (hop health --restart)`);
        } else {
            warn('daemon not running (start with hop)');
        }

        log('');
        if (problems === 0) {
            log(`  ${GREEN}All checks passed.${RESET}\n`, RESET);
            process.exit(0);
        }
        log(`  ${RED}${problems} problem(s) found.${RESET}\n`, RESET);
        process.exit(1);
    }

    // Handle `hop logs [-f] [hay-host]` command - view daemon/host logs
    if (process.argv[2] === 'logs') {
        const follow = process.argv.includes('-f') || process.argv.includes('--follow');
        const wantHayHost = process.argv.includes('hay-host') || process.argv.includes('hayhost');
        const logPath = path.join(LOG_DIR, wantHayHost ? 'hay-host.log' : 'hop-daemon.log');
        if (!fs.existsSync(logPath)) {
            log(`No log yet at ${logPath}`, YELLOW);
            log(`(start hop to create it)`, RESET);
            process.exit(0);
        }
        // -F follows across rotation; falls back to a one-shot dump if tail is absent.
        const tailArgs = follow ? ['-n', '100', '-F', logPath] : ['-n', '200', logPath];
        const tailProc = spawn('tail', tailArgs, { stdio: 'inherit' });
        tailProc.on('error', () => {
            try { process.stdout.write(fs.readFileSync(logPath, 'utf8')); } catch (e) { }
            process.exit(0);
        });
        tailProc.on('close', (code) => process.exit(code || 0));
        return;
    }

    // Handle `hop --help` or `hop help`
    if (process.argv[2] === '--help' || process.argv[2] === '-h' || process.argv[2] === 'help') {
        log(`\n${BOLD}Hop - Remote Terminal Access${RESET}\n`, CYAN);
        log(`${BOLD}Usage:${RESET}`, RESET);
        log(`  hop                       Start tunnel if needed, then launch local terminal`, RESET);
        log(`  hop start                 Start hop daemon and print QR codes`, RESET);
        log(`  hop attach [session]      Attach to an existing session`, RESET);
