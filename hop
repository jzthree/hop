            createdBy,
            agentPermitted,
            displayName: displayName || toDisplaySessionName(name),
            folderId: folderId || null,
            workspaceName
        });
        return;
    }
    const next = { ...existing };
    let changed = false;
    if (!next.createdBy) {
        next.createdBy = 'user';
        changed = true;
    }
    if (typeof next.agentPermitted !== 'boolean') {
        next.agentPermitted = next.createdBy === 'agent';
        changed = true;
    }
    if (!normalizeWorkspaceName(next.workspaceName)) {
        next.workspaceName = workspaceName;
        changed = true;
    } else if (opts.workspaceName && next.workspaceName !== workspaceName) {
        next.workspaceName = workspaceName;
        changed = true;
    }
    if (cwd && existing.cwd !== cwd) {
        next.cwd = cwd;
        changed = true;
    }
    if (opts.shell && existing.shell !== opts.shell) {
        next.shell = opts.shell;
        changed = true;
    }
    if (opts.env && existing.env !== opts.env) {
        next.env = opts.env;
        changed = true;
    }
    if (Number.isInteger(opts.cols) && existing.cols !== opts.cols) {
        next.cols = opts.cols;
        changed = true;
    }
    if (Number.isInteger(opts.rows) && existing.rows !== opts.rows) {
        next.rows = opts.rows;
        changed = true;
    }
    if (opts.startup && existing.startup !== opts.startup) {
        next.startup = opts.startup;
        changed = true;
    }
    if (typeof opts.autoStart === 'boolean' && existing.autoStart !== opts.autoStart) {
        next.autoStart = opts.autoStart;
        changed = true;
    }
    if (opts.createdBy && existing.createdBy !== opts.createdBy) {
        next.createdBy = opts.createdBy;
        changed = true;
    }
    if (typeof opts.agentPermitted === 'boolean' && existing.agentPermitted !== opts.agentPermitted) {
        next.agentPermitted = opts.agentPermitted;
        changed = true;
    }
    if (displayName && existing.displayName !== displayName) {
        next.displayName = displayName;
        changed = true;
    }
    if (folderId !== undefined && existing.folderId !== folderId) {
        next.folderId = folderId || null;
        changed = true;
    }
    if (changed) {
        next.updatedAt = new Date().toISOString();
        setSessionConfig(name, next);
    }
}

function setPortSessionConfig(name, port, displayName, folderId, opts = {}) {
    const existing = getSessionConfig(name);
    const workspaceName = resolveSessionWorkspaceName(existing, { workspaceName: opts.workspaceName });
    setSessionConfig(name, {
        type: 'port',
        port,
        createdAt: existing?.createdAt || new Date().toISOString(),
        updatedAt: new Date().toISOString(),
        displayName: displayName || existing?.displayName || toDisplaySessionName(name),
        folderId: folderId || existing?.folderId || null,
        workspaceName
    });
}

function createFolder(name) {
    const trimmed = String(name || '').trim();
    if (!trimmed) return null;
    for (const folder of Object.values(sessionStore.folders)) {
        if (folder.name === trimmed) return null;
    }
    let id;
    do {
        id = `f_${crypto.randomBytes(4).toString('hex')}`;
    } while (sessionStore.folders[id]);
    const now = new Date().toISOString();
    const folder = { id, name: trimmed, createdAt: now, updatedAt: now };
    sessionStore.folders[id] = folder;
    if (!sessionStore.order.folders.includes(id)) {
        sessionStore.order.folders.push(id);
    }
    if (!sessionStore.order.sessions[id]) {
        sessionStore.order.sessions[id] = [];
    }
    saveSessionStore();
    return folder;
}

function renameFolder(id, name) {
    const folder = sessionStore.folders[id];
    if (!folder) return null;
    const trimmed = String(name || '').trim();
    if (!trimmed) return null;
    for (const [otherId, other] of Object.entries(sessionStore.folders)) {
        if (otherId !== id && other.name === trimmed) return null;
    }
    folder.name = trimmed;
    folder.updatedAt = new Date().toISOString();
    sessionStore.folders[id] = folder;
    saveSessionStore();
    return folder;
}

function deleteFolder(id) {
    if (!sessionStore.folders[id]) return false;
    const sessionsInFolder = sessionStore.order.sessions[id] || [];
    delete sessionStore.folders[id];
    sessionStore.order.folders = sessionStore.order.folders.filter((folderId) => folderId !== id);
    delete sessionStore.order.sessions[id];
    for (const name of sessionsInFolder) {
        const config = getSessionConfig(name);
        if (config) {
            config.folderId = null;
            config.updatedAt = new Date().toISOString();
            sessionStore.sessions[name] = config;
        }
        ensureSessionOrder(name, null);
    }
    saveSessionStore();
    return true;
}

function moveSessionToFolder(name, folderId, index) {
    const savedConfig = getSessionConfig(name);
    const config = savedConfig || getEffectiveSessionConfig(name);
    if (!config || config.type === 'port') return false;
    const targetFolder = folderId && sessionStore.folders[folderId] ? folderId : null;
    removeSessionFromOrder(name);
    const bucket = targetFolder || 'root';
    if (!sessionStore.order.sessions[bucket]) {
        sessionStore.order.sessions[bucket] = [];
    }
    const list = sessionStore.order.sessions[bucket];
    let insertIndex = Number.isInteger(index) ? Math.max(0, Math.min(index, list.length)) : list.length;
    list.splice(insertIndex, 0, name);
    const next = {
        ...config,
        type: 'terminal',
        displayName: config.displayName || toDisplaySessionName(name),
        workspaceName: resolveSessionWorkspaceName(config),
        createdBy: config.createdBy || 'user',
        agentPermitted: typeof config.agentPermitted === 'boolean'
            ? config.agentPermitted
            : (config.createdBy === 'agent'),
        folderId: targetFolder,
        updatedAt: new Date().toISOString()
    };
    setSessionConfig(name, next);
    return true;
}

function setFolderOrder(order) {
    if (!Array.isArray(order)) return false;
    const filtered = order.filter((id) => sessionStore.folders[id]);
    const missing = Object.keys(sessionStore.folders).filter((id) => !filtered.includes(id));
    sessionStore.order.folders = filtered.concat(missing);
    saveSessionStore();
    return true;
}

function getWorkspacePath(name) {
    return path.join(WORKSPACES_DIR, `${name}.json`);
}

function workspaceExists(name) {
    const normalized = normalizeWorkspaceName(name);
    if (!normalized) return false;
    return fs.existsSync(getWorkspacePath(normalized));
}

function listWorkspaceNames() {
    try {
        return fs.readdirSync(WORKSPACES_DIR)
            .filter((file) => file.endsWith('.json'))
            .map((file) => file.replace(/\.json$/, ''))
            .sort();
    } catch (e) {
        return [];
    }
}

function createWorkspaceFile(name) {
    const normalized = normalizeWorkspaceName(name);
    if (!normalized) return null;
    if (workspaceExists(normalized)) return false;
    return writeWorkspaceStore(normalized, createEmptySessionStore(normalized));
}

function loadWorkspaceFile(name) {
    const normalized = normalizeWorkspaceName(name);
    if (!normalized) return null;
    if (!workspaceExists(normalized)) return null;
    return loadWorkspaceStore(normalized);
}

function deleteWorkspaceFile(name) {
    const normalized = normalizeWorkspaceName(name);
    if (!normalized) return null;
    if (!workspaceExists(normalized)) return false;
    fs.unlinkSync(getWorkspacePath(normalized));
    const workspaceDataDir = path.join(WORKSPACES_DIR, normalized);
    if (fs.existsSync(workspaceDataDir)) {
        fs.rmSync(workspaceDataDir, { recursive: true, force: true });
    }
    return true;
}

function normalizeSnapshotSessionConfig(name, config, workspaceName) {
    const fallback = {
        createdAt: new Date().toISOString(),
        updatedAt: new Date().toISOString()
    };
    return normalizeStoredSessionConfig(name, {
        type: 'terminal',
        cwd: config?.cwd,
        shell: config?.shell,
        env: config?.env,
        cols: config?.cols,
        rows: config?.rows,
        startup: config?.startup,
        autoStart: config?.autoStart,
        createdBy: config?.createdBy || 'user',
        agentPermitted: typeof config?.agentPermitted === 'boolean' ? config.agentPermitted : false,
        displayName: config?.displayName || toDisplaySessionName(name),
        createdAt: config?.createdAt || fallback.createdAt,
        updatedAt: fallback.updatedAt
    }, {}, workspaceName, fallback);
}

async function snapshotWorkspaceFile(name, selectedInternalNames = null) {
    const workspaceName = normalizeWorkspaceName(name);
    if (!workspaceName) return { error: 'invalid-workspace' };

    const snapshot = await listAllSessionEntriesRuntimeFirst();
    const liveEntries = snapshot.entries.filter((entry) => entry && entry.type === 'terminal' && entry.live === true);
    const liveMap = new Map(liveEntries.map((entry) => [entry.internalName, entry]));

    const requestedNames = Array.isArray(selectedInternalNames) && selectedInternalNames.length
        ? Array.from(new Set(selectedInternalNames))
        : liveEntries.map((entry) => entry.internalName);

    if (requestedNames.length === 0) {
        return { error: 'no-live-sessions' };
    }

    const selectedEntries = [];
    for (const name of requestedNames) {
        if (!liveMap.has(name)) {
            return { error: 'session-not-live', internalName: name };
        }
        selectedEntries.push(liveMap.get(name));
    }

    const store = createEmptySessionStore(workspaceName);
    for (const entry of selectedEntries) {
        const internalName = entry.internalName;
        const config = getEffectiveSessionConfig(internalName) || entry;
        const normalizedConfig = normalizeSnapshotSessionConfig(internalName, {
            ...config,
            cwd: entry.cwd || config.cwd,
            displayName: entry.displayName || config.displayName || toDisplaySessionName(internalName)
        }, workspaceName);
        if (!normalizedConfig) continue;
        store.sessions[internalName] = normalizedConfig;
        store.order.sessions.root.push(internalName);
    }

    store.updatedAt = new Date().toISOString();
    const workspace = writeWorkspaceStore(workspaceName, store);
    return { workspace, selected: selectedEntries.map((entry) => entry.displayName || entry.internalName) };
}

async function promptForWorkspaceSnapshotSelection(liveEntries) {
    const entries = Array.isArray(liveEntries) ? liveEntries : [];
    if (entries.length === 0) {
        return { selectedInternalNames: [], cancelled: false };
    }

    if (!process.stdin.isTTY || !process.stdout.isTTY) {
        return { selectedInternalNames: entries.map((entry) => entry.internalName), cancelled: false };
    }

    log(`\n${BOLD}Select live sessions to save:${RESET}`, CYAN);
    entries.forEach((entry, index) => {
        const cwd = entry.cwd ? ` ${DIM}(${entry.cwd})${RESET}` : '';
        log(`  ${index + 1}. ${entry.displayName || entry.internalName}${cwd}`, RESET);
    });
    log(``, RESET);
    log(`Enter numbers like ${CYAN}1,3${RESET}, press ${CYAN}a${RESET} for all, or just press Enter to cancel.`, RESET);

    const readline = require('readline');
    const answer = await new Promise((resolve) => {
        const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
        rl.question('Selection: ', (value) => {
            rl.close();
            resolve(String(value || '').trim());
        });
    });

    if (!answer) {
        return { selectedInternalNames: [], cancelled: true };
    }
    if (answer.toLowerCase() === 'a' || answer.toLowerCase() === 'all') {
        return { selectedInternalNames: entries.map((entry) => entry.internalName), cancelled: false };
    }

    const indexes = Array.from(new Set(
        answer.split(',')
            .map((part) => Number.parseInt(part.trim(), 10))
            .filter((value) => Number.isInteger(value) && value >= 1 && value <= entries.length)
    ));
    if (indexes.length === 0) {
        return { selectedInternalNames: [], cancelled: true };
    }
    return {
        selectedInternalNames: indexes.map((value) => entries[value - 1].internalName),
        cancelled: false
    };
}

function upsertWorkspaceSessionDefinition(workspaceName, internalName, config) {
    const normalizedWorkspaceName = normalizeWorkspaceName(workspaceName);
    if (!normalizedWorkspaceName || !internalName || !SESSION_NAME_RE.test(internalName)) {
        return null;
    }
    const store = loadWorkspaceStore(normalizedWorkspaceName) || createEmptySessionStore(normalizedWorkspaceName);
    const normalizedConfig = normalizeStoredSessionConfig(internalName, config, store.folders || {}, normalizedWorkspaceName, {
        createdAt: new Date().toISOString(),
        updatedAt: new Date().toISOString()
    });
    if (!normalizedConfig) return null;
    store.sessions[internalName] = normalizedConfig;
    if (!store.order?.sessions?.root) {
        store.order = store.order && typeof store.order === 'object' ? store.order : { folders: [], sessions: {} };
        store.order.sessions = store.order.sessions && typeof store.order.sessions === 'object' ? store.order.sessions : {};
        store.order.sessions.root = [];
    }
    if (!store.order.sessions.root.includes(internalName)) {
        store.order.sessions.root.push(internalName);
    }
    return writeWorkspaceStore(normalizedWorkspaceName, store);
}

function listWorkspaceSessionDefinitions() {
    const entries = [];
    for (const workspaceName of listWorkspaceNames()) {
        const store = loadWorkspaceStore(workspaceName);
        if (!store || !store.sessions || typeof store.sessions !== 'object') continue;
        for (const [internalName, config] of Object.entries(store.sessions)) {
            if (!config || typeof config !== 'object') continue;
            entries.push({
                internalName,
                displayName: config.displayName || toDisplaySessionName(internalName),
                type: config.type === 'port' ? 'port' : 'terminal',
                port: config.port,
                cwd: config.cwd,
                shell: config.shell,
                env: config.env,
                cols: config.cols,
                rows: config.rows,
                startup: config.startup,
                autoStart: config.autoStart,
                createdAt: config.createdAt,
                createdBy: config.createdBy || 'user',
                agentPermitted: config.agentPermitted === true,
                folderId: config.folderId || null,
                workspaceName
            });
        }
    }
    return entries;
}

function getWorkspaceDisplayEntries(workspace) {
    const store = normalizeSessionStore(workspace, { workspaceName: workspace?.name });
    const ordered = [];
    const seen = new Set();
    const buckets = ['root', ...(store.order?.folders || [])];
    for (const bucket of buckets) {
        const names = Array.isArray(store.order?.sessions?.[bucket]) ? store.order.sessions[bucket] : [];
        for (const internalName of names) {
            if (seen.has(internalName)) continue;
            const config = store.sessions?.[internalName];
            if (!config) continue;
            seen.add(internalName);
            ordered.push({ internalName, ...config });
        }
    }
    for (const [internalName, config] of Object.entries(store.sessions || {})) {
        if (seen.has(internalName) || !config) continue;
        ordered.push({ internalName, ...config });
    }
    return ordered;
}

function printWorkspaceDetails(workspace) {
    const store = normalizeSessionStore(workspace, { workspaceName: workspace?.name });
    const entries = getWorkspaceDisplayEntries(store);
    const folderCount = Object.keys(store.folders || {}).length;
    log(`\n${BOLD}Workspace:${RESET} ${store.name}`, CYAN);
    log(`  Sessions: ${entries.length}`, RESET);
    log(`  Folders:  ${folderCount}`, RESET);
    if (store.updatedAt) {
        log(`  Updated:  ${store.updatedAt}`, RESET);
    }
    if (entries.length === 0) {
        log(`  ${DIM}No saved sessions.${RESET}`, RESET);
        return;
    }
    log('', RESET);
    for (const entry of entries) {
        const folderName = entry.folderId && store.folders?.[entry.folderId]?.name
            ? ` · folder ${store.folders[entry.folderId].name}`
            : '';
        if (entry.type === 'port') {
            log(`  ${entry.displayName || entry.internalName}  ${YELLOW}[PORT ${entry.port}]${RESET}${folderName}`, RESET);
            continue;
        }
        const cwdInfo = entry.cwd ? ` · ${entry.cwd}` : '';
        log(`  ${entry.displayName || entry.internalName}  ${GREEN}[TERMINAL]${RESET}${folderName}${cwdInfo}`, RESET);
    }
}

async function applyWorkspace(workspace, opts = {}) {
    const workspaceName = normalizeWorkspaceName(opts.workspaceName) || normalizeWorkspaceName(workspace?.name) || DEFAULT_WORKSPACE_NAME;
    const startSessions = opts.startSessions !== false;
    const store = normalizeSessionStore(workspace, { workspaceName });
    const created = Object.values(store.sessions)
        .map((config) => config?.displayName)
        .filter(Boolean);
    const skipped = [];
    const started = [];

    if (!startSessions) {
        return { created, skipped, started };
    }

    for (const [internalName, config] of Object.entries(store.sessions)) {
        if (!config || config.type === 'port') continue;
        try {
            await ensureExternalRuntimeSession(internalName, config.cwd, config.displayName || toDisplaySessionName(internalName), {
                shell: config.shell,
                env: config.env,
                cols: config.cols,
                rows: config.rows,
                startup: config.startup,
                autoStart: config.autoStart,
                createdBy: config.createdBy,
                agentPermitted: config.agentPermitted,
                workspaceName,
                folderId: config.folderId,
                saveDefinition: false
            });
            started.push(config.displayName || toDisplaySessionName(internalName));
        } catch (e) {
            skipped.push({ name: config.displayName || toDisplaySessionName(internalName), reason: 'start-failed' });
        }
    }

    return { created, skipped, started };
}

function resolveSessionWorkspaceName(config, opts = {}) {
    const explicit = normalizeWorkspaceName(opts.workspaceName);
    if (explicit) return explicit;
    const fromConfig = normalizeWorkspaceName(config?.workspaceName);
    if (fromConfig) return fromConfig;
    return null;
}

function ensurePrivateWritableFile(filePath) {
    if (!fs.existsSync(filePath)) {
        writePrivateFile(filePath, '');
        return;
    }
    ensurePrivateFile(filePath);
}

const MAX_LOG_BYTES = 5 * 1024 * 1024; // rotate a log once it passes 5 MB

// Open a log file for appending, first rotating it to <path>.1 if it has grown
// past maxBytes (single-generation rotation is enough for our purposes). Returns
// an fd; the caller is responsible for closing its copy after spawn.
function rotateAndOpenLogFd(logPath, maxBytes = MAX_LOG_BYTES) {
    ensurePrivateWritableFile(logPath);
    try {
        if (fs.statSync(logPath).size > maxBytes) {
            try { fs.renameSync(logPath, `${logPath}.1`); } catch (e) { }
        }
    } catch (e) { }
    return fs.openSync(logPath, 'a');
}

function ensureWorkspaceDataDirs(workspaceName) {
    const normalized = normalizeWorkspaceName(workspaceName);
    const workspaceDir = normalized
        ? path.join(WORKSPACES_DIR, normalized)
        : RUNTIME_DATA_DIR;
    const historyDir = path.join(workspaceDir, HISTORY_DIR_NAME);
    const logsDir = path.join(workspaceDir, WORKSPACE_LOGS_DIR_NAME);
    ensurePrivateDir(workspaceDir);
    ensurePrivateDir(historyDir);
    ensurePrivateDir(logsDir);
    return {
        workspaceName: normalized,
        workspaceDir,
        historyDir,
        logsDir
    };
}

function getSessionHistoryFileInfo(sessionName, workspaceName) {
    const dirs = ensureWorkspaceDataDirs(workspaceName);
    const filePath = path.join(dirs.historyDir, `${sessionName}.history`);
    ensurePrivateWritableFile(filePath);
    return { workspaceName: dirs.workspaceName, filePath };
}

function normalizeSessionEnvOverrides(rawEnv) {
    if (!rawEnv || typeof rawEnv !== 'object' || Array.isArray(rawEnv)) return {};
    const normalized = {};
    for (const [key, value] of Object.entries(rawEnv)) {
        if (!key || typeof key !== 'string') continue;
        if (typeof value === 'string' || typeof value === 'number' || typeof value === 'boolean') {
            normalized[key] = String(value);
        }
    }
    return normalized;
}

function shouldIsolateSessionHistory(config) {
    if (config?.createdBy === 'agent') {
        return ENABLE_AGENT_HISTORY_ISOLATION;
    }
    return ENABLE_USER_HISTORY_ISOLATION;
}

function buildSessionPtyEnv(sessionName, config, workspaceName) {
    const baseEnv = normalizeSessionEnvOverrides(config?.env);
    const isolated = shouldIsolateSessionHistory(config);
    if (!isolated) {
        return {
            workspaceName,
            historyFile: null,
            historyIsolated: false,
            env: {
                ...baseEnv
            }
        };
    }
    const history = getSessionHistoryFileInfo(sessionName, workspaceName);
    const historySize = String(SESSION_HISTORY_SIZE);
    return {
        workspaceName: history.workspaceName,
        historyFile: history.filePath,
        historyIsolated: true,
        env: {
            ...baseEnv,
            HISTFILE: history.filePath,
            HISTSIZE: baseEnv.HISTSIZE || historySize,
            SAVEHIST: baseEnv.SAVEHIST || historySize,
            HISTFILESIZE: baseEnv.HISTFILESIZE || String(SESSION_HISTORY_SIZE * 2)
        }
    };
}

function escapeSingleQuotedShell(value) {
    return String(value ?? '').replace(/'/g, `'\"'\"'`);
}

function shellBasename(shellPath) {
    if (!shellPath || typeof shellPath !== 'string') return '';
    return path.basename(shellPath).toLowerCase();
}

function isPosixHistoryShell(shellPath) {
    const base = shellBasename(shellPath);
    return base === 'zsh' || base === 'bash' || base === 'sh' || base === 'ksh' || base === 'dash';
}

function buildPostStartupHistoryIsolationCommand(env) {
    if (!env || typeof env !== 'object') return null;
    const keys = ['HISTFILE', 'HISTSIZE', 'SAVEHIST', 'HISTFILESIZE'];
    const exports = [];
    for (const key of keys) {
        const value = env[key];
        if (!value) continue;
        exports.push(`export ${key}='${escapeSingleQuotedShell(value)}'`);
    }
    if (exports.length === 0) return null;
    return `${exports.join('; ')}; history -a 2>/dev/null || true\n`;
}

function applyPostStartupHistoryIsolation(room, config, ptyRuntime) {
    const isAgentSession = config?.createdBy === 'agent';
    const allowPostStart = ENABLE_POST_START_HISTORY_INIT || (isAgentSession && ENABLE_AGENT_POST_START_HISTORY_INIT);
    if (!allowPostStart) return false;
    if (!ptyRuntime?.historyIsolated) return false;
    const roomSupportsSystemInput = room && typeof room.sendSystemInput === 'function';
    if (!roomSupportsSystemInput) return false;
    const shellPath = config?.shell || process.env.SHELL || '';
    if (!isPosixHistoryShell(shellPath)) return false;
    const command = buildPostStartupHistoryIsolationCommand(ptyRuntime?.env);
    if (!command) return false;
    try {
        room.sendSystemInput(command, 'hop-history-init');
        return true;
    } catch (e) {
        log('[History] Post-start isolation injection skipped due to terminal startup race', YELLOW);
        return false;
    }
}

function getSessionAuditSink(sessionName, workspaceName) {
    const existing = sessionAuditSinks.get(sessionName);
    if (existing && !existing.stream.destroyed) {
        return existing;
    }
    const dirs = ensureWorkspaceDataDirs(workspaceName);
    const sessionDir = path.join(dirs.logsDir, sessionName);
    ensurePrivateDir(sessionDir);
    const filePath = path.join(sessionDir, 'audit.ndjson');
    ensurePrivateWritableFile(filePath);
    const stream = fs.createWriteStream(filePath, { flags: 'a', mode: PRIVATE_FILE_MODE });
    const sink = {
        stream,
        filePath,
        workspaceName: dirs.workspaceName,
        failed: false
    };
    stream.on('error', () => {
        if (sink.failed) return;
        sink.failed = true;
        log(`[Audit] Failed to write session audit log for ${sessionName}`, YELLOW);
    });
    sessionAuditSinks.set(sessionName, sink);
    return sink;
}

function closeSessionAuditSink(sessionName) {
    const sink = sessionAuditSinks.get(sessionName);
    if (!sink) return;
    sessionAuditSinks.delete(sessionName);
    clearSessionAuditState(sessionName);
    try {
        sink.stream.end();
    } catch (e) { }
}

function closeAllSessionAuditSinks() {
    sessionAuditStates.clear();
    for (const sessionName of Array.from(sessionAuditSinks.keys())) {
        closeSessionAuditSink(sessionName);
    }
}

function truncateAuditText(value) {
    const raw = typeof value === 'string' ? value : String(value ?? '');
    const totalBytes = Buffer.byteLength(raw, 'utf8');
    if (totalBytes <= SESSION_AUDIT_INLINE_MAX_BYTES) {
        return {
            data: raw,
            bytes: totalBytes,
            truncated: false
        };
    }
    const buffer = Buffer.from(raw, 'utf8');
    const headBytes = Math.max(1, Math.floor(SESSION_AUDIT_INLINE_MAX_BYTES * 0.7));
    const tailBytes = Math.max(0, SESSION_AUDIT_INLINE_MAX_BYTES - headBytes);
    return {
        dataHead: buffer.subarray(0, headBytes).toString('utf8'),
        dataTail: tailBytes > 0 ? buffer.subarray(buffer.length - tailBytes).toString('utf8') : '',
        bytes: totalBytes,
        omittedBytes: Math.max(0, totalBytes - SESSION_AUDIT_INLINE_MAX_BYTES),
        truncated: true
    };
}

const ANSI_OSC_SEQUENCE_RE = /\x1b\][^\x07]*(?:\x07|\x1b\\)/g;
const ANSI_CSI_SEQUENCE_RE = /\x1b\[[0-?]*[ -/]*[@-~]/g;
const ANSI_ST_SEQUENCE_RE = /\x1b[P^_].*?\x1b\\/gs;
const AGENT_COMMAND_WRAPPERS = new Set(['npx', 'pnpm', 'pnpx', 'yarn', 'bunx', 'uvx']);
const AGENT_TRAJECTORY_HINT_CANDIDATES = {
    claude: [
        path.join(os.homedir(), '.claude', 'projects'),
        path.join(os.homedir(), '.claude', 'tasks'),
        path.join(os.homedir(), '.claude', 'history.jsonl')
    ],
    codex: [
        path.join(os.homedir(), '.codex', 'sessions'),
        path.join(os.homedir(), '.codex', 'history.jsonl')
    ],
    gemini: [
        path.join(os.homedir(), '.gemini'),
        path.join(os.homedir(), '.gemini', 'antigravity')
    ],
    opencode: [
        path.join(os.homedir(), '.opencode'),
        path.join(os.homedir(), '.config', 'opencode')
    ]
};

function stripAnsiForAudit(text) {
    return String(text || '')
        .replace(ANSI_OSC_SEQUENCE_RE, '')
        .replace(ANSI_ST_SEQUENCE_RE, '')
        .replace(ANSI_CSI_SEQUENCE_RE, '')
        .replace(/\x1b[@-_]/g, '');
}

function normalizeTuiTextForAudit(text) {
    if (!text) return '';
    return stripAnsiForAudit(text)
        .replace(/\r/g, '\n')
        .replace(/[\x00-\x08\x0b-\x1f\x7f]/g, '')
        .replace(/[ \t]+$/gm, '')
        .replace(/\n{5,}/g, '\n\n\n\n');
}

function appendTailText(current, next, maxChars) {
    const merged = `${current || ''}${next || ''}`;
    if (merged.length <= maxChars) return merged;
    return merged.slice(merged.length - maxChars);
}

function buildTuiSnapshotFromTail(tail) {
    if (!tail) return '';
    const lines = String(tail)
        .split('\n')
        .map(line => line.replace(/[ \t]+$/g, ''));
    return lines.slice(-SESSION_TUI_KEYFRAME_MAX_LINES).join('\n').trim();
}

function hashAuditText(text) {
    return crypto.createHash('sha1').update(String(text || ''), 'utf8').digest('hex');
}

function detectAgentKindFromCommandToken(token) {
    if (!token) return null;
    const raw = String(token).trim().toLowerCase();
    if (!raw) return null;
    const base = path.basename(raw);
    if (base.startsWith('claude') || raw.includes('claude')) return 'claude';
    if (base.startsWith('codex') || raw.includes('openai/codex')) return 'codex';
    if (base.startsWith('gemini') || raw.includes('/gemini')) return 'gemini';
    if (base.startsWith('opencode') || raw.includes('/opencode')) return 'opencode';
    return null;
}

function extractCommandMetadata(line) {
    if (typeof line !== 'string') return null;
    const trimmed = line.trim();
    if (!trimmed || trimmed.startsWith('#')) return null;
    const tokens = trimmed.split(/\s+/).filter(Boolean);
    if (tokens.length === 0) return null;

    let idx = 0;
    while (idx < tokens.length && /^[A-Za-z_][A-Za-z0-9_]*=.*/.test(tokens[idx])) {
        idx += 1;
    }
    if (idx >= tokens.length) return null;

    let wrapper = null;
    let commandToken = tokens[idx];
    if (AGENT_COMMAND_WRAPPERS.has(commandToken) && idx + 1 < tokens.length) {
        wrapper = commandToken;
        commandToken = tokens[idx + 1];
    }

    const agentKind = detectAgentKindFromCommandToken(commandToken);
    return {
        line: trimmed,
        commandToken,
        wrapper,
        agentKind
    };
}

function getAgentTrajectoryHints(agentKind) {
    if (!agentKind) return [];
    const candidates = AGENT_TRAJECTORY_HINT_CANDIDATES[agentKind];
    if (!Array.isArray(candidates)) return [];
    return candidates.filter((candidate) => {
        try {
            return fs.existsSync(candidate);
        } catch (e) {
            return false;
        }
    });
}

function createSessionAuditState(sessionName, workspaceName, displayName) {
    return {
        sessionName,
        workspaceName,
        displayName,
        mode: 'stream',
        alternateScreen: false,
        cursorHidden: false,
        tailText: '',
        lastKeyframeHash: null,
        lastKeyframeTs: 0,
        suppressedOutputEvents: 0,
        suppressedOutputBytes: 0,
        inputBufferByActor: new Map()
    };
}

function getSessionAuditState(sessionName, workspaceName, displayName) {
    let state = sessionAuditStates.get(sessionName);
    if (!state) {
        state = createSessionAuditState(sessionName, workspaceName, displayName);
        sessionAuditStates.set(sessionName, state);
    }
    if (workspaceName) state.workspaceName = workspaceName;
    if (displayName) state.displayName = displayName;
    return state;
}

function clearSessionAuditState(sessionName) {
    if (!sessionName) return;
    sessionAuditStates.delete(sessionName);
}

function flushSessionTuiKeyframe(state, timestamp, force = false) {
    if (!state) return false;
    const nowTs = Number.isFinite(timestamp) ? Number(timestamp) : Date.now();
    if (!force && (nowTs - state.lastKeyframeTs) < SESSION_TUI_KEYFRAME_INTERVAL_MS) {
        return false;
    }
    const snapshot = buildTuiSnapshotFromTail(state.tailText);
    if (!snapshot) return false;
    const nextHash = hashAuditText(snapshot);
    if (nextHash === state.lastKeyframeHash) {
        return false;
    }
    state.lastKeyframeHash = nextHash;
    state.lastKeyframeTs = nowTs;
    appendSessionAuditEvent(state.sessionName, state.workspaceName, 'tui_keyframe', {
        displayName: state.displayName,
        workspaceName: state.workspaceName,
        mode: state.mode,
        alternateScreen: state.alternateScreen,
        cursorHidden: state.cursorHidden,
        hash: nextHash,
        suppressedOutputEvents: state.suppressedOutputEvents,
        suppressedOutputBytes: state.suppressedOutputBytes,
        ...truncateAuditText(snapshot)
    });
    state.suppressedOutputEvents = 0;
    state.suppressedOutputBytes = 0;
    return true;
}

function setSessionAuditMode(state, nextMode, reason, timestamp) {
    if (!state || !nextMode || state.mode === nextMode) return;
    const previous = state.mode;
    if (previous === 'tui_keyframe') {
        flushSessionTuiKeyframe(state, timestamp, true);
    }
    state.mode = nextMode;
    appendSessionAuditEvent(state.sessionName, state.workspaceName, 'audit_mode', {
        displayName: state.displayName,
        workspaceName: state.workspaceName,
        from: previous,
        to: nextMode,
        reason: reason || null,
        alternateScreen: state.alternateScreen,
        cursorHidden: state.cursorHidden
    });
}

function handleSessionAuditOutput(state, outputEvent) {
    if (!state) return;
    const data = typeof outputEvent?.data === 'string' ? outputEvent.data : String(outputEvent?.data ?? '');
    const eventTs = Number.isFinite(outputEvent?.timestamp) ? Number(outputEvent.timestamp) : Date.now();
    if (state.mode !== 'tui_keyframe') {
        appendSessionAuditEvent(state.sessionName, state.workspaceName, 'output', {
            displayName: state.displayName,
            workspaceName: state.workspaceName,
            ...truncateAuditText(data)
        });
        return;
    }

    state.suppressedOutputEvents += 1;
    state.suppressedOutputBytes += Buffer.byteLength(data, 'utf8');
    const normalized = normalizeTuiTextForAudit(data);
    if (normalized) {
        state.tailText = appendTailText(state.tailText, normalized, SESSION_TUI_KEYFRAME_TAIL_CHARS);
    }
    flushSessionTuiKeyframe(state, eventTs, false);
}

function detectAndRecordCommandLaunch(state, inputEvent, actor, clientId) {
    if (!state || !inputEvent) return;
    if (actor === 'system') return;
    const raw = typeof inputEvent.data === 'string' ? inputEvent.data : String(inputEvent.data ?? '');
    if (!raw) return;
    const key = String(clientId || actor || 'unknown');
    let buffer = state.inputBufferByActor.get(key) || '';

    for (const ch of raw) {
        if (ch === '\r' || ch === '\n') {
            const commandInfo = extractCommandMetadata(buffer);
            if (commandInfo) {
                const trajectoryHints = commandInfo.agentKind ? getAgentTrajectoryHints(commandInfo.agentKind) : [];
                appendSessionAuditEvent(state.sessionName, state.workspaceName, 'command_launch', {
                    displayName: state.displayName,
                    workspaceName: state.workspaceName,
                    actor,
                    clientId: clientId || null,
                    line: commandInfo.line,
                    commandToken: commandInfo.commandToken,
                    wrapper: commandInfo.wrapper,
                    agentKind: commandInfo.agentKind,
                    trajectoryHints
                });
            }
            buffer = '';
            continue;
        }
        if (ch === '\u0003' || ch === '\u0004') {
            buffer = '';
            continue;
        }
        if (ch === '\u0008' || ch === '\u007f') {
            buffer = buffer.slice(0, -1);
            continue;
        }
        if (ch >= ' ' && ch !== '\u007f') {
            buffer += ch;
            if (buffer.length > 2048) {
                buffer = buffer.slice(buffer.length - 2048);
            }
        }
    }
    if (buffer) {
        state.inputBufferByActor.set(key, buffer);
    } else {
        state.inputBufferByActor.delete(key);
    }
}

function appendSessionAuditEvent(sessionName, workspaceName, type, payload = {}) {
    const sink = getSessionAuditSink(sessionName, workspaceName);
    if (!sink || sink.stream.destroyed) return;
    const record = {
        ts: new Date().toISOString(),
        session: sessionName,
        type,
        ...payload
    };
    try {
        sink.stream.write(JSON.stringify(record) + '\n');
    } catch (e) { }
}

function registerSessionClientActor(sessionName, clientId, actor) {
    if (!sessionName || !clientId) return;
    let actors = sessionClientActors.get(sessionName);
    if (!actors) {
        actors = new Map();
        sessionClientActors.set(sessionName, actors);
    }
    actors.set(clientId, actor || 'unknown');
}

function unregisterSessionClientActor(sessionName, clientId) {
    if (!sessionName || !clientId) return;
    const actors = sessionClientActors.get(sessionName);
    if (!actors) return;
    actors.delete(clientId);
    if (actors.size === 0) {
        sessionClientActors.delete(sessionName);
    }
}

function resolveSessionClientActor(sessionName, clientId) {
    if (!sessionName || !clientId) return null;
    const actors = sessionClientActors.get(sessionName);
    if (!actors) return null;
    return actors.get(clientId) || null;
}

function clearSessionClientActors(sessionName) {
    if (!sessionName) return;
    sessionClientActors.delete(sessionName);
}

// Load domain config if exists
function getDomainConfig() {
    if (fs.existsSync(DOMAIN_CONFIG_FILE)) {
        try {
            return JSON.parse(fs.readFileSync(DOMAIN_CONFIG_FILE, 'utf8'));
        } catch (e) {
            return null;
        }
    }
    return null;
}

function saveDomainConfig(config) {
    writePrivateFile(DOMAIN_CONFIG_FILE, JSON.stringify(config, null, 2));
}

function getCloudflaredCredentialsFile(tunnel) {
    if (!tunnel || !tunnel.id) return null;
    return path.join(os.homedir(), '.cloudflared', `${tunnel.id}.json`);
}

function getTunnelTokenFile(tunnelName) {
    const safeName = String(tunnelName || 'hop').replace(/[^a-zA-Z0-9_-]/g, '-');
    return path.join(HOME_DIR, `.tunnel-token-${safeName}`);
}

function ensureTunnelRunCredential(tunnelName, tunnel) {
    const credentialsFile = getCloudflaredCredentialsFile(tunnel);
    if (credentialsFile && fs.existsSync(credentialsFile)) {
        return { credentialsFile };
    }

    const tokenFile = getTunnelTokenFile(tunnelName);
    if (fs.existsSync(tokenFile)) {
        ensurePrivateFile(tokenFile);
        return { tunnelTokenFile: tokenFile };
    }

    const token = execFileSync('cloudflared', ['tunnel', 'token', tunnelName], {
        encoding: 'utf8',
        stdio: ['pipe', 'pipe', 'pipe']
    }).trim();
    if (!token) {
        throw new Error('cloudflared returned an empty tunnel token');
    }
    writePrivateFile(tokenFile, `${token}\n`);
    return { tunnelTokenFile: tokenFile };
}

// --- Global hop config ---
function getHopConfig() {
    if (fs.existsSync(HOP_CONFIG_FILE)) {
        try {
            return JSON.parse(fs.readFileSync(HOP_CONFIG_FILE, 'utf8'));
        } catch (e) {
            return {};
        }
    }
    return {};
}

function saveHopConfig(config) {
    writePrivateFile(HOP_CONFIG_FILE, JSON.stringify(config, null, 2));
}

function getNamingTheme() {
    const config = getHopConfig();
    if (config.naming_theme && isValidTheme(config.naming_theme)) {
        return config.naming_theme;
    }
    return null;
}

function setNamingTheme(theme) {
    const config = getHopConfig();
    config.naming_theme = theme;
    saveHopConfig(config);
}

async function promptNamingTheme() {
    if (!process.stdin.isTTY || !process.stdout.isTTY) {
        return DEFAULT_THEME;
    }
    const choices = getThemeChoices();
    console.log(`\n${BOLD}Choose a session naming theme:${RESET}\n`);
    choices.forEach((c, i) => {
        console.log(`  ${CYAN}${i + 1}${RESET}) ${c.label.padEnd(10)} ${DIM}(${c.example})${RESET}`);
    });
    console.log('');

    const readline = require('readline');
    const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
    const ask = (q) => new Promise((resolve) => rl.question(q, resolve));
    let selected = null;
    for (let attempt = 0; attempt < 2 && !selected; attempt++) {
        const answer = await ask(`  Select [1-${choices.length}]: `);
        const num = parseInt(String(answer || '').trim(), 10);
        if (num >= 1 && num <= choices.length) {
            selected = choices[num - 1].id;
        } else if (attempt === 0) {
            console.log(`  Invalid choice. Enter a number from 1 to ${choices.length} (${choices.map((c) => c.id).join(', ')}).`);
        }
    }
    rl.close();
    if (selected) {
        setNamingTheme(selected);
        console.log(`\n  ${GREEN}Theme set to "${selected}".${RESET}\n`);
        return selected;
    }
    setNamingTheme(DEFAULT_THEME);
    console.log(`\n  Invalid choice. Using default theme "${DEFAULT_THEME}". Change it later with ${CYAN}hop config theme <name>${RESET}.\n`);
    return DEFAULT_THEME;
}

// Shared y/N confirmation for destructive commands. Callers must handle non-TTY themselves.
function promptYesNo(question) {
    const readline = require('readline');
    return new Promise((resolve) => {
        const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
        rl.question(question, (answer) => {
            rl.close();
            resolve(/^y(es)?$/i.test(String(answer || '').trim()));
        });
    });
}

async function ensureNamingTheme() {
    let theme = getNamingTheme();
    if (!theme) {
        theme = await promptNamingTheme();
    }
    return theme;
}

// Check if cloudflared is logged in
function isCloudflaredLoggedIn() {
    const certPath = path.join(os.homedir(), '.cloudflared', 'cert.pem');
    return fs.existsSync(certPath);
}

// Get existing tunnels
function listCloudflaredTunnels() {
    try {
        const output = execSync('cloudflared tunnel list -o json', { encoding: 'utf8', stdio: ['pipe', 'pipe', 'pipe'] });
        return JSON.parse(output);
    } catch (e) {
        return [];
    }
}

// Setup custom domain
async function setupDomain(hostname) {
    const tunnelName = 'hop';
    let tunnelCreatedByUs = false;  // Track if we created it (for cleanup)

    log(`\n${BOLD}Setting up custom domain: ${hostname}${RESET}\n`, CYAN);

    // Step 1: Check cloudflared login
    log(`[1/4] Checking Cloudflare authentication...`, BOLD);
    if (!isCloudflaredLoggedIn()) {
        log(`  Opening browser for Cloudflare login...`, YELLOW);
        log(`  Please authorize in your browser.\n`, RESET);
        try {
            execSync('cloudflared tunnel login', { stdio: 'inherit' });
        } catch (e) {
            log(`Failed to authenticate with Cloudflare.`, RED);
            process.exit(1);
        }
    }
    log(`  Authenticated with Cloudflare.`, GREEN);

    // Step 2: Check if tunnel exists, create if not
    log(`[2/4] Setting up tunnel...`, BOLD);
    const tunnels = listCloudflaredTunnels();
    let tunnel = tunnels.find(t => t.name === tunnelName);

    if (tunnel) {
        log(`  Using existing tunnel: ${tunnelName} (${tunnel.id})`, GREEN);
    } else {
        log(`  Creating new tunnel: ${tunnelName}...`, YELLOW);
        try {
            execSync(`cloudflared tunnel create ${tunnelName}`, { encoding: 'utf8' });
            log(`  Tunnel created.`, GREEN);
            tunnelCreatedByUs = true;
            // Re-fetch to get the ID
            const newTunnels = listCloudflaredTunnels();
            tunnel = newTunnels.find(t => t.name === tunnelName);
        } catch (e) {
            log(`Failed to create tunnel: ${e.message}`, RED);
            process.exit(1);
        }
    }

    // Step 3: Setup DNS route - this validates domain ownership
    log(`[3/4] Configuring DNS...`, BOLD);
    let dnsSuccess = false;
    try {
        // Capture both stdout and stderr to check for errors
        const result = execSync(`cloudflared tunnel route dns ${tunnelName} ${hostname} 2>&1`, {
            encoding: 'utf8'
        });

        // Check for failure FIRST (before checking for "already exists" which can appear in error messages)
        if (result.includes('Failed to add route') || result.includes('Failed to create record')) {
            // This is an error, even if it contains "already exists"
            log(`\n${RED}ERROR: DNS configuration failed.${RESET}`, RED);
            log(`Details: ${result.trim()}`, YELLOW);
            dnsSuccess = false;
        } else if (result.includes('Added CNAME')) {
            dnsSuccess = true;
            log(`  DNS configured: ${hostname} → tunnel`, GREEN);
        } else if (result.includes('already exists') && !result.includes('Failed')) {
            // Only treat as success if it's not part of a failure message
            dnsSuccess = true;
            log(`  DNS already configured.`, GREEN);
        } else if (result.includes('already configured to route to your tunnel') && !result.includes('Failed')) {
            dnsSuccess = true;
            log(`  DNS already configured.`, GREEN);
        } else {
            // Unexpected output - treat as potential failure
            log(`  Unexpected response: ${result.trim()}`, YELLOW);
            dnsSuccess = false;
        }
    } catch (e) {
        const errorOutput = e.stdout || e.stderr || e.message || '';

        // Check for failure indicators FIRST
        if (errorOutput.includes('Failed to add route') || errorOutput.includes('Failed to create record')) {
            log(`\n${RED}ERROR: DNS configuration failed.${RESET}`, RED);
            log(`Details: ${errorOutput.trim()}`, YELLOW);
            dnsSuccess = false;
        } else if (errorOutput.includes('zone') || errorOutput.includes('not found') || errorOutput.includes('does not exist')) {
            log(`\n${RED}ERROR: Domain "${hostname}" is not in your Cloudflare account.${RESET}`, RED);
            log(`\nMake sure:`, YELLOW);
            log(`  1. You own this domain`, RESET);
            log(`  2. The domain is added to your Cloudflare account`, RESET);
            log(`  3. You're using the correct Cloudflare account`, RESET);
            dnsSuccess = false;
        } else if (errorOutput.includes('authentication') || errorOutput.includes('unauthorized')) {
            log(`\n${RED}ERROR: Authentication failed.${RESET}`, RED);
            log(`Try: cloudflared tunnel login`, YELLOW);
            dnsSuccess = false;
        } else if (errorOutput.includes('already exists') && !errorOutput.includes('Failed')) {
            // Only treat as success if it's a clean "already exists" not part of error
            dnsSuccess = true;
            log(`  DNS already configured.`, GREEN);
        } else if (errorOutput.includes('already configured to route to your tunnel') && !errorOutput.includes('Failed')) {
            dnsSuccess = true;
            log(`  DNS already configured.`, GREEN);
        } else {
            log(`\n${RED}ERROR: DNS configuration failed.${RESET}`, RED);
            log(`Details: ${errorOutput.trim()}`, YELLOW);
            dnsSuccess = false;
        }
    }

    // If DNS failed, clean up the tunnel we created
    if (!dnsSuccess) {
        if (tunnelCreatedByUs) {
            log(`\nCleaning up...`, YELLOW);
            try {
                execSync(`cloudflared tunnel delete ${tunnelName}`, { stdio: 'ignore' });
                log(`  Deleted tunnel: ${tunnelName}`, RESET);
            } catch (e) {
                log(`  Note: You may need to manually delete tunnel: cloudflared tunnel delete ${tunnelName}`, YELLOW);
            }
        }
        log(`\nSetup failed. Please fix the issue and try again.`, RED);
        process.exit(1);
    }

    // Step 4: Save config
    log(`[4/4] Saving configuration...`, BOLD);
    let runCredential = {};
    try {
        runCredential = ensureTunnelRunCredential(tunnelName, tunnel);
    } catch (e) {
        log(`Failed to prepare tunnel credential: ${e.message}`, RED);
        process.exit(1);
    }
    saveDomainConfig({
        tunnelName,
        tunnelId: tunnel ? tunnel.id : null,
        hostname,
        credentialsFile: runCredential.credentialsFile || null,
        tunnelTokenFile: runCredential.tunnelTokenFile || null,
        createdAt: new Date().toISOString()
    });
    log(`  Configuration saved.`, GREEN);

    log(`\n${BOLD}${GREEN}✓ Custom domain setup complete!${RESET}`, GREEN);
    log(`\nYour hop URL: https://${hostname}`, BOLD);

    // Require password for fixed domains
    if (!isPasswordEnabled()) {
        log(`\n${YELLOW}⚠ Password required for fixed domains.${RESET}`, YELLOW);
        log(`A fixed URL is publicly known - password adds essential protection.\n`, RESET);

        const readline = require('readline');
        const stream = require('stream');

        const askPassword = (prompt) => new Promise((resolve) => {
            const rl = readline.createInterface({
                input: process.stdin,
                output: new stream.Writable({
                    write: (chunk, encoding, callback) => callback()
                }),
                terminal: true
            });

            process.stdout.write(prompt);
            rl.question('', (answer) => {
                rl.close();
                process.stdout.write('\n');
                resolve(answer);
            });
        });

        const password = await askPassword('Set a password: ');
        if (password.length < 4) {
            log(`Password too short. Run ${CYAN}hop password set${RESET} to set later.`, RED);
        } else {
            const confirm = await askPassword('Confirm password: ');
            if (password !== confirm) {
                log(`Passwords don't match. Run ${CYAN}hop password set${RESET} to set later.`, RED);
            } else {
                setPassword(password);
                log(`${GREEN}✓ Password set.${RESET}`, GREEN);
            }
        }
    }

    log(`\nRun ${CYAN}hop${RESET} to start with your custom domain.`, RESET);
}

// --- Multi-user management ---
const USERS_FILE = path.join(HOME_DIR, '.users.json');

function getUsers() {
    if (fs.existsSync(USERS_FILE)) {
        try {
            return JSON.parse(fs.readFileSync(USERS_FILE, 'utf8'));
        } catch (e) {
            return {};
        }
    }
    return {};
}

function saveUsers(users) {
    fs.writeFileSync(USERS_FILE, JSON.stringify(users, null, 2));
}

// Get base domain from existing config (e.g., hop.example.com -> example.com)
function getBaseDomain() {
    const config = getDomainConfig();
    if (!config || !config.hostname) return null;
    // Extract base domain: hop.example.com -> example.com
    const parts = config.hostname.split('.');
    if (parts.length >= 2) {
        return parts.slice(-2).join('.');
    }
    return config.hostname;
}

// Get subdomain prefix (e.g., hop.example.com -> hop)
function getSubdomainPrefix() {
    const config = getDomainConfig();
    if (!config || !config.hostname) return 'hop';
    const parts = config.hostname.split('.');
    if (parts.length >= 3) {
        return parts[0];
    }
    return 'hop';
}

async function addUser(username) {
    // Validate username
    if (!/^[a-zA-Z0-9_-]+$/.test(username)) {
        log(`Invalid username. Use only letters, numbers, underscore, hyphen.`, RED);
        process.exit(1);
    }

    const baseDomain = getBaseDomain();
    const prefix = getSubdomainPrefix();

    if (!baseDomain) {
        log(`You must set up your own domain first.`, RED);
        log(`Run: hop domain <your-subdomain.yourdomain.com>`, RESET);
        process.exit(1);
    }

    if (!isCloudflaredLoggedIn()) {
        log(`You must be logged in to Cloudflare.`, RED);
        log(`Run: hop domain <hostname> to set up.`, RESET);
        process.exit(1);
    }

    const users = getUsers();
    if (users[username]) {
        log(`User "${username}" already exists.`, YELLOW);
        log(`Hostname: ${users[username].hostname}`, RESET);
        process.exit(0);
    }

    const tunnelName = `hop-${username}`;
    const hostname = `${username}.${prefix}.${baseDomain}`;
    let tunnelCreatedByUs = false;

    log(`\n${BOLD}Adding user: ${username}${RESET}\n`, CYAN);

    // Step 1: Create tunnel
    log(`[1/3] Creating tunnel...`, BOLD);
    const tunnels = listCloudflaredTunnels();
    let tunnel = tunnels.find(t => t.name === tunnelName);

    if (tunnel) {
        log(`  Tunnel already exists: ${tunnelName}`, GREEN);
    } else {
        try {
            execSync(`cloudflared tunnel create ${tunnelName}`, { encoding: 'utf8', stdio: ['pipe', 'pipe', 'pipe'] });
            log(`  Tunnel created: ${tunnelName}`, GREEN);
            tunnelCreatedByUs = true;
            // Re-fetch to get the ID
            const newTunnels = listCloudflaredTunnels();
            tunnel = newTunnels.find(t => t.name === tunnelName);
        } catch (e) {
            log(`Failed to create tunnel: ${e.message}`, RED);
            process.exit(1);
        }
    }

    // Step 2: Setup DNS
    log(`[2/3] Configuring DNS...`, BOLD);
    let dnsSuccess = false;
    try {
        const result = execSync(`cloudflared tunnel route dns ${tunnelName} ${hostname} 2>&1`, {
            encoding: 'utf8'
        });
        // Check for failure FIRST
        if (result.includes('Failed to add route') || result.includes('Failed to create record')) {
            log(`\n${RED}ERROR: DNS failed: ${result.trim()}${RESET}`, RED);
            dnsSuccess = false;
        } else if (result.includes('Added CNAME')) {
            dnsSuccess = true;
            log(`  DNS configured: ${hostname}`, GREEN);
        } else if (result.includes('already exists') && !result.includes('Failed')) {
            dnsSuccess = true;
            log(`  DNS already configured.`, GREEN);
        } else {
            log(`  Unexpected response: ${result.trim()}`, YELLOW);
        }
    } catch (e) {
        const errorOutput = e.stdout || e.stderr || e.message || '';
        // Check for failure FIRST
        if (errorOutput.includes('Failed to add route') || errorOutput.includes('Failed to create record')) {
            log(`\n${RED}ERROR: DNS failed: ${errorOutput.trim()}${RESET}`, RED);
        } else if (errorOutput.includes('already exists') && !errorOutput.includes('Failed')) {
            dnsSuccess = true;
            log(`  DNS already configured.`, GREEN);
        } else if (errorOutput.includes('zone') || errorOutput.includes('not found')) {
            log(`\n${RED}ERROR: Domain not in your Cloudflare account.${RESET}`, RED);
        } else {
            log(`\n${RED}ERROR: DNS failed: ${errorOutput.trim()}${RESET}`, RED);
        }
    }

    // If DNS failed, clean up
    if (!dnsSuccess) {
        if (tunnelCreatedByUs) {
            log(`\nCleaning up...`, YELLOW);
            try {
                execSync(`cloudflared tunnel delete ${tunnelName}`, { stdio: 'ignore' });
                log(`  Deleted tunnel: ${tunnelName}`, RESET);
            } catch (e) { }
        }
        process.exit(1);
    }

    // Step 3: Save user info
    log(`[3/3] Saving user...`, BOLD);

    // Find the credentials file
    const cloudflaredDir = path.join(os.homedir(), '.cloudflared');
    let credentialsFile = null;
    if (tunnel && tunnel.id) {
        credentialsFile = path.join(cloudflaredDir, `${tunnel.id}.json`);
    }

    users[username] = {
        tunnelName,
        tunnelId: tunnel ? tunnel.id : null,
        hostname,
        credentialsFile,
        createdAt: new Date().toISOString()
    };
    saveUsers(users);
    log(`  User saved.`, GREEN);

    log(`\n${BOLD}${GREEN}✓ User "${username}" added!${RESET}`, GREEN);
    log(`\nTheir URL: https://${hostname}`, BOLD);
    log(`\nTo export credentials for them:`, RESET);
    log(`  ${CYAN}hop user export ${username}${RESET}`, RESET);
}

