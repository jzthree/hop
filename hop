    });
}

// Start or get existing ttyd for a session
function getOrCreateSession(sessionName) {
    const normalizedName = normalizeSessionName(sessionName);
    if (!normalizedName) {
        throw new Error('Invalid session name');
    }
    sessionName = normalizedName;
    if (activeSessions[sessionName]) {
        return activeSessions[sessionName];
    }

    const port = nextPort++;
    const logFilePath = path.join(LOG_DIR, `ttyd-${sessionName}.log`);
    const logFile = fs.openSync(logFilePath, 'w', PRIVATE_FILE_MODE);
    ensurePrivateFile(logFilePath);
    const themeJson = getTheme();
    const exitFlagPath = path.join(HOME_DIR, `.exit-${sessionName}`);

    // Shell wrapper with safety loop
    // Uses respawn-on-remain-exit in tmux for reliability
    // To cleanly exit: type "tunnel-exit" or kill the tmux session
    const ttyd = spawn('ttyd', [
        '-p', port.toString(),
        '-i', '127.0.0.1',
        '-W',
        '-t', `theme=${themeJson}`,
        '-t', 'fontFamily="Menlo, Monaco, Consolas, monospace"',
        '-t', 'fontSize=15',
        '-t', 'disableLeaveAlert=true',
        '-t', 'rendererType=canvas',
        HOP_TMUX_WRAPPER,
        HOP_TMUX_CONF,
        sessionName,
        exitFlagPath
    ], {
        stdio: ['ignore', logFile, logFile],
        detached: false
    });

    ttyd.on('error', (err) => log(`Failed TTYD for ${sessionName}: ${err.message}`, RED));
    ttyd.on('close', () => {
        delete activeSessions[sessionName];
        log(`Session ${sessionName} closed.`, YELLOW);
    });

    activeSessions[sessionName] = { ttyd, port };
    log(`  Started session "${sessionName}" on port ${port}`, GREEN);

    // Apply tmux styles with retries (give tmux time to start)
    const applyStylesWithRetry = (retries = 0) => {
        try {
            const state = JSON.parse(fs.readFileSync(STATE_FILE, 'utf8'));
            if (state.url) {
                applyTmuxStyles(sessionName, state.url);
            }
        } catch (e) { }
        // Retry a few times to catch slow tmux starts
        if (retries < 5) {
            setTimeout(() => applyStylesWithRetry(retries + 1), 500);
        }
    };
    setTimeout(() => applyStylesWithRetry(), 300);

    return activeSessions[sessionName];
}

// Resolve current session name (follows rename chain)
function resolveSessionName(name) {
    let current = name;
    while (sessionRenames[current]) {
        current = sessionRenames[current];
    }
    return current;
}

// Apply tmux styling synchronously for reliable results
function applyTmuxStyles(sessionName, publicUrl) {
    // Resolve to current name in case of renames
    const s = resolveSessionName(sessionName);
    // Strip hop- prefix for display
    const displayName = s.startsWith(HOP_SESSION_PREFIX)
        ? s.slice(HOP_SESSION_PREFIX.length)
        : s;
    const run = (cmd) => {
        try {
            execSync(cmd, { stdio: 'ignore' });
        } catch (e) { }
    };

    // Enable truecolor
    run(`tmux set-option -g default-terminal tmux-256color`);
    run(`tmux set-option -ga terminal-overrides ',xterm*:Tc,alacritty:Tc,*:Tc'`);

    // Core settings
    run(`tmux set-option -t ${s} mouse on`);
    run(`tmux set-option -t ${s} escape-time 0`);
    run(`tmux set-option -g window-size latest`);
    run(`tmux set-window-option -t ${s} aggressive-resize on`);
    run(`tmux set-option -g fill-character ' '`);

    // Status bar styling
    run(`tmux set-option -t ${s} status on`);
    run(`tmux set-option -t ${s} status-position bottom`);
    run(`tmux set-option -t ${s} status-style 'bg=#e4e4e7,fg=#52525b'`);
    run(`tmux set-option -t ${s} status-left '#[fg=#7c3aed,bold]● #[fg=#18181b,bold]${displayName} #[fg=#a1a1aa,nobold]│#[bg=#e4e4e7]  '`);
    run(`tmux set-option -t ${s} status-left-length 40`);
    run(`tmux set-option -t ${s} status-right '#[bg=#e4e4e7]    #[fg=#a1a1aa]│ #[fg=#71717a]${publicUrl} '`);
    run(`tmux set-option -t ${s} status-right-length 200`);

    // Window status
    run(`tmux set-window-option -t ${s} window-status-current-style 'fg=#18181b,bold'`);
    run(`tmux set-window-option -t ${s} window-status-style 'fg=#a1a1aa'`);
    run(`tmux set-window-option -t ${s} window-status-separator '#[fg=#d4d4d8] │ '`);

    // Pane borders
    run(`tmux set-option -t ${s} pane-border-style 'fg=#e4e4e7'`);
    run(`tmux set-option -t ${s} pane-active-border-style 'fg=#7c3aed'`);

    // Message/mode styling
    run(`tmux set-option -t ${s} message-style 'bg=#f0f0f0,fg=#18181b'`);
    run(`tmux set-option -t ${s} mode-style 'bg=#ddd6fe,fg=#18181b'`);
}

// iOS Virtual Keyboard - Returns {hook, ui} for proper injection timing
// hook: WebSocket interceptor script (goes in <head> before ttyd scripts)
// ui: keyboard HTML/CSS/JS (goes before </body>)
function getIOSKeyboardInjection() {
    // WebSocket interceptor - MUST run before ttyd creates its socket
    const hook = `
<script>
(function() {
    // Capture ttyd's WebSocket when it's created
    window.__hopSocket = null;
    window.__hopOnData = null;
    function patchTerminal(Terminal) {
        if (!Terminal || Terminal.__hopPatched) return;
        var orig = Terminal.prototype.onData;
        if (typeof orig !== 'function') return;
        Terminal.prototype.onData = function(cb) {
            window.__hopOnData = cb;
            window.__hopTerm = this;
            return orig.call(this, cb);
        };
        Terminal.__hopPatched = true;
    }
    try { patchTerminal(window.Terminal); } catch (e) { }
    try {
        var desc = Object.getOwnPropertyDescriptor(window, 'Terminal');
        if (!desc || desc.configurable) {
            var terminalValue = window.Terminal;
            Object.defineProperty(window, 'Terminal', {
                configurable: true,
                get: function() { return terminalValue; },
                set: function(v) { terminalValue = v; patchTerminal(v); }
            });
        } else {
            setInterval(function() { patchTerminal(window.Terminal); }, 250);
        }
    } catch (e) {
        setInterval(function() { patchTerminal(window.Terminal); }, 250);
    }
    var OriginalWebSocket = window.WebSocket;
    window.WebSocket = function(url, protocols) {
        // Call original constructor properly (with or without protocols)
        var ws = protocols ? new OriginalWebSocket(url, protocols) : new OriginalWebSocket(url);
        
        // Check if this is ttyd's socket by protocol OR URL pattern
        var isTtyProtocol = protocols === 'tty' ||
            (Array.isArray(protocols) && protocols.indexOf('tty') >= 0);
        var wsUrl = '';
        try { wsUrl = (typeof url === 'string') ? url : (url && url.toString ? url.toString() : ''); } catch (e) { wsUrl = ''; }
        var isTtyUrl = wsUrl && /\\/ws(?:\\?|$|\\/)/.test(wsUrl);
        
        if (isTtyProtocol || isTtyUrl) {
            console.log('[HopKb] Captured ttyd socket via ' + (isTtyProtocol ? 'protocol' : 'URL'));
            ws.binaryType = 'arraybuffer';
            window.__hopSocket = ws;
        }
        return ws;
    };
    window.WebSocket.CONNECTING = OriginalWebSocket.CONNECTING;
    window.WebSocket.OPEN = OriginalWebSocket.OPEN;
    window.WebSocket.CLOSING = OriginalWebSocket.CLOSING;
    window.WebSocket.CLOSED = OriginalWebSocket.CLOSED;
    window.WebSocket.prototype = OriginalWebSocket.prototype;
})();
</script>`;

    // Read keyboard UI from file
    const keyboardFile = path.join(__dirname, 'keyboard.html');
    let ui = '<!-- keyboard.html not found -->';
    try {
        ui = fs.readFileSync(keyboardFile, 'utf8');
    } catch (e) {
        log(`Warning: keyboard.html not found`, YELLOW);
    }

    return { hook, ui };
}

// Helper to get client IP (handles proxies)
function getClientIp(req) {
    return req.headers['cf-connecting-ip'] ||
        req.headers['x-forwarded-for'] ||
        req.socket.remoteAddress ||
        'unknown';
}

function setNoCache(res) {
    res.setHeader('Cache-Control', 'no-store, no-cache, must-revalidate, proxy-revalidate');
    res.setHeader('Pragma', 'no-cache');
    res.setHeader('Expires', '0');
}

function appendSetCookie(res, cookies) {
    const existing = res.getHeader('Set-Cookie');
    if (!existing) {
        res.setHeader('Set-Cookie', cookies);
        return;
    }
    const merged = Array.isArray(existing) ? existing.concat(cookies) : [existing].concat(cookies);
    res.setHeader('Set-Cookie', merged);
}

function clearAuthCookies(res) {
    const expires = new Date(0);
    appendSetCookie(res, [
        cookie.serialize(SESSION_COOKIE_NAME, '', {
            httpOnly: true,
            secure: true,
            sameSite: 'lax',
            path: '/',
            expires,
            maxAge: 0
        }),
        cookie.serialize(SESSION_COOKIE_NAME, '', {
            httpOnly: true,
            secure: true,
            sameSite: 'lax',
            path: '/api',
            expires,
            maxAge: 0
        })
    ]);
}

function startAuthProxy(authEmitter) {
    log(`[2/4] Starting Session Manager on port ${PROXY_PORT}...`, BOLD);

    const server = http.createServer((req, res) => {
        const parsedUrl = url.parse(req.url, true);
        const cookies = cookie.parse(req.headers.cookie || '');
        const ip = getClientIp(req);

        // Check auth via cookie OR Authorization header (internal hop-to-hop only)
        // Bearer token is read from state file by other hop processes on same machine
        const authHeader = req.headers.authorization;
        const tokenFromHeader = authHeader && authHeader.startsWith('Bearer ')
            ? authHeader.substring(7)
            : null;
        const isAuthenticated = cookies[SESSION_COOKIE_NAME] === SESSION_SECRET
            || tokenFromHeader === SESSION_SECRET;

        // --- LOGIN PAGE ---
        if (!isAuthenticated) {
            const passwordRequired = isPasswordEnabled();
            const storedPasswordHash = getStoredPassword();

            // API Login endpoint - authenticates via password (if enabled) + TOTP
            if (req.method === 'POST' && parsedUrl.pathname === '/api/login') {
                const limit = checkRateLimit(ip);
                if (!limit.allowed) {
                    res.writeHead(429, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ success: false, error: `Too many attempts. Try again in ${limit.remaining}s.` }));
                    return;
                }

                let body = '';
                req.on('data', chunk => body += chunk);
                req.on('end', () => {
                    try {
                        const { totp, password } = JSON.parse(body);

                        // Check password if enabled
                        if (passwordRequired && !verifyPassword(password || '', storedPasswordHash)) {
                            recordFailure(ip);
                            res.writeHead(401, { 'Content-Type': 'application/json' });
                            res.end(JSON.stringify({ success: false, error: 'Invalid password' }));
                            return;
                        }

                        // Check TOTP
                        if (authenticator.check(totp, AUTH_SECRET)) {
                            resetFailure(ip);
                            res.setHeader('Set-Cookie', cookie.serialize(SESSION_COOKIE_NAME, SESSION_SECRET, {
                                httpOnly: true,
                                secure: true,
                                sameSite: 'lax',
                                path: '/',
                                maxAge: 60 * 60 * 24 * 7
                            }));
                            res.writeHead(200, { 'Content-Type': 'application/json' });
                            res.end(JSON.stringify({ success: true }));
                            if (authEmitter) authEmitter.emit('authenticated');
                        } else {
                            recordFailure(ip);
                            res.writeHead(401, { 'Content-Type': 'application/json' });
                            res.end(JSON.stringify({ success: false, error: 'Invalid code' }));
                        }
                    } catch (e) {
                        res.writeHead(400, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ success: false, error: 'Invalid request' }));
                    }
                });
                return;
            }

            // Web form login
            if (req.method === 'POST' && parsedUrl.pathname === '/') {
                const limit = checkRateLimit(ip);
                if (!limit.allowed) {
                    res.writeHead(429, { 'Content-Type': 'text/html; charset=utf-8' });
                    res.end(`Too many attempts. Try again in ${limit.remaining}s. <a href="/">Back</a>`);
                    return;
                }

                let body = '';
                req.on('data', chunk => body += chunk);
                req.on('end', () => {
                    const params = new URLSearchParams(body);
                    const token = params.get('token');
                    const password = params.get('password');

                    try {
                        // Check password if enabled
                        if (passwordRequired && !verifyPassword(password || '', storedPasswordHash)) {
                            recordFailure(ip);
                            res.writeHead(401, { 'Content-Type': 'text/html; charset=utf-8' });
                            res.end('Invalid password. <a href="/">Try Again</a>');
                            return;
                        }

                        // Check TOTP
                        if (authenticator.check(token, AUTH_SECRET)) {
                            resetFailure(ip);
                            res.setHeader('Set-Cookie', cookie.serialize(SESSION_COOKIE_NAME, SESSION_SECRET, {
                                httpOnly: true,
                                secure: true,
                                sameSite: 'lax',
                                path: '/',
                                maxAge: 60 * 60 * 24 * 7
                            }));
                            res.writeHead(302, { 'Location': '/' });
                            res.end();
                            if (authEmitter) authEmitter.emit('authenticated');
                        } else {
                            recordFailure(ip);
                            res.writeHead(401, { 'Content-Type': 'text/html; charset=utf-8' });
                            res.end('Invalid Code. <a href="/">Try Again</a>');
                        }
                    } catch (e) {
                        res.writeHead(401);
                        res.end('Error verifying code');
                    }
                });
                return;
            }

            // Show login page - with password field if enabled
            const passwordFieldHtml = passwordRequired ? `
                <div style="margin-bottom: 1.5rem;">
                    <input type="password" name="password" id="passwordField" placeholder="Password"
                        style="width: 100%; padding: 0.8rem 1rem; font-size: 1rem; border: 1px solid #e4e4e7; border-radius: 8px; background: #fff; color: #18181b; box-sizing: border-box;"
                        required>
