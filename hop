// Setup custom domain
async function setupDomain(hostname) {
    const tunnelName = 'hop';
    let tunnelCreatedByUs = false;  // Track if we created it (for cleanup)

    log(`\n${BOLD}Setting up custom domain: ${hostname}${RESET}\n`, CYAN);

    // Step 1: Check cloudflared login
    log(`[1/4] Checking Cloudflare authentication...`, BOLD);
    if (!isCloudflaredLoggedIn()) {
        log(`  Opening browser for Cloudflare login...`, YELLOW);
        log(`  Please authorize in your browser.\n`, RESET);
        try {
            execSync('cloudflared tunnel login', { stdio: 'inherit' });
        } catch (e) {
            log(`Failed to authenticate with Cloudflare.`, RED);
            process.exit(1);
        }
    }
    log(`  Authenticated with Cloudflare.`, GREEN);

    // Step 2: Check if tunnel exists, create if not
    log(`[2/4] Setting up tunnel...`, BOLD);
    const tunnels = listCloudflaredTunnels();
    let tunnel = tunnels.find(t => t.name === tunnelName);

    if (tunnel) {
        log(`  Using existing tunnel: ${tunnelName} (${tunnel.id})`, GREEN);
    } else {
        log(`  Creating new tunnel: ${tunnelName}...`, YELLOW);
        try {
            execSync(`cloudflared tunnel create ${tunnelName}`, { encoding: 'utf8' });
            log(`  Tunnel created.`, GREEN);
            tunnelCreatedByUs = true;
            // Re-fetch to get the ID
            const newTunnels = listCloudflaredTunnels();
            tunnel = newTunnels.find(t => t.name === tunnelName);
        } catch (e) {
            log(`Failed to create tunnel: ${e.message}`, RED);
            process.exit(1);
        }
    }

    // Step 3: Setup DNS route - this validates domain ownership
    log(`[3/4] Configuring DNS...`, BOLD);
    let dnsSuccess = false;
    try {
        // Capture both stdout and stderr to check for errors
        const result = execSync(`cloudflared tunnel route dns ${tunnelName} ${hostname} 2>&1`, {
            encoding: 'utf8'
        });

        // Check for failure FIRST (before checking for "already exists" which can appear in error messages)
        if (result.includes('Failed to add route') || result.includes('Failed to create record')) {
            // This is an error, even if it contains "already exists"
            log(`\n${RED}ERROR: DNS configuration failed.${RESET}`, RED);
            log(`Details: ${result.trim()}`, YELLOW);
            dnsSuccess = false;
        } else if (result.includes('Added CNAME')) {
            dnsSuccess = true;
            log(`  DNS configured: ${hostname} → tunnel`, GREEN);
        } else if (result.includes('already exists') && !result.includes('Failed')) {
            // Only treat as success if it's not part of a failure message
            dnsSuccess = true;
            log(`  DNS already configured.`, GREEN);
        } else {
            // Unexpected output - treat as potential failure
            log(`  Unexpected response: ${result.trim()}`, YELLOW);
            dnsSuccess = false;
        }
    } catch (e) {
        const errorOutput = e.stdout || e.stderr || e.message || '';

        // Check for failure indicators FIRST
        if (errorOutput.includes('Failed to add route') || errorOutput.includes('Failed to create record')) {
            log(`\n${RED}ERROR: DNS configuration failed.${RESET}`, RED);
            log(`Details: ${errorOutput.trim()}`, YELLOW);
            dnsSuccess = false;
        } else if (errorOutput.includes('zone') || errorOutput.includes('not found') || errorOutput.includes('does not exist')) {
            log(`\n${RED}ERROR: Domain "${hostname}" is not in your Cloudflare account.${RESET}`, RED);
            log(`\nMake sure:`, YELLOW);
            log(`  1. You own this domain`, RESET);
            log(`  2. The domain is added to your Cloudflare account`, RESET);
            log(`  3. You're using the correct Cloudflare account`, RESET);
            dnsSuccess = false;
        } else if (errorOutput.includes('authentication') || errorOutput.includes('unauthorized')) {
            log(`\n${RED}ERROR: Authentication failed.${RESET}`, RED);
            log(`Try: cloudflared tunnel login`, YELLOW);
            dnsSuccess = false;
        } else if (errorOutput.includes('already exists') && !errorOutput.includes('Failed')) {
            // Only treat as success if it's a clean "already exists" not part of error
            dnsSuccess = true;
            log(`  DNS already configured.`, GREEN);
        } else {
            log(`\n${RED}ERROR: DNS configuration failed.${RESET}`, RED);
            log(`Details: ${errorOutput.trim()}`, YELLOW);
            dnsSuccess = false;
        }
    }

    // If DNS failed, clean up the tunnel we created
    if (!dnsSuccess) {
        if (tunnelCreatedByUs) {
            log(`\nCleaning up...`, YELLOW);
            try {
                execSync(`cloudflared tunnel delete ${tunnelName}`, { stdio: 'ignore' });
                log(`  Deleted tunnel: ${tunnelName}`, RESET);
            } catch (e) {
                log(`  Note: You may need to manually delete tunnel: cloudflared tunnel delete ${tunnelName}`, YELLOW);
            }
        }
        log(`\nSetup failed. Please fix the issue and try again.`, RED);
        process.exit(1);
    }

    // Step 4: Save config
    log(`[4/4] Saving configuration...`, BOLD);
    saveDomainConfig({
        tunnelName,
        tunnelId: tunnel ? tunnel.id : null,
        hostname,
        createdAt: new Date().toISOString()
    });
    log(`  Configuration saved.`, GREEN);

    log(`\n${BOLD}${GREEN}✓ Custom domain setup complete!${RESET}`, GREEN);
    log(`\nYour hop URL: https://${hostname}`, BOLD);

    // Require password for fixed domains
    if (!isPasswordEnabled()) {
        log(`\n${YELLOW}⚠ Password required for fixed domains.${RESET}`, YELLOW);
        log(`A fixed URL is publicly known - password adds essential protection.\n`, RESET);

        const readline = require('readline');
        const stream = require('stream');

        const askPassword = (prompt) => new Promise((resolve) => {
            const rl = readline.createInterface({
                input: process.stdin,
                output: new stream.Writable({
                    write: (chunk, encoding, callback) => callback()
                }),
                terminal: true
            });

            process.stdout.write(prompt);
            rl.question('', (answer) => {
                rl.close();
                process.stdout.write('\n');
                resolve(answer);
            });
        });

        const password = await askPassword('Set a password: ');
        if (password.length < 4) {
            log(`Password too short. Run ${CYAN}hop password set${RESET} to set later.`, RED);
        } else {
            const confirm = await askPassword('Confirm password: ');
            if (password !== confirm) {
                log(`Passwords don't match. Run ${CYAN}hop password set${RESET} to set later.`, RED);
            } else {
                setPassword(password);
                log(`${GREEN}✓ Password set.${RESET}`, GREEN);
            }
        }
    }

    log(`\nRun ${CYAN}hop${RESET} to start with your custom domain.`, RESET);
}

