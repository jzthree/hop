        // --- AUTHENTICATED ROUTES ---
        const sessionInfoAuth = parseSessionFromRequest(req, parsedUrl);
        const sessionName = sessionInfoAuth ? sessionInfoAuth.internalName : null;
        const displayName = sessionInfoAuth ? sessionInfoAuth.displayName : null;
        const strippedUrl = sessionInfoAuth ? sessionInfoAuth.strippedUrl : req.url;
        const strippedPathname = sessionInfoAuth ? sessionInfoAuth.strippedPathname : (parsedUrl.pathname || '/');

        if (sessionInfoAuth && sessionInfoAuth.source === 'path' && sessionInfoAuth.aliasRedirect && shouldRedirectToSessionPath(req)) {
            const target = buildSessionPath(displayName) + (parsedUrl.search || '');
            res.writeHead(302, { 'Location': target });
            res.end();
            return;
        }

        if (sessionInfoAuth && sessionInfoAuth.source === 'query' && shouldRedirectToSessionPath(req)) {
            res.writeHead(302, { 'Location': buildSessionPath(displayName) });
            res.end();
            return;
        }
        if (sessionInfoAuth && sessionInfoAuth.source === 'path' && sessionInfoAuth.needsSlash && shouldRedirectToSessionPath(req)) {
            const target = buildSessionPath(displayName) + (parsedUrl.search || '');
            res.writeHead(302, { 'Location': target });
            res.end();
            return;
        }

        // API: Ping (triggers auth event for mobile login)
        if (parsedUrl.pathname === '/api/ping' && req.method === 'POST') {
            recordAuth(authEmitter);
            res.writeHead(200, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ ok: true, message: 'Mobile login' }));
            return;
        }

        // API: Tunnel status (local diagnostics for hop health)
        if (parsedUrl.pathname === '/api/tunnel/status' && req.method === 'GET') {
            let tunnelPid = currentTunnelProc && !currentTunnelProc.killed ? currentTunnelProc.pid : null;
            let tunnelRunning = false;
            if (tunnelPid) {
                try {
                    process.kill(tunnelPid, 0);
                    tunnelRunning = true;
                } catch (e) {
                    tunnelPid = null;
                }
            }
            if (!tunnelRunning && tunnelStatus.connected) {
                updateTunnelStatus({
                    connected: false,
                    lastEvent: 'stale',
                    lastError: 'cloudflared process not running'
                });
            }
            res.writeHead(200, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({
                url: currentPublicUrl,
                connected: tunnelStatus.connected,
                lastEvent: tunnelStatus.lastEvent,
                lastError: tunnelStatus.lastError,
                lastUpdateAt: tunnelStatus.lastUpdateAt,
                lastConnectedAt: tunnelStatus.lastConnectedAt,
                lastRestartAt: tunnelStatus.lastRestartAt,
                consecutiveFailures: tunnelStatus.consecutiveFailures,
                tunnelPid,
                tunnelRunning
            }));
            return;
        }

        // API: Tunnel restart (local diagnostics for hop health)
        if (parsedUrl.pathname === '/api/tunnel/restart' && req.method === 'POST') {
            if (tunnelRestartInProgress) {
                res.writeHead(202, { 'Content-Type': 'application/json' });
                res.end(JSON.stringify({ ok: true, inProgress: true }));
                return;
            }
            updateTunnelStatus({ lastRestartAt: Date.now(), lastEvent: 'restarting' });
            if (currentTunnelProc && !currentTunnelProc.killed) {
                try { currentTunnelProc.kill('SIGTERM'); } catch (e) { }
            } else {
                startTunnelWithRestart();
            }
            res.writeHead(200, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ ok: true }));
            return;
        }

        // API: List sessions
        if (parsedUrl.pathname === '/api/sessions' && req.method === 'GET') {
            const snapshot = await listAllSessionEntriesRuntimeFirst();
            const sessions = snapshot.entries.map(s => ({
                name: s.displayName,
                displayName: s.displayName,
                internalName: s.internalName,
                windows: s.windows,
                attached: s.attached,
                live: s.live === true,
                type: s.type,
                port: s.port,
                hostPort: s.hostPort,
                folderId: s.folderId || null,
                cwd: s.cwd,
                shell: s.shell,
                env: s.env,
                cols: s.cols,
                rows: s.rows,
                startup: s.startup,
                autoStart: s.autoStart,
                createdAt: s.createdAt,
                createdBy: s.createdBy || 'user',
                agentPermitted: s.agentPermitted === true,
                hasLocalCli: !!s.hasLocalCli,
                localCliCount: s.localCliCount || 0
            }));
            const activeSessionNames = snapshot.activeDisplayNames;
            const startingSessionNames = Array.from(startingSessions).map(getSessionDisplayName);
            const folders = sessionStore.order.folders
                .map((id) => sessionStore.folders[id])
                .filter(Boolean);
            res.writeHead(200, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({
                sessions,
                active: activeSessionNames,
                starting: startingSessionNames,
                folders,
                order: sessionStore.order,
                aliases: sessionAliases,
                runtimeAvailable: snapshot.runtimeAvailable
            }));
            return;
        }

        // API: Atomically choose and reserve a session for a local CLI attach.
        if (parsedUrl.pathname === '/api/sessions/claim-local-cli' && req.method === 'POST') {
            let body = '';
            req.on('data', chunk => body += chunk);
            req.on('end', async () => {
                try {
                    const parsed = body ? JSON.parse(body) : {};
                    const cwdPath = typeof parsed.cwd === 'string' && parsed.cwd.trim()
                        ? parsed.cwd
                        : process.cwd();
                    const cwdName = typeof parsed.cwdName === 'string' && parsed.cwdName.trim()
                        ? parsed.cwdName
                        : path.basename(cwdPath).replace(/[^a-zA-Z0-9_-]/g, '-');
                    const claimed = await withLocalCliClaimLock(() => (
                        claimUnnamedLocalCliSession({ cwdPath, cwdName })
                    ));
                    res.writeHead(200, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({
                        ok: true,
                        createdNew: claimed.createdNew,
                        target: claimed.target
                    }));
                } catch (e) {
                    const status = Number.isInteger(e?.status) ? e.status : 500;
                    res.writeHead(status, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: e?.message || 'Failed to claim local session' }));
                }
            });
            return;
        }

        // API: Create session
        if (parsedUrl.pathname === '/api/sessions' && req.method === 'POST') {
            let body = '';
            req.on('data', chunk => body += chunk);
            req.on('end', async () => {
                try {
                    let { name, type, port, cwd, folderId, startRuntime, workspace, workspaceName } = JSON.parse(body);
                    const displayName = name;
                    const internalName = toInternalSessionName(displayName);
                    if (!internalName || !displayName) {
                        res.writeHead(400, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Invalid session name' }));
                        return;
                    }
                    if (isDisplayNameInUse(displayName)) {
                        res.writeHead(409, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Session name already in use' }));
                        return;
                    }
                    if (hasSavedSessionConfig(internalName)) {
                        res.writeHead(409, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Session internal name already in use' }));
                        return;
                    }
                    type = (type || 'terminal').toLowerCase();
                    if (type !== 'terminal' && type !== 'port') {
                        res.writeHead(400, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Invalid session type' }));
                        return;
                    }
                    const targetFolderId = folderId && sessionStore.folders[folderId] ? folderId : null;
                    const targetWorkspaceName = normalizeWorkspaceName(workspaceName || workspace);
                    if (type === 'port') {
                        const parsedPort = parseInt(port, 10);
                        if (!Number.isInteger(parsedPort) || parsedPort < 1 || parsedPort > 65535) {
                            res.writeHead(400, { 'Content-Type': 'application/json' });
                            res.end(JSON.stringify({ error: 'Invalid port' }));
                            return;
                        }
                        if (await runtimeTerminalSessionExists(internalName)) {
                            res.writeHead(409, { 'Content-Type': 'application/json' });
                            res.end(JSON.stringify({ error: 'Terminal session already exists with this name' }));
                            return;
                        }
                        const existingConfig = getEffectiveSessionConfig(internalName);
                        if (existingConfig && existingConfig.type === 'terminal') {
                            res.writeHead(409, { 'Content-Type': 'application/json' });
                            res.end(JSON.stringify({ error: 'Terminal session already exists with this name' }));
                            return;
                        }
                        if (targetWorkspaceName) {
                            const saved = upsertWorkspaceSessionDefinition(targetWorkspaceName, internalName, {
                                type: 'port',
                                port: parsedPort,
                                displayName,
                                folderId: targetFolderId,
                                createdAt: new Date().toISOString(),
                                updatedAt: new Date().toISOString(),
                                createdBy: 'user',
                                agentPermitted: false,
                                workspaceName: targetWorkspaceName
                            });
                            if (!saved) {
                                res.writeHead(400, { 'Content-Type': 'application/json' });
                                res.end(JSON.stringify({ error: 'Invalid workspace session config' }));
                                return;
                            }
                        } else {
                            setPortSessionConfig(internalName, parsedPort, displayName, targetFolderId);
                        }
                    } else {
                        const existingConfig = getEffectiveSessionConfig(internalName);
                        if (existingConfig && existingConfig.type === 'port') {
                            res.writeHead(409, { 'Content-Type': 'application/json' });
                            res.end(JSON.stringify({ error: 'Port session already exists with this name' }));
                            return;
                        }
                        if (startRuntime === false) {
                            if (targetWorkspaceName) {
                                const saved = upsertWorkspaceSessionDefinition(targetWorkspaceName, internalName, {
                                    type: 'terminal',
                                    cwd,
                                    displayName,
                                    folderId: targetFolderId,
                                    createdAt: new Date().toISOString(),
                                    updatedAt: new Date().toISOString(),
                                    createdBy: 'user',
                                    agentPermitted: false,
                                    workspaceName: targetWorkspaceName
                                });
                                if (!saved) {
                                    res.writeHead(400, { 'Content-Type': 'application/json' });
                                    res.end(JSON.stringify({ error: 'Invalid workspace session config' }));
                                    return;
                                }
                            } else {
                                res.writeHead(400, { 'Content-Type': 'application/json' });
                                res.end(JSON.stringify({ error: 'workspace is required when startRuntime is false' }));
                                return;
                            }
                        } else if (isExternalTerminalBackend()) {
                            await ensureExternalRuntimeSession(internalName, cwd, displayName, {
                                folderId: targetFolderId,
                                saveDefinition: false
                            });
                        } else {
                            getOrCreateSession(internalName, cwd, displayName);
                        }
                    }
                    res.writeHead(200, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ ok: true, name: displayName, type }));
                } catch (e) {
                    const status = Number.isInteger(e?.status) ? e.status : 500;
                    const message = e?.message || 'Failed to create session';
                    res.writeHead(status, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: message }));
                }
            });
            return;
        }

        // API: Create folder
        if (parsedUrl.pathname === '/api/folders' && req.method === 'POST') {
            let body = '';
            req.on('data', chunk => body += chunk);
            req.on('end', async () => {
                try {
                    const { name } = JSON.parse(body);
                    const folder = createFolder(name);
                    if (!folder) {
                        res.writeHead(400, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Invalid folder name' }));
                        return;
                    }
                    res.writeHead(200, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ ok: true, folder }));
                } catch (e) {
                    res.writeHead(400, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Invalid request body' }));
                }
            });
            return;
        }

        // API: Rename folder
        if (parsedUrl.pathname === '/api/folders/rename' && req.method === 'POST') {
            let body = '';
            req.on('data', chunk => body += chunk);
            req.on('end', async () => {
                try {
                    const { id, name } = JSON.parse(body);
                    const folder = renameFolder(id, name);
                    if (!folder) {
                        res.writeHead(404, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Folder not found or invalid name' }));
                        return;
                    }
                    res.writeHead(200, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ ok: true, folder }));
                } catch (e) {
                    res.writeHead(400, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Invalid request body' }));
                }
            });
            return;
        }

        // API: Delete folder
        if (parsedUrl.pathname === '/api/folders/delete' && req.method === 'POST') {
            let body = '';
            req.on('data', chunk => body += chunk);
            req.on('end', async () => {
                try {
                    const { id } = JSON.parse(body);
                    const ok = deleteFolder(id);
                    if (!ok) {
                        res.writeHead(404, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Folder not found' }));
                        return;
                    }
                    res.writeHead(200, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ ok: true }));
                } catch (e) {
                    res.writeHead(400, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Invalid request body' }));
                }
            });
            return;
        }

        // API: Reorder folders
        if (parsedUrl.pathname === '/api/folders/order' && req.method === 'POST') {
            let body = '';
            req.on('data', chunk => body += chunk);
            req.on('end', () => {
                try {
                    const { order } = JSON.parse(body);
                    const ok = setFolderOrder(order);
                    if (!ok) {
                        res.writeHead(400, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Invalid folder order' }));
                        return;
                    }
                    res.writeHead(200, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ ok: true }));
                } catch (e) {
                    res.writeHead(400, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Invalid request body' }));
                }
            });
            return;
        }

        // API: Move session (folder/order)
        if (parsedUrl.pathname === '/api/sessions/move' && req.method === 'POST') {
            let body = '';
            req.on('data', chunk => body += chunk);
            req.on('end', () => {
                try {
                    const { name, internalName, folderId, index } = JSON.parse(body);
                    let targetName = internalName && sessionStore.sessions[internalName] ? internalName : null;
                    if (!targetName && name) {
                        const displayName = resolveDisplayNameAlias(name);
                        targetName = findInternalSessionName(displayName);
                    }
                    if (!targetName) {
                        res.writeHead(404, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Session not found' }));
                        return;
                    }
                    const ok = moveSessionToFolder(targetName, folderId || null, index);
                    if (!ok) {
                        res.writeHead(400, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Failed to move session' }));
                        return;
                    }
                    res.writeHead(200, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ ok: true }));
                } catch (e) {
                    res.writeHead(400, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Invalid request body' }));
                }
            });
            return;
        }

        // API: Rename session
        if (parsedUrl.pathname === '/api/sessions/rename' && req.method === 'POST') {
            let body = '';
            req.on('data', chunk => body += chunk);
            req.on('end', () => {
                try {
                    const { oldName, newName } = JSON.parse(body);
                    renameSessionDisplayName(oldName, newName);
                    res.writeHead(200, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ ok: true }));
                } catch (e) {
                    res.writeHead(e?.status || 500, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: e?.message || 'Rename failed' }));
                }
            });
            return;
        }

        // API: Set agent permission
        if (parsedUrl.pathname === '/api/sessions/agent-permission' && req.method === 'POST') {
            let body = '';
            req.on('data', chunk => body += chunk);
            req.on('end', () => {
                try {
                    const { name, internalName, allowed } = JSON.parse(body);
                    const resolved = resolveSessionInternalName(name, internalName);
                    if (!resolved) {
                        res.writeHead(404, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Session not found' }));
                        return;
                    }
                    const savedConfig = getSessionConfig(resolved);
                    const config = getEffectiveSessionConfig(resolved);
                    if (!config || config.type === 'port') {
                        res.writeHead(400, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Session not a terminal' }));
                        return;
                    }
                    const next = { ...config };
                    next.agentPermitted = !!allowed;
                    if (!next.createdBy) next.createdBy = 'user';
                    next.updatedAt = new Date().toISOString();
                    if (savedConfig) {
                        setSessionConfig(resolved, next);
                    } else {
                        rememberRuntimeSessionMetadata(resolved, next);
                    }
                    res.writeHead(200, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ ok: true, agentPermitted: next.agentPermitted }));
                } catch (e) {
                    res.writeHead(400, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Invalid request body' }));
                }
            });
            return;
        }

        // API: Delete session
        if (parsedUrl.pathname === '/api/sessions/delete' && req.method === 'POST') {
            let body = '';
            req.on('data', chunk => body += chunk);
            req.on('end', async () => {
                try {
                    let { name, internalName } = JSON.parse(body || '{}');
                    const resolved = resolveSessionInternalName(name, internalName);
                    if (!resolved) {
                        res.writeHead(404, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Session not found' }));
                        return;
                    }
                    const savedConfig = getSessionConfig(resolved);
                    const config = getEffectiveSessionConfig(resolved);
                    if (config && config.type === 'port') {
                        deleteSessionConfig(resolved);
                        clearRuntimeSessionMetadata(resolved);
                        res.writeHead(200, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ ok: true, type: 'port' }));
                        return;
                    }

                    const exists = hopSessionExists(resolved);
                    if (!exists && !config) {
                        res.writeHead(404, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Session not found' }));
                        return;
                    }

                    // Close the terminal session if it exists
                    if (isExternalTerminalBackend()) {
                        await terminateExternalHaySession(resolved);
                    } else if (hayRooms.hasRoom(resolved)) {
                        hayRooms.closeRoom(resolved);
                    }

                    // Clean up internal tracking
                    if (activeSessions[resolved]) {
                        delete activeSessions[resolved];
                    }
                    clearRuntimeSessionMetadata(resolved);
                    sessionClientSummary.delete(resolved);

                    if (savedConfig) {
                        deleteSessionConfig(resolved);
                    }

                    res.writeHead(200, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ ok: true, type: 'terminal' }));
                } catch (e) {
                    res.writeHead(500, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Delete failed' }));
                }
            });
            return;
        }

        // API: List terminal API sessions
        if (parsedUrl.pathname === '/api/terminals' && req.method === 'GET') {
            const actor = resolveActor(req);
            const sessions = Array.from(terminalApiSessions.values())
                .filter((entry) => {
                    const config = getEffectiveSessionConfig(entry.sessionName);
                    return canActorAccessSession(actor, config);
                })
                .map(entry => ({
                    id: entry.id,
                    sessionName: entry.sessionName,
                    displayName: entry.displayName,
                    actor: entry.actor,
                    createdAt: entry.createdAt
                }));
            res.writeHead(200, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ terminals: sessions }));
            return;
        }

        // API: Create terminal session
        if (parsedUrl.pathname === '/api/terminals' && req.method === 'POST') {
            let body = '';
            req.on('data', chunk => body += chunk);
            req.on('end', async () => {
                try {
                    const actor = resolveActor(req);
                    const payload = JSON.parse(body || '{}');
                    const displayName = payload.name || `${actor}-${Date.now()}`;
                    const cwd = payload.cwd;
                    const cols = payload.cols;
                    const rows = payload.rows;
                    const shell = payload.shell;
                    const env = payload.env;
                    const startup = payload.startup;
                    const autoStart = payload.autoStart;
                    const targetWorkspaceName = normalizeWorkspaceName(payload.workspaceName || payload.workspace);
                    const folderId = payload.folderId && sessionStore.folders[payload.folderId]
                        ? payload.folderId
                        : null;
                    const saveDefinition = payload.saveDefinition === true;

                    if (isExternalTerminalBackend()) {
                        await ensureExternalHayHostReady();
                    }

                    if (!SESSION_NAME_RE.test(displayName)) {
                        res.writeHead(400, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Invalid session name' }));
                        return;
                    }
                    if (cwd && !path.isAbsolute(cwd)) {
                        res.writeHead(400, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'cwd must be an absolute path' }));
                        return;
                    }
                    if (isDisplayNameInUse(displayName)) {
                        res.writeHead(409, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Session name already in use' }));
                        return;
                    }
                    const internalName = toInternalSessionName(displayName);
                    if (!internalName) {
                        res.writeHead(400, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Invalid session name' }));
                        return;
                    }
                    if (saveDefinition && !targetWorkspaceName) {
                        res.writeHead(400, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'workspace is required when saveDefinition is true' }));
                        return;
                    }

                    if (saveDefinition) {
                        const saved = upsertWorkspaceSessionDefinition(targetWorkspaceName, internalName, {
                            type: 'terminal',
                            cwd,
                            shell,
                            env,
                            cols,
                            rows,
                            startup,
                            autoStart,
                            createdBy: actor,
                            agentPermitted: actor === 'agent',
                            displayName,
                            folderId,
                            workspaceName: targetWorkspaceName,
                            createdAt: new Date().toISOString(),
                            updatedAt: new Date().toISOString()
                        });
                        if (!saved) {
                            res.writeHead(400, { 'Content-Type': 'application/json' });
                            res.end(JSON.stringify({ error: 'Invalid workspace session config' }));
                            return;
                        }
                    }
                    rememberRuntimeSessionMetadata(internalName, {
                        type: 'terminal',
                        cwd,
                        displayName,
                        shell,
                        env,
                        cols,
                        rows,
                        startup,
                        autoStart,
                        createdBy: actor,
                        agentPermitted: actor === 'agent',
                        folderId,
                        workspaceName: targetWorkspaceName || null
                    });

                    const entry = await attachTerminalApiClient(internalName, displayName, {
                        actor,
                        cols,
                        rows,
                        cwd,
                        label: actor,
                        shell,
                        env,
                        startup,
                        autoStart,
                        createdBy: actor,
                        agentPermitted: actor === 'agent',
                        folderId,
                        workspaceName: targetWorkspaceName || null,
                        saveDefinition
                    });

                    if (startup && autoStart !== false) {
                        sendTerminalInput(entry, startup.endsWith('\n') ? startup : `${startup}\n`);
                    }

                    res.writeHead(200, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({
                        ok: true,
                        id: entry.id,
                        sessionName: internalName,
                        displayName: entry.displayName
                    }));
                } catch (e) {
                    res.writeHead(400, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Invalid request body' }));
                }
            });
            return;
        }

        // API: Attach terminal API client to existing session
        if (parsedUrl.pathname === '/api/terminals/attach' && req.method === 'POST') {
            let body = '';
            req.on('data', chunk => body += chunk);
            req.on('end', async () => {
                try {
                    const actor = resolveActor(req);
                    const payload = JSON.parse(body || '{}');
                    const target = resolveSessionInternalName(payload.name, payload.internalName);
                    if (!target) {
                        res.writeHead(404, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Session not found' }));
                        return;
                    }
                    const config = getEffectiveSessionConfig(target);
                    if (!canActorAccessSession(actor, config)) {
                        res.writeHead(403, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Agent access not permitted' }));
                        return;
                    }
                    if (isExternalTerminalBackend()) {
                        await ensureExternalHayHostReady();
                    }
                    const entry = await attachTerminalApiClient(target, config?.displayName, {
                        actor,
                        cols: payload.cols,
                        rows: payload.rows,
                        label: actor
                    });
                    res.writeHead(200, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({
                        ok: true,
                        id: entry.id,
                        sessionName: entry.sessionName,
                        displayName: entry.displayName
                    }));
                } catch (e) {
                    res.writeHead(400, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Invalid request body' }));
                }
            });
            return;
        }

        // API: Terminal stream (SSE)
        const terminalStreamMatch = (parsedUrl.pathname || '').match(/^\/api\/terminals\/([^/]+)\/stream$/);
        if (terminalStreamMatch && req.method === 'GET') {
            const terminalId = terminalStreamMatch[1];
            const entry = terminalApiSessions.get(terminalId);
            if (!entry) {
                res.writeHead(404, { 'Content-Type': 'application/json' });
                res.end(JSON.stringify({ error: 'Terminal not found' }));
                return;
            }
            const actor = resolveActor(req);
            const config = getEffectiveSessionConfig(entry.sessionName);
            if (!canActorAccessSession(actor, config)) {
                res.writeHead(403, { 'Content-Type': 'application/json' });
                res.end(JSON.stringify({ error: 'Agent access not permitted' }));
                return;
            }
            const afterRaw = parsedUrl.query?.after;
            const after = Number.isFinite(Number(afterRaw)) ? Number(afterRaw) : 0;
            res.writeHead(200, {
                'Content-Type': 'text/event-stream',
                'Cache-Control': 'no-cache',
                'Connection': 'keep-alive'
            });
            res.write(`data: ${JSON.stringify({ type: 'ready', timestamp: Date.now() })}\n\n`);

            const replayEvents = listTerminalEvents(terminalId, after);
            for (const payload of replayEvents) {
                res.write(`data: ${JSON.stringify(payload)}\n\n`);
            }

            registerTerminalStream(terminalId, res);
            req.on('close', () => unregisterTerminalStream(terminalId, res));
            return;
        }

        // API: Terminal write
        const terminalWriteMatch = (parsedUrl.pathname || '').match(/^\/api\/terminals\/([^/]+)\/write$/);
        if (terminalWriteMatch && req.method === 'POST') {
            const terminalId = terminalWriteMatch[1];
            const entry = terminalApiSessions.get(terminalId);
            if (!entry) {
                res.writeHead(404, { 'Content-Type': 'application/json' });
                res.end(JSON.stringify({ error: 'Terminal not found' }));
                return;
            }
            const actor = resolveActor(req);
            const config = getEffectiveSessionConfig(entry.sessionName);
            if (!canActorAccessSession(actor, config)) {
                res.writeHead(403, { 'Content-Type': 'application/json' });
                res.end(JSON.stringify({ error: 'Agent access not permitted' }));
                return;
            }
            let body = '';
            req.on('data', chunk => body += chunk);
            req.on('end', () => {
                try {
                    const payload = JSON.parse(body || '{}');
                    const data = payload.data;
                    if (!data) {
                        res.writeHead(400, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Missing data' }));
                        return;
                    }
                    sendTerminalInput(entry, String(data));
                    res.writeHead(200, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ ok: true }));
                } catch (e) {
                    res.writeHead(400, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Invalid request body' }));
                }
            });
            return;
        }

        // API: Terminal resize
        const terminalResizeMatch = (parsedUrl.pathname || '').match(/^\/api\/terminals\/([^/]+)\/resize$/);
        if (terminalResizeMatch && req.method === 'POST') {
            const terminalId = terminalResizeMatch[1];
            const entry = terminalApiSessions.get(terminalId);
            if (!entry) {
                res.writeHead(404, { 'Content-Type': 'application/json' });
                res.end(JSON.stringify({ error: 'Terminal not found' }));
                return;
            }
            const actor = resolveActor(req);
            const config = getEffectiveSessionConfig(entry.sessionName);
            if (!canActorAccessSession(actor, config)) {
                res.writeHead(403, { 'Content-Type': 'application/json' });
                res.end(JSON.stringify({ error: 'Agent access not permitted' }));
                return;
            }
            let body = '';
            req.on('data', chunk => body += chunk);
            req.on('end', () => {
                try {
                    const payload = JSON.parse(body || '{}');
                    sendTerminalResize(entry, payload.cols, payload.rows);
                    res.writeHead(200, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ ok: true }));
                } catch (e) {
                    res.writeHead(400, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Invalid request body' }));
                }
            });
            return;
        }

        // API: Terminal exec (convenience wrapper around write)
        const terminalExecMatch = (parsedUrl.pathname || '').match(/^\/api\/terminals\/([^/]+)\/exec$/);
        if (terminalExecMatch && req.method === 'POST') {
            const terminalId = terminalExecMatch[1];
            const entry = terminalApiSessions.get(terminalId);
            if (!entry) {
                res.writeHead(404, { 'Content-Type': 'application/json' });
                res.end(JSON.stringify({ error: 'Terminal not found' }));
                return;
            }
            const actor = resolveActor(req);
            const config = getEffectiveSessionConfig(entry.sessionName);
            if (!canActorAccessSession(actor, config)) {
                res.writeHead(403, { 'Content-Type': 'application/json' });
                res.end(JSON.stringify({ error: 'Agent access not permitted' }));
                return;
            }
            let body = '';
            req.on('data', chunk => body += chunk);
            req.on('end', () => {
                try {
                    const payload = JSON.parse(body || '{}');
                    const command = payload.command;
                    if (!command) {
                        res.writeHead(400, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Missing command' }));
                        return;
                    }
                    const line = String(command);
                    sendTerminalInput(entry, line.endsWith('\n') ? line : `${line}\n`);
                    res.writeHead(200, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ ok: true }));
                } catch (e) {
                    res.writeHead(400, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Invalid request body' }));
                }
            });
            return;
        }

        // API: Terminal detach (optional kill session)
        const terminalDeleteMatch = (parsedUrl.pathname || '').match(/^\/api\/terminals\/([^/]+)$/);
        if (terminalDeleteMatch && req.method === 'DELETE') {
            const terminalId = terminalDeleteMatch[1];
            const entry = terminalApiSessions.get(terminalId);
            if (!entry) {
                res.writeHead(404, { 'Content-Type': 'application/json' });
                res.end(JSON.stringify({ error: 'Terminal not found' }));
                return;
            }
            const actor = resolveActor(req);
            const config = getEffectiveSessionConfig(entry.sessionName);
            if (!canActorAccessSession(actor, config)) {
                res.writeHead(403, { 'Content-Type': 'application/json' });
                res.end(JSON.stringify({ error: 'Agent access not permitted' }));
                return;
            }
            const killSession = parsedUrl.query?.killSession === 'true';
            entry.adapter.close();
            if (killSession) {
                if (isExternalTerminalBackend()) {
                    await terminateExternalHaySession(entry.sessionName);
                } else if (hayRooms.hasRoom(entry.sessionName)) {
                    hayRooms.closeRoom(entry.sessionName);
                }
                if (activeSessions[entry.sessionName]) {
                    delete activeSessions[entry.sessionName];
                }
                clearRuntimeSessionMetadata(entry.sessionName);
                sessionClientSummary.delete(entry.sessionName);
                const savedConfig = getSessionConfig(entry.sessionName);
                if (savedConfig) {
                    deleteSessionConfig(entry.sessionName);
                }
            }
            res.writeHead(200, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ ok: true }));
            return;
        }

        // API: List workspaces
        if (parsedUrl.pathname === '/api/workspaces' && req.method === 'GET') {
            const names = listWorkspaceNames();
            res.writeHead(200, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ workspaces: names }));
            return;
        }

        // API: Show workspace definition
        if (parsedUrl.pathname === '/api/workspaces/show' && req.method === 'GET') {
            const name = typeof parsedUrl.query?.name === 'string' ? parsedUrl.query.name : '';
            const workspace = loadWorkspaceFile(name);
            if (!workspace) {
                res.writeHead(404, { 'Content-Type': 'application/json' });
                res.end(JSON.stringify({ error: 'Workspace not found' }));
                return;
            }
            res.writeHead(200, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ ok: true, workspace }));
            return;
        }

        // API: Create workspace
        if (parsedUrl.pathname === '/api/workspaces/create' && req.method === 'POST') {
            let body = '';
            req.on('data', chunk => body += chunk);
            req.on('end', () => {
                try {
                    const { name } = JSON.parse(body);
                    const created = createWorkspaceFile(name);
                    if (created === null) {
                        res.writeHead(400, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Invalid workspace name' }));
                        return;
                    }
                    if (created === false) {
                        res.writeHead(409, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Workspace already exists' }));
                        return;
                    }
                    res.writeHead(200, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ ok: true, workspace: created }));
                } catch (e) {
                    res.writeHead(400, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Invalid request body' }));
                }
            });
            return;
        }

        // API: Save workspace snapshot from selected live sessions
        if (parsedUrl.pathname === '/api/workspaces/save' && req.method === 'POST') {
            let body = '';
            req.on('data', chunk => body += chunk);
            req.on('end', async () => {
                try {
                    const payload = JSON.parse(body);
                    const name = payload?.name;
                    const sessionNames = Array.isArray(payload?.sessionNames)
                        ? payload.sessionNames.filter((entry) => typeof entry === 'string' && entry)
                        : null;
                    const result = await snapshotWorkspaceFile(name, sessionNames);
                    if (!result || result.error === 'invalid-workspace') {
                        res.writeHead(400, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Invalid workspace name' }));
                        return;
                    }
                    if (result.error === 'no-live-sessions') {
                        res.writeHead(400, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'No live terminal sessions to save' }));
                        return;
                    }
                    if (result.error === 'session-not-live') {
                        res.writeHead(400, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: `Session is not live: ${result.internalName}` }));
                        return;
                    }
                    res.writeHead(200, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ ok: true, workspace: result.workspace, selected: result.selected || [] }));
                } catch (e) {
                    res.writeHead(400, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Invalid request body' }));
                }
            });
            return;
        }

        // API: Load workspace (start defined sessions)
        if (parsedUrl.pathname === '/api/workspaces/load' && req.method === 'POST') {
            let body = '';
            req.on('data', chunk => body += chunk);
            req.on('end', async () => {
                try {
                    const { name, start } = JSON.parse(body);
                    const workspace = loadWorkspaceFile(name);
                    if (!workspace) {
                        res.writeHead(404, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Workspace not found' }));
                        return;
                    }
                    const result = await applyWorkspace(workspace, {
                        startSessions: start !== false,
                        workspaceName: name
                    });
                    res.writeHead(200, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ ok: true, result }));
                } catch (e) {
                    res.writeHead(400, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Invalid request body' }));
                }
            });
            return;
        }

        // API: Delete workspace definition
        if (parsedUrl.pathname === '/api/workspaces/delete' && req.method === 'POST') {
            let body = '';
            req.on('data', chunk => body += chunk);
            req.on('end', () => {
                try {
                    const { name } = JSON.parse(body);
                    const deleted = deleteWorkspaceFile(name);
                    if (deleted === null) {
                        res.writeHead(400, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Invalid workspace name' }));
                        return;
                    }
                    if (deleted === false) {
                        res.writeHead(404, { 'Content-Type': 'application/json' });
                        res.end(JSON.stringify({ error: 'Workspace not found' }));
                        return;
                    }
                    res.writeHead(200, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ ok: true }));
                } catch (e) {
                    res.writeHead(400, { 'Content-Type': 'application/json' });
                    res.end(JSON.stringify({ error: 'Invalid request body' }));
                }
            });
            return;
        }

        // If no session selected, show session picker
        if (parsedUrl.pathname === '/sessions') {
            const sessionsFile = path.join(__dirname, 'sessions.html');
            let sessionsHtml = '<!-- sessions.html not found -->';
            try {
                sessionsHtml = fs.readFileSync(sessionsFile, 'utf8');
            } catch (e) {
                log(`Warning: sessions.html not found`, YELLOW);
            }
            res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8' });
            res.end(sessionsHtml);
            return;
        }
        if (!sessionName) {
            const sessionsFile = path.join(__dirname, 'sessions.html');
            let sessionsHtml = '<!-- sessions.html not found -->';
            try {
                sessionsHtml = fs.readFileSync(sessionsFile, 'utf8');
            } catch (e) {
                log(`Warning: sessions.html not found`, YELLOW);
            }
            res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8' });
            res.end(sessionsHtml);
            return;
        }
        // --- CHECK FOR iOS - Intercept and inject virtual keyboard ---
        const userAgent = req.headers['user-agent'] || '';
        const isIOS = /iPad|iPhone|iPod/.test(userAgent);
        const isMobile = isIOS || /Android/i.test(userAgent);
        const sessionConfig = getEffectiveSessionConfig(sessionName);
        if (sessionConfig && sessionConfig.type === 'port') {
            const targetPort = sessionConfig.port;
            if (!targetPort) {
                res.writeHead(500);
                res.end('Port session missing target port.');
                return;
            }
            const shouldInject = isMobile && shouldInjectSessionSwitcher(req);
            if (shouldInject) {
                waitForPort(targetPort).then((ready) => {
                    if (!ready) {
                        sendStartingPage(res, displayName);
                        return;
                    }
                    const headers = { ...req.headers };
                    delete headers['accept-encoding'];
                    const proxyReq = http.request({
                        hostname: '127.0.0.1',
                        port: targetPort,
                        method: req.method,
                        path: strippedUrl,
                        headers
                    }, (proxyRes) => {
                        const contentType = String(proxyRes.headers['content-type'] || '').toLowerCase();
                        const contentEncoding = String(proxyRes.headers['content-encoding'] || '').toLowerCase();
                        const isHtml = contentType.includes('text/html');
                        const isPlain = contentType.includes('text/plain');
                        const canModify = (isHtml || isPlain) && (!contentEncoding || contentEncoding === 'identity');
                        if (!canModify) {
                            res.writeHead(proxyRes.statusCode || 200, proxyRes.headers);
                            proxyRes.pipe(res);
                            return;
                        }
                        let chunks = [];
                        proxyRes.on('data', chunk => chunks.push(chunk));
                        proxyRes.on('end', () => {
                            let html = Buffer.concat(chunks).toString('utf8');
                            const overlay = getSessionSwitcherOverlay();
                            if (isPlain && !html.includes('<html')) {
                                const body = `<pre style="white-space:pre-wrap;font:14px/1.4 ui-monospace,Menlo,Monaco,Consolas,monospace;margin:24px;color:#18181b;">${escapeHtml(html)}</pre>`;
                                html = `<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1"></head><body>${body}${overlay}</body></html>`;
                            } else if (html.includes('</body>')) {
                                html = html.split('</body>').join(overlay + '</body>');
                            } else {
                                html += overlay;
                            }
                            const outHeaders = { ...proxyRes.headers };
                            delete outHeaders['content-length'];
                            delete outHeaders['content-encoding'];
                            if (isPlain) {
                                outHeaders['content-type'] = 'text/html; charset=utf-8';
                            }
                            res.writeHead(proxyRes.statusCode || 200, outHeaders);
                            res.end(html);
                        });
                    });
                    proxyReq.on('error', () => {
                        sendStartingPage(res, displayName);
                    });
                    req.pipe(proxyReq);
                });
                return;
            }

            waitForPort(targetPort).then((ready) => {
                if (!ready) {
                    sendStartingPage(res, displayName);
                    return;
                }
                const proxy = httpProxy.createProxyServer({ target: `http://127.0.0.1:${targetPort}`, ws: false });
                const originalUrl = req.url;
                req.url = strippedUrl;
                proxy.web(req, res, {}, () => {
                    sendStartingPage(res, displayName);
                });
                req.url = originalUrl;
            });
            return;
        }

        // Ensure session exists (creates hay room if needed)
        try {
            getOrCreateSession(sessionName);
        } catch (e) {
            res.writeHead(500);
            res.end('Failed to create session');
            return;
        }

        // Serve hay web client (has built-in mobile keyboard)
        const reqPath = strippedPathname || '/';

        // Map request path to file
        let filePath;
        if (reqPath === '/' || reqPath === '') {
            filePath = path.join(HAY_WEB_DIR, 'index.html');
        } else if (reqPath.startsWith('/assets/')) {
            filePath = path.join(HAY_WEB_DIR, reqPath);
        } else {
            // Fallback to index.html for SPA routing
            filePath = path.join(HAY_WEB_DIR, 'index.html');
        }

        // Containment check: prevent path traversal (e.g. /assets/../../secret)
        // from escaping the web asset directory via raw ".." segments.
        const resolvedFilePath = path.resolve(filePath);
        const webDirRoot = path.resolve(HAY_WEB_DIR);
        if (resolvedFilePath !== webDirRoot && !resolvedFilePath.startsWith(webDirRoot + path.sep)) {
            res.writeHead(403);
            res.end('Forbidden');
            return;
        }
        filePath = resolvedFilePath;

        // Check if file exists
        if (!fs.existsSync(filePath)) {
            res.writeHead(404);
            res.end('Not Found');
            return;
        }

        // Determine content type
        const ext = path.extname(filePath).toLowerCase();
        const contentTypes = {
            '.html': 'text/html; charset=utf-8',
            '.js': 'application/javascript',
            '.css': 'text/css',
            '.json': 'application/json',
            '.png': 'image/png',
            '.jpg': 'image/jpeg',
            '.svg': 'image/svg+xml',
            '.ico': 'image/x-icon'
        };
        const contentType = contentTypes[ext] || 'application/octet-stream';

        // Read and serve the file
        let content = fs.readFileSync(filePath);

        // For HTML files, inject config and fix asset paths
        if (ext === '.html') {
            let html = content.toString('utf8');
            const sessionBasePath = `/s/${displayName}/`;

            // Inject hop session configuration
            const injectScript = `<script>
                // Hop session configuration - use /ws endpoint with room as query param
                window.__HOP_SESSION__ = ${JSON.stringify({
                    room: displayName,
                    name: 'Guest',
                    wsUrl: '/ws'
                })};
            </script>`;
            html = html.replace('<head>', '<head>' + injectScript);

            // Convert absolute asset paths to relative (remove leading /)
            html = html.replace(/src="\/assets\//g, 'src="assets/');
            html = html.replace(/href="\/assets\//g, 'href="assets/');

            content = Buffer.from(html, 'utf8');
        }

        // No caching in dev mode (when serving from hay)
        const isDevMode = !HAY_WEB_DIR.includes('hay-web');
        const headers = {
            'Content-Type': contentType,
            'Content-Length': content.length
        };
        if (isDevMode) {
            headers['Cache-Control'] = 'no-cache, no-store, must-revalidate';
            headers['Pragma'] = 'no-cache';
            headers['Expires'] = '0';
        }
        res.writeHead(200, headers);
        res.end(content);
    });

    // WebSocket upgrade for terminal
    server.on('upgrade', (req, socket, head) => {
        const parsedUrl = url.parse(req.url, true);
        const cookies = cookie.parse(req.headers.cookie || '');

        // Auth via cookie, Bearer token, or query param (for local CLI connections)
        const authHeader = req.headers.authorization || '';
        const bearerToken = authHeader.startsWith('Bearer ') ? authHeader.slice(7) : null;
        const tokenFromQuery = parsedUrl.query.token;
        const isAuthenticated = cookies[SESSION_COOKIE_NAME] === SESSION_SECRET ||
                               bearerToken === SESSION_SECRET ||
                               tokenFromQuery === SESSION_SECRET;

        if (!isAuthenticated) {
            socket.write('HTTP/1.1 401 Unauthorized\r\n\r\n');
            socket.destroy();
            return;
        }

        // Support both /ws?room=X (hay CLI format) and /s/{session}/ws (legacy)
        let sessionName = null;
        let sessionInfo = null;

        if (parsedUrl.pathname === '/ws') {
            // Hay CLI format: /ws?room=X
            const roomParam = parsedUrl.query.room;
            if (roomParam && typeof roomParam === 'string') {
                const resolved = resolveSessionDisplayName(roomParam);
                sessionName = resolved.internalName;
            }
        } else {
            // Legacy format: /s/{session}/ws
            sessionInfo = parseSessionFromRequest(req, parsedUrl);
            sessionName = sessionInfo ? sessionInfo.internalName : null;
        }

        if (!sessionName) {
            socket.write('HTTP/1.1 404 Session Not Found\r\n\r\n');
            socket.destroy();
            return;
        }

        const sessionConfig = getEffectiveSessionConfig(sessionName);
        if (sessionConfig && sessionConfig.type === 'port') {
            const targetPort = sessionConfig.port;
            if (!targetPort) {
                socket.write('HTTP/1.1 502 Bad Gateway\r\n\r\n');
                socket.destroy();
                return;
            }
            const proxy = httpProxy.createProxyServer({ target: `http://127.0.0.1:${targetPort}`, ws: true });
            proxy.once('error', () => {
                try { socket.destroy(); } catch (e) { }
            });
            const originalUrl = req.url;
            req.url = sessionInfo ? sessionInfo.strippedUrl : req.url;
            proxy.ws(req, socket, head);
            req.url = originalUrl;
            return;
        }

        // Get or create hay session
        if (isExternalTerminalBackend()) {
            (async () => {
                try {
                    await reconcileExternalRuntimeSessions();
                    await ensureExternalRuntimeSession(sessionName, sessionConfig?.cwd, getSessionDisplayName(sessionName), {
                        shell: sessionConfig?.shell,
                        env: sessionConfig?.env,
                        cols: sessionConfig?.cols,
                        rows: sessionConfig?.rows,
                        startup: sessionConfig?.startup,
                        autoStart: sessionConfig?.autoStart,
                        createdBy: sessionConfig?.createdBy,
                        agentPermitted: sessionConfig?.agentPermitted,
                        workspaceName: sessionConfig?.workspaceName,
                        folderId: sessionConfig?.folderId,
                        saveDefinition: hasSavedSessionConfig(sessionName)
                    });
                } catch (e) {
                    socket.write('HTTP/1.1 500 Server Error\r\n\r\n');
                    socket.destroy();
                    return;
                }

                const source = typeof parsedUrl.query.source === 'string' ? parsedUrl.query.source : '';
                const claimId = typeof parsedUrl.query.claim === 'string' ? parsedUrl.query.claim : null;
                noteClientConnected(sessionName, source, claimId);
                let disconnected = false;
                const handleDisconnect = () => {
                    if (disconnected) return;
                    disconnected = true;
                    noteClientDisconnected(sessionName, source);
                };
                socket.once('close', handleDisconnect);
                socket.once('error', handleDisconnect);

                try {
                    const targetPort = getExternalHayHostPortForSession(sessionName);
                    const proxy = httpProxy.createProxyServer({ target: `ws://127.0.0.1:${targetPort}`, ws: true });
                    proxy.once('error', () => {
                        handleDisconnect();
                        try { socket.destroy(); } catch (e) { }
                    });
                    const originalUrl = req.url;
                    req.url = buildExternalHayWsPath(parsedUrl, sessionName);
                    proxy.ws(req, socket, head);
                    req.url = originalUrl;
                } catch (e) {
                    handleDisconnect();
                    socket.write('HTTP/1.1 502 Bad Gateway\r\n\r\n');
                    socket.destroy();
                }
            })();
            return;
        }

        let session = activeSessions[sessionName];
        if (!session) {
            try {
                session = getOrCreateSession(sessionName);
            } catch (e) {
                socket.write('HTTP/1.1 500 Server Error\r\n\r\n');
                socket.destroy();
                return;
            }
        }

        // Create WebSocket server for this upgrade
        const wss = new WebSocket.Server({ noServer: true });
        wss.handleUpgrade(req, socket, head, (ws) => {
            // Parse query params for client info
            const wsUrl = new URL(req.url, 'http://localhost');
            const clientName = hay.sanitizeName(wsUrl.searchParams.get('name') || 'Anonymous');
            const cols = parseInt(wsUrl.searchParams.get('cols') || '80', 10);
            const rows = parseInt(wsUrl.searchParams.get('rows') || '24', 10);
            const source = wsUrl.searchParams.get('source') || '';
            const claimId = wsUrl.searchParams.get('claim') || null;

            const clientId = hay.generateClientId();
            const colorIndex = Math.floor(Math.random() * 1000);
            const actorLabel = source ? `web:${source}` : 'web';

            noteClientConnected(sessionName, source, claimId);
            registerSessionClientActor(sessionName, clientId, actorLabel);
            let disconnected = false;
            const handleDisconnect = () => {
                if (disconnected) return;
                disconnected = true;
                noteClientDisconnected(sessionName, source);
                unregisterSessionClientActor(sessionName, clientId);
            };
            ws.on('close', handleDisconnect);
            ws.on('error', handleDisconnect);

            // Attach client to hay room
            session.room.attachClient(
                { id: clientId, name: clientName, colorIndex, cols, rows },
                hay.createSocketAdapter(ws)
            );
        });
    });

    server.listen(PROXY_PORT, '127.0.0.1');
    return server;
}

// Tunnel manager - handles auto-restart and URL updates
let currentTunnelProc = null;
let currentPublicUrl = null;
let shuttingDown = false;  // Prevent restart during cleanup
const tunnelEmitter = new EventEmitter();
let CLIENT_TUNNEL_CONFIG = null; // { tunnelId, credentialsPath, hostname, configDir }
const plannedTunnelShutdowns = new WeakSet();
const tunnelStatus = {
    connected: false,
    lastEvent: null,
    lastError: null,
    lastUpdateAt: null,
    lastConnectedAt: null,
    lastRestartAt: null,
    consecutiveFailures: 0
};

function updateTunnelStatus(update) {
    Object.assign(tunnelStatus, update);
    tunnelStatus.lastUpdateAt = Date.now();
    // Any time the tunnel reports a live connection, clear the restart backoff
    // so the next outage starts retrying quickly again.
    if (update.connected === true) {
        tunnelRestartAttempts = 0;
        tunnelStatus.consecutiveFailures = 0;
    }
}

// Exponential backoff for tunnel restarts. Previously every close/error retried
// on a flat 3s loop forever (and could double-schedule), so a persistently
// broken tunnel (bad creds, network down) hammered `spawn('cloudflared')` and
// flooded the log at a constant rate. Back off 3s -> 60s with jitter, deduped,
// reset on a verified connection (see updateTunnelStatus).
const TUNNEL_BACKOFF_BASE_MS = 3000;
const TUNNEL_BACKOFF_MAX_MS = 60000;
let tunnelRestartAttempts = 0;
let tunnelBackoffTimer = null;

function scheduleTunnelRestart() {
    if (shuttingDown) return;
    if (tunnelBackoffTimer || tunnelRestartInProgress) return; // don't stack restarts
    const exp = Math.min(TUNNEL_BACKOFF_BASE_MS * Math.pow(2, tunnelRestartAttempts), TUNNEL_BACKOFF_MAX_MS);
    const delay = exp + Math.floor(Math.random() * 1000); // 0-1s jitter
    tunnelRestartAttempts += 1;
    updateTunnelStatus({ consecutiveFailures: tunnelRestartAttempts });
    log(`[Tunnel] Restart attempt ${tunnelRestartAttempts} in ${Math.round(delay / 1000)}s`, YELLOW);
    tunnelBackoffTimer = setTimeout(() => {
        tunnelBackoffTimer = null;
        if (!shuttingDown) startTunnelWithRestart();
    }, delay);
}

function isPlannedTunnelShutdown(tunnel) {
    return !!(tunnel && plannedTunnelShutdowns.has(tunnel));
}

function markPlannedTunnelShutdown(tunnel) {
    if (!tunnel || typeof tunnel.kill !== 'function') return false;
    plannedTunnelShutdowns.add(tunnel);
    return true;
}

function clearPlannedTunnelShutdown(tunnel) {
    if (!tunnel) return;
    plannedTunnelShutdowns.delete(tunnel);
}

function startTunnel(isRestart = false) {
    const domainConfig = getDomainConfig();
    const useNamedTunnel = domainConfig && domainConfig.tunnelName && domainConfig.hostname;

    if (!isRestart) {
        if (useNamedTunnel) {
            log(`[3/4] Opening Cloudflare Tunnel (${domainConfig.hostname})...`, BOLD);
        } else {
            log(`[3/4] Opening Cloudflare Tunnel...`, BOLD);
        }
    } else {
        log(`[Tunnel] Reconnecting...`, YELLOW);
    }

    // Use named tunnel if configured, otherwise quick tunnel
    let tunnel;
    let publicUrl;

    const localTunnelHost = '127.0.0.1';

    if (useNamedTunnel) {
        // Named tunnel with custom domain - URL is fixed
        publicUrl = `https://${domainConfig.hostname}`;

        // Create config file for the tunnel
        const tunnelConfigPath = path.join(HOME_DIR, '.tunnel-config.yml');
        const tunnelConfig = `
url: http://${localTunnelHost}:${PROXY_PORT}
tunnel: ${domainConfig.tunnelName}
`;
        writePrivateFile(tunnelConfigPath, tunnelConfig);

        const runArgs = ['tunnel', '--config', tunnelConfigPath, 'run'];
        if (domainConfig.tunnelTokenFile && fs.existsSync(domainConfig.tunnelTokenFile)) {
            runArgs.push('--token-file', domainConfig.tunnelTokenFile);
        } else if (domainConfig.credentialsFile && fs.existsSync(domainConfig.credentialsFile)) {
            runArgs.push('--credentials-file', domainConfig.credentialsFile);
        }
        runArgs.push(domainConfig.tunnelName);
        tunnel = spawn('cloudflared', runArgs);
    } else {
        // Quick tunnel - URL is random
        tunnel = spawn('cloudflared', ['tunnel', '--url', `http://${localTunnelHost}:${PROXY_PORT}`]);
    }

    tunnel.on('close', (code) => {
        if (shuttingDown) return;  // Don't restart during cleanup
        const planned = isPlannedTunnelShutdown(tunnel);
        clearPlannedTunnelShutdown(tunnel);
        updateTunnelStatus({
            connected: false,
            lastEvent: planned ? 'planned_close' : 'closed',
            lastError: planned ? null : `cloudflared exited (code ${code})`
        });
        if (planned) return;
        log(`[Tunnel] Disconnected (code ${code}).`, YELLOW);
        scheduleTunnelRestart();
    });

    tunnel.on('error', (err) => {
        if (shuttingDown) return;  // Don't restart during cleanup
        const planned = isPlannedTunnelShutdown(tunnel);
        clearPlannedTunnelShutdown(tunnel);
        updateTunnelStatus({
            connected: false,
            lastEvent: planned ? 'planned_error' : 'error',
            lastError: planned ? null : err.message
        });
        if (planned) return;
        log(`[Tunnel] Error: ${err.message}.`, RED);
        scheduleTunnelRestart();
    });

    // For named tunnels, resolve immediately with the known URL
    updateTunnelStatus({ connected: false, lastEvent: isRestart ? 'restarting' : 'starting', lastError: null });
    if (useNamedTunnel) {
        currentTunnelProc = tunnel;
        currentPublicUrl = publicUrl;

        // Wait a moment for tunnel to establish, then resolve
        return new Promise((resolve) => {
            let resolved = false;

            // Listen for successful connection or error
            tunnel.stderr.on('data', (data) => {
                const output = data.toString();
                // Look for connection established message
                if (!resolved && (output.includes('Registered tunnel connection') || output.includes('Connection'))) {
                    resolved = true;
                    updateTunnelStatus({
                        connected: true,
                        lastEvent: 'connected',
                        lastError: null,
                        lastConnectedAt: Date.now()
                    });
                    if (isRestart) {
                        tunnelEmitter.emit('urlChanged', publicUrl);
                        log(`[Tunnel] Reconnected: ${publicUrl}`, GREEN);
                    }
                    resolve({ tunnel, publicUrl });
                }
            });

            // Timeout fallback - assume connected after 5 seconds
            setTimeout(() => {
                if (!resolved) {
                    resolved = true;
                    updateTunnelStatus({
                        connected: true,
                        lastEvent: 'assumed_connected',
                        lastError: null,
                        lastConnectedAt: Date.now()
                    });
                    if (isRestart) {
                        tunnelEmitter.emit('urlChanged', publicUrl);
                    }
                    resolve({ tunnel, publicUrl });
                }
            }, 5000);
        });
    }

    // For quick tunnels, parse URL from output
    let urlFound = false;
    return new Promise((resolve, reject) => {
        tunnel.stderr.on('data', (data) => {
            if (urlFound) return;
            const output = data.toString();
            const match = output.match(/https:\/\/[a-zA-Z0-9-]+\.trycloudflare\.com/);

            if (match) {
                const parsedUrl = match[0];
                if (parsedUrl.includes('api.trycloudflare.com')) return;

                urlFound = true;
                currentTunnelProc = tunnel;
                currentPublicUrl = parsedUrl;
                updateTunnelStatus({
                    connected: true,
                    lastEvent: 'connected',
                    lastError: null,
                    lastConnectedAt: Date.now()
                });

                // Emit URL change event for restarts
                if (isRestart) {
                    tunnelEmitter.emit('urlChanged', parsedUrl);
                    log(`[Tunnel] New URL: ${parsedUrl}`, GREEN);
                }

                resolve({ tunnel, publicUrl: parsedUrl });
            }
        });

        // Timeout - don't hang forever waiting for cloudflared
        setTimeout(() => {
            if (!urlFound) {
                tunnel.kill();
                log(`\n${RED}ERROR: Cloudflare tunnel failed to start (timeout after 30s)${RESET}`, RED);
                log(`Check your internet connection or try again.`, YELLOW);
                process.exit(1);
            }
        }, 30000);
    });
}

function startClientTunnel(isRestart = false) {
    if (!CLIENT_TUNNEL_CONFIG) {
        throw new Error('Client tunnel config missing');
    }

    const { tunnelId, credentialsPath, hostname, configDir } = CLIENT_TUNNEL_CONFIG;
    const publicUrl = hostname ? `https://${hostname}` : null;

    if (!isRestart) {
        log(`[3/4] Opening Cloudflare Tunnel${hostname ? ` (${hostname})` : ''}...`, BOLD);
    } else {
        log(`[Tunnel] Reconnecting...`, YELLOW);
    }

    const tunnelConfigPath = path.join(configDir, 'tunnel-config.yml');
    const tunnelConfig = `
url: http://127.0.0.1:${PROXY_PORT}
tunnel: ${tunnelId}
credentials-file: ${path.resolve(credentialsPath)}
`;
    writePrivateFile(tunnelConfigPath, tunnelConfig);

    const tunnel = spawn('cloudflared', ['tunnel', '--config', tunnelConfigPath, 'run'], {
        stdio: ['ignore', 'pipe', 'pipe']
    });

    tunnel.on('close', (code) => {
        if (shuttingDown) return;  // Don't restart during cleanup
        const planned = isPlannedTunnelShutdown(tunnel);
        clearPlannedTunnelShutdown(tunnel);
        updateTunnelStatus({
            connected: false,
            lastEvent: planned ? 'planned_close' : 'closed',
            lastError: planned ? null : `cloudflared exited (code ${code})`
        });
        if (planned) return;
        log(`[Tunnel] Disconnected (code ${code}).`, YELLOW);
        scheduleTunnelRestart();
    });

    tunnel.on('error', (err) => {
        if (shuttingDown) return;  // Don't restart during cleanup
        const planned = isPlannedTunnelShutdown(tunnel);
        clearPlannedTunnelShutdown(tunnel);
        updateTunnelStatus({
            connected: false,
            lastEvent: planned ? 'planned_error' : 'error',
            lastError: planned ? null : err.message
        });
        if (planned) return;
        log(`[Tunnel] Error: ${err.message}.`, RED);
        scheduleTunnelRestart();
    });

    currentTunnelProc = tunnel;
    currentPublicUrl = publicUrl;
    updateTunnelStatus({ connected: false, lastEvent: isRestart ? 'restarting' : 'starting', lastError: null });

    return new Promise((resolve) => {
        let resolved = false;

        tunnel.stderr.on('data', (data) => {
            const output = data.toString();
            if (!resolved && (output.includes('Registered tunnel connection') || output.includes('Connection'))) {
                resolved = true;
                updateTunnelStatus({
                    connected: true,
                    lastEvent: 'connected',
                    lastError: null,
                    lastConnectedAt: Date.now()
                });
                if (isRestart) {
                    if (publicUrl) {
                        tunnelEmitter.emit('urlChanged', publicUrl);
                        log(`[Tunnel] Reconnected: ${publicUrl}`, GREEN);
                    } else {
                        log(`[Tunnel] Reconnected.`, GREEN);
                    }
                }
                resolve({ tunnel, publicUrl });
            }
        });

        // Timeout fallback - assume connected after 5 seconds
        setTimeout(() => {
            if (!resolved) {
                resolved = true;
                updateTunnelStatus({
                    connected: true,
                    lastEvent: 'assumed_connected',
                    lastError: null,
                    lastConnectedAt: Date.now()
                });
                if (isRestart && publicUrl) {
                    tunnelEmitter.emit('urlChanged', publicUrl);
                }
                resolve({ tunnel, publicUrl });
            }
        }, 5000);
    });
}

let tunnelRestartInProgress = false;
let tunnelRestartQueued = false;

async function startTunnelWithRestart() {
    // Prevent concurrent restarts
    if (tunnelRestartInProgress) {
        tunnelRestartQueued = true;
        log(`[Tunnel] Restart already in progress, queuing.`, YELLOW);
        return;
    }
    tunnelRestartInProgress = true;
    updateTunnelStatus({ lastRestartAt: Date.now(), lastEvent: 'restarting' });

    let shouldReschedule = false;
    try {
        const { tunnel, publicUrl } = CLIENT_TUNNEL_CONFIG
            ? await startClientTunnel(true)
            : await startTunnel(true);

        const verified = await waitForTunnelHealthy(publicUrl, {
            timeoutMs: TUNNEL_RESTART_VERIFY_TIMEOUT,
            intervalMs: TUNNEL_RESTART_VERIFY_INTERVAL
        });
        if (!verified.ok) {
            const result = verified.result || {};
            const reason = result.error || (result.status ? `HTTP ${result.status}` : 'Unknown error');
            updateTunnelStatus({
                connected: false,
                lastEvent: 'restart_unhealthy',
                lastError: `Public tunnel still unhealthy after restart: ${reason}`
            });
            if (tunnel && !tunnel.killed) {
                markPlannedTunnelShutdown(tunnel);
                try { tunnel.kill('SIGTERM'); } catch (e) { }
            }
            throw new Error(`Tunnel failed verification (${reason})`);
        }

        updateTunnelStatus({
            connected: true,
            lastEvent: 'healthy',
            lastError: null,
            lastConnectedAt: Date.now()
        });
        log(`[Tunnel] Verified healthy: ${publicUrl}`, GREEN);

        // Update state file
        if (fs.existsSync(STATE_FILE)) {
            try {
                const state = JSON.parse(fs.readFileSync(STATE_FILE, 'utf8'));
                state.url = publicUrl;
                writePrivateFile(STATE_FILE, JSON.stringify(state));
            } catch (e) { }
        }
    } catch (e) {
        log(`[Tunnel] Failed to restart: ${e.message}.`, RED);
        shouldReschedule = true;
    } finally {
        tunnelRestartInProgress = false;
        if (shouldReschedule) {
            scheduleTunnelRestart();
            return;
        }
        if (tunnelRestartQueued) {
            tunnelRestartQueued = false;
            setTimeout(startTunnelWithRestart, 0);
        }
    }
}

// Tunnel health monitor - detects stale connections (e.g., after VPN change)
let tunnelHealthInterval = null;
const TUNNEL_HEALTH_CHECK_INTERVAL = 30000; // Check every 30s
const TUNNEL_HEALTH_TIMEOUT = 10000; // 10s timeout for health check
const TUNNEL_RESTART_VERIFY_TIMEOUT = 25000;
const TUNNEL_RESTART_VERIFY_INTERVAL = 1500;

async function probeTunnelHealth(publicUrl, timeoutMs = TUNNEL_HEALTH_TIMEOUT) {
    if (!publicUrl) {
        return { ok: false, error: 'Missing tunnel URL', status: null, time: 0 };
    }
    const https = require('https');
    const startedAt = Date.now();
    return new Promise((resolve) => {
        const req = https.get(publicUrl, { timeout: timeoutMs }, (res) => {
            resolve({
                ok: typeof res.statusCode === 'number' && res.statusCode < 500,
                status: res.statusCode,
                error: null,
                time: Date.now() - startedAt
            });
        });
        req.on('error', (err) => {
            resolve({
                ok: false,
                status: null,
                error: err.message,
                time: Date.now() - startedAt
            });
        });
        req.on('timeout', () => {
            req.destroy();
            resolve({
                ok: false,
                status: null,
                error: `Timeout (${Math.ceil(timeoutMs / 1000)}s)`,
                time: Date.now() - startedAt
            });
        });
    });
}

async function waitForTunnelHealthy(publicUrl, options = {}) {
    const timeoutMs = Number.isFinite(options.timeoutMs)
        ? Math.max(1, Math.floor(options.timeoutMs))
        : TUNNEL_RESTART_VERIFY_TIMEOUT;
    const intervalMs = Number.isFinite(options.intervalMs)
        ? Math.max(100, Math.floor(options.intervalMs))
        : TUNNEL_RESTART_VERIFY_INTERVAL;
    const startedAt = Date.now();
    let lastResult = { ok: false, error: 'No checks performed', status: null, time: 0 };

    while ((Date.now() - startedAt) < timeoutMs) {
        lastResult = await probeTunnelHealth(publicUrl, TUNNEL_HEALTH_TIMEOUT);
        if (lastResult.ok) {
            return {
                ok: true,
                result: lastResult,
                waitedMs: Date.now() - startedAt
            };
        }
        await new Promise((resolve) => setTimeout(resolve, intervalMs));
    }

    return {
        ok: false,
        result: lastResult,
        waitedMs: Date.now() - startedAt
    };
}

function startTunnelHealthMonitor() {
    if (tunnelHealthInterval) return;

    tunnelHealthInterval = setInterval(async () => {
        if (shuttingDown || !currentPublicUrl) return;

        const result = await probeTunnelHealth(currentPublicUrl, TUNNEL_HEALTH_TIMEOUT);
        if (!result.ok) {
            const reason = result.error || (result.status ? `HTTP ${result.status}` : 'Unknown error');
            updateTunnelStatus({
                connected: false,
                lastEvent: 'unhealthy',
                lastError: reason
            });
            log(`[Tunnel] Health check failed: ${reason}. Restarting tunnel...`, YELLOW);
            if (currentTunnelProc && !currentTunnelProc.killed) {
                try { currentTunnelProc.kill('SIGTERM'); } catch (err) { }
                // The 'close' handler will trigger restart
            } else {
                // Cloudflared already dead, restart directly
                startTunnelWithRestart();
            }
        } else if (tunnelStatus.lastEvent !== 'healthy') {
            updateTunnelStatus({
                connected: true,
                lastEvent: 'healthy',
                lastError: null
            });
        }
    }, TUNNEL_HEALTH_CHECK_INTERVAL);
}

function stopTunnelHealthMonitor() {
    if (tunnelHealthInterval) {
        clearInterval(tunnelHealthInterval);
        tunnelHealthInterval = null;
    }
}

