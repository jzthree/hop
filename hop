function normalizeSessionStore(raw, opts = {}) {
    const workspaceName = normalizeWorkspaceName(opts.workspaceName) || normalizeWorkspaceName(raw?.name) || DEFAULT_WORKSPACE_NAME;
    const empty = createEmptySessionStore(workspaceName);
    if (!raw || typeof raw !== 'object') return empty;

    const folders = {};
    for (const [id, folder] of Object.entries(raw.folders || {})) {
        if (!id || !folder || typeof folder !== 'object') continue;
        const name = String(folder.name || '').trim();
        if (!name) continue;
        folders[id] = {
            id,
            name,
            createdAt: folder.createdAt || empty.createdAt,
            updatedAt: folder.updatedAt || empty.updatedAt
        };
    }

    const sessions = {};
    for (const [name, config] of Object.entries(raw.sessions || {})) {
        const normalizedConfig = normalizeStoredSessionConfig(name, config, folders, workspaceName, empty);
        if (!normalizedConfig) continue;
        sessions[name] = normalizedConfig;
    }

    const rawOrder = raw.order && typeof raw.order === 'object' ? raw.order : {};
    const folderOrder = Array.isArray(rawOrder.folders)
        ? rawOrder.folders.filter((id) => folders[id])
        : [];
    const rawOrderSessions = rawOrder.sessions && typeof rawOrder.sessions === 'object' ? rawOrder.sessions : {};
    const canonicalizeOrderList = (list) => {
        if (!Array.isArray(list)) return [];
        const out = [];
        const seen = new Set();
        for (const name of list) {
            if (!sessions[name] || seen.has(name)) continue;
            seen.add(name);
            out.push(name);
        }
        return out;
    };

    const order = {
        folders: folderOrder,
        sessions: {
            root: canonicalizeOrderList(rawOrderSessions.root)
        }
    };

    for (const id of Object.keys(folders)) {
        order.sessions[id] = canonicalizeOrderList(rawOrderSessions[id]);
        if (!order.folders.includes(id)) {
            order.folders.push(id);
        }
    }

    for (const [name, config] of Object.entries(sessions)) {
        const bucket = config.folderId || 'root';
        if (!order.sessions[bucket]) {
            order.sessions[bucket] = [];
        }
        if (!order.sessions[bucket].includes(name)) {
            order.sessions[bucket].push(name);
        }
    }

    return {
        version: SESSION_STORE_VERSION,
        name: workspaceName,
        createdAt: raw.createdAt || empty.createdAt,
        updatedAt: raw.updatedAt || empty.updatedAt,
        sessions,
        folders,
        order
