{
  "name": "hop2",
  "version": "0.8.0",
  "description": "🐰 Hop into your terminal from anywhere. Secure remote shell access with 2FA via Cloudflare Tunnel. Next-gen rewrite with native terminal sharing.",
  "main": "hop",
  "bin": {
    "hop2": "./hop"
  },
  "scripts": {
    "start": "node hop",
    "build": "npm --prefix hay install && npm --prefix hay run build && rsync -a --delete hay/apps/web/dist/ hay-web/",
    "test": "node --check hop"
  },
  "keywords": [
    "terminal",
    "remote",
    "shell",
    "ssh",
    "tunnel",
    "cloudflare",
    "termshare",
    "2fa",
    "totp",
    "web-terminal",
    "mobile"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jzthree/hop"
  },
  "homepage": "https://github.com/jzthree/hop#readme",
  "bugs": {
    "url": "https://github.com/jzthree/hop/issues"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "dependencies": {
    "cookie": "^1.1.1",
    "http-proxy": "^1.18.1",
    "node-pty-prebuilt-multiarch": "^0.10.1-pre.5",
    "otplib": "^12.0.1",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0"
  }
}
