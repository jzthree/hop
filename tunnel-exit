#!/bin/bash
# tunnel-exit: Clean exit command for Tunnel Shell
# This creates a flag file that the shell wrapper checks to break the respawn loop
#
# Usage: Run this command in the terminal, then type 'exit' to trigger shutdown

SESSION="${1:-default}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
EXIT_FILE="$SCRIPT_DIR/.exit-$SESSION"

touch "$EXIT_FILE"
echo ""
echo "Exit signal sent for session: $SESSION"
echo "Now type 'exit' to trigger the shutdown."
echo ""
echo "(The respawn loop will see the flag and stop)"
